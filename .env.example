# Public base URL used for canonical, hreflang, and sitemap generation.
PUBLIC_SITE_URL=https://www.littlechubbypress.com

# Buttondown username used to build newsletter action URL.
PUBLIC_BUTTONDOWN_USERNAME=YOUR_BUTTONDOWN_USERNAME

# Formspree form id used to build contact action URL.
PUBLIC_FORMSPREE_FORM_ID=YOUR_FORM_ID

# Supabase – get these from https://supabase.com/dashboard/project/_/settings/api
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Social Media Automation ────────────────────────────────────────────────
# Bluesky — Create app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=littlechubbypress.bsky.social
BLUESKY_PASSWORD=YOUR_APP_PASSWORD

# Facebook/Instagram — https://developers.facebook.com (optional)
META_PAGE_ACCESS_TOKEN=YOUR_PAGE_TOKEN
META_PAGE_ID=YOUR_PAGE_ID
META_IG_USER_ID=YOUR_IG_BUSINESS_ACCOUNT_ID

# Make.com relay (recommended for Meta auth stability)
MAKE_WEBHOOK_URL=https://hook.us2.make.com/YOUR_WEBHOOK_ID
MAKE_WEBHOOK_SECRET=OPTIONAL_SHARED_SECRET
# Optional allowlist for webhook hosts (comma-separated). Default allows *.make.com.
MAKE_WEBHOOK_ALLOWED_HOSTS=make.com

# Anthropic Claude API — AI-powered social post generation (optional)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
