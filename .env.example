# Public base URL used for canonical, hreflang, and sitemap generation.
PUBLIC_SITE_URL=https://www.littlechubbypress.com

# Buttondown username used to build newsletter action URL.
PUBLIC_BUTTONDOWN_USERNAME=YOUR_BUTTONDOWN_USERNAME

# Formspree form id used to build contact action URL.
PUBLIC_FORMSPREE_FORM_ID=YOUR_FORM_ID

# Supabase – get these from https://supabase.com/dashboard/project/_/settings/api
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Cron auth secret for /api/cron/* endpoints
CRON_SECRET=GENERATE_A_LONG_RANDOM_SECRET

# ─── Social Media Automation ────────────────────────────────────────────────
# Bluesky — Create app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=littlechubbypress.bsky.social
BLUESKY_PASSWORD=YOUR_APP_PASSWORD

# Facebook/Instagram — https://developers.facebook.com (optional)
META_PAGE_ACCESS_TOKEN=YOUR_PAGE_TOKEN
META_PAGE_ID=YOUR_PAGE_ID
META_IG_USER_ID=YOUR_IG_BUSINESS_ACCOUNT_ID

# Anthropic Claude API — AI-powered social post generation (optional)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Nano Banana image generation API (optional)
NANO_BANANA_API_KEY=YOUR_NANO_BANANA_KEY

# ─── DataForSEO — Amazon ratings sync ───────────────────────────────────────
# Get credentials at https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=YOUR_EMAIL
DATAFORSEO_PASSWORD=YOUR_API_PASSWORD

# ─── Daily Analytics Email ──────────────────────────────────────────────────
# Resend — transactional email for daily analytics reports
# Sign up free at https://resend.com and create an API key
RESEND_API_KEY=re_YOUR_KEY_HERE

# Email address to receive daily analytics reports. Personal operator
# email — set in Vercel / GitHub secrets, never commit the real value.
ANALYTICS_EMAIL=operator@example.com

# Emergency admin allowlist (comma-separated, case-insensitive). The brand
# mailbox hello@littlechubbypress.com is always included by default.
# Add personal operator emails here via Vercel env / GitHub secrets only.
ADMIN_EMAILS=

# ─── Sentry Error Tracking (recommended) ───────────────────────────────────
# DSN is safe to expose publicly and is used by browser + server SDK.
PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@o000000.ingest.sentry.io/0000000

# Optional server-only DSN override (if omitted, PUBLIC_SENTRY_DSN is used).
SENTRY_DSN=

# Optional release/source-map upload (only needed in CI).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Better Stack Heartbeats (optional, recommended in production) ─────────
BETTERSTACK_HEARTBEAT_MONTHLY_DRAW=
BETTERSTACK_HEARTBEAT_WEEKLY_NEWSLETTER=
BETTERSTACK_HEARTBEAT_NEWSLETTER_REMINDERS=
BETTERSTACK_HEARTBEAT_AWARD_TOP_EARNERS=
BETTERSTACK_HEARTBEAT_REFUND_EXPIRED_GIFTS=
BETTERSTACK_HEARTBEAT_REFRESH_LEADERBOARD=
