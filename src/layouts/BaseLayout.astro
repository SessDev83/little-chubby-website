---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import LeadMagnetPopup from "../components/LeadMagnetPopup.astro";
import ChubbyChat from "../components/ChubbyChat.astro";
import ParentalConsentBanner from "../components/ParentalConsentBanner.astro";
import { siteConfig } from "../data/site";
import type { Lang } from "../data/i18n";
import { switchLangPath } from "../data/i18n";
import { EVENT_CONTRACT_VERSION, EVENT_NAME_ALIASES } from "../lib/analytics-event-contract.mjs";
import "../styles/global.css";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  pathname: string;
  alternatePath?: string;
  breadcrumbs?: { name: string; url: string }[];
  articleSchema?: {
    headline: string;
    description: string;
    datePublished: string;
    url: string;
    ogImage?: string;
  };
  ogImage?: string;
}

const { lang, title, description, pathname, alternatePath, breadcrumbs, articleSchema, ogImage: customOgImage } = Astro.props;

// Show lead magnet popup on public-facing pages only
const hidePopupPaths = ["/admin", "/login", "/register", "/thanks", "/auth", "/logout", "/forgot-password"];
const showLeadMagnet = !hidePopupPaths.some((p) => pathname.includes(p));
const hideHeaderNav = ["/admin", "/login", "/register", "/forgot-password"].some((p) => pathname.includes(p));
// Block search engines from admin / auth pages and per-user dynamic pages
const noIndexPaths = ["/admin", "/login", "/register", "/auth", "/logout", "/forgot-password"];
const noIndexSubstrings = ["/books/early-access", "/premium-downloads"];
const shouldNoIndex =
  noIndexPaths.some((p) => pathname.startsWith(p)) ||
  noIndexSubstrings.some((p) => pathname.includes(p));
const shouldExposePinterestVerification = !pathname.startsWith("/admin");
const canonical = new URL(pathname, siteConfig.siteUrl).toString();
const ogImage = customOgImage
  ? new URL(customOgImage, siteConfig.siteUrl).toString()
  : new URL(siteConfig.brandAssets.ogCover, siteConfig.siteUrl).toString();
const alternateLang = lang === "es" ? "en" : "es";
const alternateHref = new URL(alternatePath || switchLangPath(pathname, alternateLang), siteConfig.siteUrl).toString();
const skipLabel = lang === "es" ? "Saltar al contenido" : "Skip to content";
const organizationJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.brandName,
  url: siteConfig.siteUrl,
  logo: new URL(siteConfig.brandAssets.logoMark, siteConfig.siteUrl).toString(),
  sameAs: [siteConfig.social.instagram, siteConfig.social.facebook, siteConfig.social.bluesky, siteConfig.social.amazonAuthor],
  contactPoint: [{
    "@type": "ContactPoint",
    email: siteConfig.contactEmail,
    contactType: "customer support"
  }]
});
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.brandName,
  url: siteConfig.siteUrl,
  inLanguage: ["es", "en"]
});

const breadcrumbJsonLd = breadcrumbs && breadcrumbs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: new URL(item.url, siteConfig.siteUrl).toString()
  }))
}) : null;

const articleJsonLd = articleSchema ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleSchema.headline,
  description: articleSchema.description,
  datePublished: articleSchema.datePublished,
  url: new URL(articleSchema.url, siteConfig.siteUrl).toString(),
  author: {
    "@type": "Organization",
    name: siteConfig.brandName,
    url: siteConfig.siteUrl
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.brandName,
    logo: {
      "@type": "ImageObject",
      url: new URL(siteConfig.brandAssets.logoMark, siteConfig.siteUrl).toString()
    }
  },
  image: articleSchema.ogImage
    ? new URL(articleSchema.ogImage, siteConfig.siteUrl).toString()
    : new URL(siteConfig.brandAssets.ogCover, siteConfig.siteUrl).toString(),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(articleSchema.url, siteConfig.siteUrl).toString()
  }
}) : null;
const eventContractJson = JSON.stringify({
  version: EVENT_CONTRACT_VERSION,
  aliases: EVENT_NAME_ALIASES,
}).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f6f1e7" />
    <meta name="author" content={siteConfig.brandName} />
    <meta name="x-sb-url" content={import.meta.env.PUBLIC_SUPABASE_URL} />
    <meta name="x-sb-key" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />

    <!-- Auto dark mode from OS preference -->
    <script is:inline>
      (function(){
        function applyTheme() {
          var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (dark) {
            document.documentElement.setAttribute("data-theme", "dark");
            var mc = document.querySelector('meta[name="theme-color"]');
            if (mc) mc.setAttribute("content", "#1a1613");
          } else {
            document.documentElement.removeAttribute("data-theme");
            var mc = document.querySelector('meta[name="theme-color"]');
            if (mc) mc.setAttribute("content", "#f6f1e7");
          }
        }
        applyTheme();
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", applyTheme);
      })();
    </script>
    {shouldNoIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="alternate" type="application/rss+xml" title="Little Chubby Press Blog" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Little Chubby Press Blog (Español)" href="/rss-es.xml" />

    <link rel="dns-prefetch" href="//images-na.ssl-images-amazon.com" />
    <link rel="dns-prefetch" href="//m.media-amazon.com" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700&family=Lora:wght@400&display=swap"
      onload="this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700&family=Lora:wght@400&display=swap" rel="stylesheet" />
    </noscript>

    <title>{title}</title>
    <meta name="description" content={description} />
    {shouldExposePinterestVerification && <meta name="p:domain_verify" content="bc8eff299b41603bc3d11c3cae8f371c" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alternateLang} href={alternateHref} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", siteConfig.siteUrl).toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@LtlChubbyPress" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <ClientRouter />

    <script type="application/ld+json" set:html={organizationJsonLd}></script>
    <script type="application/ld+json" set:html={websiteJsonLd}></script>
    {breadcrumbJsonLd && <script type="application/ld+json" set:html={breadcrumbJsonLd}></script>}
    {articleJsonLd && <script type="application/ld+json" set:html={articleJsonLd}></script>}
  </head>
  <body>
    <a class="skip-link" href="#contenido-principal">{skipLabel}</a>
    <!-- SPA route-change announcer for screen readers (a11y). Updated by
         astro:after-swap hook below; aria-live=polite avoids interrupting AT. -->
    <div id="a11y-route-announcer" class="visually-hidden" role="status" aria-live="polite" aria-atomic="true"></div>
    <ParentalConsentBanner lang={lang} />
    <Header lang={lang} pathname={pathname} alternatePath={alternatePath} hideNav={hideHeaderNav} />
    <main id="contenido-principal">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />
    {showLeadMagnet && <LeadMagnetPopup lang={lang} />}
    {!pathname.startsWith("/admin") && <ChubbyChat lang={lang} />}

    <script id="lcp-event-contract" type="application/json" is:inline set:html={eventContractJson}></script>

    <!-- Vercel Analytics & Speed Insights (cookie-free, GDPR-compliant) -->
    <script>
      import { inject } from "@vercel/analytics";
      import { injectSpeedInsights } from "@vercel/speed-insights";
      inject();
      injectSpeedInsights();
    </script>

    <!-- Toast for ?msg= query params (confirm, unsubscribe, errors) -->
    <script is:inline>
      function _showMsgToast() {
        var params = new URLSearchParams(location.search);
        var msg = params.get("msg");
        if (!msg) return;
        var isEs = document.documentElement.lang === "es";
        var messages = {
          "subscribed":        isEs ? "✅ ¡Suscripción confirmada! Bienvenido/a." : "✅ Subscription confirmed! Welcome aboard.",
          "already-confirmed": isEs ? "Ya estás suscrito/a." : "You're already subscribed.",
          "unsubscribed":      isEs ? "Te has dado de baja correctamente." : "You have been unsubscribed.",
          "invalid-token":     isEs ? "El enlace no es válido o ya expiró." : "This link is invalid or has expired.",
          "error":             isEs ? "Algo salió mal. Intenta de nuevo." : "Something went wrong. Please try again."
        };
        var text = messages[msg];
        if (!text) return;
        var toast = document.createElement("div");
        toast.setAttribute("role", "alert");
        toast.style.cssText = "position:fixed;top:1rem;left:50%;transform:translateX(-50%);z-index:9999;background:#fff;color:#4b4239;padding:0.85rem 1.5rem;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,0.15);font-size:0.95rem;font-family:inherit;max-width:90vw;text-align:center;border:2px solid " + (msg === "error" || msg === "invalid-token" ? "#e74c3c" : "#5c9650") + ";animation:toastIn .3s ease";
        toast.textContent = text;
        document.body.appendChild(toast);
        // Clean URL
        var clean = location.pathname + location.hash;
        history.replaceState(null, "", clean);
        setTimeout(function(){ toast.style.opacity = "0"; toast.style.transition = "opacity .4s"; }, 4000);
        setTimeout(function(){ toast.remove(); }, 4500);
      }
      _showMsgToast();
      document.addEventListener("astro:after-swap", _showMsgToast);
    </script>

    <!-- SPA a11y: announce route change (document.title) to screen readers
         after Astro view transitions. Master doc VIII-C.3. -->
    <script is:inline>
      (function () {
        var node = document.getElementById("a11y-route-announcer");
        if (!node) return;
        function announce() {
          var t = (document.title || "").trim();
          if (!t) return;
          // Clear then set on next frame so AT re-announces identical titles.
          node.textContent = "";
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              node.textContent = t;
            });
          });
        }
        document.addEventListener("astro:after-swap", announce);
      })();
    </script>

    <!-- Lightweight pageview tracker → Supabase (for daily email report) -->
    <script is:inline>
      (function(){
        if (navigator.webdriver) return;                       // skip bots
        var p = location.pathname;
        if (p.startsWith("/admin")) return;                    // skip admin
        var key = "pv:" + p;
        if (sessionStorage.getItem(key)) return;               // once per session per page
        sessionStorage.setItem(key, "1");
        // build a daily visitor hash from random session id + date
        var sid = sessionStorage.getItem("_pvs");
        if (!sid) { sid = Math.random().toString(36).slice(2); sessionStorage.setItem("_pvs", sid); }
        var vh = sid + "_" + new Date().toISOString().slice(0,10);
        var sb = document.querySelector('meta[name="x-sb-url"]');
        var sk = document.querySelector('meta[name="x-sb-key"]');
        if (!sb || !sk) return;
        var body = { path: p, referrer: document.referrer || null, visitor_hash: vh };
        // Capture UTM parameters from landing URL (set by social agents)
        try {
          var qs = new URLSearchParams(location.search);
          var us = qs.get("utm_source");
          if (us) {
            body.utm_source = us;
            body.utm_medium = qs.get("utm_medium") || null;
            body.utm_campaign = qs.get("utm_campaign") || null;
            body.utm_content = qs.get("utm_content") || null;
            body.landing_page = p + location.search;
          }
        } catch(e){}
        // Try to get country from Vercel header (edge) or timezone fallback
        try {
          var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "";
          body.country = tz.split("/")[0]; // rough region (America, Europe, Asia…)
        } catch(e){}
        fetch(sb.content + "/rest/v1/pageviews", {
          method: "POST", headers: {
            "Content-Type": "application/json",
            apikey: sk.content,
            Authorization: "Bearer " + sk.content,
            Prefer: "return=minimal"
          }, body: JSON.stringify(body), keepalive: true
        }).catch(function(){});
      })();
    </script>

    <!--
      Lightweight event tracker -> Supabase conversion_events.
      Exposes window.lcpTrack(event_name, props) for funnel instrumentation.
      Same anon-key + RLS pattern as pageviews. Pkg P5-01.
    -->
    <script is:inline>
      (function () {
        if (navigator.webdriver) { window.lcpTrack = function () {}; return; }
        var sb = document.querySelector('meta[name="x-sb-url"]');
        var sk = document.querySelector('meta[name="x-sb-key"]');
        if (!sb || !sk) { window.lcpTrack = function () {}; return; }
        function makeId(prefix) {
          try {
            if (window.crypto && window.crypto.getRandomValues) {
              var bytes = new Uint8Array(8);
              window.crypto.getRandomValues(bytes);
              var hex = Array.prototype.map.call(bytes, function (b) { return b.toString(16).padStart(2, "0"); }).join("");
              return prefix + "_" + hex;
            }
          } catch (e) {}
          return prefix + "_" + Math.random().toString(36).slice(2) + Date.now().toString(36);
        }
        function getStoredId(storage, key, prefix) {
          try {
            var id = storage.getItem(key);
            if (!id) {
              id = makeId(prefix);
              storage.setItem(key, id);
            }
            return id;
          } catch (e) { return null; }
        }
        function getSessionId() {
          return getStoredId(sessionStorage, "_lcp_session_id", "sess");
        }
        function getAnonymousId() {
          return getStoredId(localStorage, "_lcp_anonymous_id", "anon");
        }
        function getVisitorHash() {
          try {
            var sid = sessionStorage.getItem("_pvs");
            if (!sid) {
              sid = Math.random().toString(36).slice(2);
              sessionStorage.setItem("_pvs", sid);
            }
            return sid + "_" + new Date().toISOString().slice(0, 10);
          } catch (e) { return null; }
        }
        function getUtmState() {
          try {
            var qs = new URLSearchParams(location.search);
            var current = {
              utm_source: qs.get("utm_source") || "",
              utm_medium: qs.get("utm_medium") || "",
              utm_campaign: qs.get("utm_campaign") || "",
              utm_content: qs.get("utm_content") || "",
              landing_page: location.pathname + location.search
            };
            if (current.utm_source) {
              sessionStorage.setItem("_lcp_utm", JSON.stringify(current));
              return current;
            }
            var saved = sessionStorage.getItem("_lcp_utm");
            return saved ? JSON.parse(saved) : current;
          } catch (e) { return {}; }
        }
        function getSource(utm) {
          if (utm && utm.utm_source) return utm.utm_source;
          try {
            if (!document.referrer) return "direct";
            var host = new URL(document.referrer).hostname.replace(/^www\./, "");
            if (host.indexOf(location.hostname.replace(/^www\./, "")) >= 0) return "internal";
            return host;
          } catch (e) { return "unknown"; }
        }
        function getDeviceClass() {
          try {
            var w = window.innerWidth || document.documentElement.clientWidth || 0;
            if (w < 640) return "mobile";
            if (w < 1024) return "tablet";
            return "desktop";
          } catch (e) { return "unknown"; }
        }
        function getEventContract() {
          try {
            var el = document.getElementById("lcp-event-contract");
            return el && el.textContent ? JSON.parse(el.textContent) : { version: "conversion_events_v1", aliases: {} };
          } catch (e) { return { version: "conversion_events_v1", aliases: {} }; }
        }
        var eventContract = getEventContract();
        function canonicalEventName(eventName) {
          return (eventContract.aliases && eventContract.aliases[eventName]) || eventName;
        }
        function getFunnelStage(eventName) {
          eventName = canonicalEventName(eventName);
          if (eventName === "amazon_click") return "amazon_click";
          if (/book_page|sample/.test(eventName)) return "book_intent";
          if (/lead_magnet|newsletter/.test(eventName)) return "lead";
          if (/register_|login_/.test(eventName)) return "registered";
          if (/download|first_peanut|first_value/.test(eventName)) return "activated";
          if (/peanut|shop|lottery|ticket|share_click/.test(eventName)) return "engaged";
          if (/review|share_completed|art_|reaction/.test(eventName)) return "community";
          if (/return_session/.test(eventName)) return "return";
          return null;
        }
        function safeProps(props) {
          var out = {};
          if (!props || typeof props !== "object") return out;
          var keys = Object.keys(props).slice(0, 24);
          for (var i = 0; i < keys.length; i++) {
            var k = keys[i];
            var v = props[k];
            if (v === null || v === undefined || v === "") continue;
            if (typeof v === "string") {
              out[k] = v.length > 200 ? v.slice(0, 200) : v;
            } else if (typeof v === "number" || typeof v === "boolean") {
              out[k] = v;
            }
          }
          return out;
        }
        window.lcpTrack = function (eventName, props) {
          try {
            if (!eventName || typeof eventName !== "string") return;
            var originalEventName = eventName;
            eventName = canonicalEventName(eventName);
            if (eventName.length > 64) eventName = eventName.slice(0, 64);
            var occurredAt = new Date().toISOString();
            var utm = getUtmState();
            var mergedProps = safeProps({
              event_contract_version: eventContract.version || "conversion_events_v1",
              event_id: makeId("evt"),
              occurred_at: occurredAt,
              legacy_event_name: originalEventName !== eventName ? originalEventName : "",
              session_id: getSessionId(),
              anonymous_id: getAnonymousId(),
              source: getSource(utm),
              utm_source: utm.utm_source,
              utm_medium: utm.utm_medium,
              utm_campaign: utm.utm_campaign,
              utm_content: utm.utm_content,
              landing_page: utm.landing_page,
              device_class: getDeviceClass(),
              funnel_stage: getFunnelStage(eventName)
            });
            var eventProps = safeProps(props);
            for (var propName in eventProps) mergedProps[propName] = eventProps[propName];
            var body = {
              event_id: mergedProps.event_id,
              event_name: eventName,
              occurred_at: mergedProps.occurred_at,
              path: location.pathname,
              visitor_hash: getVisitorHash(),
              props: mergedProps,
              lang: document.documentElement.lang || null
            };
            function send(payload, allowSchemaFallback) {
              return fetch(sb.content + "/rest/v1/conversion_events", {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                  apikey: sk.content,
                  Authorization: "Bearer " + sk.content,
                  Prefer: "return=minimal"
                },
                body: JSON.stringify(payload),
                keepalive: true
              }).then(function (res) {
                if (allowSchemaFallback && !res.ok && (res.status === 400 || res.status === 404)) {
                  var fallback = Object.assign({}, payload);
                  delete fallback.event_id;
                  delete fallback.occurred_at;
                  return send(fallback, false);
                }
                return res;
              });
            }
            send(body, true).catch(function () {});
          } catch (e) { /* never throw from tracker */ }
        };

        function slugFromPath(pattern) {
          var match = location.pathname.match(pattern);
          return match ? decodeURIComponent(match[2] || match[1]) : null;
        }
        function asinFromUrl(url) {
          var match = String(url || "").match(/\/dp\/([A-Z0-9]{10})/i);
          return match ? match[1].toUpperCase() : null;
        }
        function linkText(el) {
          return (el && el.textContent ? el.textContent.trim().replace(/\s+/g, " ").slice(0, 80) : "");
        }
        document.addEventListener("click", function (event) {
          try {
            var rawTarget = event.target;
            var target = rawTarget && rawTarget.closest ? rawTarget.closest("a,button,[data-lcp-event]") : null;
            if (!target) return;
            var explicitEvent = target.getAttribute("data-lcp-event");
            if (explicitEvent) {
              window.lcpTrack(explicitEvent, {
                book_id: target.getAttribute("data-lcp-book-id") || "",
                content_id: target.getAttribute("data-lcp-content-id") || "",
                artwork_id: target.getAttribute("data-lcp-artwork-id") || "",
                link_text: linkText(target)
              });
            }
            var anchor = target.tagName === "A" ? target : (target.closest ? target.closest("a") : null);
            if (!anchor || !anchor.href) return;
            if (/amazon\./i.test(anchor.href)) {
              window.lcpTrack("amazon_click", {
                asin: asinFromUrl(anchor.href) || "",
                book_id: slugFromPath(/^\/(?:en|es)\/books\/([^/]+)\/?$/) || "",
                content_id: slugFromPath(/^\/(?:en|es)\/blog\/([^/]+)\/?$/) || "",
                link_text: linkText(anchor)
              });
            }
            if (anchor.hasAttribute("download")) {
              window.lcpTrack("download_link_clicked", {
                content_id: anchor.getAttribute("href") || "",
                link_text: linkText(anchor)
              });
            }
            if (anchor.classList && anchor.classList.contains("book-look-inside__item")) {
              window.lcpTrack("sample_viewed", {
                book_id: slugFromPath(/^\/(?:en|es)\/books\/([^/]+)\/?$/) || "",
                content_id: anchor.getAttribute("href") || ""
              });
            }
            if (anchor.classList && anchor.classList.contains("book-try-samples__cta")) {
              window.lcpTrack("sample_cta_click", {
                book_id: slugFromPath(/^\/(?:en|es)\/books\/([^/]+)\/?$/) || ""
              });
            }
          } catch (e) {}
        }, true);

        try {
          var bookId = slugFromPath(/^\/(?:en|es)\/books\/([^/]+)\/?$/);
          if (bookId) window.lcpTrack("book_page_viewed", { book_id: bookId });
        } catch (e) {}
      })();
    </script>
  </body>
</html>
