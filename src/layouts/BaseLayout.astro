---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { siteConfig } from "../data/site";
import type { Lang } from "../data/i18n";
import { switchLangPath } from "../data/i18n";
import "../styles/global.css";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  pathname: string;
  alternatePath?: string;
  breadcrumbs?: { name: string; url: string }[];
  articleSchema?: {
    headline: string;
    description: string;
    datePublished: string;
    url: string;
  };
  ogImage?: string;
}

const { lang, title, description, pathname, alternatePath, breadcrumbs, articleSchema, ogImage: customOgImage } = Astro.props;
const canonical = new URL(pathname, siteConfig.siteUrl).toString();
const ogImage = customOgImage
  ? new URL(customOgImage, siteConfig.siteUrl).toString()
  : new URL(siteConfig.brandAssets.ogCover, siteConfig.siteUrl).toString();
const alternateLang = lang === "es" ? "en" : "es";
const alternateHref = new URL(alternatePath || switchLangPath(pathname, alternateLang), siteConfig.siteUrl).toString();
const skipLabel = lang === "es" ? "Saltar al contenido" : "Skip to content";
const organizationJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.brandName,
  url: siteConfig.siteUrl,
  logo: new URL(siteConfig.brandAssets.logoMark, siteConfig.siteUrl).toString(),
  sameAs: [siteConfig.social.instagram, siteConfig.social.facebook, siteConfig.social.bluesky, siteConfig.social.amazonAuthor],
  contactPoint: [{
    "@type": "ContactPoint",
    email: siteConfig.contactEmail,
    contactType: "customer support"
  }]
});
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.brandName,
  url: siteConfig.siteUrl,
  inLanguage: ["es", "en"]
});

const breadcrumbJsonLd = breadcrumbs && breadcrumbs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: new URL(item.url, siteConfig.siteUrl).toString()
  }))
}) : null;

const articleJsonLd = articleSchema ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleSchema.headline,
  description: articleSchema.description,
  datePublished: articleSchema.datePublished,
  url: new URL(articleSchema.url, siteConfig.siteUrl).toString(),
  author: {
    "@type": "Organization",
    name: siteConfig.brandName,
    url: siteConfig.siteUrl
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.brandName,
    logo: {
      "@type": "ImageObject",
      url: new URL(siteConfig.brandAssets.logoMark, siteConfig.siteUrl).toString()
    }
  },
  image: new URL(siteConfig.brandAssets.ogCover, siteConfig.siteUrl).toString(),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(articleSchema.url, siteConfig.siteUrl).toString()
  }
}) : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f6f1e7" />
    <meta name="author" content={siteConfig.brandName} />

    <!-- Prevent dark-mode flash (runs before paint) -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem("lcp-theme");
        if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.setAttribute("data-theme", "dark");
          var mc = document.querySelector('meta[name="theme-color"]');
          if (mc) mc.setAttribute("content", "#1a1613");
        }
      })();
    </script>
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="alternate" type="application/rss+xml" title="Little Chubby Press Blog" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Little Chubby Press Blog (Español)" href="/rss-es.xml" />

    <link rel="dns-prefetch" href="//images-na.ssl-images-amazon.com" />
    <link rel="dns-prefetch" href="//m.media-amazon.com" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700&family=Lora:wght@400&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={alternateLang} href={alternateHref} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", siteConfig.siteUrl).toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <ClientRouter />

    <script type="application/ld+json" set:html={organizationJsonLd}></script>
    <script type="application/ld+json" set:html={websiteJsonLd}></script>
    {breadcrumbJsonLd && <script type="application/ld+json" set:html={breadcrumbJsonLd}></script>}
    {articleJsonLd && <script type="application/ld+json" set:html={articleJsonLd}></script>}
  </head>
  <body>
    <a class="skip-link" href="#contenido-principal">{skipLabel}</a>
    <Header lang={lang} pathname={pathname} alternatePath={alternatePath} />
    <main id="contenido-principal">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />

    <!-- Vercel Analytics & Speed Insights (cookie-free, GDPR-compliant) -->
    <script>
      import { inject } from "@vercel/analytics";
      import { injectSpeedInsights } from "@vercel/speed-insights";
      inject();
      injectSpeedInsights();
    </script>
  </body>
</html>
