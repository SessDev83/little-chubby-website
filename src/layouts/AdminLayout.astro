---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  current?: string;
}

const { title, current } = Astro.props;

const navGroups = [
  {
    label: "Command",
    items: [
      { href: "/admin/", icon: "▣", label: "Dashboard", key: "dashboard" },
      { href: "/admin/analytics/", icon: "↗", label: "Analytics", key: "analytics" },
      { href: "/admin/traffic/", icon: "▥", label: "Traffic", key: "traffic" },
      { href: "/admin/content-performance/", icon: "◈", label: "Content", key: "content-performance" },
    ],
  },
  {
    label: "Operations",
    items: [
      { href: "/admin/users/", icon: "◉", label: "Users", key: "users" },
      { href: "/admin/newsletter/", icon: "✉", label: "Newsletter", key: "newsletter" },
      { href: "/admin/economy/", icon: "●", label: "Economy", key: "economy" },
    ],
  },
  {
    label: "Community",
    items: [
      { href: "/admin/reviews/", icon: "✎", label: "Reviews", key: "reviews" },
      { href: "/admin/lottery/", icon: "◇", label: "Lottery", key: "lottery" },
      { href: "/admin/gallery/", icon: "▧", label: "Gallery", key: "gallery" },
      { href: "/admin/shoutouts/", icon: "⌁", label: "Shoutouts", key: "shoutouts" },
    ],
  },
  {
    label: "System",
    items: [
      { href: "/admin/audit/", icon: "☷", label: "Audit Log", key: "audit" },
    ],
  },
];
---

<BaseLayout lang="en" title={`${title} | Admin`} description="Admin panel" pathname={`/admin/`}>
  <section class="page-section container">
    <nav class="admin-nav" aria-label="Admin navigation">
      {navGroups.map((group) => (
        <div class="admin-nav-group">
          <div class="admin-nav-label">{group.label}</div>
          <div class="admin-nav-links">
            {group.items.map((item) => (
              <a
                href={item.href}
                class:list={["admin-nav-link", { active: current === item.key }]}
                aria-current={current === item.key ? "page" : undefined}
              >
                <span class="admin-nav-icon" aria-hidden="true">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </nav>
    <slot />
  </section>
</BaseLayout>

<style>
  .admin-nav {
    display: grid;
    grid-template-columns: 1.25fr 1fr 1.2fr auto;
    gap: 0.85rem;
    align-items: start;
    margin-bottom: 1.6rem;
    padding: 0.8rem;
    background: var(--surface-strong, #f8f8f8);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }
  .admin-nav-group {
    min-width: 0;
  }
  .admin-nav-label {
    margin: 0 0 0.35rem 0.2rem;
    color: var(--ink-soft);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .admin-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .admin-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .admin-nav-icon {
    display: inline-grid;
    place-items: center;
    width: 1rem;
    color: var(--brand-blue);
    font-size: 0.78rem;
    line-height: 1;
  }
  .admin-nav-link:hover {
    background: var(--surface);
    color: var(--ink);
    border-color: var(--line);
  }
  .admin-nav-link.active {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    color: #fff;
  }
  .admin-nav-link.active .admin-nav-icon {
    color: #fff;
  }
  @media (max-width: 980px) {
    .admin-nav {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .admin-nav {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      padding-bottom: 0.9rem;
      scroll-snap-type: x proximity;
    }
    .admin-nav-group {
      min-width: 14rem;
      scroll-snap-align: start;
    }
    .admin-nav-links {
      flex-wrap: nowrap;
    }
    .admin-nav-link {
      white-space: nowrap;
    }
  }
</style>
