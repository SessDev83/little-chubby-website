---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  current?: string;
}

const { title, current } = Astro.props;

const navGroups = [
  {
    label: "Command",
    items: [
      { href: "/admin/", icon: "▣", label: "Dashboard", key: "dashboard" },
      { href: "/admin/analytics/", icon: "↗", label: "Analytics", key: "analytics" },
      { href: "/admin/funnel/", icon: "⇢", label: "Funnel", key: "funnel" },
      { href: "/admin/audience-signals/", icon: "◌", label: "Audience", key: "audience-signals" },
      { href: "/admin/first-value/", icon: "◍", label: "First Value", key: "first-value" },
      { href: "/admin/intelligence/", icon: "◎", label: "Brief", key: "intelligence" },
      { href: "/admin/learning-ledger/", icon: "☰", label: "Ledger", key: "learning-ledger" },
      { href: "/admin/agent-contract/", icon: "▨", label: "Contract", key: "agent-contract" },
      { href: "/admin/conversion-agent/", icon: "⇄", label: "Conversion", key: "conversion-agent" },
      { href: "/admin/ops-feed/", icon: "≋", label: "Ops Feed", key: "ops-feed" },
      { href: "/admin/traffic/", icon: "▥", label: "Traffic", key: "traffic" },
      { href: "/admin/channel-scorecard/", icon: "▦", label: "Channels", key: "channel-scorecard" },
      { href: "/admin/social-feedback/", icon: "↬", label: "Social", key: "social-feedback" },
      { href: "/admin/language-market/", icon: "◫", label: "Languages", key: "language-market" },
      { href: "/admin/amazon-attribution/", icon: "◇", label: "Amazon", key: "amazon-attribution" },
      { href: "/admin/book-scorecard/", icon: "▤", label: "Books", key: "book-scorecard" },
      { href: "/admin/resilience/", icon: "□", label: "Resilience", key: "resilience" },
      { href: "/admin/content-performance/", icon: "◈", label: "Content", key: "content-performance" },
    ],
  },
  {
    label: "Operations",
    items: [
      { href: "/admin/users/", icon: "◉", label: "Users", key: "users" },
      { href: "/admin/retention/", icon: "↺", label: "Retention", key: "retention" },
      { href: "/admin/newsletter/", icon: "✉", label: "Newsletter", key: "newsletter" },
      { href: "/admin/economy/", icon: "●", label: "Economy", key: "economy" },
      { href: "/admin/community-agent/", icon: "◒", label: "Engagement", key: "community-agent" },
    ],
  },
  {
    label: "Community",
    items: [
      { href: "/admin/reviews/", icon: "✎", label: "Reviews", key: "reviews" },
      { href: "/admin/lottery/", icon: "◇", label: "Lottery", key: "lottery" },
      { href: "/admin/gallery/", icon: "▧", label: "Gallery", key: "gallery" },
      { href: "/admin/shoutouts/", icon: "⌁", label: "Shoutouts", key: "shoutouts" },
    ],
  },
  {
    label: "System",
    items: [
      { href: "/admin/audit/", icon: "☷", label: "Audit Log", key: "audit" },
    ],
  },
];
---

<BaseLayout lang="en" title={`${title} | Admin`} description="Admin panel" pathname={`/admin/`}>
  <section class="page-section container">
    <nav class="admin-nav" aria-label="Admin navigation">
      {navGroups.map((group) => (
        <div class="admin-nav-group">
          <div class="admin-nav-label">{group.label}</div>
          <div class="admin-nav-links">
            {group.items.map((item) => (
              <a
                href={item.href}
                class:list={["admin-nav-link", { active: current === item.key }]}
                aria-current={current === item.key ? "page" : undefined}
              >
                <span class="admin-nav-icon" aria-hidden="true">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </nav>
    <slot />
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("submit", function(event) {
    var form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    if (!form.matches("[data-admin-pending], [data-admin-confirm]")) return;

    var submitter = event.submitter instanceof HTMLElement ? event.submitter : null;
    var confirmText = submitter?.getAttribute("data-admin-confirm") || form.getAttribute("data-admin-confirm");
    if (confirmText && !window.confirm(confirmText)) {
      event.preventDefault();
      return;
    }

    if (form.dataset.adminSubmitting === "1") {
      event.preventDefault();
      return;
    }
    if (!form.checkValidity()) return;

    form.dataset.adminSubmitting = "1";
    form.setAttribute("aria-busy", "true");

    if ((submitter instanceof HTMLButtonElement || submitter instanceof HTMLInputElement) && submitter.name) {
      var mirror = document.createElement("input");
      mirror.type = "hidden";
      mirror.name = submitter.name;
      mirror.value = submitter.value;
      mirror.setAttribute("data-admin-submit-mirror", "true");
      form.appendChild(mirror);
    }

    var pendingText = submitter?.getAttribute("data-admin-pending") || form.getAttribute("data-admin-pending");
    if (pendingText && submitter) {
      if (submitter instanceof HTMLInputElement) {
        submitter.value = pendingText;
      } else {
        submitter.textContent = pendingText;
      }
    }

    form.querySelectorAll('button, input[type="submit"]').forEach(function(control) {
      if (control instanceof HTMLButtonElement && control.type !== "submit") return;
      if (!(control instanceof HTMLButtonElement || control instanceof HTMLInputElement)) return;
      control.disabled = true;
      control.setAttribute("aria-disabled", "true");
    });
  });

  document.addEventListener("click", function(event) {
    var target = event.target;
    if (!(target instanceof Element)) return;
    if (target.closest("a, button, input, select, textarea, summary, label")) return;
    var row = target.closest("[data-admin-row-href]");
    if (row instanceof HTMLElement) {
      var href = row.getAttribute("data-admin-row-href");
      if (href) window.location.href = href;
    }
  });

  document.addEventListener("keydown", function(event) {
    if (event.key !== "Enter" && event.key !== " ") return;
    var target = event.target;
    if (!(target instanceof HTMLElement)) return;
    var href = target.getAttribute("data-admin-row-href");
    if (!href) return;
    event.preventDefault();
    window.location.href = href;
  });
</script>

<style>
  .admin-nav {
    display: grid;
    grid-template-columns: 1.25fr 1fr 1.2fr auto;
    gap: 0.85rem;
    align-items: start;
    margin-bottom: 1.6rem;
    padding: 0.8rem;
    background: var(--surface-strong, #f8f8f8);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }
  .admin-nav-group {
    min-width: 0;
  }
  .admin-nav-label {
    margin: 0 0 0.35rem 0.2rem;
    color: var(--ink-soft);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .admin-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .admin-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .admin-nav-icon {
    display: inline-grid;
    place-items: center;
    width: 1rem;
    color: var(--brand-blue);
    font-size: 0.78rem;
    line-height: 1;
  }
  .admin-nav-link:hover {
    background: var(--surface);
    color: var(--ink);
    border-color: var(--line);
  }
  .admin-nav-link.active {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    color: #fff;
  }
  .admin-nav-link.active .admin-nav-icon {
    color: #fff;
  }

  :global(.admin-page-head),
  :global(.surface-card),
  :global(.stat-card),
  :global(.admin-panel) {
    min-width: 0;
  }

  :global(.table-wrap),
  :global(.admin-table-wrap),
  :global(.journey-timeline) {
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
  }

  :global(.admin-table) {
    width: 100%;
    max-width: 100%;
  }

  :global(.admin-table th),
  :global(.admin-table td) {
    max-width: clamp(8rem, 24vw, 24rem);
    vertical-align: top;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  :global(.admin-table code),
  :global(.admin-code-cell) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(.admin-wrap) {
    white-space: normal !important;
    overflow: visible !important;
    text-overflow: clip !important;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(.admin-truncate) {
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.admin-nowrap),
  :global(.admin-table .nowrap) {
    white-space: nowrap;
  }

  :global(.admin-number) {
    text-align: right;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  :global(.stat-card strong),
  :global(.stat-number),
  :global(.stat-value),
  :global(.mini-num) {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  :global(form[aria-busy="true"]) {
    opacity: 0.78;
  }

  :global(form[aria-busy="true"] button),
  :global(button[aria-disabled="true"]) {
    cursor: wait;
  }

  :global(.admin-empty-state) {
    margin: 0;
    padding: 1rem;
    border: 1px dashed var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface, #fff);
    color: var(--ink-soft);
    text-align: center;
  }

  :global(.admin-action-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  :global(.admin-action-cell) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }

  :global(.admin-danger) {
    color: #8f1f18 !important;
  }

  :global([data-admin-row-href]) {
    cursor: pointer;
  }

  :global([data-admin-row-href]:focus-visible) {
    outline: 2px solid var(--brand-blue);
    outline-offset: -2px;
  }

  @media (max-width: 980px) {
    .admin-nav {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .admin-nav {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      padding-bottom: 0.9rem;
      scroll-snap-type: x proximity;
    }
    .admin-nav-group {
      min-width: 14rem;
      scroll-snap-align: start;
    }
    .admin-nav-links {
      flex-wrap: nowrap;
    }
    .admin-nav-link {
      white-space: nowrap;
    }
  }
</style>
