---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { ADMIN_EMAILS, getServiceClient, isAdmin } from "../../lib/supabase";
import { books, getMonthlyPrizeBook } from "../../data/books";
import { emailUserReviewApproved, emailUserReviewRejected, emailUserLotteryWin } from "../../lib/notifications";
import crypto from "node:crypto";

const user = Astro.locals.user;
if (!user || !(await isAdmin(user))) {
  return Astro.redirect("/es/login/");
}

const sc = getServiceClient();
const currentMonth = new Date().toISOString().slice(0, 7);
const prizeBook = getMonthlyPrizeBook(currentMonth);

let drawResult = "";
let drawError = "";
let configMsg = "";
let reviewMsg = "";
let bulkMsg = "";

/** Log every admin action for audit trail */
async function auditLog(action: string, targetType: string, targetId: string | null, details: Record<string, unknown> = {}) {
  try {
    await sc.from("admin_audit_log").insert({
      admin_id: user!.email || user!.id,
      action,
      target_type: targetType,
      target_id: targetId,
      details,
    });
  } catch { /* non-blocking */ }
}

/** Cryptographically secure random index */
function secureRandomIndex(max: number): number {
  const arr = new Uint32Array(1);
  crypto.getRandomValues(arr);
  return arr[0] % max;
}

// ── Get or create this month's config ────────────────
let { data: config } = await sc
  .from("lottery_config")
  .select("*")
  .eq("month", currentMonth)
  .maybeSingle();

if (!config) {
  await sc.from("lottery_config").insert({ month: currentMonth });
  const { data: fresh } = await sc.from("lottery_config").select("*").eq("month", currentMonth).single();
  config = fresh;
}

// Check if draw already happened this month (prevent duplicates)
const { data: monthWinners } = await sc
  .from("lottery_winners")
  .select("id")
  .eq("month", currentMonth)
  .limit(1);
const drawAlreadyDone = (monthWinners ?? []).length > 0;

async function notifyUserReviewDecision(
  reviewId: string,
  status: "approved" | "rejected",
  reviewerNote: string
): Promise<void> {
  try {
    const { data: rev } = await sc
      .from("book_reviews")
      .select("user_id, book_id")
      .eq("id", reviewId)
      .single();
    if (!rev) return;

    const { data: profile } = await sc
      .from("profiles")
      .select("lang_pref")
      .eq("id", rev.user_id)
      .single();
    const { data: authUser } = await sc.auth.admin.getUserById(rev.user_id);
    const email = authUser?.user?.email;
    if (!email) return;

    const lang = (profile?.lang_pref || "en") as "en" | "es";
    const bookTitle = books.find(b => b.id === rev.book_id)?.title[lang] || rev.book_id;
    if (status === "approved") {
      await emailUserReviewApproved(email, bookTitle, lang, reviewerNote);
    } else {
      await emailUserReviewRejected(email, bookTitle, lang, reviewerNote);
    }
  } catch {
    // Non-blocking: moderation action should succeed even if email fails.
  }
}

// ── Handle POST actions ──────────────────────────────
if (Astro.request.method === "POST") {
  // ── CSRF: validate Origin header ──
  const origin = Astro.request.headers.get("origin");
  const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://www.littlechubbypress.com";
  const allowedOrigins = [new URL(siteUrl).origin, "https://www.littlechubbypress.com", "https://littlechubbypress.com"];
  if (!origin || !allowedOrigins.includes(origin)) {
    reviewMsg = "⛔ Request blocked: invalid origin.";
  }

  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (reviewMsg) {
    // Origin check failed — skip all actions
  } else if (action === "save_config") {
    const maxWinners = parseInt(formData.get("max_winners")?.toString() || "3", 10);
    const winnerPct = parseFloat(formData.get("winner_pct")?.toString() || "1");
    const minPurchases = parseInt(formData.get("min_purchases")?.toString() || "0", 10);
    const isActive = formData.get("is_active") === "on";
    const drawDate = formData.get("draw_date")?.toString() || null;
    const prizeDescription = formData.get("prize_description")?.toString() || "";

    await sc.from("lottery_config").update({
      max_winners: maxWinners,
      winner_pct: winnerPct,
      min_purchases: minPurchases,
      is_active: true,
      draw_date: drawDate || null,
      prize_description: prizeDescription,
    }).eq("month", currentMonth);

    config = { ...config!, max_winners: maxWinners, winner_pct: winnerPct, min_purchases: minPurchases, is_active: true, draw_date: drawDate, prize_description: prizeDescription };
    configMsg = "Config saved.";
    await auditLog("save_config", "config", currentMonth, { maxWinners, winnerPct, minPurchases });
  }

  else if (action === "approve_review" || action === "reject_review") {
    const reviewId = formData.get("review_id")?.toString();
    const newStatus = action === "approve_review" ? "approved" : "rejected";
    const reviewerNote = formData.get("reviewer_note")?.toString().trim() || "";

    if (!reviewId) {
      reviewMsg = "Missing review id.";
    } else if (newStatus === "rejected" && !reviewerNote) {
      reviewMsg = "Please add a rejection reason so the user knows what to fix.";
    } else {
      const { error: updateError } = await sc.from("book_reviews").update({
        status: newStatus,
        reviewed_at: new Date().toISOString(),
        reviewer_note: reviewerNote || null,
      }).eq("id", reviewId);

      if (updateError) {
        reviewMsg = `Error: ${updateError.message}`;
      } else {
        await notifyUserReviewDecision(reviewId, newStatus, reviewerNote);
        await auditLog(action, "review", reviewId, { newStatus, reviewerNote: reviewerNote || null });
        reviewMsg = `Review ${newStatus}.`;
      }
    }
  }

  else if (action === "bulk_approve" || action === "bulk_reject") {
    const ids = formData.getAll("selected_ids").map(v => v.toString());
    const newStatus = action === "bulk_approve" ? "approved" : "rejected";
    const reviewerNote = formData.get("bulk_reviewer_note")?.toString().trim() || "";
    if (ids.length > 0) {
      if (newStatus === "rejected" && !reviewerNote) {
        bulkMsg = "Please add a rejection reason for users before bulk reject.";
      } else {
        const { error } = await sc.from("book_reviews").update({
          status: newStatus,
          reviewed_at: new Date().toISOString(),
          reviewer_note: reviewerNote || null,
        }).in("id", ids);

        if (!error) {
          for (const rid of ids) {
            await notifyUserReviewDecision(rid, newStatus, reviewerNote);
          }
        }

        bulkMsg = error ? `Error: ${error.message}` : `${newStatus === "approved" ? "✓" : "✗"} ${ids.length} review(s) ${newStatus}.`;
        if (!error) await auditLog(action, "review", ids.join(","), { count: ids.length, newStatus, reviewerNote: reviewerNote || null });
      }
    }
  }

  else if (action === "toggle_featured") {
    const reviewId = formData.get("review_id")?.toString();
    const featured = formData.get("featured") === "true";
    await sc.from("book_reviews").update({ featured: !featured }).eq("id", reviewId);
    await auditLog("toggle_featured", "review", reviewId ?? null, { newFeatured: !featured });
    reviewMsg = "Featured status updated.";
  }

  else if (action === "delete_review") {
    const reviewId = formData.get("review_id")?.toString();
    if (reviewId) {
      await sc.from("book_reviews").delete().eq("id", reviewId);
      await auditLog("delete_review", "review", reviewId, {});
      reviewMsg = "Review deleted.";
    }
  }

  else if (action === "draw") {
    // Prevent duplicate draw for same month
    const { data: existCheck } = await sc
      .from("lottery_winners")
      .select("id")
      .eq("month", currentMonth)
      .limit(1);

    if (existCheck && existCheck.length > 0) {
      drawError = "⚠️ Draw already completed for this month. Cannot draw again.";
    } else {
      // Each user with ≥1 approved review gets 5 tickets per approved book
      const { data: reviews } = await sc
        .from("book_reviews")
        .select("user_id")
        .eq("status", "approved");

      // Also include paid lottery entries
      const { data: paidEntries } = await sc
        .from("lottery_entries")
        .select("user_id, entry_count")
        .eq("month", currentMonth);

      if ((!reviews || reviews.length === 0) && (!paidEntries || paidEntries.length === 0)) {
        drawError = "No approved reviews and no paid entries — nobody is eligible.";
      } else {
        const ticketMap = new Map<string, number>();
        for (const r of reviews!) {
          ticketMap.set(r.user_id, (ticketMap.get(r.user_id) || 0) + 5);
        }

        // Add purchased entries to ticket pool
        if (paidEntries) {
          for (const pe of paidEntries) {
            ticketMap.set(pe.user_id, (ticketMap.get(pe.user_id) || 0) + pe.entry_count);
          }
        }

        const minReq = config?.min_purchases ?? 0;
        const eligible = [...ticketMap.entries()].filter(([, tickets]) => tickets >= minReq * 5);
        const pool = eligible;

        if (pool.length === 0) {
          drawError = "No eligible users (check min requirements).";
        } else {
          const pctWinners = Math.ceil(pool.length * ((config?.winner_pct ?? 1) / 100));
          const numToDraw = Math.min(pctWinners, config?.max_winners ?? 3, pool.length);

          if (numToDraw <= 0) {
            drawError = "Winner count resolves to 0. Check config.";
          } else {
            const weightedPool: string[] = [];
            let totalTicketsCount = 0;
            for (const [uid, tickets] of pool) {
              for (let i = 0; i < tickets; i++) {
                weightedPool.push(uid);
              }
              totalTicketsCount += tickets;
            }

            const winnerIds = new Set<string>();
            let attempts = 0;
            while (winnerIds.size < numToDraw && attempts < weightedPool.length * 10) {
              const idx = secureRandomIndex(weightedPool.length);
              winnerIds.add(weightedPool[idx]);
              attempts++;
            }

            const drawn: string[] = [];
            const claimDeadline = new Date();
            claimDeadline.setDate(claimDeadline.getDate() + 14);

            for (const winnerId of winnerIds) {
              const { error } = await sc.from("lottery_winners").insert({
                user_id: winnerId,
                month: currentMonth,
                claim_deadline: claimDeadline.toISOString(),
              });
              if (!error) {
                const { data: profile } = await sc.from("profiles").select("email, display_name, lang_pref").eq("id", winnerId).single();
                drawn.push(profile?.display_name || profile?.email || winnerId);
                // Send email + in-app notification to winner
                const { data: authUser } = await sc.auth.admin.getUserById(winnerId);
                if (authUser?.user?.email) {
                  await emailUserLotteryWin(authUser.user.email, claimDeadline.toISOString().slice(0, 10), profile?.lang_pref || "en", prizeBook.title[profile?.lang_pref === "es" ? "es" : "en"]);
                }
                // In-app notification (via DB function)
                await sc.rpc("notify_user", {
                  p_user_id: winnerId,
                  p_type: "lottery_win",
                  p_title_en: "You Won the Monthly Giveaway! 🏆",
                  p_title_es: "¡Ganaste el Sorteo Mensual! 🏆",
                  p_body_en: `Claim your free book before ${claimDeadline.toISOString().slice(0, 10)}!`,
                  p_body_es: `¡Reclama tu libro gratis antes del ${claimDeadline.toISOString().slice(0, 10)}!`,
                });
              }
            }

            // Audit trail
            await sc.from("lottery_draw_log").insert({
              month: currentMonth,
              config_snapshot: config ?? {},
              eligible_users: pool.length,
              total_tickets: totalTicketsCount,
              winners_drawn: drawn.length,
              drawn_by: user!.id,
            });

            drawResult = `Drew ${drawn.length} winner(s): ${drawn.join(", ")} — from ${pool.length} eligible users, ${totalTicketsCount} weighted tickets`;
          }
        }
      }
    }
  }
}

// ── Data for display ─────────────────────────────────
const { data: pendingReviews } = await sc
  .from("book_reviews")
  .select("id, user_id, book_id, photo_url, extra_photos, rating, review_text, featured, submitted_at, profiles(email, display_name)")
  .eq("status", "pending")
  .order("submitted_at", { ascending: true });

const { count: totalApproved } = await sc
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "approved");

// Unique users with approved reviews
const { data: approvedUsers } = await sc
  .from("book_reviews")
  .select("user_id")
  .eq("status", "approved");
const uniqueUserIds = new Set((approvedUsers ?? []).map(r => r.user_id));

// Count total paid entries this month
const { data: monthPaidEntries } = await sc
  .from("lottery_entries")
  .select("entry_count")
  .eq("month", currentMonth);
const totalPaidEntries = (monthPaidEntries ?? []).reduce((sum, e) => sum + (e.entry_count || 0), 0);

// Paid entry users detail (for the table)
const { data: paidEntryUsers } = await sc
  .from("lottery_entries")
  .select("user_id, entry_count, purchased_at, profiles!inner(display_name, email, country)")
  .eq("month", currentMonth)
  .order("purchased_at", { ascending: false });

const { data: winners } = await sc
  .from("lottery_winners")
  .select("month, book_chosen, claimed, shipping_name, shipping_address, claim_deadline, notified, profiles!inner(email, display_name)")
  .order("month", { ascending: false })
  .limit(50);

const bookMap = Object.fromEntries(books.map(b => [b.id, b.title.en]));
const stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);
---

<BaseLayout lang="en" title="Lottery & Reviews | Admin" description="Review + lottery management" pathname="/admin/lottery/">
  <section class="page-section container">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
      <h1>Lottery & Reviews</h1>
      <a href="/admin/" class="btn btn-secondary">← Dashboard</a>
    </div>

    {/* ── Config ── */}
    <div class="surface-card" style="padding:1.6rem; margin-top:2rem;">
      <h2>Config for {currentMonth}</h2>
      {configMsg && <p class="msg-ok">{configMsg}</p>}
      <form method="POST" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(10rem,1fr)); gap:1rem; margin-top:1rem;">
        <input type="hidden" name="action" value="save_config" />
        <div class="form-group">
          <label>Max winners</label>
          <input type="number" name="max_winners" value={config?.max_winners ?? 3} min="1" max="50" />
        </div>
        <div class="form-group">
          <label>Winner % of pool</label>
          <input type="number" name="winner_pct" value={config?.winner_pct ?? 1} min="0.1" max="100" step="0.1" />
        </div>
        <div class="form-group">
          <label>Min reviews required</label>
          <input type="number" name="min_purchases" value={config?.min_purchases ?? 0} min="0" />
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <p style="display:flex; align-items:center; gap:0.5rem; margin:0;">
            <strong>🎁 Giveaway</strong>
            <span style="font-size:0.85rem; color:var(--brand-green); font-weight:700;">🟢 Always Active</span>
            <span style="font-size:0.8rem; color:var(--ink-soft);">(auto-rotates book each month)</span>
          </p>
        </div>
        <div class="form-group">
          <label>Draw Date</label>
          <input type="date" name="draw_date" value={config?.draw_date ?? ""} />
        </div>
        <div class="form-group" style="grid-column:span 2;">
          <label>Prize Description <span style="font-size:0.8rem; color:var(--ink-soft);">(optional extra note)</span></label>
          <p style="font-size:0.85rem; margin:0 0 0.4rem; color:var(--brand-blue);">📖 Auto-rotation: <strong>{prizeBook.title.en}</strong></p>
          <input type="text" name="prize_description" value={config?.prize_description ?? ""} placeholder="e.g. Free shipping included!" style="width:100%;" />
        </div>
        <button type="submit" class="btn btn-secondary">Save Config</button>
      </form>
    </div>

    {/* ── Draw ── */}
    <div class="surface-card" style="padding:1.6rem; margin-top:1.5rem;">
      <h2>Draw — {currentMonth}</h2>
      <p>Approved reviews: <strong>{totalApproved ?? 0}</strong> · Eligible users: <strong>{uniqueUserIds.size}</strong> · Paid entries: <strong>{totalPaidEntries}</strong></p>

      {drawResult && <p class="msg-ok">🎉 {drawResult}</p>}
      {drawError && <p class="msg-err">{drawError}</p>}

      {drawAlreadyDone ? (
        <p class="msg-err">⚠️ Draw already completed for {currentMonth}. Winners have been selected.</p>
      ) : (
        <form method="POST" style="margin-top:1rem;" id="drawForm">
          <input type="hidden" name="action" value="draw" />
          <button type="submit" class="btn btn-primary" id="drawBtn" onclick="this.disabled=true;this.textContent='⏳ Drawing...';this.form.submit();">🎲 Draw Winners</button>
        </form>
      )}
    </div>

    {/* ── Paid Entry Users ── */}
    {paidEntryUsers && paidEntryUsers.length > 0 && (
      <div class="surface-card" style="padding:1.6rem; margin-top:1.5rem;">
        <h2>🎟️ Paid Entries — {currentMonth}</h2>
        <div style="overflow-x:auto; margin-top:0.8rem;">
          <table class="admin-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Tickets</th>
                <th>Country</th>
                <th>Purchased</th>
              </tr>
            </thead>
            <tbody>
              {paidEntryUsers.map((pe: any) => (
                <tr>
                  <td style="font-weight:600;">{(pe.profiles as any)?.display_name || "—"}</td>
                  <td>{(pe.profiles as any)?.email || "—"}</td>
                  <td style="text-align:center; font-weight:700; color:var(--brand-blue);">{pe.entry_count}</td>
                  <td>{(pe.profiles as any)?.country || "—"}</td>
                  <td>{new Date(pe.purchased_at).toLocaleDateString()}</td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr style="border-top:2px solid var(--line); font-weight:700;">
                <td colspan="2">Total</td>
                <td style="text-align:center;">{paidEntryUsers.reduce((s: number, pe: any) => s + (pe.entry_count || 0), 0)}</td>
                <td colspan="2"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    )}

    {/* ── Pending Reviews with Bulk Actions ── */}
    {pendingReviews && pendingReviews.length > 0 && (
      <div style="margin-top:2rem;">
        <h2>Pending Reviews ({pendingReviews.length})</h2>
        {reviewMsg && <p class="msg-ok">{reviewMsg}</p>}
        {bulkMsg && <p class="msg-ok">{bulkMsg}</p>}

        <form method="POST" id="bulkForm">
          <div class="bulk-bar" id="bulkBar" style="display:none;">
            <label class="bulk-select-all">
              <input type="checkbox" id="selectAll" /> Select All
            </label>
            <span id="bulkCount">0 selected</span>
            <input
              type="text"
              name="bulk_reviewer_note"
              id="bulkReviewerNote"
              class="bulk-note-input"
              placeholder="Message to users (required for bulk reject)"
            />
            <button type="submit" name="action" value="bulk_approve" id="bulkApproveBtn" class="btn btn-ghost" style="font-size:0.8rem; padding:0.3rem 0.6rem;">✓ Approve Selected</button>
            <button type="submit" name="action" value="bulk_reject" id="bulkRejectBtn" class="btn btn-secondary" style="font-size:0.8rem; padding:0.3rem 0.6rem;">✗ Reject Selected</button>
          </div>
        </form>
        <div class="review-queue">
          {pendingReviews.map((r: any) => (
            <div class="review-card-admin">
              <div class="review-checkbox">
                <input type="checkbox" name="selected_ids" value={r.id} class="bulk-checkbox" form="bulkForm" />
              </div>
              <div class="review-left">
                <div class="review-details">
                  <strong>{(r.profiles as any)?.display_name || (r.profiles as any)?.email || r.user_id}</strong>
                  <span class="review-book-name">{bookMap[r.book_id] || r.book_id}</span>
                  <span class="review-stars-admin">{stars(r.rating)}</span>
                  {r.review_text && <p class="review-text-admin">{r.review_text}</p>}
                  <small style="color:var(--ink-soft);">{new Date(r.submitted_at).toLocaleDateString()}</small>
                </div>
                <div class="review-photos-admin">
                  <div class="photo-group">
                    <div class="photo-label">📕 Cover</div>
                    <img src={r.photo_url} alt="Cover" class="review-img-admin review-img-cover" loading="lazy" />
                  </div>
                  {r.extra_photos && (r.extra_photos as string[]).length > 0 && (
                    <div class="photo-group">
                      <div class="photo-label">📖 Interior</div>
                      <div class="interior-strip">
                        {(r.extra_photos as string[]).map((url: string) => (
                          <img src={url} alt="Interior" class="review-img-admin review-img-interior" loading="lazy" />
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
              <div class="review-actions">
                <form method="POST">
                  <input type="hidden" name="action" value="approve_review" />
                  <input type="hidden" name="review_id" value={r.id} />
                  <input type="text" name="reviewer_note" placeholder="Note (optional)" maxlength="500" class="action-input" />
                  <button type="submit" class="btn btn-ghost action-btn">✓ Approve</button>
                </form>
                <form method="POST">
                  <input type="hidden" name="action" value="reject_review" />
                  <input type="hidden" name="review_id" value={r.id} />
                  <input type="text" name="reviewer_note" required placeholder="Rejection reason" maxlength="500" class="action-input" />
                  <button type="submit" class="btn btn-secondary action-btn">✗ Reject</button>
                </form>
                <div class="action-row-compact">
                  <form method="POST">
                    <input type="hidden" name="action" value="toggle_featured" />
                    <input type="hidden" name="review_id" value={r.id} />
                    <input type="hidden" name="featured" value={r.featured ? "true" : "false"} />
                    <button type="submit" class="btn btn-ghost action-btn-sm">
                      {r.featured ? "★ Unfeature" : "☆ Feature"}
                    </button>
                  </form>
                  <form method="POST" onsubmit="return confirm('Delete this review permanently?')">
                    <input type="hidden" name="action" value="delete_review" />
                    <input type="hidden" name="review_id" value={r.id} />
                    <button type="submit" class="btn btn-secondary action-btn-sm" style="color:#8f1f18;">🗑 Delete</button>
                  </form>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {(!pendingReviews || pendingReviews.length === 0) && (
      <div class="surface-card" style="padding:1.2rem; margin-top:2rem;">
        <h2>Pending Reviews</h2>
        <p style="margin:0; color:var(--ink-soft);">No pending reviews right now.</p>
      </div>
    )}

    {/* ── Winners ── */}
    {winners && winners.length > 0 && (
      <div style="margin-top:2rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
          <h2>Winners History</h2>
          <button type="button" class="btn btn-secondary" id="exportCsvBtn" style="font-size:0.85rem;">📥 Export CSV</button>
        </div>
        <div style="overflow-x:auto; margin-top:1rem;">
          <table class="admin-table" id="winnersTable">
            <thead>
              <tr>
                <th>Month</th>
                <th>Winner</th>
                <th>Email</th>
                <th>Book</th>
                <th>Claimed</th>
                <th>Ship To</th>
                <th>Deadline</th>
                <th>Notified</th>
              </tr>
            </thead>
            <tbody>
              {winners.map((w: any) => (
                <tr>
                  <td style="font-weight:700; color:var(--brand-blue);">{w.month}</td>
                  <td>{(w.profiles as any)?.display_name || "—"}</td>
                  <td>{(w.profiles as any)?.email || "—"}</td>
                  <td>{w.book_chosen ? (bookMap[w.book_chosen] || w.book_chosen) : "—"}</td>
                  <td>{w.claimed ? "✓" : "—"}</td>
                  <td style="max-width:14rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    {w.claimed ? `${w.shipping_name} — ${w.shipping_address}` : "—"}
                  </td>
                  <td>{w.claim_deadline ? new Date(w.claim_deadline).toLocaleDateString() : "—"}</td>
                  <td>{w.notified ? "✓" : "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  // ── Bulk select logic ─────────────────────────
  const checkboxes = document.querySelectorAll(".bulk-checkbox");
  const selectAll = document.getElementById("selectAll");
  const bulkBar = document.getElementById("bulkBar");
  const bulkCount = document.getElementById("bulkCount");
  const bulkReviewerNote = document.getElementById("bulkReviewerNote");
  const bulkApproveBtn = document.getElementById("bulkApproveBtn");
  const bulkRejectBtn = document.getElementById("bulkRejectBtn");

  function updateBulk() {
    const checked = document.querySelectorAll(".bulk-checkbox:checked").length;
    if (bulkBar) bulkBar.style.display = checked > 0 || (checkboxes.length > 0) ? "flex" : "none";
    if (bulkCount) bulkCount.textContent = checked + " selected";
  }

  if (selectAll) {
    selectAll.addEventListener("change", () => {
      checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
      updateBulk();
    });
  }
  checkboxes.forEach(cb => cb.addEventListener("change", updateBulk));
  if (checkboxes.length > 0 && bulkBar) bulkBar.style.display = "flex";

  if (bulkRejectBtn && bulkReviewerNote) {
    bulkRejectBtn.addEventListener("click", () => {
      bulkReviewerNote.setAttribute("required", "required");
    });
  }
  if (bulkApproveBtn && bulkReviewerNote) {
    bulkApproveBtn.addEventListener("click", () => {
      bulkReviewerNote.removeAttribute("required");
    });
  }

  // ── Review image modal (desktop + mobile) ───────
  const adminPhotoModal = document.createElement("div");
  adminPhotoModal.className = "admin-photo-modal";
  adminPhotoModal.innerHTML =
    '<button type="button" class="admin-photo-close" aria-label="Close image viewer">✕</button>' +
    '<img class="admin-photo-modal-img" alt="Review image preview" />';
  document.body.appendChild(adminPhotoModal);

  const modalImg = adminPhotoModal.querySelector(".admin-photo-modal-img");
  const closeBtn = adminPhotoModal.querySelector(".admin-photo-close");

  function closePhotoModal() {
    adminPhotoModal.classList.remove("open");
    document.body.style.overflow = "";
    if (modalImg) modalImg.src = "";
  }

  document.querySelectorAll(".review-img-admin").forEach((img) => {
    img.addEventListener("click", () => {
      if (!modalImg) return;
      modalImg.src = img.src;
      adminPhotoModal.classList.add("open");
      document.body.style.overflow = "hidden";
    });
  });

  if (closeBtn) closeBtn.addEventListener("click", closePhotoModal);
  adminPhotoModal.addEventListener("click", (e) => {
    if (e.target === adminPhotoModal) closePhotoModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && adminPhotoModal.classList.contains("open")) {
      closePhotoModal();
    }
  });

  // ── CSV Export ────────────────────────────────
  const exportBtn = document.getElementById("exportCsvBtn");
  const table = document.getElementById("winnersTable");
  if (exportBtn && table) {
    exportBtn.addEventListener("click", () => {
      const rows = table.querySelectorAll("tr");
      const csv = [];
      rows.forEach(row => {
        const cells = row.querySelectorAll("th, td");
        const line = [];
        cells.forEach(cell => {
          let val = cell.textContent.trim().replace(/"/g, '""');
          line.push('"' + val + '"');
        });
        csv.push(line.join(","));
      });
      const blob = new Blob([csv.join("\n")], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      const month = new Date().toISOString().slice(0, 7);
      a.href = url;
      a.download = "lottery-winners-" + month + ".csv";
      a.click();
      URL.revokeObjectURL(url);
    });
  }
});
</script>

