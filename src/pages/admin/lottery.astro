---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getServiceClient, isAdmin } from "../../lib/supabase";
import { validateOrigin } from "../../lib/csrf";
import { books, getMonthlyPrizeBook } from "../../data/books";
import { emailUserLotteryWin } from "../../lib/notifications";
import crypto from "node:crypto";

const user = Astro.locals.user;
if (!user || !(await isAdmin(user))) {
  return Astro.redirect("/es/login/");
}

const sc = getServiceClient();
const currentMonth = new Date().toISOString().slice(0, 7);
const prizeBook = getMonthlyPrizeBook(currentMonth);

let drawResult = "";
let drawError = "";
let configMsg = "";

/** Log every admin action for audit trail */
async function auditLog(action: string, targetType: string, targetId: string | null, details: Record<string, unknown> = {}) {
  try {
    await sc.from("admin_audit_log").insert({
      admin_id: user!.email || user!.id,
      action,
      target_type: targetType,
      target_id: targetId,
      details: details as any,
    });
  } catch { /* non-blocking */ }
}

/** Cryptographically secure random index (rejection sampling to avoid modulo bias) */
function secureRandomIndex(max: number): number {
  const arr = new Uint32Array(1);
  const limit = Math.floor(0x100000000 / max) * max;
  do { crypto.getRandomValues(arr); } while (arr[0] >= limit);
  return arr[0] % max;
}

// ── Get or create this month's config ────────────────
let { data: config } = await sc
  .from("lottery_config")
  .select("*")
  .eq("month", currentMonth)
  .maybeSingle();

if (!config) {
  await sc.from("lottery_config").insert({ month: currentMonth });
  const { data: fresh } = await sc.from("lottery_config").select("*").eq("month", currentMonth).single();
  config = fresh;
}

// Check if draw already happened this month
const { data: monthWinners } = await sc
  .from("lottery_winners")
  .select("id")
  .eq("month", currentMonth)
  .limit(1);
const drawAlreadyDone = (monthWinners ?? []).length > 0;

// ── Handle POST actions ──────────────────────────────
if (Astro.request.method === "POST") {
  if (!validateOrigin(Astro.request, Astro.url)) {
    drawError = "⛔ Request blocked: invalid origin.";
  } else {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "save_config") {
      const maxWinners = parseInt(formData.get("max_winners")?.toString() || "3", 10);
      const winnerPct = parseFloat(formData.get("winner_pct")?.toString() || "1");
      const minPurchases = parseInt(formData.get("min_purchases")?.toString() || "0", 10);
      const drawDate = formData.get("draw_date")?.toString() || null;
      const prizeDescription = (formData.get("prize_description")?.toString() || "").slice(0, 500);
      const participantBoost = parseInt(formData.get("participant_boost")?.toString() || "0", 10);

      await sc.from("lottery_config").update({
        max_winners: maxWinners,
        winner_pct: winnerPct,
        min_purchases: minPurchases,
        is_active: true,
        draw_date: drawDate || null,
        prize_description: prizeDescription,
        participant_boost: participantBoost,
      }).eq("month", currentMonth);

      config = { ...config!, max_winners: maxWinners, winner_pct: winnerPct, min_purchases: minPurchases, is_active: true, draw_date: drawDate, prize_description: prizeDescription, participant_boost: participantBoost };
      configMsg = "Config saved.";
      await auditLog("save_config", "config", currentMonth, { maxWinners, winnerPct, minPurchases });
    }

    else if (action === "draw") {
      const { data: existCheck } = await sc
        .from("lottery_winners")
        .select("id")
        .eq("month", currentMonth)
        .limit(1);

      if (existCheck && existCheck.length > 0) {
        drawError = "⚠️ Draw already completed for this month. Cannot draw again.";
      } else {
        const { data: paidEntries } = await sc
          .from("lottery_entries")
          .select("user_id, entry_count")
          .eq("month", currentMonth);

        if (!paidEntries || paidEntries.length === 0) {
          drawError = "No entries for this month — nobody is eligible.";
        } else {
          const ticketMap = new Map<string, number>();
          for (const pe of paidEntries) {
            ticketMap.set(pe.user_id, (ticketMap.get(pe.user_id) || 0) + pe.entry_count);
          }

          const minReq = config?.min_purchases ?? 0;
          const pool = [...ticketMap.entries()].filter(([, tickets]) => tickets >= minReq * 5);

          if (pool.length === 0) {
            drawError = "No eligible users (check min requirements).";
          } else {
            const pctWinners = Math.ceil(pool.length * ((config?.winner_pct ?? 1) / 100));
            const numToDraw = Math.min(pctWinners, config?.max_winners ?? 3, pool.length);

            if (numToDraw <= 0) {
              drawError = "Winner count resolves to 0. Check config.";
            } else {
              const weightedPool: string[] = [];
              let totalTicketsCount = 0;
              for (const [uid, tickets] of pool) {
                for (let i = 0; i < tickets; i++) weightedPool.push(uid);
                totalTicketsCount += tickets;
              }

              const winnerIds = new Set<string>();
              let attempts = 0;
              while (winnerIds.size < numToDraw && attempts < weightedPool.length * 10) {
                const idx = secureRandomIndex(weightedPool.length);
                winnerIds.add(weightedPool[idx]);
                attempts++;
              }

              const drawn: string[] = [];
              const claimDeadline = new Date();
              claimDeadline.setDate(claimDeadline.getDate() + 14);

              for (const winnerId of winnerIds) {
                const { error } = await sc.from("lottery_winners").insert({
                  user_id: winnerId,
                  month: currentMonth,
                  claim_deadline: claimDeadline.toISOString(),
                });
                if (!error) {
                  const { data: profile } = await sc.from("profiles").select("email, display_name, lang_pref").eq("id", winnerId).single();
                  drawn.push(profile?.display_name || profile?.email || winnerId);
                  const { data: authUser } = await sc.auth.admin.getUserById(winnerId);
                  if (authUser?.user?.email) {
                    await emailUserLotteryWin(authUser.user.email, claimDeadline.toISOString().slice(0, 10), profile?.lang_pref || "en", prizeBook.title[profile?.lang_pref === "es" ? "es" : "en"]);
                  }
                  await sc.rpc("notify_user", {
                    p_user_id: winnerId,
                    p_type: "lottery_win",
                    p_title_en: "You Won the Monthly Giveaway! 🏆",
                    p_title_es: "¡Ganaste el Sorteo Mensual! 🏆",
                    p_body_en: `Claim your free book before ${claimDeadline.toISOString().slice(0, 10)}!`,
                    p_body_es: `¡Reclama tu libro gratis antes del ${claimDeadline.toISOString().slice(0, 10)}!`,
                  });
                }
              }

              await sc.from("lottery_draw_log").insert({
                month: currentMonth,
                config_snapshot: config ?? {},
                eligible_users: pool.length,
                total_tickets: totalTicketsCount,
                winners_drawn: drawn.length,
                drawn_by: user!.id,
              });

              drawResult = `Drew ${drawn.length} winner(s): ${drawn.join(", ")} — from ${pool.length} eligible users, ${totalTicketsCount} weighted tickets`;
            }
          }
        }
      }
    }
  }
}

// ── Data for display ─────────────────────────────────
const { count: totalApproved } = await sc
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "approved");

const { data: approvedUsers } = await sc
  .from("book_reviews")
  .select("user_id")
  .eq("status", "approved");
const uniqueUserIds = new Set((approvedUsers ?? []).map(r => r.user_id));

const { data: monthPaidEntries } = await sc
  .from("lottery_entries")
  .select("entry_count")
  .eq("month", currentMonth);
const totalPaidEntries = (monthPaidEntries ?? []).reduce((sum, e) => sum + (e.entry_count || 0), 0);

// Leaderboard
const { data: paidEntryUsers } = await sc
  .from("lottery_entries")
  .select("user_id, entry_count, purchased_at, profiles!inner(display_name, email, country)")
  .eq("month", currentMonth)
  .order("purchased_at", { ascending: false });

type LeaderboardEntry = { name: string; email: string; country: string; tickets: number; rank: number };
const leaderboard: LeaderboardEntry[] = [];
if (paidEntryUsers && paidEntryUsers.length > 0) {
  const userMap = new Map<string, { name: string; email: string; country: string; tickets: number }>();
  for (const pe of paidEntryUsers as any[]) {
    const uid = pe.user_id;
    const existing = userMap.get(uid);
    if (existing) {
      existing.tickets += pe.entry_count || 0;
    } else {
      userMap.set(uid, {
        name: pe.profiles?.display_name || "\u2014",
        email: pe.profiles?.email || "\u2014",
        country: pe.profiles?.country || "\u2014",
        tickets: pe.entry_count || 0,
      });
    }
  }
  const sorted = [...userMap.values()].sort((a, b) => b.tickets - a.tickets);
  sorted.forEach((u, i) => leaderboard.push({ ...u, rank: i + 1 }));
}
const participantCount = leaderboard.length;

// Winners with month filter + pagination
const filterMonth = Astro.url.searchParams.get("month") || "";
const winnersPage = Math.max(1, parseInt(Astro.url.searchParams.get("wp") || "1", 10));
const WINNERS_PAGE_SIZE = 20;
const winnersOffset = (winnersPage - 1) * WINNERS_PAGE_SIZE;

let winnersQuery = sc
  .from("lottery_winners")
  .select("month, book_chosen, claimed, shipping_name, shipping_address, claim_deadline, notified, profiles!inner(email, display_name)", { count: "exact" });
if (filterMonth) winnersQuery = winnersQuery.eq("month", filterMonth);
const { data: winners, count: winnersTotal } = await winnersQuery
  .order("month", { ascending: false })
  .range(winnersOffset, winnersOffset + WINNERS_PAGE_SIZE - 1);

const winnersTotalPages = Math.ceil((winnersTotal ?? 0) / WINNERS_PAGE_SIZE);

// Distinct months for filter dropdown
const { data: allMonths } = await sc
  .from("lottery_winners")
  .select("month")
  .order("month", { ascending: false });
const distinctMonths = [...new Set((allMonths ?? []).map(m => m.month))];

const bookMap = Object.fromEntries(books.map(b => [b.id, b.title.en]));
---

<AdminLayout title="Lottery" current="lottery">
  <h1>🎲 Lottery Management</h1>

  {/* ── Config ── */}
  <div class="surface-card" style="padding:1.6rem; margin-top:1.5rem;">
    <h2>Config for {currentMonth}</h2>
    {configMsg && <p class="msg-ok">{configMsg}</p>}
    <form method="POST" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(10rem,1fr)); gap:1rem; margin-top:1rem;">
      <input type="hidden" name="action" value="save_config" />
      <div class="form-group">
        <label>Max winners</label>
        <input type="number" name="max_winners" value={config?.max_winners ?? 3} min="1" max="50" />
      </div>
      <div class="form-group">
        <label>Winner % of pool</label>
        <input type="number" name="winner_pct" value={config?.winner_pct ?? 1} min="0.1" max="100" step="0.1" />
      </div>
      <div class="form-group">
        <label>Min reviews required</label>
        <input type="number" name="min_purchases" value={config?.min_purchases ?? 0} min="0" />
      </div>
      <div class="form-group" style="grid-column:1/-1;">
        <p style="display:flex; align-items:center; gap:0.5rem; margin:0;">
          <strong>🎁 Giveaway</strong>
          <span style="font-size:0.85rem; color:var(--brand-green); font-weight:700;">🟢 Always Active</span>
          <span style="font-size:0.8rem; color:var(--ink-soft);">(auto-rotates book each month)</span>
        </p>
      </div>
      <div class="form-group">
        <label>Draw Date</label>
        <input type="date" name="draw_date" value={config?.draw_date ?? ""} />
      </div>
      <div class="form-group" style="grid-column:span 2;">
        <label>Prize Description <span style="font-size:0.8rem; color:var(--ink-soft);">(optional extra note)</span></label>
        <p style="font-size:0.85rem; margin:0 0 0.4rem; color:var(--brand-blue);">📖 Auto-rotation: <strong>{prizeBook.title.en}</strong></p>
        <input type="text" name="prize_description" value={config?.prize_description ?? ""} placeholder="e.g. Free shipping included!" style="width:100%;" />
      </div>
      <div class="form-group">
        <label>Participant Boost 👥 <span style="font-size:0.8rem; color:var(--ink-soft);">(fictitious participants added to public count)</span></label>
        <input type="number" name="participant_boost" value={config?.participant_boost ?? 0} min="0" max="500" />
        <p style="font-size:0.8rem; margin:0.3rem 0 0; color:var(--ink-soft);">Added to real count shown publicly. Only you see this.</p>
      </div>
      <button type="submit" class="btn btn-secondary">Save Config</button>
    </form>
  </div>

  {/* ── Draw ── */}
  <div class="surface-card" style="padding:1.6rem; margin-top:1.5rem;">
    <h2>Draw — {currentMonth}</h2>
    <p>Approved reviews: <strong>{totalApproved ?? 0}</strong> · Eligible users: <strong>{uniqueUserIds.size}</strong> · Paid entries: <strong>{totalPaidEntries}</strong></p>

    {drawResult && <p class="msg-ok">🎉 {drawResult}</p>}
    {drawError && <p class="msg-err">{drawError}</p>}

    {drawAlreadyDone ? (
      <p class="msg-err">⚠️ Draw already completed for {currentMonth}.</p>
    ) : (
      <form method="POST" style="margin-top:1rem;" id="drawForm">
        <input type="hidden" name="action" value="draw" />
        <button type="submit" class="btn btn-primary" id="drawBtn" onclick="this.disabled=true;this.textContent='⏳ Drawing...';this.form.submit();">🎲 Draw Winners</button>
      </form>
    )}
  </div>

  {/* ── Leaderboard ── */}
  {leaderboard.length > 0 && (
    <div class="surface-card" style="padding:1.6rem; margin-top:1.5rem;">
      <h2>🏆 Leaderboard — {currentMonth} <span style="font-size:0.85rem; font-weight:400; color:var(--ink-soft);">({participantCount} participant{participantCount !== 1 ? "s" : ""})</span></h2>
      <div style="overflow-x:auto; margin-top:0.8rem;">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width:3rem;">Rank</th>
              <th>User</th>
              <th>Email</th>
              <th>Tickets</th>
              <th>Country</th>
            </tr>
          </thead>
          <tbody>
            {leaderboard.map((u) => {
              const medal = u.rank === 1 ? "🥇" : u.rank === 2 ? "🥈" : u.rank === 3 ? "🥉" : String(u.rank);
              const bg = u.rank === 1 ? "rgba(255,215,0,0.10)" : u.rank === 2 ? "rgba(192,192,192,0.10)" : u.rank === 3 ? "rgba(205,127,50,0.08)" : "";
              return (
                <tr style={bg ? `background:${bg};` : ""}>
                  <td style="text-align:center; font-size:1.2rem;">{medal}</td>
                  <td style="font-weight:600;">{u.name}</td>
                  <td>{u.email}</td>
                  <td style="text-align:center; font-weight:700; color:var(--brand-blue); font-size:1.1rem;">{u.tickets}</td>
                  <td>{u.country}</td>
                </tr>
              );
            })}
          </tbody>
          <tfoot>
            <tr style="border-top:2px solid var(--line); font-weight:700;">
              <td></td>
              <td>Total</td>
              <td></td>
              <td style="text-align:center;">{leaderboard.reduce((s, u) => s + u.tickets, 0)}</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  )}

  {/* ── Winners History ── */}
  <div style="margin-top:2rem;">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
      <h2>Winners History ({winnersTotal ?? 0})</h2>
      <div style="display:flex; gap:0.5rem; align-items:center;">
        <form method="GET" style="display:flex; gap:0.4rem; align-items:center;">
          <select name="month" onchange="this.form.submit()" style="padding:0.3rem 0.5rem; border:1px solid var(--line); border-radius:var(--radius-sm); font-size:0.85rem;">
            <option value="">All months</option>
            {distinctMonths.map((m) => (
              <option value={m} selected={m === filterMonth}>{m}</option>
            ))}
          </select>
        </form>
        <button type="button" class="btn btn-secondary" id="exportCsvBtn" style="font-size:0.85rem;">📥 CSV</button>
      </div>
    </div>

    {winners && winners.length > 0 ? (
      <>
        <div style="overflow-x:auto; margin-top:1rem;">
          <table class="admin-table" id="winnersTable">
            <thead>
              <tr>
                <th>Month</th>
                <th>Winner</th>
                <th>Email</th>
                <th>Book</th>
                <th>Claimed</th>
                <th>Ship To</th>
                <th>Deadline</th>
                <th>Notified</th>
              </tr>
            </thead>
            <tbody>
              {winners.map((w: any) => (
                <tr>
                  <td style="font-weight:700; color:var(--brand-blue);">{w.month}</td>
                  <td>{(w.profiles as any)?.display_name || "—"}</td>
                  <td>{(w.profiles as any)?.email || "—"}</td>
                  <td>{w.book_chosen ? (bookMap[w.book_chosen] || w.book_chosen) : "—"}</td>
                  <td>{w.claimed ? "✓" : "—"}</td>
                  <td style="max-width:14rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    {w.claimed ? `${w.shipping_name} — ${w.shipping_address}` : "—"}
                  </td>
                  <td>{w.claim_deadline ? new Date(w.claim_deadline).toLocaleDateString() : "—"}</td>
                  <td>{w.notified ? "✓" : "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {winnersTotalPages > 1 && (
          <nav class="pagination">
            {winnersPage > 1 && <a href={`?wp=${winnersPage - 1}${filterMonth ? `&month=${filterMonth}` : ""}`} class="btn btn-ghost">← Prev</a>}
            <span class="page-info">Page {winnersPage} of {winnersTotalPages}</span>
            {winnersPage < winnersTotalPages && <a href={`?wp=${winnersPage + 1}${filterMonth ? `&month=${filterMonth}` : ""}`} class="btn btn-ghost">Next →</a>}
          </nav>
        )}
      </>
    ) : (
      <p style="margin-top:1rem; color:var(--ink-soft);">No winners yet.</p>
    )}
  </div>
</AdminLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const exportBtn = document.getElementById("exportCsvBtn");
  const table = document.getElementById("winnersTable");
  if (exportBtn && table) {
    exportBtn.addEventListener("click", () => {
      const rows = table.querySelectorAll("tr");
      const csv = [];
      rows.forEach(row => {
        const cells = row.querySelectorAll("th, td");
        const line = [];
        cells.forEach(cell => {
          let val = cell.textContent.trim().replace(/"/g, '""');
          line.push('"' + val + '"');
        });
        csv.push(line.join(","));
      });
      const blob = new Blob([csv.join("\n")], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "lottery-winners-" + new Date().toISOString().slice(0, 7) + ".csv";
      a.click();
      URL.revokeObjectURL(url);
    });
  }
});
</script>

<style>
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }
  .admin-table th,
  .admin-table td {
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .admin-table thead tr {
    border-bottom: 2px solid var(--line);
  }
  .admin-table tbody tr {
    border-bottom: 1px solid var(--line);
  }
  .msg-ok {
    padding: 0.8rem;
    border-radius: 0.5rem;
    background: rgba(92,150,80,0.14);
    color: var(--brand-green);
    border: 1px solid rgba(92,150,80,0.3);
    margin: 1rem 0;
  }
  .msg-err {
    padding: 0.8rem;
    border-radius: 0.5rem;
    background: rgba(220,50,50,0.08);
    color: #8f1f18;
    border: 1px solid rgba(220,50,50,0.25);
    margin: 1rem 0;
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1rem 0;
  }
  .page-info {
    font-size: 0.9rem;
    color: var(--ink-soft);
    font-weight: 600;
  }
</style>
