---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdmin, getServiceClient } from "../../lib/supabase";

const user = Astro.locals.user;
if (!user || !(await isAdmin(user))) {
  return Astro.redirect("/es/login/");
}

// ── Range parsing ─────────────────────────────────
const rangeParam = (Astro.url.searchParams.get("range") || "7d").toLowerCase();
const RANGES: Record<string, number> = { "24h": 1, "7d": 7, "30d": 30, "90d": 90 };
const days = RANGES[rangeParam] ?? 7;
const sinceIso = new Date(Date.now() - days * 24 * 60 * 60 * 1000).toISOString();
const todayIso = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();

const sc = getServiceClient();

// ── Parallel queries ─────────────────────────────
const [
  { data: pvRows, count: totalPv },
  { data: pvToday, count: todayPv },
  { data: utmClicks },
  { data: weekly },
] = await Promise.all([
  sc
    .from("pageviews")
    .select("path, referrer, country, visitor_hash, created_at, utm_source, utm_medium, utm_campaign, utm_content, landing_page", { count: "exact" })
    .gte("created_at", sinceIso)
    .order("created_at", { ascending: false })
    .limit(5000),
  sc
    .from("pageviews")
    .select("visitor_hash", { count: "exact", head: true })
    .gte("created_at", todayIso),
  sc
    .from("pageviews")
    .select("utm_source, utm_campaign, utm_content, created_at")
    .gte("created_at", sinceIso)
    .not("utm_source", "is", null)
    .limit(2000),
  sc
    .from("weekly_reports")
    .select("week_start, week_end, total_pageviews, unique_visitors, total_clicks, new_subscribers, summary, recommendations")
    .order("week_start", { ascending: false })
    .limit(1),
]);

const rows = pvRows ?? [];
const utmRows = utmClicks ?? [];
const latestWeekly = weekly?.[0] ?? null;

// ── Derived metrics ──────────────────────────────
const uniqueVisitors = new Set(rows.map((r) => r.visitor_hash).filter(Boolean)).size;
const totalPageviews = totalPv ?? rows.length;
const todayCount = todayPv ?? 0;
const avgPvPerVisitor = uniqueVisitors ? (rows.length / uniqueVisitors).toFixed(2) : "0";

// Source classification
function classifySource(row: any): { cat: string; label: string } {
  if (row.utm_source) return { cat: "utm", label: `utm/${row.utm_source}` };
  const ref = row.referrer || "";
  if (!ref) return { cat: "direct", label: "direct" };
  try {
    const host = new URL(ref).hostname.replace(/^www\./, "");
    if (host.includes("facebook") || host === "fb.me" || host === "m.facebook.com") return { cat: "social", label: "facebook" };
    if (host.includes("bsky") || host.includes("bluesky")) return { cat: "social", label: "bluesky" };
    if (host.includes("instagram")) return { cat: "social", label: "instagram" };
    if (host.includes("pinterest")) return { cat: "social", label: "pinterest" };
    if (host.includes("twitter") || host === "t.co" || host === "x.com") return { cat: "social", label: "twitter/x" };
    if (host.includes("reddit")) return { cat: "social", label: "reddit" };
    if (host.includes("tiktok")) return { cat: "social", label: "tiktok" };
    if (host.includes("google") || host.includes("bing") || host.includes("duckduckgo") || host.includes("yahoo")) return { cat: "organic", label: host };
    if (host.includes("littlechubbypress.com")) return { cat: "internal", label: "internal" };
    return { cat: "referral", label: host };
  } catch {
    return { cat: "referral", label: "unknown" };
  }
}

const sourceMap = new Map<string, { count: number; cat: string }>();
for (const r of rows) {
  const s = classifySource(r);
  const current = sourceMap.get(s.label);
  sourceMap.set(s.label, { count: (current?.count ?? 0) + 1, cat: s.cat });
}
const topSources = [...sourceMap.entries()]
  .map(([label, v]) => ({ label, ...v }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 12);

// Pageviews per day for sparkline
const dayBucket: Record<string, { pv: number; uv: Set<string> }> = {};
for (const r of rows) {
  const d = (r.created_at || "").slice(0, 10);
  if (!d) continue;
  if (!dayBucket[d]) dayBucket[d] = { pv: 0, uv: new Set() };
  dayBucket[d].pv += 1;
  if (r.visitor_hash) dayBucket[d].uv.add(r.visitor_hash);
}
// Fill missing days with 0
const series: { date: string; pv: number; uv: number }[] = [];
for (let i = days - 1; i >= 0; i--) {
  const d = new Date(Date.now() - i * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
  const b = dayBucket[d];
  series.push({ date: d, pv: b?.pv ?? 0, uv: b?.uv.size ?? 0 });
}
const maxPv = Math.max(1, ...series.map((s) => s.pv));

// Top paths
const pathMap = new Map<string, { count: number; unique: Set<string> }>();
for (const r of rows) {
  const p = r.path || "/";
  if (!pathMap.has(p)) pathMap.set(p, { count: 0, unique: new Set() });
  const e = pathMap.get(p)!;
  e.count += 1;
  if (r.visitor_hash) e.unique.add(r.visitor_hash);
}
const topPaths = [...pathMap.entries()]
  .map(([path, v]) => ({ path, count: v.count, unique: v.unique.size }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 15);

// Countries
const countryMap = new Map<string, number>();
for (const r of rows) {
  const c = r.country || "??";
  countryMap.set(c, (countryMap.get(c) || 0) + 1);
}
const topCountries = [...countryMap.entries()]
  .map(([code, count]) => ({ code, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

// UTM attribution
const utmMap = new Map<string, { clicks: number; source: string; campaign: string }>();
for (const r of utmRows) {
  const key = r.utm_content || `${r.utm_source}/${r.utm_campaign || "-"}`;
  if (!utmMap.has(key)) utmMap.set(key, { clicks: 0, source: r.utm_source || "", campaign: r.utm_campaign || "" });
  utmMap.get(key)!.clicks += 1;
}
const topUtm = [...utmMap.entries()]
  .map(([key, v]) => ({ key, ...v }))
  .sort((a, b) => b.clicks - a.clicks)
  .slice(0, 10);

// Recent live feed (last 20)
const liveFeed = rows.slice(0, 20).map((r) => ({
  when: r.created_at,
  path: r.path,
  source: classifySource(r).label,
  country: r.country || "??",
}));

// Source category colours
const catColour: Record<string, string> = {
  utm: "#8b5cf6",
  social: "#2563eb",
  organic: "#10b981",
  direct: "#6b7280",
  internal: "#fbbf24",
  referral: "#ec4899",
};

// ── Build SVG line chart (pv per day) ────────────
const W = 760;
const H = 200;
const PAD = 28;
const plotW = W - PAD * 2;
const plotH = H - PAD * 2;
const stepX = series.length > 1 ? plotW / (series.length - 1) : plotW;
const pointsPv = series.map((s, i) => `${PAD + i * stepX},${H - PAD - (s.pv / maxPv) * plotH}`).join(" ");
const pointsUv = series.map((s, i) => `${PAD + i * stepX},${H - PAD - (s.uv / maxPv) * plotH}`).join(" ");

function short(p: string) {
  if (p.length <= 42) return p;
  return p.slice(0, 39) + "…";
}
function fmtTime(iso: string) {
  const d = new Date(iso);
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  const dd = String(d.getDate()).padStart(2, "0");
  const hh = String(d.getHours()).padStart(2, "0");
  const mi = String(d.getMinutes()).padStart(2, "0");
  return `${mm}/${dd} ${hh}:${mi}`;
}
---

<AdminLayout title="Traffic" current="traffic">
  <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
    <h1 style="margin:0;">📊 Live Traffic</h1>
    <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
      {(["24h", "7d", "30d", "90d"] as const).map((r) => (
        <a
          href={`?range=${r}`}
          class:list={["range-btn", { active: rangeParam === r }]}
        >{r}</a>
      ))}
      <label style="display:flex; align-items:center; gap:0.4rem; font-size:0.85rem; color:var(--ink-soft); margin-left:0.6rem;">
        <input type="checkbox" id="auto-refresh" />
        Auto-refresh (30s)
      </label>
    </div>
  </div>

  <p style="margin-top:0.3rem; color:var(--ink-soft); font-size:0.9rem;">
    Window: last {days === 1 ? "24 hours" : `${days} days`} · {rows.length.toLocaleString()} pageviews loaded
    · <span id="last-refresh">just now</span>
  </p>

  {/* ─── KPI cards ─── */}
  <div class="stat-grid" id="kpi-grid">
    <div class="stat-card">
      <div class="stat-number" style="color:var(--brand-blue);" data-kpi="today">{todayCount.toLocaleString()}</div>
      <div class="stat-label">Pageviews · last 24h</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" style="color:var(--brand-green);" data-kpi="pv">{totalPageviews.toLocaleString()}</div>
      <div class="stat-label">Pageviews · {days === 1 ? "24h" : `${days}d`}</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" style="color:var(--accent-gold);" data-kpi="uv">{uniqueVisitors.toLocaleString()}</div>
      <div class="stat-label">Unique visitors</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" style="color:var(--brand-brown);">{avgPvPerVisitor}</div>
      <div class="stat-label">PV / visitor</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" style="color:#8b5cf6;">{topSources[0]?.label ?? "—"}</div>
      <div class="stat-label">Top source</div>
    </div>
  </div>

  {/* ─── Line chart ─── */}
  <div class="surface-card" style="padding:1.4rem; margin-top:1.5rem;">
    <h2 style="margin-top:0; margin-bottom:0.6rem;">Trend · pageviews & unique visitors</h2>
    <div id="chart-wrap" style="overflow-x:auto; position:relative;" data-series={JSON.stringify(series)} data-chart={JSON.stringify({ W, H, PAD, plotW, plotH, stepX, maxPv })}>
      <svg id="trend-chart" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid meet" style="width:100%; max-width:100%; height:auto; min-width:600px; display:block;" aria-label="Pageviews line chart">
        {/* Gridlines */}
        {[0.25, 0.5, 0.75, 1].map((f) => (
          <line x1={PAD} x2={W - PAD} y1={H - PAD - f * plotH} y2={H - PAD - f * plotH} stroke="currentColor" stroke-opacity="0.1" stroke-dasharray="2 3" />
        ))}
        {/* Y-axis labels */}
        {[0, 0.5, 1].map((f) => (
          <text x={PAD - 6} y={H - PAD - f * plotH + 4} text-anchor="end" style="font-size:10px; fill:currentColor; fill-opacity:0.55;">
            {Math.round(maxPv * f)}
          </text>
        ))}
        {/* X-axis labels (first, middle, last) */}
        {[0, Math.floor(series.length / 2), series.length - 1].map((i) => (
          <text x={PAD + i * stepX} y={H - PAD + 16} text-anchor="middle" style="font-size:10px; fill:currentColor; fill-opacity:0.55;">
            {series[i]?.date.slice(5)}
          </text>
        ))}
        {/* Filled area for PV */}
        <polyline
          points={`${PAD},${H - PAD} ${pointsPv} ${PAD + (series.length - 1) * stepX},${H - PAD}`}
          fill="rgba(37, 99, 235, 0.12)"
          stroke="none"
        />
        {/* PV line */}
        <polyline points={pointsPv} fill="none" stroke="#2563eb" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
        {/* UV line */}
        <polyline points={pointsUv} fill="none" stroke="#10b981" stroke-width="2" stroke-dasharray="4 3" stroke-linejoin="round" stroke-linecap="round" />
        {/* Static dots (fallback / always visible) */}
        {series.map((s, i) => (
          <circle cx={PAD + i * stepX} cy={H - PAD - (s.pv / maxPv) * plotH} r="3" fill="#2563eb" />
        ))}
        {/* Hover guide (hidden until mousemove) */}
        <line id="hover-guide" x1="0" y1={PAD} x2="0" y2={H - PAD} stroke="#2563eb" stroke-opacity="0.35" stroke-dasharray="3 3" style="display:none;" />
        <circle id="hover-dot-pv" r="5" fill="#2563eb" stroke="#fff" stroke-width="2" style="display:none;"></circle>
        <circle id="hover-dot-uv" r="5" fill="#10b981" stroke="#fff" stroke-width="2" style="display:none;"></circle>
        {/* Transparent capture overlay for pointer events */}
        <rect id="hover-capture" x={PAD} y={PAD} width={plotW} height={plotH} fill="transparent" style="cursor:crosshair;" />
      </svg>
      <div id="chart-tooltip" style="position:absolute; pointer-events:none; display:none; background:rgba(23,23,23,0.94); color:#fff; padding:0.5rem 0.7rem; border-radius:8px; font-size:0.78rem; line-height:1.35; box-shadow:0 4px 14px rgba(0,0,0,0.25); white-space:nowrap; z-index:5; transform:translate(-50%, -100%);">
        <div id="tt-date" style="font-weight:600; margin-bottom:3px;"></div>
        <div><span style="display:inline-block; width:8px; height:8px; background:#2563eb; border-radius:50%; margin-right:5px;"></span><span id="tt-pv"></span> pageviews</div>
        <div><span style="display:inline-block; width:8px; height:8px; background:#10b981; border-radius:50%; margin-right:5px;"></span><span id="tt-uv"></span> unique visitors</div>
      </div>
    </div>
    <div style="display:flex; gap:1.2rem; font-size:0.82rem; color:var(--ink-soft); margin-top:0.4rem;">
      <span><span style="display:inline-block; width:14px; height:3px; background:#2563eb; vertical-align:middle;"></span> Pageviews</span>
      <span><span style="display:inline-block; width:14px; height:3px; background:repeating-linear-gradient(90deg, #10b981 0 4px, transparent 4px 7px); vertical-align:middle;"></span> Unique visitors</span>
    </div>
  </div>

  {/* ─── Sources bar chart + Countries ─── */}
  <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.4rem; margin-top:1.5rem;" class="grid-2">
    <div class="surface-card" style="padding:1.4rem;">
      <h2 style="margin-top:0; margin-bottom:0.8rem;">🌐 Traffic sources</h2>
      {topSources.length === 0 ? (
        <p style="color:var(--ink-soft);">No data yet for this window.</p>
      ) : (
        <div>
          {topSources.map((s) => {
            const pct = (s.count / rows.length) * 100;
            return (
              <div style="margin-bottom:0.55rem;">
                <div style="display:flex; justify-content:space-between; font-size:0.85rem; margin-bottom:2px;">
                  <span>
                    <span style={`display:inline-block; width:8px; height:8px; border-radius:50%; background:${catColour[s.cat] || "#999"}; margin-right:6px;`}></span>
                    {s.label}
                  </span>
                  <span style="color:var(--ink-soft);">{s.count.toLocaleString()} · {pct.toFixed(1)}%</span>
                </div>
                <div style="background:var(--border-soft); height:6px; border-radius:3px; overflow:hidden;">
                  <div style={`width:${pct}%; height:100%; background:${catColour[s.cat] || "#999"};`}></div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <div class="surface-card" style="padding:1.4rem;">
      <h2 style="margin-top:0; margin-bottom:0.8rem;">🗺️ Countries</h2>
      {topCountries.length === 0 ? (
        <p style="color:var(--ink-soft);">No data.</p>
      ) : (
        <ul style="list-style:none; padding:0; margin:0; font-size:0.9rem;">
          {topCountries.map((c) => (
            <li style="display:flex; justify-content:space-between; padding:0.35rem 0; border-bottom:1px solid var(--border-soft);">
              <span><strong>{c.code}</strong></span>
              <span style="color:var(--ink-soft);">{c.count.toLocaleString()}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>

  {/* ─── Top pages + UTM ─── */}
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.4rem; margin-top:1.5rem;" class="grid-2">
    <div class="surface-card" style="padding:1.4rem;">
      <h2 style="margin-top:0; margin-bottom:0.8rem;">📄 Top pages</h2>
      {topPaths.length === 0 ? (
        <p style="color:var(--ink-soft);">No data.</p>
      ) : (
        <div style="overflow-x:auto;">
          <table class="admin-table" style="width:100%;">
            <thead>
              <tr>
                <th>Path</th>
                <th style="text-align:right;">Views</th>
                <th style="text-align:right;">Unique</th>
              </tr>
            </thead>
            <tbody>
              {topPaths.map((p) => (
                <tr>
                  <td style="font-family:monospace; font-size:0.8rem; max-width:28rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title={p.path}>{short(p.path)}</td>
                  <td style="text-align:right;">{p.count.toLocaleString()}</td>
                  <td style="text-align:right; color:var(--ink-soft);">{p.unique.toLocaleString()}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <div class="surface-card" style="padding:1.4rem;">
      <h2 style="margin-top:0; margin-bottom:0.8rem;">🎯 UTM attribution</h2>
      {topUtm.length === 0 ? (
        <p style="color:var(--ink-soft); font-size:0.88rem;">
          No UTM-tagged clicks yet in this window. Social posts tagged with UTMs (via <code>buildUtmUrl()</code>) will appear here.
        </p>
      ) : (
        <div style="overflow-x:auto;">
          <table class="admin-table" style="width:100%;">
            <thead>
              <tr>
                <th>Creative / Campaign</th>
                <th>Source</th>
                <th style="text-align:right;">Clicks</th>
              </tr>
            </thead>
            <tbody>
              {topUtm.map((u) => (
                <tr>
                  <td style="font-family:monospace; font-size:0.78rem; max-width:18rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title={u.key}>{u.key}</td>
                  <td style="font-size:0.82rem;">{u.source}</td>
                  <td style="text-align:right;"><strong>{u.clicks}</strong></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>

  {/* ─── Live feed + latest weekly ─── */}
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.4rem; margin-top:1.5rem;" class="grid-2">
    <div class="surface-card" style="padding:1.4rem;">
      <h2 style="margin-top:0; margin-bottom:0.8rem;">⚡ Live feed · last 20 visits</h2>
      {liveFeed.length === 0 ? (
        <p style="color:var(--ink-soft);">No data.</p>
      ) : (
        <div style="overflow-x:auto;">
          <table class="admin-table" style="width:100%;">
            <thead>
              <tr>
                <th>When</th>
                <th>Source</th>
                <th>Country</th>
                <th>Path</th>
              </tr>
            </thead>
            <tbody id="live-feed">
              {liveFeed.map((v) => (
                <tr>
                  <td style="font-size:0.78rem; white-space:nowrap; color:var(--ink-soft);">{fmtTime(v.when)}</td>
                  <td style="font-size:0.82rem;">{v.source}</td>
                  <td style="font-size:0.82rem;">{v.country}</td>
                  <td style="font-family:monospace; font-size:0.78rem; max-width:18rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title={v.path}>{short(v.path || "/")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <div class="surface-card" style="padding:1.4rem;">
      <h2 style="margin-top:0; margin-bottom:0.8rem;">📆 Latest weekly report</h2>
      {!latestWeekly ? (
        <p style="color:var(--ink-soft);">No weekly report yet. First one arrives Monday 02:00 UTC.</p>
      ) : (
        <div>
          <p style="margin:0; font-size:0.88rem; color:var(--ink-soft);">
            <strong>{latestWeekly.week_start} → {latestWeekly.week_end}</strong>
          </p>
          <p style="margin-top:0.4rem; font-size:0.92rem;">{latestWeekly.summary}</p>
          {Array.isArray(latestWeekly.recommendations) && latestWeekly.recommendations.length > 0 && (
            <>
              <h3 style="font-size:0.95rem; margin-top:1rem; margin-bottom:0.4rem;">Recommendations</h3>
              <ul style="padding-left:1.1rem; margin:0; font-size:0.85rem;">
                {latestWeekly.recommendations.slice(0, 5).map((r: any) => (
                  <li style="margin-bottom:0.3rem;">
                    <span class:list={["prio", `prio-${r.priority}`]}>{r.priority?.toUpperCase()}</span>
                    {r.action}
                  </li>
                ))}
              </ul>
            </>
          )}
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  // ── Interactive tooltip on line chart ──
  (() => {
    const wrap = document.getElementById("chart-wrap");
    const svg = document.getElementById("trend-chart") as SVGSVGElement | null;
    const capture = document.getElementById("hover-capture");
    const guide = document.getElementById("hover-guide");
    const dotPv = document.getElementById("hover-dot-pv");
    const dotUv = document.getElementById("hover-dot-uv");
    const tip = document.getElementById("chart-tooltip");
    const ttDate = document.getElementById("tt-date");
    const ttPv = document.getElementById("tt-pv");
    const ttUv = document.getElementById("tt-uv");
    if (!wrap || !svg || !capture || !guide || !dotPv || !dotUv || !tip || !ttDate || !ttPv || !ttUv) return;

    let series: { date: string; pv: number; uv: number }[] = [];
    let cfg: { W: number; H: number; PAD: number; plotW: number; plotH: number; stepX: number; maxPv: number } | null = null;
    try {
      series = JSON.parse(wrap.getAttribute("data-series") || "[]");
      cfg = JSON.parse(wrap.getAttribute("data-chart") || "null");
    } catch {}
    if (!cfg || series.length === 0) return;

    const show = (display: string) => {
      guide.style.display = display;
      dotPv.style.display = display;
      dotUv.style.display = display;
      tip.style.display = display;
    };

    const onMove = (ev: PointerEvent) => {
      const rect = svg.getBoundingClientRect();
      // Map client X back to SVG viewBox coordinates
      const scaleX = cfg!.W / rect.width;
      const svgX = (ev.clientX - rect.left) * scaleX;
      // Find closest point
      const rel = svgX - cfg!.PAD;
      let idx = Math.round(rel / cfg!.stepX);
      if (idx < 0) idx = 0;
      if (idx > series.length - 1) idx = series.length - 1;
      const s = series[idx];
      const cx = cfg!.PAD + idx * cfg!.stepX;
      const cyPv = cfg!.H - cfg!.PAD - (s.pv / cfg!.maxPv) * cfg!.plotH;
      const cyUv = cfg!.H - cfg!.PAD - (s.uv / cfg!.maxPv) * cfg!.plotH;
      guide.setAttribute("x1", String(cx));
      guide.setAttribute("x2", String(cx));
      dotPv.setAttribute("cx", String(cx));
      dotPv.setAttribute("cy", String(cyPv));
      dotUv.setAttribute("cx", String(cx));
      dotUv.setAttribute("cy", String(cyUv));
      show("");
      ttDate.textContent = s.date;
      ttPv.textContent = s.pv.toLocaleString();
      ttUv.textContent = s.uv.toLocaleString();
      // Position tooltip relative to wrapper
      const wrapRect = wrap.getBoundingClientRect();
      const pxPerUnit = rect.width / cfg!.W;
      const tipX = rect.left - wrapRect.left + cx * pxPerUnit;
      const tipY = rect.top - wrapRect.top + cyPv * pxPerUnit - 8;
      tip.style.left = `${tipX}px`;
      tip.style.top = `${tipY}px`;
    };

    capture.addEventListener("pointermove", onMove as EventListener);
    capture.addEventListener("pointerenter", onMove as EventListener);
    capture.addEventListener("pointerleave", () => show("none"));
  })();

  // Lightweight auto-refresh — only when admin checks the box & tab is visible.
  const cb = document.getElementById("auto-refresh") as HTMLInputElement | null;
  const savedState = localStorage.getItem("admin-traffic-auto") === "1";
  if (cb) cb.checked = savedState;

  let timer: number | null = null;

  async function refresh() {
    if (document.hidden) return;
    try {
      const params = new URLSearchParams(window.location.search);
      const r = await fetch(`/api/admin/traffic-stats?range=${params.get("range") || "7d"}`, { credentials: "include" });
      if (!r.ok) return;
      const data = await r.json();
      const tag = (id: string, val: string | number) => {
        const el = document.querySelector(`[data-kpi="${id}"]`);
        if (el) el.textContent = typeof val === "number" ? val.toLocaleString() : val;
      };
      tag("today", data.todayCount);
      tag("pv", data.totalPageviews);
      tag("uv", data.uniqueVisitors);
      const lr = document.getElementById("last-refresh");
      if (lr) lr.textContent = `updated ${new Date().toLocaleTimeString()}`;
    } catch { /* silent */ }
  }

  function start() {
    stop();
    refresh();
    timer = window.setInterval(refresh, 30_000);
  }
  function stop() {
    if (timer !== null) { window.clearInterval(timer); timer = null; }
  }

  cb?.addEventListener("change", () => {
    localStorage.setItem("admin-traffic-auto", cb.checked ? "1" : "0");
    if (cb.checked) start(); else stop();
  });
  if (savedState) start();
</script>

