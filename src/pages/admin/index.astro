---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { isAdmin, getServiceClient } from "../../lib/supabase";

const user = Astro.locals.user;
if (!user || !(await isAdmin(user))) {
  return Astro.redirect("/es/login/");
}

const serviceClient = getServiceClient();

// Stats
const { count: usersCount } = await serviceClient
  .from("profiles")
  .select("*", { count: "exact", head: true });

const currentMonth = new Date().toISOString().slice(0, 7);

const { count: pendingReviews } = await serviceClient
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "pending");

const { count: approvedReviews } = await serviceClient
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "approved");

const { count: winnersCount } = await serviceClient
  .from("lottery_winners")
  .select("*", { count: "exact", head: true });
---

<BaseLayout lang="en" title="Admin Dashboard | Little Chubby Press" description="Admin dashboard" pathname="/admin/">
  <section class="page-section container">
    <h1>Admin Dashboard</h1>
    <p>Welcome, {user.email}</p>

    <div class="admin-stats" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(12rem,1fr)); gap:1rem; margin-top:2rem;">
      <div class="surface-card" style="padding:1.4rem; text-align:center;">
        <div style="font-size:2rem; font-weight:700; color:var(--brand-blue); font-family:'Baloo 2',sans-serif;">
          {usersCount ?? 0}
        </div>
        <div style="color:var(--ink-soft);">Registered Users</div>
      </div>

      <div class="surface-card" style="padding:1.4rem; text-align:center;">
        <div style="font-size:2rem; font-weight:700; color:var(--brand-green); font-family:'Baloo 2',sans-serif;">
          {approvedReviews ?? 0}
        </div>
        <div style="color:var(--ink-soft);">Approved Reviews</div>
      </div>

      <div class="surface-card" style="padding:1.4rem; text-align:center;">
        <div style="font-size:2rem; font-weight:700; color:var(--brand-brown); font-family:'Baloo 2',sans-serif;">
          {pendingReviews ?? 0}
        </div>
        <div style="color:var(--ink-soft);">Pending Reviews</div>
      </div>

      <div class="surface-card" style="padding:1.4rem; text-align:center;">
        <div style="font-size:2rem; font-weight:700; color:var(--accent-gold); font-family:'Baloo 2',sans-serif;">
          {winnersCount ?? 0}
        </div>
        <div style="color:var(--ink-soft);">Total Winners</div>
      </div>
    </div>

    <nav style="display:flex; gap:1rem; margin-top:2rem; flex-wrap:wrap;">
      <a href="/admin/users/" class="btn btn-primary">Manage Users</a>
      <a href="/admin/lottery/" class="btn btn-primary">Lottery Draw</a>
    </nav>
  </section>
</BaseLayout>
