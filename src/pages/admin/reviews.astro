---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getServiceClient, isAdmin } from "../../lib/supabase";
import { validateOrigin } from "../../lib/csrf";
import { books } from "../../data/books";
import { emailUserReviewApproved, emailUserReviewRejected } from "../../lib/notifications";

const user = Astro.locals.user;
if (!user || !(await isAdmin(user))) {
  return Astro.redirect("/es/login/");
}

const sc = getServiceClient();
const PAGE_SIZE = 30;
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1", 10));
const offset = (page - 1) * PAGE_SIZE;

let reviewMsg = "";
let bulkMsg = "";

/** Log every admin action for audit trail */
async function auditLog(action: string, targetType: string, targetId: string | null, details: Record<string, unknown> = {}) {
  try {
    await sc.from("admin_audit_log").insert({
      admin_id: user!.email || user!.id,
      action,
      target_type: targetType,
      target_id: targetId,
      details: details as any,
    });
  } catch { /* non-blocking */ }
}

async function notifyUserReviewDecision(
  reviewId: string,
  status: "approved" | "rejected",
  reviewerNote: string
): Promise<void> {
  try {
    const { data: rev } = await sc
      .from("book_reviews")
      .select("user_id, book_id")
      .eq("id", reviewId)
      .single();
    if (!rev) return;

    const { data: profile } = await sc
      .from("profiles")
      .select("lang_pref")
      .eq("id", rev.user_id)
      .single();
    const { data: authUser } = await sc.auth.admin.getUserById(rev.user_id);
    const email = authUser?.user?.email;
    if (!email) return;

    const lang = (profile?.lang_pref || "en") as "en" | "es";
    const bookTitle = books.find(b => b.id === rev.book_id)?.title[lang] || rev.book_id;
    if (status === "approved") {
      await emailUserReviewApproved(email, bookTitle, lang, reviewerNote);
    } else {
      await emailUserReviewRejected(email, bookTitle, lang, reviewerNote);
    }
  } catch {
    // Non-blocking
  }
}

// ── Handle POST actions ──────────────────────────────
if (Astro.request.method === "POST") {
  if (!validateOrigin(Astro.request, Astro.url)) {
    reviewMsg = "⛔ Request blocked: invalid origin.";
  } else {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "approve_review" || action === "reject_review") {
      const reviewId = formData.get("review_id")?.toString();
      const newStatus = action === "approve_review" ? "approved" : "rejected";
      const reviewerNote = (formData.get("reviewer_note")?.toString().trim() || "").slice(0, 500);

      if (!reviewId) {
        reviewMsg = "Missing review id.";
      } else if (newStatus === "rejected" && !reviewerNote) {
        reviewMsg = "Please add a rejection reason so the user knows what to fix.";
      } else {
        const { error: updateError } = await sc.from("book_reviews").update({
          status: newStatus,
          reviewed_at: new Date().toISOString(),
          reviewer_note: reviewerNote || null,
        }).eq("id", reviewId);

        if (updateError) {
          reviewMsg = `Error: ${updateError.message}`;
        } else {
          if (newStatus === "approved") {
            const { data: rev } = await sc.from("book_reviews").select("user_id").eq("id", reviewId).single();
            if (rev?.user_id) {
              await sc.rpc("award_review_tickets", { p_user_id: rev.user_id, p_review_id: reviewId });
            }
          }
          await notifyUserReviewDecision(reviewId, newStatus, reviewerNote);
          await auditLog(action, "review", reviewId, { newStatus, reviewerNote: reviewerNote || null });
          reviewMsg = `Review ${newStatus}.`;
        }
      }
    }

    else if (action === "bulk_approve" || action === "bulk_reject") {
      const ids = formData.getAll("selected_ids").map(v => v.toString());
      const newStatus = action === "bulk_approve" ? "approved" : "rejected";
      const reviewerNote = (formData.get("bulk_reviewer_note")?.toString().trim() || "").slice(0, 500);
      if (ids.length > 0) {
        if (newStatus === "rejected" && !reviewerNote) {
          bulkMsg = "Please add a rejection reason for users before bulk reject.";
        } else {
          const { error } = await sc.from("book_reviews").update({
            status: newStatus,
            reviewed_at: new Date().toISOString(),
            reviewer_note: reviewerNote || null,
          }).in("id", ids);

          if (!error) {
            for (const rid of ids) {
              if (newStatus === "approved") {
                const { data: rev } = await sc.from("book_reviews").select("user_id").eq("id", rid).single();
                if (rev?.user_id) {
                  await sc.rpc("award_review_tickets", { p_user_id: rev.user_id, p_review_id: rid });
                }
              }
              await notifyUserReviewDecision(rid, newStatus, reviewerNote);
            }
          }

          bulkMsg = error ? `Error: ${error.message}` : `${newStatus === "approved" ? "✓" : "✗"} ${ids.length} review(s) ${newStatus}.`;
          if (!error) await auditLog(action, "review", ids.join(","), { count: ids.length, newStatus, reviewerNote: reviewerNote || null });
        }
      }
    }

    else if (action === "toggle_featured") {
      const reviewId = formData.get("review_id")?.toString();
      const featured = formData.get("featured") === "true";
      await sc.from("book_reviews").update({ featured: !featured }).eq("id", reviewId!);
      await auditLog("toggle_featured", "review", reviewId ?? null, { newFeatured: !featured });
      reviewMsg = "Featured status updated.";
    }

    else if (action === "delete_review") {
      const reviewId = formData.get("review_id")?.toString();
      if (reviewId) {
        await sc.from("book_reviews").delete().eq("id", reviewId);
        await auditLog("delete_review", "review", reviewId, {});
        reviewMsg = "Review deleted.";
      }
    }
  }
}

// ── Data for display ─────────────────────────────────
const { count: totalPending } = await sc
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "pending");

const { data: pendingReviews } = await sc
  .from("book_reviews")
  .select("id, user_id, book_id, photo_url, extra_photos, rating, review_text, featured, submitted_at, profiles(email, display_name)")
  .eq("status", "pending")
  .order("submitted_at", { ascending: true })
  .range(offset, offset + PAGE_SIZE - 1);

const { count: totalApproved } = await sc
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "approved");

const { count: totalRejected } = await sc
  .from("book_reviews")
  .select("*", { count: "exact", head: true })
  .eq("status", "rejected");

const bookMap = Object.fromEntries(books.map(b => [b.id, b.title.en]));
const stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);
const totalPages = Math.ceil((totalPending ?? 0) / PAGE_SIZE);
---

<AdminLayout title="Reviews" current="reviews">
  <h1>Review Moderation</h1>

  <div class="review-stats">
    <div class="stat-pill pending">{totalPending ?? 0} Pending</div>
    <div class="stat-pill approved">{totalApproved ?? 0} Approved</div>
    <div class="stat-pill rejected">{totalRejected ?? 0} Rejected</div>
  </div>

  {reviewMsg && <p class="msg-ok">{reviewMsg}</p>}
  {bulkMsg && <p class={bulkMsg.startsWith("Error") ? "msg-err" : "msg-ok"}>{bulkMsg}</p>}

  {pendingReviews && pendingReviews.length > 0 ? (
    <>
      <form method="POST" id="bulkForm">
        <div class="bulk-bar" id="bulkBar" style="display:none;">
          <label class="bulk-select-all">
            <input type="checkbox" id="selectAll" /> Select All
          </label>
          <span id="bulkCount">0 selected</span>
          <input
            type="text"
            name="bulk_reviewer_note"
            id="bulkReviewerNote"
            class="bulk-note-input"
            placeholder="Message to users (required for bulk reject)"
          />
          <button type="submit" name="action" value="bulk_approve" id="bulkApproveBtn" class="btn btn-ghost" style="font-size:0.8rem; padding:0.3rem 0.6rem;">✓ Approve Selected</button>
          <button type="submit" name="action" value="bulk_reject" id="bulkRejectBtn" class="btn btn-secondary" style="font-size:0.8rem; padding:0.3rem 0.6rem;">✗ Reject Selected</button>
        </div>
      </form>
      <div class="review-queue">
        {pendingReviews.map((r: any) => (
          <div class="review-card-admin">
            <div class="review-checkbox">
              <input type="checkbox" name="selected_ids" value={r.id} class="bulk-checkbox" form="bulkForm" />
            </div>
            <div class="review-left">
              <div class="review-details">
                <strong>{(r.profiles as any)?.display_name || (r.profiles as any)?.email || r.user_id}</strong>
                <span class="review-book-name">{bookMap[r.book_id] || r.book_id}</span>
                <span class="review-stars-admin">{stars(r.rating)}</span>
                {r.review_text && <p class="review-text-admin">{r.review_text}</p>}
                <small style="color:var(--ink-soft);">{new Date(r.submitted_at).toLocaleDateString()}</small>
              </div>
              <div class="review-photos-admin">
                <div class="photo-group">
                  <div class="photo-label">📕 Cover</div>
                  <img src={r.photo_url} alt="Cover" class="review-img-admin review-img-cover" loading="lazy" />
                </div>
                {r.extra_photos && (r.extra_photos as string[]).length > 0 && (
                  <div class="photo-group">
                    <div class="photo-label">📖 Interior</div>
                    <div class="interior-strip">
                      {(r.extra_photos as string[]).map((url: string) => (
                        <img src={url} alt="Interior" class="review-img-admin review-img-interior" loading="lazy" />
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
            <div class="review-actions">
              <form method="POST">
                <input type="hidden" name="action" value="approve_review" />
                <input type="hidden" name="review_id" value={r.id} />
                <input type="text" name="reviewer_note" placeholder="Note (optional)" maxlength="500" class="action-input" />
                <button type="submit" class="btn btn-ghost action-btn">✓ Approve</button>
              </form>
              <form method="POST">
                <input type="hidden" name="action" value="reject_review" />
                <input type="hidden" name="review_id" value={r.id} />
                <input type="text" name="reviewer_note" required placeholder="Rejection reason" maxlength="500" class="action-input" />
                <button type="submit" class="btn btn-secondary action-btn">✗ Reject</button>
              </form>
              <div class="action-row-compact">
                <form method="POST">
                  <input type="hidden" name="action" value="toggle_featured" />
                  <input type="hidden" name="review_id" value={r.id} />
                  <input type="hidden" name="featured" value={r.featured ? "true" : "false"} />
                  <button type="submit" class="btn btn-ghost action-btn-sm">
                    {r.featured ? "★ Unfeature" : "☆ Feature"}
                  </button>
                </form>
                <form method="POST" onsubmit="return confirm('Delete this review permanently?')">
                  <input type="hidden" name="action" value="delete_review" />
                  <input type="hidden" name="review_id" value={r.id} />
                  <button type="submit" class="btn btn-secondary action-btn-sm" style="color:#8f1f18;">🗑 Delete</button>
                </form>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Pagination */}
      {totalPages > 1 && (
        <nav class="pagination">
          {page > 1 && <a href={`?page=${page - 1}`} class="btn btn-ghost">← Prev</a>}
          <span class="page-info">Page {page} of {totalPages}</span>
          {page < totalPages && <a href={`?page=${page + 1}`} class="btn btn-ghost">Next →</a>}
        </nav>
      )}
    </>
  ) : (
    <div class="surface-card" style="padding:1.2rem; margin-top:1rem;">
      <p style="margin:0; color:var(--ink-soft);">No pending reviews right now. 🎉</p>
    </div>
  )}
</AdminLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const checkboxes = document.querySelectorAll(".bulk-checkbox");
  const selectAll = document.getElementById("selectAll");
  const bulkBar = document.getElementById("bulkBar");
  const bulkCount = document.getElementById("bulkCount");
  const bulkReviewerNote = document.getElementById("bulkReviewerNote");
  const bulkApproveBtn = document.getElementById("bulkApproveBtn");
  const bulkRejectBtn = document.getElementById("bulkRejectBtn");

  function updateBulk() {
    const checked = document.querySelectorAll(".bulk-checkbox:checked").length;
    if (bulkBar) bulkBar.style.display = checked > 0 || (checkboxes.length > 0) ? "flex" : "none";
    if (bulkCount) bulkCount.textContent = checked + " selected";
  }

  if (selectAll) {
    selectAll.addEventListener("change", () => {
      checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
      updateBulk();
    });
  }
  checkboxes.forEach(cb => cb.addEventListener("change", updateBulk));
  if (checkboxes.length > 0 && bulkBar) bulkBar.style.display = "flex";

  if (bulkRejectBtn && bulkReviewerNote) {
    bulkRejectBtn.addEventListener("click", () => {
      bulkReviewerNote.setAttribute("required", "required");
    });
  }
  if (bulkApproveBtn && bulkReviewerNote) {
    bulkApproveBtn.addEventListener("click", () => {
      bulkReviewerNote.removeAttribute("required");
    });
  }

  // Review image modal
  const adminPhotoModal = document.createElement("div");
  adminPhotoModal.className = "admin-photo-modal";
  adminPhotoModal.innerHTML =
    '<button type="button" class="admin-photo-close" aria-label="Close">✕</button>' +
    '<img class="admin-photo-modal-img" alt="Review image preview" />';
  document.body.appendChild(adminPhotoModal);

  const modalImg = adminPhotoModal.querySelector(".admin-photo-modal-img");
  const closeBtn = adminPhotoModal.querySelector(".admin-photo-close");

  function closePhotoModal() {
    adminPhotoModal.classList.remove("open");
    document.body.style.overflow = "";
    if (modalImg) modalImg.src = "";
  }

  document.querySelectorAll(".review-img-admin").forEach((img) => {
    img.addEventListener("click", () => {
      if (!modalImg) return;
      modalImg.src = img.src;
      adminPhotoModal.classList.add("open");
      document.body.style.overflow = "hidden";
    });
  });

  if (closeBtn) closeBtn.addEventListener("click", closePhotoModal);
  adminPhotoModal.addEventListener("click", (e) => {
    if (e.target === adminPhotoModal) closePhotoModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && adminPhotoModal.classList.contains("open")) closePhotoModal();
  });
});
</script>

<style>
  .review-stats {
    display: flex;
    gap: 0.8rem;
    margin: 1rem 0;
    flex-wrap: wrap;
  }
  .stat-pill {
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-weight: 700;
    font-size: 0.88rem;
  }
  .stat-pill.pending {
    background: rgba(220, 150, 30, 0.12);
    color: #b8860b;
    border: 1px solid rgba(220, 150, 30, 0.3);
  }
  .stat-pill.approved {
    background: rgba(92, 150, 80, 0.12);
    color: var(--brand-green);
    border: 1px solid rgba(92, 150, 80, 0.3);
  }
  .stat-pill.rejected {
    background: rgba(220, 50, 50, 0.08);
    color: #8f1f18;
    border: 1px solid rgba(220, 50, 50, 0.2);
  }
  .review-queue {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }
  .review-card-admin {
    display: flex;
    gap: 0.8rem;
    padding: 0.8rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--surface);
    align-items: flex-start;
  }
  .review-left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .review-photos-admin {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .photo-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .interior-strip {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .photo-label {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .review-img-admin {
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    cursor: zoom-in;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .review-img-admin:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
  }
  .review-img-cover {
    width: 5.5rem;
    height: 5.5rem;
  }
  .review-img-interior {
    width: 4rem;
    height: 4rem;
  }
  .review-details {
    min-width: 0;
  }
  .review-details strong {
    display: block;
    margin-bottom: 0.15rem;
    font-size: 0.9rem;
  }
  .review-book-name {
    display: block;
    color: var(--brand-blue);
    font-weight: 700;
    font-size: 0.88rem;
  }
  .review-stars-admin {
    color: var(--accent-gold);
    font-size: 0.9rem;
    display: block;
    margin: 0.1rem 0;
  }
  .review-text-admin {
    font-size: 0.84rem;
    color: var(--ink-soft);
    margin: 0.2rem 0 0;
    max-height: 3.6em;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
  .review-actions {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex-shrink: 0;
    width: 10rem;
    align-self: flex-start;
  }
  .action-input {
    font-size: 0.75rem;
    padding: 0.2rem 0.35rem;
    width: 100%;
    margin-bottom: 0.2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }
  .action-btn {
    font-size: 0.78rem;
    padding: 0.25rem 0.5rem;
    width: 100%;
  }
  .action-row-compact {
    display: flex;
    gap: 0.3rem;
    margin-top: 0.2rem;
  }
  .action-btn-sm {
    font-size: 0.72rem;
    padding: 0.2rem 0.35rem;
    white-space: nowrap;
  }
  .review-checkbox {
    display: flex;
    align-items: flex-start;
    padding: 0.2rem 0;
    flex-shrink: 0;
  }
  .review-checkbox input {
    width: 1.1rem;
    height: 1.1rem;
    cursor: pointer;
  }
  .bulk-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 1rem;
    background: var(--surface-strong);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    margin: 1rem 0;
    flex-wrap: wrap;
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1rem 0;
  }
  .page-info {
    font-size: 0.9rem;
    color: var(--ink-soft);
    font-weight: 600;
  }
  .msg-ok {
    padding: 0.8rem;
    border-radius: 0.5rem;
    background: rgba(92,150,80,0.14);
    color: var(--brand-green);
    border: 1px solid rgba(92,150,80,0.3);
    margin: 1rem 0;
  }
  @media (max-width: 640px) {
    .review-card-admin {
      flex-wrap: wrap;
    }
    .review-actions {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .action-input {
      min-width: 8rem;
      flex: 1;
    }
  }
</style>
