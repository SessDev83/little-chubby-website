---
import { siteConfig } from "../data/site";

const fallbackHref = "/es/";
const canonical = new URL("/", siteConfig.siteUrl).toString();
const description = "Little Chubby Press official website for family-friendly coloring books, creative resources, and bilingual content.";
const ogImage = new URL(siteConfig.brandAssets.ogCover, siteConfig.siteUrl).toString();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="p:domain_verify" content="bc8eff299b41603bc3d11c3cae8f371c" />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang="es" href={new URL("/es/", siteConfig.siteUrl).toString()} />
		<link rel="alternate" hreflang="en" href={new URL("/en/", siteConfig.siteUrl).toString()} />
		<link rel="alternate" hreflang="x-default" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Little Chubby Press" />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Little Chubby Press" />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta http-equiv="refresh" content={`0; url=${fallbackHref}`} />
		<title>Little Chubby Press</title>
	</head>
	<body>
		<h1 style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Little Chubby Press</h1>
		<script>
			const stored = localStorage.getItem("lcp-lang");
			const browserPref = navigator.language && navigator.language.toLowerCase().startsWith("en") ? "en" : "es";
			const lang = stored === "en" || stored === "es" ? stored : browserPref;
			window.location.replace(`/${lang}/`);
		</script>
		<noscript>
			<p>
				Continue to
				<a href={fallbackHref}>Little Chubby Press</a>
			</p>
		</noscript>
	</body>
</html>
