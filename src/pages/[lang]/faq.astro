---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";
import { languages, getLangFromParam, ui } from "../../data/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/faq/`;

// Last updated — kept in sync with privacy + docs/LEGAL_MAINTENANCE.md (bi-weekly review).
const lastUpdatedES = "22 de abril de 2026";
const lastUpdatedEN = "April 22, 2026";

// ---------------------------------------------------------------------------
// FAQ content — ALWAYS ALPHABETICAL A→Z by question, in both languages.
// When adding a new Q&A, insert it in alphabetical order. Each item is
// rendered as a native <details> accordion for zero-JS, fully accessible UX.
// Keep ES and EN arrays in strict parity (same number of entries, same order).
// ---------------------------------------------------------------------------

type QA = { q: string; a: string };

const faqES: QA[] = [
  {
    q: "¿Aparece mi resena automaticamente en la galeria publica?",
    a: "Solo despues de que un humano la revise y la apruebe. Moderamos para proteger a la comunidad (sin datos personales visibles, sin contenido inadecuado). Puedes editarla o borrarla cuando quieras desde tu perfil.",
  },
  {
    q: "¿Borran mi cuenta si yo lo pido?",
    a: "Si. No hace falta escribirnos: desde tu perfil, en la seccion 'Privacidad y datos', tienes un boton rojo 'Eliminar mi cuenta'. Tu perfil, resenas, fotos y saldos desaparecen al instante de la app y las copias de seguridad se purgan en un maximo de 30 dias. Antes de borrar, desde la misma seccion puedes descargar una copia de todos tus datos. Solo conservamos estadisticas anonimas agregadas y los registros tecnicos obligatorios por ley.",
  },
  {
    q: "¿Como cambio mi email?",
    a: "Desde 'Profile → Seguridad → Cambiar email'. Escribes el nuevo email, nosotros enviamos un enlace de confirmacion a esa direccion, y cuando lo pulsas queda actualizado. Tranqui: tus cacahuetes, tickets, resenas y badges estan ligados a tu cuenta (no al email), asi que no pierdes nada al cambiarlo.",
  },
  {
    q: "¿Como descargo una lamina para colorear?",
    a: "En la pagina 'Coloring Corner'. Cada descarga cuesta 1 cacahuete 🥜 (que se gana gratis compartiendo, con tu racha diaria o dejando resenas aprobadas).",
  },
  {
    q: "¿Como funciona el sorteo mensual?",
    a: "Cada mes regalamos 1 libro fisico gratis. Cada resena aprobada te da 5 tickets 🎟️ y puedes comprar mas con cacahuetes (3 🥜 = 1 ticket). El sorteo se ejecuta automaticamente el dia 1 de cada mes y notificamos al ganador por email.",
  },
  {
    q: "¿Como funcionan los cacahuetes 🥜?",
    a: "Son nuestra moneda interna. Se ganan GRATIS (compartiendo, con tu racha diaria, con resenas) y se gastan en cosas cosmeticas o utiles (badges, boosts, descargas, tickets). Nunca cuestan dinero real. No se pueden comprar, no se pueden canjear por dinero.",
  },
  {
    q: "¿Como funciona la racha diaria?",
    a: "Si entras a la app al menos una vez al dia, tu racha sube. Por mantenerla ganas +2 cacahuetes al dia. Si fallas un dia, la racha vuelve a 1 (salvo que tengas un freeze disponible).",
  },
  {
    q: "¿Como me doy de baja del newsletter?",
    a: "Cada email tiene un enlace 'Unsubscribe / Darme de baja' al final. Un solo clic basta. No pedimos motivos ni confirmaciones extra.",
  },
  {
    q: "¿Como subo una resena de un libro?",
    a: "Ve a 'Reviews' desde el menu, elige el libro, sube una foto de la portada + al menos 1 foto del interior, pon tu puntuacion (1-5 estrellas) y, si quieres, un comentario. Despues pasa por moderacion.",
  },
  {
    q: "¿Cuanto tardan en aprobar mi resena?",
    a: "Intentamos moderarla en menos de 48 horas. Cuando se aprueba recibes un email y tus 5 tickets se suman automaticamente a tu cuenta.",
  },
  {
    q: "¿En que idiomas esta la app?",
    a: "Espanol e Ingles, con paridad total: cada pagina, email y notificacion existe en ambos. Tenemos en el plan anadir Italiano, Portugues y Frances en las siguientes fases.",
  },
  {
    q: "¿Es gratis usar la app?",
    a: "Si. Registrarse, dejar resenas, descargar laminas gratis, participar en el sorteo mensual y ganar cacahuetes es 100% gratis. Los libros fisicos se compran en Amazon; ahi sales de nuestra app.",
  },
  {
    q: "¿Funciona la app sin conexion (offline)?",
    a: "Hoy no. La app es 100% web. Los siguientes pasos del plan incluyen convertirla en PWA (instalable en movil) y mas adelante en app nativa.",
  },
  {
    q: "¿Hay un minimo de edad para crear una cuenta?",
    a: "Si. La cuenta la gestiona un adulto de 18 anos o mas (padre, madre, abuelo/a o tutor/a legal). Lo confirmas con una casilla al registrarte. Los peques de la familia pueden leer los libros, colorear y participar contigo, pero la cuenta siempre esta a nombre del adulto responsable. Si detectamos una cuenta gestionada por un menor sin adulto detras, la eliminamos.",
  },
  {
    q: "¿Los premios del sorteo son reales?",
    a: "Si. Enviamos un libro fisico al ganador de cada mes. Por eso, si tu direccion postal aparece en el perfil, solo la pedimos en ese momento para hacer el envio. Nunca la usamos para publicidad.",
  },
  {
    q: "¿Me pueden pagar por dejar una resena?",
    a: "No. Las recompensas siempre son cacahuetes 🥜 y tickets 🎟️ del sistema interno. Nunca dinero real, nunca pago directo, nunca promesas externas.",
  },
  {
    q: "¿Mis datos viajan fuera de mi pais?",
    a: "Nuestros proveedores (Supabase, Vercel, Resend, Google Fonts) pueden procesar datos en Estados Unidos o la Union Europea. Todos cumplen con las clausulas contractuales tipo u equivalentes, garantizando proteccion legal aunque el servidor este en otra jurisdiccion.",
  },
  {
    q: "¿Pagan dinero real por cacahuetes?",
    a: "No. Los cacahuetes son solo una moneda interna simbolica. No se compran, no se venden, no tienen valor monetario fuera de la app.",
  },
  {
    q: "¿Puedo cambiar mi nombre visible o avatar cuando quiera?",
    a: "Si. Desde 'Profile → Settings' puedes cambiar nombre, avatar, idioma y direccion postal las veces que necesites.",
  },
  {
    q: "¿Puedo participar en el sorteo sin gastar dinero?",
    a: "Si, al 100%. Todas las formas de ganar tickets son gratuitas: dejar resenas aprobadas (+5), suscribirte al newsletter (+1), mantener racha y canjear cacahuetes (3 🥜 = 1 ticket).",
  },
  {
    q: "¿Puedo regalar tickets a otra persona?",
    a: "Si. Desde la pagina 'Lottery' puedes regalar tickets a un amigo, este registrado o no. Si aun no tiene cuenta, le enviamos una invitacion por email y los tickets quedan reservados 30 dias a su nombre; si crea cuenta en los primeros 7 dias, como bonus referido te devolvemos a ti la misma cantidad de tickets como premio.",
  },
  {
    q: "¿Puedo ver que datos tenes sobre mi?",
    a: "Si, cuando quieras. Desde tu perfil, en la seccion 'Privacidad y datos', pulsa 'Descargar mis datos' y te generamos un archivo con toda tu informacion al instante. Si prefieres pedirlo por email tambien puedes escribir a " + siteConfig.contactEmail + " y te respondemos en un plazo maximo de 30 dias. Es un derecho reconocido por el GDPR y leyes equivalentes.",
  },
  {
    q: "¿Que cookies usa la app?",
    a: "Solo esenciales: 3 cookies de sesion de Supabase (httpOnly + Secure, duran 7 dias) para mantenerte conectado. NO usamos cookies publicitarias, ni Google Analytics, ni Meta Pixel, ni trackers de terceros.",
  },
  {
    q: "¿Que es el badge destacado?",
    a: "Un badge que tu eliges mostrar publicamente junto a tu nombre en la galeria. Solo puedes destacar uno que ya poseas. Se cambia desde 'Profile → Adventure → Badge destacado'.",
  },
  {
    q: "¿Que es el ranking mensual?",
    a: "Los 5 usuarios que mas cacahuetes ganan en el mes aparecen en la pagina 'Peanuts'. Es OPT-IN: por defecto NO apareces. Desde 'Profile → Settings → Mostrar en rankings' lo activas o desactivas cuando quieras.",
  },
  {
    q: "¿Que hago si un email o una resena parece spam o abuso?",
    a: "Escribenos a " + siteConfig.contactEmail + " con una captura. Revisamos en menos de 48 horas. Tenemos moderacion humana + limites automaticos anti-abuso (rate limiting) en todas las acciones importantes.",
  },
  {
    q: "¿Que pasa si olvido mi contrasena?",
    a: "En la pagina de login hay un enlace 'Olvide mi contrasena'. Te enviamos un email con un enlace seguro para crear una nueva. Tambien puedes entrar con 'magic link' (un enlace de un solo uso que llega a tu email).",
  },
  {
    q: "¿Que pasa si rechazan mi resena?",
    a: "Te llega un email explicando el motivo (foto borrosa, sin interior visible, contenido inapropiado, etc.). Puedes editarla y volver a enviarla. No pierdes cacahuetes por reintentarlo.",
  },
  {
    q: "¿Quien ve mi email?",
    a: "Solo nosotros (el equipo interno) y nuestros proveedores tecnicos (Supabase para autenticarte, Resend para enviarte emails). Nunca se muestra publicamente en la galeria ni en tu perfil publico.",
  },
  {
    q: "¿Se me cobra automaticamente algo?",
    a: "Nunca. No guardamos tarjetas ni procesamos pagos. La unica transaccion externa posible es comprar un libro en Amazon, y eso ocurre fuera de nuestra app, dentro de la web de Amazon.",
  },
  {
    q: "¿Venden o ceden mis datos a terceros?",
    a: "No. Nunca vendemos datos y no los cedemos con fines publicitarios. Solo los comparten con nuestros proveedores estrictamente necesarios (base de datos, hosting, emails), bajo contrato y solo para prestar el servicio.",
  },
];

const faqEN: QA[] = [
  {
    q: "Are giveaway prizes real?",
