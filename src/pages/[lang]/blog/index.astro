---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import Button from "../../../components/Button.astro";
import { getCollection, render } from "astro:content";
import { languages, getLangFromParam, ui, formatDate } from "../../../data/i18n";
import { siteConfig } from "../../../data/site";
import { funFactCategories } from "../../../data/funFactCategories";
import { articleCategories } from "../../../data/articleCategories";
import { buildTrackedShareUrl } from "../../../lib/social-share-tracking.mjs";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/blog/`;
const breadcrumbs = [
  { name: lang === "es" ? "Inicio" : "Home", url: `/${lang}/` },
  { name: text.navBlog, url: pathname }
];

const allPosts = await getCollection("blog", (entry) => entry.data.lang === lang);
const sortedPosts = allPosts.sort((a, b) => b.data.date.localeCompare(a.data.date));

const articles = sortedPosts.filter((p) => (p.data.category || "article") === "article");
const funFacts = sortedPosts.filter((p) => p.data.category === "fun-fact");
const jokes = sortedPosts.filter((p) => (p.data.category || "article") === "joke");
const renderedJokes = await Promise.all(
  jokes.map(async (joke) => {
    const { Content } = await render(joke);
    return { joke, Content };
  })
);

const categories = [
  { value: "article", label: text.blogFilterArticles },
  { value: "fun-fact", label: text.blogFilterFunFacts },
  { value: "joke", label: text.blogFilterJokes },
];
---

<BaseLayout lang={lang} title={text.blogMetaTitle} description={text.blogMetaDescription} pathname={pathname} breadcrumbs={breadcrumbs}>
  <section class="page-section">
    <div class="container">
      <div class="section-head">
        <h1>{text.blogSectionTitle}</h1>
        <p>
          {lang === "es"
            ? "Consejos editoriales, datos curiosos, chistes y recursos para impulsar creatividad infantil en casa."
            : "Editorial notes, fun facts, jokes, and practical resources to nurture creativity at home."}
        </p>
      </div>

      <div class="blog-filters" role="group" aria-label={text.blogFilterLabel}>
        {categories.map((cat) => (
          <button
            class:list={["blog-filter-btn", { active: cat.value === "article" }]}
            data-blog-category={cat.value}
            type="button"
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div class="blog-category-section" data-section="article">
        <nav class="ff-category-filter" aria-label={lang === "es" ? "Categorías de artículos" : "Article categories"}>
          {articleCategories.map((cat) => (
            <a class="ff-cat-btn" href={`/${lang}/articles/${cat.slug}/`} style={`--ff-cat-color: ${cat.color};`}>
              <span class="ff-cat-emoji" aria-hidden="true">{cat.icon}</span>
              {cat.shortLabel[lang]}
            </a>
          ))}
        </nav>

        <p class="ff-section-label">{lang === "es" ? "Publicaciones recientes" : "Recent posts"}</p>

        <div class="grid-cards posts">
          {articles.length > 0
            ? articles.slice(0, 4).map((post) => <PostCard post={post} lang={lang} readLabel={text.ctaReadPost} />)
            : <p class="blog-empty-msg">{lang === "es" ? "No hay artículos todavía." : "No articles yet."}</p>
          }
        </div>

        <div class="ff-hub-banner">
          <div class="ff-hub-banner-text">
            <strong>{lang === "es" ? `${articles.length} artículos en 5 categorías` : `${articles.length} articles across 5 categories`}</strong>
            <span>{lang === "es" ? "Explora el catálogo completo organizado por tema." : "Browse the full catalog organized by topic."}</span>
          </div>
          <a class="ff-hub-banner-btn" href={`/${lang}/articles/`}>
            {lang === "es" ? "Ver todas las categorías" : "Explore all categories"}
          </a>
        </div>
      </div>

      <div class="blog-category-section" data-section="fun-fact" style="display:none;">
        <nav class="ff-category-filter" aria-label={lang === "es" ? "Categorías de datos curiosos" : "Fun fact categories"}>
          {funFactCategories.map((cat) => (
            <a class="ff-cat-btn" href={`/${lang}/fun-facts/${cat.slug}/`} style={`--ff-cat-color: ${cat.color};`}>
              <span class="ff-cat-emoji" aria-hidden="true">{cat.icon}</span>
              {cat.shortLabel[lang]}
            </a>
          ))}
        </nav>
        <p class="ff-section-label">{lang === "es" ? "Publicaciones recientes" : "Recent posts"}</p>

        <div class="grid-cards posts">
          {funFacts.length > 0
            ? funFacts.slice(0, 4).map((post) => <PostCard post={post} lang={lang} readLabel={text.ctaReadPost} />)
            : <p class="blog-empty-msg">{lang === "es" ? "No hay datos curiosos todavía." : "No fun facts yet."}</p>
          }
        </div>

        <div class="ff-hub-banner">
          <div class="ff-hub-banner-text">
            <strong>{lang === "es" ? `${funFacts.length} datos curiosos en ${funFactCategories.length} categorías` : `${funFacts.length} fun facts across ${funFactCategories.length} categories`}</strong>
            <span>{lang === "es" ? "Explora el catálogo completo organizado por tema." : "Browse the full catalog organized by topic."}</span>
          </div>
          <a class="ff-hub-banner-btn" href={`/${lang}/fun-facts/`}>
            {lang === "es" ? "Ver todas las categorías" : "Explore all categories"}
          </a>
        </div>
      </div>

      <div class="blog-category-section" data-section="joke" style="display:none;">
        <div class="jokes-inline-grid">
          {renderedJokes.length > 0
            ? renderedJokes.map(({ joke, Content }) => {
                const jokeSlug = joke.id.replace(/^(es|en)\//, "");
                const jokeHref = `/${lang}/blog/${jokeSlug}/`;
                const jokeUrl = new URL(jokeHref, siteConfig.siteUrl).toString();
                const jokeFacebookUrl = buildTrackedShareUrl(jokeUrl, { platform: "facebook", lang, contentType: "joke", contentId: jokeSlug, title: joke.data.title });
                const jokeBlueskyUrl = buildTrackedShareUrl(jokeUrl, { platform: "bluesky", lang, contentType: "joke", contentId: jokeSlug, title: joke.data.title });
                const jokeCopyUrl = buildTrackedShareUrl(jokeUrl, { platform: "copy-link", lang, contentType: "joke", contentId: jokeSlug, title: joke.data.title });
                return (
                <article class="joke-inline-card">
                  <div class="joke-inline-header">
                    <span class="category-badge" style="--badge-color: var(--accent-coral);">
                      {lang === "es" ? "Chiste" : "Joke"}
                    </span>
                    <span class="joke-inline-date">{formatDate(joke.data.date, lang)}</span>
                  </div>
                  <div class="joke-inline-content">
                    <Content />
                  </div>
                  <div class="joke-inline-actions">
                    <div class="joke-share-row">
                      <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="share-btn share-instagram" aria-label={text.followInstagram}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
                      <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(jokeFacebookUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-facebook" data-share-platform="facebook" data-shared-path={jokeHref} aria-label={lang === "es" ? "Compartir en Facebook" : "Share on Facebook"}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
                      <a href={`https://bsky.app/intent/compose?text=${encodeURIComponent(joke.data.title + " " + jokeBlueskyUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn share-bluesky" data-share-platform="bluesky" data-shared-path={jokeHref} aria-label={lang === "es" ? "Compartir en Bluesky" : "Share on Bluesky"}><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.643 3.593 3.519 6.173 3.175-.375.52-1.611 1.753-.875 3.613C7.182 20.756 12 18.906 12 18.906s4.818 1.85 6.078-1.871c.736-1.86-.5-3.093-.875-3.613 2.58.344 5.388-.532 6.173-3.175C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.86-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.747 13.087 8.686 12 10.8"/></svg></a>
                      <button type="button" class="share-btn share-copy-link joke-copy-link" data-url={jokeCopyUrl} data-share-platform="copy-link" data-shared-path={jokeHref} aria-label={lang === "es" ? "Copiar enlace" : "Copy link"}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></button>
                    </div>
                    <div class="card-actions">
                      <Button href={jokeHref} label={lang === "es" ? "Ver más" : "See more"} variant="ghost" />
                    </div>
                  </div>
                </article>
              );})
            : <p class="blog-empty-msg">
                {lang === "es" ? "No hay chistes todavía." : "No jokes yet."}
              </p>
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
function initBlogFilters() {
  var btns = document.querySelectorAll("[data-blog-category]");
  var sections = document.querySelectorAll("[data-section]");
  if (!btns.length) return;

  btns.forEach(function(btn) {
    btn.addEventListener("click", function() {
      btns.forEach(function(b) { b.classList.remove("active"); });
      btn.classList.add("active");
      var cat = btn.getAttribute("data-blog-category");
      sections.forEach(function(sec) {
        sec.style.display = sec.getAttribute("data-section") === cat ? "" : "none";
      });
    });
  });

  // Sticky shadow — reads --header-h at check time so it stays
  // accurate when the smart header collapses/expands.
  var filtersEl = document.querySelector(".blog-filters");
  if (filtersEl) {
    if (filtersEl._stuckCleanup) filtersEl._stuckCleanup();
    function checkBlogStuck() {
      var headerH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue("--header-h")) || 0;
      var top = filtersEl.getBoundingClientRect().top;
      filtersEl.classList.toggle("stuck", Math.abs(top - headerH) < 2);
    }
    window.addEventListener("scroll", checkBlogStuck, { passive: true });
    window.addEventListener("lcp:header-resize", checkBlogStuck);
    checkBlogStuck();
    filtersEl._stuckCleanup = function() {
      window.removeEventListener("scroll", checkBlogStuck);
      window.removeEventListener("lcp:header-resize", checkBlogStuck);
    };
  }
}
initBlogFilters();
document.addEventListener("astro:after-swap", initBlogFilters);


function initJokeCopyLinks() {
  document.querySelectorAll(".joke-copy-link").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var url = btn.getAttribute("data-url");
      navigator.clipboard.writeText(url).then(function() {
        var orig = btn.textContent;
        btn.textContent = "✅";
        setTimeout(function() { btn.textContent = orig; }, 1500);
      });
    });
  });
}
initJokeCopyLinks();
document.addEventListener("astro:after-swap", initJokeCopyLinks);

function initJokeShareTracking() {
  document.querySelectorAll("[data-share-platform]").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var platform = btn.getAttribute("data-share-platform") || "";
      var sharedPath = btn.getAttribute("data-shared-path") || window.location.pathname;
      try {
        var tracker = window.lcpTrack;
        if (typeof tracker === "function") tracker("share_click", { platform: platform, shared_path: sharedPath });
      } catch (e) {}
    });
  });
}
initJokeShareTracking();
document.addEventListener("astro:after-swap", initJokeShareTracking);
</script>
