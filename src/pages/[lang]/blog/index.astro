---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { getCollection } from "astro:content";
import { languages, getLangFromParam, ui } from "../../../data/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/blog/`;
const breadcrumbs = [
  { name: lang === "es" ? "Inicio" : "Home", url: `/${lang}/` },
  { name: "Blog", url: pathname }
];

const allPosts = await getCollection("blog", (entry) => entry.data.lang === lang);
const sortedPosts = allPosts.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout lang={lang} title={text.blogMetaTitle} description={text.blogMetaDescription} pathname={pathname} breadcrumbs={breadcrumbs}>
  <section class="page-section">
    <div class="container">
      <div class="section-head">
        <h1>{text.blogSectionTitle}</h1>
        <p>
          {lang === "es"
            ? "Consejos editoriales, ideas de actividades y recursos para impulsar creatividad infantil en casa."
            : "Editorial notes, activity ideas, and practical resources to nurture creativity at home."}
        </p>
      </div>

      <div class="grid-cards posts">
        {sortedPosts.map((post) => <PostCard post={post} lang={lang} readLabel={text.ctaReadPost} />)}
      </div>
    </div>
  </section>
</BaseLayout>
