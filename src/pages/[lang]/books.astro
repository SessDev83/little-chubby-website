---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookTile from "../../components/BookTile.astro";
import { booksByNewest } from "../../data/books";
import { languages, getLangFromParam, ui } from "../../data/i18n";
import { siteConfig } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/books/`;
const breadcrumbs = [
  { name: lang === "es" ? "Inicio" : "Home", url: `/${lang}/` },
  { name: text.navBooks, url: pathname }
];

const booksJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: lang === "es" ? "Catalogo de libros Little Chubby Press" : "Little Chubby Press book catalog",
  itemListElement: booksByNewest.map((book, index) => {
    const asinMatch = book.amazonUrl.match(/\/dp\/([A-Z0-9]{10})/i);
    const asin = asinMatch ? asinMatch[1].toUpperCase() : null;
    const cover = asin
      ? `https://images-na.ssl-images-amazon.com/images/P/${asin}.01.LZZZZZZZ.jpg`
      : book.coverSrc.startsWith("http")
        ? book.coverSrc
        : new URL(book.coverSrc, siteConfig.siteUrl).toString();

    const item = {
      "@type": "Book",
      name: book.title[lang],
      description: book.description[lang],
      inLanguage: "en",
      numberOfPages: book.pages,
      image: cover,
      url: new URL(`/${lang}/books/${book.id}/`, siteConfig.siteUrl).toString()
    };

    if (typeof book.ratingValue === "number" && typeof book.ratingCount === "number" && book.ratingCount > 0) {
      return {
        "@type": "ListItem",
        position: index + 1,
        item: {
          ...item,
          aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: book.ratingValue,
            reviewCount: book.ratingCount
          }
        }
      };
    }

    return {
      "@type": "ListItem",
      position: index + 1,
      item
    };
  })
});
---

<BaseLayout lang={lang} title={text.booksMetaTitle} description={text.booksMetaDescription} pathname={pathname} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={booksJsonLd}></script>
  <section class="page-section">
    <div class="container">
      <div class="section-head">
        <h1>{text.booksSectionTitle}</h1>
        <p>
          {lang === "es"
            ? "Coleccion curada para peques y familias creativas. Cada libro incluye enlace directo a Amazon, reseñas y portada actualizada desde KDP."
            : "A curated collection for kids and creative families. Every title includes direct Amazon links, review access, and KDP-synced cover updates."}
        </p>
      </div>

      <nav class="book-filters" role="navigation" aria-label={text.booksFilterLabel}>
        <button class="book-filter-btn active" data-filter="all" type="button">{text.booksFilterAll}</button>
        <button class="book-filter-btn" data-filter="4-8" type="button">{text.booksFilter4to8}</button>
        <button class="book-filter-btn" data-filter="8-12" type="button">{text.booksFilter8to12}</button>
        <button class="book-filter-btn" data-filter="12-18+" type="button">{text.booksFilter12plus}</button>
      </nav>

      <p class="books-empty-msg book-hidden" aria-live="polite">{text.booksEmptyCategory}</p>

      <div class="books-tile-grid">
        {booksByNewest.map((book) => <BookTile book={book} lang={lang} />)}
      </div>
    </div>
  </section>

  <script>
    function initBookFilters() {
      const buttons = document.querySelectorAll<HTMLButtonElement>('.book-filter-btn');
      const cards = document.querySelectorAll<HTMLElement>('.book-tile');
      const emptyMsg = document.querySelector<HTMLElement>('.books-empty-msg');
      if (!buttons.length || !cards.length) return;

      function applyFilter(category: string) {
        let visibleCount = 0;
        cards.forEach((card) => {
          const cats = (card.dataset.categories || '').split(',');
          const show = category === 'all' || cats.includes(category);
          card.classList.toggle('book-hidden', !show);
          if (show) visibleCount++;
        });
        if (emptyMsg) {
          emptyMsg.classList.toggle('book-hidden', visibleCount > 0);
        }
        buttons.forEach((btn) => {
          const isActive = btn.dataset.filter === category;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-pressed', String(isActive));
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter || 'all';
          applyFilter(filter);
          history.replaceState(null, '', filter === 'all' ? location.pathname : `#age-${filter}`);
        });
      });

      const hash = location.hash.replace('#age-', '');
      if (hash && ['4-8', '8-12', '12-18+'].includes(hash)) {
        applyFilter(hash);
      }

      // Smart scroll: hide on scroll-down, reveal on scroll-up — mirrors site header behaviour.
      const filtersEl = document.querySelector<HTMLElement>('.book-filters');
      if (filtersEl) {
        if ((filtersEl as any)._filterCleanup) (filtersEl as any)._filterCleanup();

        const bar = filtersEl;
        const desktopMQ = window.matchMedia('(min-width: 48rem)');
        let lastScrollY = window.scrollY;
        let scrollDownDist = 0;
        let barIsHidden = false;
        let ticking = false;

        function getHeaderH() {
          return parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-h')) || 0;
        }

        function updateStuck() {
          bar.classList.toggle('stuck', Math.abs(bar.getBoundingClientRect().top - getHeaderH()) < 2);
        }

        function setBarHidden(hide: boolean) {
          if (hide === barIsHidden) return;
          barIsHidden = hide;
          bar.classList.toggle('bar-hidden', hide);
          if (!hide) updateStuck();
        }

        // Desktop: filter bar follows the site header collapse/expand state exactly.
        // lcp:header-resize fires (via ResizeObserver) throughout the header animation,
        // so --header-h is always current and the bar position stays accurate.
        function onHeaderResize() {
          if (desktopMQ.matches) {
            const headerEl = document.querySelector<HTMLElement>('.site-header');
            if (headerEl) setBarHidden(headerEl.classList.contains('header-nav-collapsed'));
          }
          if (!barIsHidden) updateStuck();
        }

        // Mobile: independent scroll detection — hide after 30 px down, show on any upward movement.
        function onScroll() {
          if (desktopMQ.matches || ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const currentY = window.scrollY;
            const delta = currentY - lastScrollY;
            lastScrollY = currentY;

            if (Math.abs(delta) >= 1) {
              if (currentY < 80) {
                setBarHidden(false);
                scrollDownDist = 0;
              } else if (delta > 0) {
                scrollDownDist += delta;
                if (scrollDownDist > 30) { scrollDownDist = 0; setBarHidden(true); }
              } else {
                scrollDownDist = 0;
                setBarHidden(false);
              }
            }

            if (!barIsHidden) updateStuck();
            ticking = false;
          });
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('lcp:header-resize', onHeaderResize);
        onHeaderResize();

        (bar as any)._filterCleanup = () => {
          window.removeEventListener('scroll', onScroll);
          window.removeEventListener('lcp:header-resize', onHeaderResize);
        };
      }
    }

    initBookFilters();
    document.addEventListener('astro:after-swap', initBookFilters);
  </script>

</BaseLayout>
