---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BookTile from "../../../components/BookTile.astro";
import Button from "../../../components/Button.astro";
import { books, booksByNewest } from "../../../data/books";
import { getBookSeo } from "../../../data/books-seo";
import { languages, getLangFromParam, ui } from "../../../data/i18n";
import { siteConfig } from "../../../data/site";

export function getStaticPaths() {
  return languages.flatMap((lang) =>
    books.map((book) => ({
      params: { lang, slug: book.id },
      props: { book },
    }))
  );
}

const { book } = Astro.props;
const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/books/${book.id}/`;

const asinMatch = book.amazonUrl.match(/\/dp\/([A-Z0-9]{10})/i);
const asin = asinMatch ? asinMatch[1].toUpperCase() : null;
const coverUrl = asin
  ? `https://images-na.ssl-images-amazon.com/images/P/${asin}.01.LZZZZZZZ.jpg`
  : book.coverSrc.startsWith("http")
    ? book.coverSrc
    : new URL(book.coverSrc, siteConfig.siteUrl).toString();

const hasRating =
  typeof book.ratingValue === "number" &&
  Number.isFinite(book.ratingValue) &&
  typeof book.ratingCount === "number" &&
  book.ratingCount > 0;
const normalizedRating = hasRating ? Math.max(0, Math.min(5, book.ratingValue ?? 0)) : 0;
const ratingPercent = `${(normalizedRating / 5) * 100}%`;
const reviewWord = (book.ratingCount ?? 0) === 1 ? text.ratingReviewSingular : text.ratingReviewPlural;
const ratingSummary = hasRating
  ? `${normalizedRating.toFixed(1)} ${text.ratingOutOfFive} (${book.ratingCount} ${reviewWord})`
  : text.ratingNoReviews;

const features = book.features?.[lang] ?? [];
const perfectFor = book.perfectFor?.[lang] ?? null;

// Related: same age category, different book, max 4
const related = booksByNewest
  .filter(
    (b) =>
      b.id !== book.id &&
      b.ageCategories.some((c) => book.ageCategories.includes(c))
  )
  .slice(0, 4);

// Prev / Next book navigation (IV-H.2 sec 11). Order = booksByNewest (same as home/catalog).
const currentIdx = booksByNewest.findIndex((b) => b.id === book.id);
const prevBook = currentIdx > 0 ? booksByNewest[currentIdx - 1] : null;
const nextBook =
  currentIdx >= 0 && currentIdx < booksByNewest.length - 1
    ? booksByNewest[currentIdx + 1]
    : null;

// JSON-LD audience age inference (IV-H.8 P2 schema enrichment).
const minAge = book.ageCategories.includes("4-8")
  ? 4
  : book.ageCategories.includes("8-12")
    ? 8
    : book.ageCategories.includes("12-18+")
      ? 12
      : 4;
const maxAge = book.ageCategories.includes("12-18+")
  ? 18
  : book.ageCategories.includes("8-12")
    ? 12
    : book.ageCategories.includes("4-8")
      ? 8
      : 8;

const breadcrumbs = [
  { name: lang === "es" ? "Inicio" : "Home", url: `/${lang}/` },
  { name: text.navBooks, url: `/${lang}/books/` },
  { name: book.title[lang], url: pathname },
];

// Per-book SEO + FAQ (IV-H). Falls back gracefully if entry not yet written.
const seo = getBookSeo(book.id);
const h1Keyword = seo?.h1Keyword?.[lang] ?? null;
const metaTitle = seo?.seoTitle?.[lang] ?? `${book.title[lang]} | Little Chubby Press`;
const metaDescription = (seo?.seoDescription?.[lang] ?? book.description[lang]).slice(0, 160);

// Self-hosted OG image (1200x630) if generated; else fall back to Amazon cover.
// IV-H — Self-hosted OG. Generated by scripts/generate-book-og-images.mjs.
const ogImageUrl = seo?.ogImage
  ? new URL(seo.ogImage, siteConfig.siteUrl).toString()
  : coverUrl;

// Unique FAQ per book if available; otherwise fall back to generic 3-entry i18n FAQ.
const faqEntries: { q: string; a: string }[] = seo?.faq?.[lang] ?? [
  { q: text.bookDetailFaqQ1, a: text.bookDetailFaqA1 },
  { q: text.bookDetailFaqQ2, a: text.bookDetailFaqA2 },
  { q: text.bookDetailFaqQ3, a: text.bookDetailFaqA3 },
];

// In-app review CTA (Master Doc invariant #17). Pre-selects book via query string.
const inAppReviewUrl = `/${lang}/reviews/?book=${encodeURIComponent(book.id)}#book-${book.id}`;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqEntries.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const bookJsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: book.title[lang],
  description: book.description[lang],
  url: new URL(pathname, siteConfig.siteUrl).toString(),
  inLanguage: lang,
  numberOfPages: book.pages,
  image: coverUrl,
  author: {
    "@type": "Organization",
    name: siteConfig.brandName,
    url: siteConfig.siteUrl,
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.brandName,
    url: siteConfig.siteUrl,
  },
  offers: {
    "@type": "Offer",
    url: book.amazonUrl,
    availability: "https://schema.org/InStock",
    seller: { "@type": "Organization", name: "Amazon" },
  },
  ...(hasRating
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: normalizedRating,
          reviewCount: book.ratingCount,
          bestRating: 5,
        },
      }
    : {}),
  ...(book.bookFormat ? { bookFormat: `https://schema.org/${book.bookFormat}` } : {}),
  ...(book.datePublished ? { datePublished: book.datePublished } : {}),
  audience: {
    "@type": "PeopleAudience",
    suggestedMinAge: minAge,
    suggestedMaxAge: maxAge,
  },
};
---

<BaseLayout
  lang={lang}
  title={metaTitle}
  description={metaDescription}
  pathname={pathname}
  breadcrumbs={breadcrumbs}
  ogImage={ogImageUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(bookJsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <section class="page-section book-detail-section">
    <div class="container">

      <a href={`/${lang}/books/`} class="book-detail-back">
        {text.bookDetailBackToCatalog}
      </a>

      <!-- Hero -->
      <div class="book-detail-hero">
        <div class="book-detail-cover">
          <img
            src={coverUrl}
            alt={book.coverAlt[lang]}
            width="420"
            height="420"
            fetchpriority="high"
            decoding="async"
          />
        </div>

        <div class="book-detail-info">
          <h1 class="book-detail-title">
            {book.title[lang]}
            {h1Keyword && <span class="book-detail-h1-tail"> — {h1Keyword}</span>}
          </h1>
          <p class="book-detail-subtitle">{book.subtitle[lang]}</p>
          <p class="book-detail-byline">{text.bookDetailByLcp}</p>

          <div class="book-detail-meta">
            <span class="badge-age">{book.ageRange[lang]}</span>
            <span class="book-detail-pages">{book.pages} {text.bookDetailPages}</span>
          </div>

          {hasRating && (
            <div class="book-rating book-detail-rating" aria-label={ratingSummary}>
              <span class="book-rating-stars" style={`--rating-percent: ${ratingPercent};`} aria-hidden="true"></span>
              <span class="book-rating-copy">{ratingSummary}</span>
            </div>
          )}

          <p class="book-detail-description">{book.description[lang]}</p>

          <div class="book-detail-actions">
            <Button href={book.amazonUrl} label={text.ctaBuyOnAmazon} variant="primary" external />
            <Button
              href={inAppReviewUrl}
              label={text.bookDetailCtaInAppReview}
              variant="ghost"
            />
          </div>
        </div>
      </div>

      <!-- What's Inside -->
      {features.length > 0 && (
        <div class="book-detail-features">
          <h2 class="book-detail-section-title">{text.bookDetailWhatsInside}</h2>
          <ul class="book-features-list">
            {features.map((f) => (
              <li class="book-features-item">
                <span class="book-features-icon" aria-hidden="true">✓</span>
                {f}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Look Inside (IV-H.2 sec 2) — only renders when previewImages exist. -->
      {seo?.previewImages && seo.previewImages.length > 0 && (
        <div class="book-look-inside" aria-labelledby="look-inside-heading">
          <h2 id="look-inside-heading" class="book-detail-section-title">
            {lang === "es" ? "Mira dentro" : "Look Inside"}
          </h2>
          <p class="book-look-inside__subtitle">
            {lang === "es"
              ? "Una muestra de las páginas interiores — el libro tiene más."
              : "A sample of interior pages — the full book has more."}
          </p>
          <ul class="book-look-inside__grid" role="list">
            {seo.previewImages.slice(0, 6).map((src, i) => (
              <li>
                <a
                  href={src}
                  target="_blank"
                  rel="noopener"
                  class="book-look-inside__item"
                  aria-label={lang === "es"
                    ? `Ver página ${i + 1} en tamaño completo`
                    : `View page ${i + 1} full size`}
                >
                  <img
                    src={src}
                    alt={lang === "es"
                      ? `Página ${i + 1} de ${book.title[lang]} (vista previa)`
                      : `Page ${i + 1} of ${book.title[lang]} (preview)`}
                    width="400"
                    height="520"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              </li>
            ))}
          </ul>
          <p class="book-look-inside__note">
            {lang === "es"
              ? "Las páginas muestran marca de agua. El libro impreso viene sin ella."
              : "Previews are watermarked. The printed book does not have the watermark."}
          </p>
        </div>
      )}

      <!-- Perfect for -->
      {perfectFor && (
        <div class="book-detail-perfect">
          <h2 class="book-detail-section-title">{text.bookDetailPerfectFor}</h2>
          <p class="book-detail-perfect-text">{perfectFor}</p>
        </div>
      )}

      <!-- Testimonials (IV-H.2 sec 5) — plain prose, NO Review structured data (IV-H.7). -->
      {seo?.testimonials && seo.testimonials[lang]?.length > 0 && (
        <div class="book-testimonials" aria-labelledby="testimonials-heading">
          <h2 id="testimonials-heading" class="book-detail-section-title">
            {lang === "es" ? "Lo que dicen los lectores" : "What readers say"}
          </h2>
          <ul class="book-testimonials__list" role="list">
            {seo.testimonials[lang].map((q) => (
              <li class="book-testimonial">
                <blockquote>
                  <p>"{q.text}"</p>
                  <footer>— {q.attribution}</footer>
                </blockquote>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Why Little Chubby Press (IV-H.2 sec 6) — fixed bilingual content, renders on all books. -->
      <div class="book-why-lcp" aria-labelledby="why-lcp-heading">
        <h2 id="why-lcp-heading" class="book-detail-section-title">
          {lang === "es" ? "Por qué Little Chubby Press" : "Why Little Chubby Press"}
        </h2>
        <ul class="book-why-lcp__list" role="list">
          <li>
            <strong>{lang === "es" ? "15 libros publicados" : "15 books published"}</strong>
            <span>{lang === "es"
              ? "Editorial independiente enfocada 100 % en coloreado infantil."
              : "Independent publisher focused 100% on kids' coloring books."}</span>
          </li>
          <li>
            <strong>{lang === "es" ? "Sin relleno" : "No filler"}</strong>
            <span>{lang === "es"
              ? "Todas las páginas son a una cara y de alta resolución."
              : "Every page is single-sided and high resolution."}</span>
          </li>
          <li>
            <strong>{lang === "es" ? "Creado por padres" : "Made by parents"}</strong>
            <span>{lang === "es"
              ? "Diseñado pensando en niños reales y en horas reales de pintura."
              : "Designed with real kids and real coloring time in mind."}</span>
          </li>
        </ul>
        <p class="book-why-lcp__cta">
          <a href={`/${lang}/about/`} rel="prefetch">
            {lang === "es" ? "Conoce Little Chubby Press →" : "About Little Chubby Press →"}
          </a>
        </p>
      </div>

      <!-- Try Before You Buy (IV-H.2 sec 7) — deep-link to coloring corner with category filter. -->
      {book.coloringCornerCategory && (
        <div class="book-try-samples" aria-labelledby="try-samples-heading">
          <h2 id="try-samples-heading" class="book-detail-section-title">
            {lang === "es" ? "Prueba antes de comprar" : "Try before you buy"}
          </h2>
          <p class="book-try-samples__lead">
            {lang === "es"
              ? `¿Te gusta el estilo? Obtén 3 muestras gratis en el mismo tema (${book.title.es}).`
              : `Like the style? Grab 3 free coloring pages in the same theme (${book.title.en}).`}
          </p>
          <a
            href={`/${lang}/coloring-corner/?category=${encodeURIComponent(book.coloringCornerCategory)}`}
            class="book-try-samples__cta"
            rel="prefetch"
          >
            {lang === "es" ? "Ver muestras gratis →" : "See free samples →"}
          </a>
        </div>
      )}

      <!-- Gift callout -->
      <div class="book-gift-callout">
        <p class="book-gift-title">{text.bookDetailGiftCallout}</p>
        <p class="book-gift-sub">{text.bookDetailGiftCalloutSub}</p>
        <Button href={book.amazonUrl} label={text.ctaBuyOnAmazon} variant="primary" external />
      </div>

      <!-- FAQ -->
      <div class="book-detail-faq">
        <h2 class="book-detail-section-title">{text.bookDetailFaqTitle}</h2>
        <dl class="book-faq-list">
          {faqEntries.map((f) => (
            <div class="book-faq-item">
              <dt class="book-faq-q">{f.q}</dt>
              <dd class="book-faq-a">{f.a}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Related books -->
      {related.length > 0 && (
        <div class="book-detail-related">
          <h2 class="book-detail-section-title">{text.bookDetailRelatedBooks}</h2>
          <div class="books-tile-grid books-tile-grid--related">
            {related.map((b) => <BookTile book={b} lang={lang} />)}
          </div>
        </div>
      )}

      <!-- Prev / Next book navigation (IV-H.2 sec 11). Order = booksByNewest. -->
      {(prevBook || nextBook) && (
        <nav
          class="book-pager"
          aria-label={lang === "es" ? "Navegación entre libros" : "Book navigation"}
        >
          <div class="book-pager__slot">
            {prevBook && (
              <a
                href={`/${lang}/books/${prevBook.id}/`}
                class="book-pager__link book-pager__link--prev"
                rel="prev"
              >
                <span class="book-pager__label">
                  {lang === "es" ? "← Libro anterior" : "← Previous book"}
                </span>
                <span class="book-pager__title">{prevBook.title[lang]}</span>
              </a>
            )}
          </div>
          <div class="book-pager__slot">
            {nextBook && (
              <a
                href={`/${lang}/books/${nextBook.id}/`}
                class="book-pager__link book-pager__link--next"
                rel="next"
              >
                <span class="book-pager__label">
                  {lang === "es" ? "Siguiente libro →" : "Next book →"}
                </span>
                <span class="book-pager__title">{nextBook.title[lang]}</span>
              </a>
            )}
          </div>
        </nav>
      )}

    </div>
  </section>
</BaseLayout>

<style>
.book-detail-back {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  color: var(--brand-brown);
  font-family: "Baloo 2", "Trebuchet MS", sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  text-decoration: none;
  margin-bottom: 2rem;
  opacity: 0.8;
  transition: opacity 0.2s;
}
.book-detail-back:hover { opacity: 1; }

/* Hero */
.book-detail-hero {
  display: grid;
  gap: 2.5rem;
  align-items: start;
  margin-bottom: 3rem;
}
@media (min-width: 48rem) {
  .book-detail-hero {
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: 3.5rem;
  }
}

.book-detail-cover img {
  width: 100%;
  max-width: 360px;
  height: auto;
  border-radius: var(--radius-md, 1rem);
  box-shadow: 0 8px 32px rgba(71, 52, 33, 0.18);
  display: block;
  margin-inline: auto;
}

.book-detail-title {
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  color: var(--brand-brown);
  margin-bottom: 0.35rem;
  line-height: 1.2;
}
.book-detail-h1-tail {
  display: block;
  font-size: 0.72em;
  font-weight: 600;
  color: var(--ink-soft);
  margin-top: 0.25rem;
  line-height: 1.3;
}
.book-detail-subtitle {
  font-size: 1.05rem;
  color: var(--ink-soft);
  margin-bottom: 0.2rem;
}
.book-detail-byline {
  font-size: 0.88rem;
  color: var(--ink-soft);
  margin-bottom: 1.1rem;
  font-style: italic;
}
.book-detail-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 1rem;
}
.book-detail-pages {
  font-size: 0.85rem;
  color: var(--ink-soft);
  background: var(--bg-paper, #f9f3e8);
  border: 1px solid var(--line, #e2cfad);
  border-radius: 999px;
  padding: 0.28rem 0.75rem;
  font-weight: 600;
}
.book-detail-rating { margin-bottom: 1.1rem; }
.book-detail-description {
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--ink);
  margin-bottom: 1.6rem;
  max-width: 52ch;
}
.book-detail-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
}

/* Shared section heading */
.book-detail-section-title {
  font-size: clamp(1.1rem, 2.8vw, 1.4rem);
  color: var(--brand-brown);
  margin-bottom: 1.1rem;
}

/* What's Inside */
.book-detail-features {
  border-top: 1px dashed var(--line);
  padding-top: 2.2rem;
  margin-bottom: 2.2rem;
}
.book-features-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 0.65rem;
}
@media (min-width: 36rem) {
  .book-features-list { grid-template-columns: 1fr 1fr; }
}
.book-features-item {
  display: flex;
  align-items: flex-start;
  gap: 0.55rem;
  font-size: 0.97rem;
  line-height: 1.5;
  color: var(--ink);
}
.book-features-icon {
  flex-shrink: 0;
  width: 1.25rem;
  height: 1.25rem;
  background: var(--brand-green, #4a7c59);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 800;
  margin-top: 0.1rem;
}

/* Perfect for */
.book-detail-perfect {
  border-top: 1px dashed var(--line);
  padding-top: 2.2rem;
  margin-bottom: 2.2rem;
}
.book-detail-perfect-text {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--ink);
  max-width: 64ch;
}

/* Gift callout */
.book-gift-callout {
  background: color-mix(in srgb, var(--brand-yellow, #f5c842) 18%, var(--bg-paper) 82%);
  border: 1.5px solid color-mix(in srgb, var(--brand-yellow, #f5c842) 50%, transparent);
  border-radius: var(--radius-md, 1rem);
  padding: clamp(1.2rem, 3vw, 2rem);
  text-align: center;
  margin-bottom: 2.5rem;
}
.book-gift-title {
  font-family: "Baloo 2", "Trebuchet MS", sans-serif;
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  font-weight: 800;
  color: var(--brand-brown);
  margin-bottom: 0.4rem;
}
.book-gift-sub {
  font-size: 0.95rem;
  color: var(--ink-soft);
  margin-bottom: 1.1rem;
  max-width: 44ch;
  margin-inline: auto;
}

/* FAQ */
.book-detail-faq {
  border-top: 1px dashed var(--line);
  padding-top: 2.2rem;
  margin-bottom: 2.5rem;
}
.book-faq-list {
  display: grid;
  gap: 1.1rem;
  margin: 0;
}
.book-faq-item {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm, 0.65rem);
  padding: 1rem 1.2rem;
}
.book-faq-q {
  font-family: "Baloo 2", "Trebuchet MS", sans-serif;
  font-size: 0.97rem;
  font-weight: 700;
  color: var(--brand-brown);
  margin-bottom: 0.4rem;
}
.book-faq-a {
  font-size: 0.93rem;
  line-height: 1.65;
  color: var(--ink);
  margin: 0;
}

/* Related books */
.book-detail-related {
  border-top: 1px dashed var(--line);
  padding-top: 2.2rem;
}
.books-tile-grid--related {
  grid-template-columns: repeat(2, 1fr);
}
@media (min-width: 32rem) {
  .books-tile-grid--related { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 52rem) {
  .books-tile-grid--related { grid-template-columns: repeat(4, 1fr); }
}

/* ── Look Inside (IV-H.2 sec 2) ────────────────────────────────────── */
.book-look-inside {
  margin: 2.5rem 0;
}
.book-look-inside__subtitle,
.book-look-inside__note {
  color: var(--ink-soft, #6b6258);
  font-size: 0.92rem;
  margin: 0.4rem 0 1rem;
}
.book-look-inside__note {
  margin-top: 1rem;
  font-style: italic;
}
.book-look-inside__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
  gap: 0.85rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
.book-look-inside__item {
  display: block;
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 8px rgba(71, 52, 33, 0.08);
  transition: transform 0.18s ease;
}
.book-look-inside__item:hover {
  transform: translateY(-2px);
}
.book-look-inside__item img {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 10 / 13;
  object-fit: cover;
}
@media (prefers-reduced-motion: reduce) {
  .book-look-inside__item { transition: none; }
  .book-look-inside__item:hover { transform: none; }
}

/* ── Testimonials (IV-H.2 sec 5) ───────────────────────────────────── */
.book-testimonials {
  margin: 2.5rem 0;
