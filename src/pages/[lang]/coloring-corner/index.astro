---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Button from "../../../components/Button.astro";
import { languages, getLangFromParam, ui } from "../../../data/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/coloring-corner/`;
const breadcrumbs = [
  { name: lang === "es" ? "Inicio" : "Home", url: `/${lang}/` },
  { name: text.coloringCornerHeading, url: pathname }
];

const artworkCategories = [
  { value: "all", label: text.blogFilterAll },
  { value: "animal-nature", label: lang === "es" ? "Animales y Naturaleza" : "Animals & Nature" },
  { value: "space", label: lang === "es" ? "Espacio" : "Space" },
  { value: "basic", label: lang === "es" ? "Elementos Basicos" : "Basic Elements" },
  { value: "dinosaur", label: lang === "es" ? "Dinosaurios" : "Dinosaurs" },
  { value: "food-drink", label: lang === "es" ? "Comida y Bebida" : "Food & Drinks" },
  { value: "jobs", label: lang === "es" ? "Profesiones" : "Jobs" },
  { value: "kids-favorites", label: lang === "es" ? "Favoritos de los Peques" : "Kids Favorites" },
  { value: "machines", label: lang === "es" ? "Maquinas" : "Machines" },
  { value: "mini-scenes", label: lang === "es" ? "Mini Escenas" : "Mini Scenes" },
];
---

<BaseLayout lang={lang} title={text.coloringCornerMetaTitle} description={text.coloringCornerMetaDescription} pathname={pathname} breadcrumbs={breadcrumbs}>
  <section class="page-section">
    <div class="container">
      <div class="coloring-corner-hero">
        <h1>🎨 {text.coloringCornerHeading}</h1>
        <p>{text.coloringCornerDescription}</p>
      </div>

      <!-- Peanuts banner (shown for logged-in users) -->
      <div id="cc-points-banner" class="cc-points-banner" style="display:none;">
        <div class="cc-points-inner">
          <span class="cc-points-icon">🥜</span>
          <span class="cc-points-label">{lang === "es" ? "Tus Peanuts:" : "Your Peanuts:"}</span>
          <span id="cc-points-value" class="cc-points-value">0</span>
        </div>
        <p class="cc-points-hint">{lang === "es"
          ? "Gana Peanuts compartiendo (+1, máx 3/día). Usa Peanuts para descargar láminas y comprar tickets extra para el sorteo."
          : "Earn Peanuts by sharing (+1, max 3/day). Use Peanuts to download pages and buy extra giveaway tickets."}</p>
      </div>

      <!-- Category filters -->
      <div class="blog-filters" role="group" aria-label={lang === "es" ? "Filtrar por categoria" : "Filter by category"}>
        {artworkCategories.map((cat) => (
          <button
            class:list={["blog-filter-btn", { active: cat.value === "all" }]}
            data-artwork-category={cat.value}
            type="button"
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Artwork grid (populated client-side from Supabase) -->
      <div id="cc-grid" class="artwork-grid">
        <p id="cc-loading" style="text-align:center; grid-column: 1/-1; color: var(--ink-soft);">
          {lang === "es" ? "Cargando imagenes..." : "Loading images..."}
        </p>
      </div>

      <!-- Empty state -->
      <p id="cc-empty" class="blog-empty-msg" style="display:none;">
        {lang === "es" ? "Aun no hay imagenes en esta categoria. ¡Pronto anadiremos mas!" : "No images in this category yet. More coming soon!"}
      </p>

      <!-- CTA for non-logged-in users -->
      <div id="cc-cta-login" class="coloring-corner-cta" style="display:none;">
        <h2>{lang === "es" ? "¡Crea tu cuenta gratis!" : "Create your free account!"}</h2>
        <p>{lang === "es" ? "Inicia sesión para ganar Peanuts 🥜, descargar imágenes y participar en giveaways." : "Log in to earn Peanuts 🥜, download images, and enter giveaways."}</p>
        <div class="card-actions" style="justify-content:center;">
          <Button href={`/${lang}/login/`} label={text.navLogin} variant="primary" />
          <Button href={`/${lang}/register/`} label={lang === "es" ? "Crear cuenta" : "Create account"} variant="ghost" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
function initColoringCorner() {
  var grid = document.getElementById("cc-grid");
  var loading = document.getElementById("cc-loading");
  var emptyMsg = document.getElementById("cc-empty");
  var pointsBanner = document.getElementById("cc-points-banner");
  var pointsValue = document.getElementById("cc-points-value");
  var ctaLogin = document.getElementById("cc-cta-login");
  if (!grid) return;

  var sb = document.querySelector("meta[name='x-sb-url']");
  var sk = document.querySelector("meta[name='x-sb-key']");
  if (!sb || !sk) { if (loading) loading.textContent = "Configuration error"; return; }
  var supabaseUrl = sb.getAttribute("content");
  var supabaseKey = sk.getAttribute("content");

  var isLoggedIn = document.cookie.indexOf("sb-logged-in=") !== -1;
  var lang = document.documentElement.getAttribute("lang") || "en";
  var allArtworks = [];
  var userBalance = 0;
  var userId = "";

  // Show login CTA if not logged in
  if (!isLoggedIn && ctaLogin) ctaLogin.style.display = "";

  // Fetch artworks
  fetch(supabaseUrl + "/rest/v1/free_artworks?select=id,title_es,title_en,category,image_path,thumbnail_path,active,sort_order&active=eq.true&order=sort_order.asc,created_at.desc", {
    headers: { "apikey": supabaseKey, "Authorization": "Bearer " + supabaseKey }
  })
  .then(function(r) { return r.json(); })
  .then(function(artworks) {
    if (loading) loading.style.display = "none";
    allArtworks = artworks || [];
    if (allArtworks.length === 0) {
      if (emptyMsg) emptyMsg.style.display = "";
      return;
    }
    renderArtworks(allArtworks);
    // Deep-link support (P3-14 — IV-H.2 sec 7): if URL has ?category=<slug>,
    // pre-apply that filter by simulating a click on the matching filter button.
    try {
      var urlParams = new URLSearchParams(window.location.search);
      var deepCat = urlParams.get("category");
      if (deepCat) {
        var sel = '[data-artwork-category="' + (window.CSS && CSS.escape ? CSS.escape(deepCat) : deepCat) + '"]';
        var deepBtn = document.querySelector(sel);
        if (deepBtn && typeof deepBtn.click === "function") {
          deepBtn.click();
          var galleryEl = document.querySelector(".blog-filters");
          if (galleryEl && galleryEl.scrollIntoView) {
            galleryEl.scrollIntoView({ behavior: "auto", block: "start" });
          }
        }
      }
    } catch (e) { /* deep-link is non-critical; ignore failures */ }
    // If logged in, fetch user info from server-side API (httpOnly cookies)
    if (isLoggedIn) fetchUserInfo();
  })
  .catch(function() {
    if (loading) loading.textContent = lang === "es" ? "Error al cargar." : "Failed to load.";
  });

  // Fetch user ID + balance via server-side API (reads httpOnly auth cookies)
  function fetchUserInfo() {
    fetch("/api/me/", { credentials: "same-origin" })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.user && data.user.id) {
        userId = data.user.id;
        userBalance = data.balance || 0;
        updatePointsDisplay();
      }
    })
    .catch(function() {});
  }

  function updatePointsDisplay() {
    if (pointsBanner && pointsValue) {
      pointsValue.textContent = userBalance;
      pointsBanner.style.display = "";
    }
    // Sync header peanuts badge
    var headerCount = document.getElementById("peanuts-count");
    if (headerCount) {
      headerCount.textContent = String(userBalance);
      sessionStorage.setItem("lcp-peanuts", String(userBalance));
    }
  }

  // SVG icons as strings
  var svgWhatsApp = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>';
  var svgFacebook = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>';
  var svgBluesky = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.643 3.593 3.519 6.173 3.175-.375.52-1.611 1.753-.875 3.613C7.182 20.756 12 18.906 12 18.906s4.818 1.85 6.078-1.871c.736-1.86-.5-3.093-.875-3.613 2.58.344 5.388-.532 6.173-3.175C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.86-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.747 13.087 8.686 12 10.8"/></svg>';
  var svgCopyLink = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';

  function renderArtworks(artworks) {
    grid.innerHTML = "";
    artworks.forEach(function(art) {
      var title = lang === "es" ? art.title_es : art.title_en;
      if (!title) title = lang === "es" ? art.title_en : art.title_es;

      var card = document.createElement("div");
      card.className = "artwork-card";
      card.setAttribute("data-artwork-cat", art.category);

      var thumbSrc = art.thumbnail_path
        ? supabaseUrl + "/storage/v1/object/public/free-artworks/" + art.thumbnail_path
        : supabaseUrl + "/storage/v1/object/public/free-artworks/" + art.image_path;

      var shareRow = isLoggedIn
        ? '<div class="artwork-share-row">' +
            '<a class="artwork-share-btn share-wa" data-platform="whatsapp" data-artwork-id="' + art.id + '" data-artwork-title="' + (title || "Coloring page").replace(/"/g, "&quot;") + '" title="WhatsApp">' + svgWhatsApp + '</a>' +
            '<a class="artwork-share-btn share-fb" data-platform="facebook" data-artwork-id="' + art.id + '" data-artwork-title="' + (title || "Coloring page").replace(/"/g, "&quot;") + '" title="Facebook">' + svgFacebook + '</a>' +
            '<a class="artwork-share-btn share-bs" data-platform="bluesky" data-artwork-id="' + art.id + '" data-artwork-title="' + (title || "Coloring page").replace(/"/g, "&quot;") + '" title="Bluesky">' + svgBluesky + '</a>' +
            '<button class="artwork-share-btn share-cl" data-platform="copy-link" data-artwork-id="' + art.id + '" data-artwork-title="' + (title || "Coloring page").replace(/"/g, "&quot;") + '" title="' + (lang === "es" ? "Copiar enlace" : "Copy link") + '">' + svgCopyLink + '</button>' +
          '</div>' +
          '<button class="artwork-claim-btn" data-artwork-id="' + art.id + '" style="display:none;">🥜 ' + (lang === "es" ? "¡Reclamar Peanut!" : "Claim Peanut!") + '</button>'
        : '';

      var artworkDetailUrl = '/' + lang + '/coloring-corner/' + art.id + '/';

      card.innerHTML =
        '<a href="' + artworkDetailUrl + '" class="artwork-img-wrap">' +
          '<img src="' + thumbSrc + '" alt="' + (title || "Coloring page").replace(/"/g, "&quot;") + '" loading="lazy" width="512" height="512" />' +
        '</a>' +
        '<div class="artwork-card-body">' +
          '<h3>' + (title || "Coloring page") + '</h3>' +
          '<button class="artwork-download-btn" data-artwork-id="' + art.id + '" data-image-path="' + art.image_path + '">' +
            '<span class="dl-icon">⬇</span> ' +
            (lang === "es" ? "Descargar" : "Download") +
            ' <span class="dl-cost">(-1 🥜)</span>' +
          '</button>' +
          shareRow +
        '</div>';

      grid.appendChild(card);
    });

    // Download button handlers
    grid.querySelectorAll(".artwork-download-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        if (!isLoggedIn) {
          if (ctaLogin) { ctaLogin.style.display = ""; ctaLogin.scrollIntoView({ behavior: "smooth" }); }
          return;
        }
        handleDownload(btn);
      });
    });

    // Share button handlers — open share dialog with per-image URL
    grid.querySelectorAll(".artwork-share-btn").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.preventDefault();
        var platform = btn.getAttribute("data-platform");
        var artId = btn.getAttribute("data-artwork-id");
        var artTitle = btn.getAttribute("data-artwork-title");
        handleShare(platform, artId, artTitle, btn);
      });
    });

    // Claim buttons
    grid.querySelectorAll(".artwork-claim-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        handleClaim(btn);
      });
    });
  }

  function handleDownload(btn) {
    if (!userId) return;
    var artworkId = btn.getAttribute("data-artwork-id");
    var imagePath = btn.getAttribute("data-image-path");

    btn.disabled = true;
    var origHTML = btn.innerHTML;
    btn.textContent = "...";

    // Server-side credit check + download via API
    fetch("/api/download-artwork/", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify({ artwork_id: artworkId, image_path: imagePath })
    })
    .then(function(res) { return res.json().then(function(d) { return { status: res.status, data: d }; }); })
    .then(function(result) {
      if (result.status === 403 && result.data.error === "no_credits") {
        btn.innerHTML = lang === "es" ? "🥜 Sin Peanuts" : "🥜 No Peanuts";
        setTimeout(function() { btn.innerHTML = origHTML; btn.disabled = false; }, 2500);
        return;
      }
      if (result.status !== 200 || !result.data.ok) {
        btn.textContent = "Error";
        setTimeout(function() { btn.innerHTML = origHTML; btn.disabled = false; }, 2000);
        return;
      }

      // Download as blob to force actual file save (signed URLs are cross-origin)
      fetch(result.data.signedUrl)
        .then(function(r) { return r.blob(); })
        .then(function(blob) {
          var url = URL.createObjectURL(blob);
          var a = document.createElement("a");
          a.href = url;
          a.download = imagePath.split("/").pop() || "coloring-page.png";
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        });

      // Update balance
      userBalance = result.data.balance;
      updatePointsDisplay();

      btn.innerHTML = "✅ " + (lang === "es" ? "Descargado" : "Downloaded");
      setTimeout(function() { btn.innerHTML = origHTML; btn.disabled = false; }, 2000);
    })
    .catch(function() {
      btn.textContent = "Error";
      setTimeout(function() { btn.innerHTML = origHTML; btn.disabled = false; }, 2000);
    });
  }

  function handleShare(platform, artId, artTitle, btn) {
    // Build per-artwork share URL
    var origin = window.location.origin;
    var artworkUrl = origin + "/" + lang + "/coloring-corner/" + artId + "/";
    var shareText = lang === "es"
      ? '🎨 ¡Mira qué lindo! "' + artTitle + '" — página para colorear gratis. ¡Descarga la tuya en Little Chubby Press! 🐘 '
      : '🎨 Look what I found! "' + artTitle + '" — a free coloring page so cute! Download yours at Little Chubby Press 🐘 ';

    // Open share target
    if (platform === "whatsapp") {
      window.open("https://wa.me/?text=" + encodeURIComponent(shareText + artworkUrl), "_blank");
    } else if (platform === "facebook") {
      window.open("https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent(artworkUrl) + "&quote=" + encodeURIComponent(shareText), "_blank", "width=600,height=400");
    } else if (platform === "bluesky") {
      window.open("https://bsky.app/intent/compose?text=" + encodeURIComponent(shareText + artworkUrl), "_blank");
    } else if (platform === "copy-link") {
      if (navigator.clipboard) {
        navigator.clipboard.writeText(artworkUrl);
      } else {
        var ta = document.createElement("textarea"); ta.value = artworkUrl;
        document.body.appendChild(ta); ta.select(); document.execCommand("copy"); document.body.removeChild(ta);
      }
      var origHTML = btn.innerHTML;
      btn.innerHTML = '✓';
      setTimeout(function() { btn.innerHTML = origHTML; }, 1500);
    }

    // Show claim button for this card (don't auto-grant)
    if (userId) {
      var card = btn.closest(".artwork-card");
      if (card) {
        var claimBtn = card.querySelector(".artwork-claim-btn");
        if (claimBtn) {
          claimBtn.setAttribute("data-platform", platform);
          claimBtn.setAttribute("data-shared-url", artworkUrl);
          claimBtn.style.display = "";
          claimBtn.classList.add("artwork-claim-btn--pulse");
        }
      }
    }
  }

  function handleClaim(btn) {
    if (!userId) return;
    var platform = btn.getAttribute("data-platform");
    var sharedUrl = btn.getAttribute("data-shared-url");
    if (!platform || !sharedUrl) return;

    btn.disabled = true;
    var origHTML = btn.innerHTML;
    btn.textContent = "...";

    fetch("/api/track-share/", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify({ platform: platform, shared_url: sharedUrl })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.credited) {
        userBalance = data.balance;
        updatePointsDisplay();
        btn.innerHTML = '<span style="color:var(--brand-green)">✅ +1 🥜</span>';
        btn.classList.remove("artwork-claim-btn--pulse");
      } else if (data.duplicate) {
        btn.textContent = lang === "es" ? "Ya reclamado" : "Already claimed";
      } else {
        btn.textContent = lang === "es" ? "Máx diario" : "Daily max";
      }
      setTimeout(function() { btn.style.display = "none"; btn.innerHTML = origHTML; btn.disabled = false; }, 3000);
    })
    .catch(function() {
      btn.textContent = "Error";
      setTimeout(function() { btn.style.display = "none"; btn.innerHTML = origHTML; btn.disabled = false; }, 2000);
    });
  }

  // Category filter
  var filterBtns = document.querySelectorAll("[data-artwork-category]");
  filterBtns.forEach(function(btn) {
    btn.addEventListener("click", function() {
      filterBtns.forEach(function(b) { b.classList.remove("active"); });
      btn.classList.add("active");
      var cat = btn.getAttribute("data-artwork-category");
      var filtered = cat === "all"
        ? allArtworks
        : allArtworks.filter(function(a) { return a.category === cat; });
      renderArtworks(filtered);
      if (emptyMsg) emptyMsg.style.display = filtered.length === 0 ? "" : "none";
    });
  });

  // Sticky shadow — reads --header-h at check time so it stays
  // accurate when the smart header collapses/expands.
  var filtersEl = document.querySelector(".blog-filters");
  if (filtersEl) {
    if (filtersEl._stuckCleanup) filtersEl._stuckCleanup();
    function checkCCStuck() {
      var headerH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue("--header-h")) || 0;
      var top = filtersEl.getBoundingClientRect().top;
      filtersEl.classList.toggle("stuck", Math.abs(top - headerH) < 2);
    }
    window.addEventListener("scroll", checkCCStuck, { passive: true });
    window.addEventListener("lcp:header-resize", checkCCStuck);
    checkCCStuck();
    filtersEl._stuckCleanup = function() {
      window.removeEventListener("scroll", checkCCStuck);
      window.removeEventListener("lcp:header-resize", checkCCStuck);
    };
  }
}

initColoringCorner();
document.addEventListener("astro:after-swap", initColoringCorner);
</script>
