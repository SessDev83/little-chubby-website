---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import { languages, getLangFromParam, ui } from "../../data/i18n";
import { siteConfig, hasSupportLinks } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/about/`;

const pageTitle = lang === "es"
  ? "Sobre nosotros | Little Chubby Press"
  : "About us | Little Chubby Press";
const pageDescription = lang === "es"
  ? "Conoce a Little Chubby Press: nuestra historia, misión y por qué creamos libros de colorear para familias."
  : "Meet Little Chubby Press: our story, mission, and why we create coloring books for families.";
---

<BaseLayout lang={lang} title={pageTitle} description={pageDescription} pathname={pathname}>
  <section class="page-section">
    <div class="container">
      <article class="surface-card" style="padding: clamp(1.2rem, 3vw, 2.2rem);">
        <h1>{lang === "es" ? "Sobre Little Chubby Press" : "About Little Chubby Press"}</h1>

        <div style="display: flex; align-items: center; gap: 1.2rem; margin: 1.5rem 0;">
          <img
            src={siteConfig.brandAssets.logoMark}
            alt={siteConfig.brandName}
            width="80"
            height="80"
            style="border-radius: var(--radius-md);"
          />
          <div>
            <p style="font-family: 'Baloo 2', sans-serif; font-weight: 700; font-size: 1.2rem; color: var(--brand-brown); margin: 0;">
              {siteConfig.brandName}
            </p>
            <p style="margin: 0; color: var(--ink-soft); font-size: 0.95rem;">
              {siteConfig.tagline[lang]}
            </p>
          </div>
        </div>

        {lang === "es" ? (
          <div class="article-prose">
            <h2>Nuestra misión</h2>
            <p>En Little Chubby Press creemos que la creatividad empieza en la infancia. Publicamos libros de colorear diseñados para que las familias compartan momentos de calidad lejos de las pantallas.</p>
            <p>Cada libro nace de una idea simple: que colorear sea fácil de empezar, divertido de completar y significativo de compartir. Nuestras ilustraciones son amigables, nuestros temas diversos y nuestros diseños pensados para todas las edades.</p>

            <h2>¿Qué nos hace diferentes?</h2>
            <ul>
              <li><strong>Diseño de una sola cara</strong> — para que los peques puedan arrancar y exhibir sus obras favoritas.</li>
              <li><strong>Temas variados</strong> — desde criaturas mágicas hasta moda, espacio, emociones y aventuras culinarias.</li>
              <li><strong>Para toda la familia</strong> — libros para peques de 4-8 años, adolescentes y adultos creativos.</li>
              <li><strong>Calidad profesional</strong> — papel grueso, trazos claros e impresos bajo demanda en Amazon.</li>
            </ul>

            <h2>Nuestro compromiso</h2>
            <p>Cada libro que publicamos pasa por un proceso cuidadoso de diseño, pruebas con familias reales y ajustes de calidad. No somos una fábrica de contenido: somos una editorial pequeña con corazón grande.</p>
            <p>Queremos que cada página coloreada sea un recuerdo feliz.</p>
          </div>
        ) : (
          <div class="article-prose">
            <h2>Our mission</h2>
            <p>At Little Chubby Press, we believe creativity starts in childhood. We publish coloring books designed for families to share quality time away from screens.</p>
            <p>Every book starts with a simple idea: make coloring easy to begin, fun to finish, and meaningful to share. Our illustrations are friendly, our themes diverse, and our designs made for all ages.</p>

            <h2>What makes us different?</h2>
            <ul>
              <li><strong>Single-sided pages</strong> — so kids can tear out and display their favorite artwork.</li>
              <li><strong>Diverse themes</strong> — from magical creatures to fashion, space, emotions, and food adventures.</li>
              <li><strong>For the whole family</strong> — books for kids ages 4-8, teens, and creative adults.</li>
              <li><strong>Professional quality</strong> — thick paper, clean lines, and printed on demand through Amazon.</li>
            </ul>

            <h2>Our commitment</h2>
            <p>Every book we publish goes through careful design, real family testing, and quality adjustments. We are not a content factory — we are a small press with a big heart.</p>
            <p>We want every colored page to become a happy memory.</p>
          </div>
        )}

        <div class="hero-actions" style="margin-top: 1.8rem;">
          <Button href={`/${lang}/books/`} label={text.ctaViewAllBooks} variant="primary" />
          <Button href={`/${lang}/contact/`} label={text.navContact} variant="secondary" />
        </div>
      </article>
      {hasSupportLinks && (
        <section id="support" class="about-support" aria-labelledby="support-heading">
          <h2 id="support-heading">
            {lang === "es" ? "Apoya el proyecto" : "Support the project"}
          </h2>
          <p>
            {lang === "es"
              ? "Little Chubby Press es un proyecto independiente y gratuito. Si el contenido te resulta útil y quieres ayudarnos a cubrir los costos de hosting, sorteos y nuevas páginas para colorear, puedes hacerlo con una contribución voluntaria:"
              : "Little Chubby Press is an independent, free project. If you find the content useful and want to help us cover hosting costs, giveaways, and new coloring pages, you can chip in with a voluntary contribution:"}
          </p>
          <div class="about-support__buttons">
            {siteConfig.support.buyMeACoffee && (
              <Button
                href={siteConfig.support.buyMeACoffee}
                label="☕ Buy Me a Coffee"
                variant="primary"
                external
              />
            )}
            {siteConfig.support.kofi && (
              <Button
                href={siteConfig.support.kofi}
                label="🧋 Ko-fi"
                variant="secondary"
                external
              />
            )}
          </div>
          <div class="about-support__disclosure">
            <h3>{lang === "es" ? "Qué no cambia con una donación" : "What a donation does NOT change"}</h3>
            <ul>
              <li>{lang === "es"
                ? "No otorga tickets de sorteo ni 🥜 peanuts extra."
                : "It does not grant giveaway tickets or extra 🥜 peanuts."}</li>
              <li>{lang === "es"
                ? "No da ventaja en reviews, gallery ni ranking."
                : "It gives no advantage in reviews, gallery, or ranking."}</li>
              <li>{lang === "es"
                ? "Todo el contenido sigue siendo gratis para todos — con o sin donación."
                : "All content remains free for everyone — with or without a donation."}</li>
            </ul>
            <p class="about-support__note">
              {lang === "es"
                ? "Los pagos son procesados por la plataforma externa (Buy Me a Coffee / Ko-fi). Little Chubby Press no recibe ni almacena datos de tarjeta."
                : "Payments are processed by the external platform (Buy Me a Coffee / Ko-fi). Little Chubby Press never receives or stores card details."}
            </p>
          </div>
        </section>
      )}
    </div>
  </section>
</BaseLayout>

<style>
.about-support {
  margin: 3rem 0 1rem;
  padding: 2rem;
  background: var(--bg-paper, #fffaf2);
  border-radius: 14px;
}
.about-support__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin: 1rem 0 1.5rem;
}
.about-support__disclosure {
  border-top: 1px solid var(--line, #e8e0d3);
  padding-top: 1rem;
  margin-top: 1rem;
}
.about-support__disclosure h3 {
  font-size: 1rem;
  margin: 0 0 0.5rem;
  color: var(--ink-soft, #6b6258);
}
.about-support__disclosure ul {
  margin: 0 0 0.8rem;
  padding-left: 1.2rem;
}
.about-support__disclosure li {
  margin-bottom: 0.3rem;
}
.about-support__note {
  font-size: 0.88rem;
  color: var(--ink-soft, #6b6258);
  font-style: italic;
  margin: 0;
}
</style>
