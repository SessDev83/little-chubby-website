---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase, getServiceClient } from "../../lib/supabase";
import { books } from "../../data/books";
import { notifyNewReview, notifyReviewUpdated } from "../../lib/notifications";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/reviews/`;

// ── Auth ─────────────────────────────────────────────
const user = Astro.locals.user;
const sc = getServiceClient();

// ── User state ───────────────────────────────────────
let myReviews: { id: string; book_id: string; photo_url: string; extra_photos?: string[]; rating: number; review_text: string; status: string; submitted_at: string; reviewer_note?: string }[] = [];
let shareMsg = "";
let shareMsgType: "success" | "error" | "" = "";

if (user) {
  const { data: reviewData } = await supabase
    .from("book_reviews")
    .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
    .eq("user_id", user.id)
    .order("submitted_at", { ascending: false });
  myReviews = reviewData ?? [];

  // ── Handle POST actions ──────────────────────────
  if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "delete_review") {
      const reviewId = formData.get("review_id")?.toString();
      if (reviewId) {
        const toDelete = myReviews.find(r => r.id === reviewId);
        if (toDelete) {
          const photoPath = `${user.id}/${toDelete.book_id}.jpg`;
          await sc.storage.from("book-photos").remove([photoPath]);
          await sc.from("book_reviews").delete().eq("id", reviewId).eq("user_id", user.id);
          const { data: refreshed } = await supabase
            .from("book_reviews")
            .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
            .eq("user_id", user.id)
            .order("submitted_at", { ascending: false });
          myReviews = refreshed ?? [];
          shareMsg = lang === "es" ? "Review eliminada." : "Review deleted.";
          shareMsgType = "success";
        }
      }
    }

    if (action === "share_book") {
      const bookId = formData.get("book_id")?.toString() || "";
      const rating = parseInt(formData.get("rating")?.toString() || "0", 10);
      const reviewText = formData.get("review_text")?.toString().trim() || "";
      const photos = formData.getAll("photos") as File[];
      const editId = formData.get("edit_id")?.toString() || "";

      const MAX_BYTES = 500 * 1024;
      const MAX_PHOTOS = 5;
      const ALLOWED_TYPES = ["image/jpeg", "image/png", "image/webp", "image/heic", "image/heif"];

      const validPhotos = photos.filter(f => f && f.size > 0);
      const tooLarge = validPhotos.some(f => f.size > MAX_BYTES);
      const badType = validPhotos.some(f => !ALLOWED_TYPES.includes(f.type));

      if (tooLarge) {
        shareMsg = text.shareTooLarge;
        shareMsgType = "error";
      } else if (badType) {
        shareMsg = text.shareInvalidType;
        shareMsgType = "error";
      } else if (validPhotos.length > MAX_PHOTOS) {
        shareMsg = text.shareTooLarge;
        shareMsgType = "error";
      } else if (!bookId || rating < 1 || rating > 5) {
        shareMsg = text.loginError;
        shareMsgType = "error";
      } else {
        let photoUrl = "";
        let extraPhotos: string[] = [];

        if (validPhotos.length > 0) {
          for (let i = 0; i < validPhotos.length; i++) {
            const suffix = i === 0 ? "" : `_${i + 1}`;
            const filePath = `${user.id}/${bookId}${suffix}.jpg`;
            const arrayBuf = await validPhotos[i].arrayBuffer();
            const buffer = new Uint8Array(arrayBuf);
            const { error: uploadError } = await sc.storage
              .from("book-photos")
              .upload(filePath, buffer, { contentType: "image/jpeg", upsert: true });
            if (uploadError) {
              shareMsg = text.loginError;
              shareMsgType = "error";
              break;
            }
            const { data: urlData } = sc.storage.from("book-photos").getPublicUrl(filePath);
            if (i === 0) {
              photoUrl = urlData.publicUrl;
            } else {
              extraPhotos.push(urlData.publicUrl);
            }
          }
        }

        if (shareMsgType !== "error") {
          if (editId) {
            const photosChanged = validPhotos.length > 0;
            const updateData: any = {
              rating,
              review_text: reviewText,
              show_in_gallery: formData.get("show_in_gallery") === "on",
            };
            if (photosChanged) {
              updateData.status = "pending";
              updateData.reviewed_at = null;
              updateData.reviewer_note = null;
            }
            if (photoUrl) updateData.photo_url = photoUrl;
            if (extraPhotos.length > 0) updateData.extra_photos = extraPhotos;

            const { error: updateError } = await sc
              .from("book_reviews")
              .update(updateData)
              .eq("id", editId)
              .eq("user_id", user.id);

            if (updateError) {
              shareMsg = text.loginError;
              shareMsgType = "error";
            } else {
              shareMsg = text.shareSuccess;
              shareMsgType = "success";
              const bTitle = books.find(b => b.id === bookId)?.title[lang] || bookId;
              notifyReviewUpdated(user.email || "unknown", bTitle, rating).catch(() => {});
            }
          } else {
            if (!photoUrl) {
              shareMsg = text.shareInvalidType;
              shareMsgType = "error";
            } else {
              const { error: insertError } = await sc
                .from("book_reviews")
                .insert({
                  user_id: user.id,
                  book_id: bookId,
                  photo_url: photoUrl,
                  extra_photos: extraPhotos,
                  rating,
                  review_text: reviewText,
                  show_in_gallery: formData.get("show_in_gallery") === "on",
                });

              if (insertError?.code === "23505") {
                shareMsg = text.shareAlreadyReviewed;
                shareMsgType = "error";
              } else if (insertError) {
                shareMsg = text.loginError;
                shareMsgType = "error";
              } else {
                shareMsg = text.shareSuccess;
                shareMsgType = "success";
                const bTitle = books.find(b => b.id === bookId)?.title[lang] || bookId;
                notifyNewReview(user.email || "unknown", bTitle, rating, reviewText).catch(() => {});
              }
            }
          }

          const { data: refreshed } = await supabase
            .from("book_reviews")
            .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
            .eq("user_id", user.id)
            .order("submitted_at", { ascending: false });
          myReviews = refreshed ?? [];
        }
      }
    }
  }
}

// Books already reviewed (to exclude from dropdown)
const reviewedBookIds = new Set(myReviews.map(r => r.book_id));
const bookOptions = books.map(b => ({ id: b.id, title: b.title[lang] }));
const availableBooks = bookOptions.filter(b => !reviewedBookIds.has(b.id));
const bookMap = Object.fromEntries(bookOptions.map(b => [b.id, b.title]));
const stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);

// Approved reviews earn 5 peanuts each
const approvedCount = myReviews.filter(r => r.status === "approved").length;
---

<BaseLayout
  lang={lang}
  title={text.reviewsMetaTitle}
  description={text.reviewsDescription}
  pathname={pathname}
  breadcrumbs={[
    { name: text.navHome, url: `/${lang}/` },
    { name: text.reviewsHeading, url: pathname }
  ]}
>
  <section class="page-section container">
    <div class="section-head" style="text-align:center; max-width:42rem; margin:0 auto 2rem;">
      <h1>{text.reviewsHeading}</h1>
      <p>{text.reviewsDescription}</p>
    </div>

    {!user ? (
      <div class="surface-card" style="max-width:28rem; margin:0 auto; padding:2rem 1.6rem; text-align:center;">
        <p>{text.lotteryNotLoggedIn}</p>
        <a href={`/${lang}/login/`} class="btn btn-primary">{text.navLogin}</a>
      </div>
    ) : (
      <div style="max-width:42rem; margin:0 auto;">

        {/* ── Peanuts earned info ── */}
        {approvedCount > 0 && (
          <div class="surface-card peanuts-info" style="padding:1rem 1.4rem; margin-bottom:1.5rem; text-align:center;">
            <p>🥜 {approvedCount} {approvedCount === 1
              ? (lang === "es" ? "review aprobada" : "approved review")
              : (lang === "es" ? "reviews aprobadas" : "approved reviews")} = <strong>{approvedCount * 5} 🥜</strong> {lang === "es" ? "ganados" : "earned"}</p>
            <a href={`/${lang}/peanuts/`} class="btn-small" style="color:var(--accent-gold);">{text.peanutShopTitle} →</a>
          </div>
        )}

        {/* ── Review editing note ── */}
        <div class="surface-card edit-info" style="padding:0.8rem 1.2rem; margin-bottom:1.2rem; font-size:0.88rem; color:var(--ink-soft);">
          <p style="margin:0;">✏️ {text.reviewsEditKeepsApproval}</p>
          <p style="margin:0.3rem 0 0;">📸 {text.reviewsEditResetsPhotos}</p>
        </div>

        {/* ── Share Your Book Form ── */}
        {availableBooks.length > 0 && (
          <div class="surface-card" style="padding:1.6rem; margin-bottom:1.5rem;">
            <h2 style="margin-bottom:1rem;">📸 {text.shareYourBook}</h2>

            {shareMsg && (
              <p class={`msg ${shareMsgType === "success" ? "msg-success" : "msg-error"}`}>{shareMsg}</p>
            )}

            <form method="POST" enctype="multipart/form-data" class="form-grid" id="shareForm">
              <input type="hidden" name="action" value="share_book" />
              <input type="hidden" name="edit_id" id="editId" value="" />

              <div class="form-group">
                <label for="bookSearch">{text.shareBookLabel}</label>
                <input type="hidden" id="book_id" name="book_id" value="" required />
                <div class="book-combo" id="bookCombo">
                  <input
                    type="text"
                    id="bookSearch"
                    class="book-search-input"
                    placeholder={text.shareBookSearch}
                    autocomplete="off"
                    required
                  />
                  <ul class="book-dropdown" id="bookDropdown" role="listbox">
                    {availableBooks.map(b => (
                      <li class="book-option" role="option" data-value={b.id}>{b.title}</li>
                    ))}
                  </ul>
                </div>
              </div>

              {/* ── Drag & drop photo zone ── */}
              <div class="form-group">
                <label>{text.sharePhotoLabel}</label>
                <div class="photo-dropzone" id="photoDropzone">
                  <div class="dropzone-content">
                    <span class="dropzone-icon">📷</span>
                    <p class="dropzone-text">{text.reviewsPhotoDropzone}</p>
                    <small class="dropzone-hint">{text.sharePhotoHint}</small>
                  </div>
                  <input
                    type="file"
                    id="photos"
                    name="photos"
                    accept="image/*"
                    multiple
                    required
                    class="dropzone-input"
                  />
                </div>
                <div id="photoPreview" class="photo-preview"></div>
                <small id="photoCount" class="photo-count" style="display:none;"></small>
                <small id="photoStatus" class="photo-status" style="display:none;"></small>
              </div>

              <div class="form-group">
                <label>{text.shareRatingLabel}</label>
                <div class="star-picker" id="starPicker">
                  {[1, 2, 3, 4, 5].map(n => (
                    <button type="button" class="star-btn" data-value={n.toString()} aria-label={`${n} star${n > 1 ? "s" : ""}`}>
                      <span class="star-icon">★</span>
                    </button>
                  ))}
                </div>
                <input type="hidden" name="rating" id="ratingInput" value="" required />
              </div>

              <div class="form-group">
                <label for="review_text">{text.shareReviewLabel}</label>
                <textarea
                  id="review_text"
                  name="review_text"
                  rows="3"
                  placeholder={text.shareReviewPlaceholder}
                ></textarea>
              </div>

              <div class="form-group" style="display:flex; align-items:center; gap:0.5rem;">
                <input type="checkbox" id="show_in_gallery" name="show_in_gallery" checked />
                <label for="show_in_gallery" style="margin:0; font-size:0.95rem;">{text.shareGalleryOptIn}</label>
              </div>

              <button type="submit" class="btn btn-primary" style="width:100%;" id="submitBtn">{text.shareSubmit}</button>
            </form>
          </div>
        )}

        {/* ── My Reviews ── */}
        {myReviews.length > 0 && (
          <div class="surface-card" style="padding:1.4rem; margin-bottom:1.5rem;">
            <h2 style="margin-bottom:1rem;">{text.myReviews}</h2>
            <div class="reviews-list">
              {myReviews.map(r => (
                <div class="review-row">
                  <div class="review-thumbs">
                    <img src={r.photo_url} alt="" class="review-thumb" loading="lazy" width="56" height="56" />
                    {(r.extra_photos || []).map((url: string) => (
                      <img src={url} alt="" class="review-thumb review-thumb-extra" loading="lazy" width="36" height="36" />
                    ))}
                  </div>
                  <div class="review-info">
                    <strong>{bookMap[r.book_id] || r.book_id}</strong>
                    <span class="review-stars">{stars(r.rating)}</span>
                    {r.review_text && <p class="review-text-preview">{r.review_text}</p>}
                    {r.status === "rejected" && r.reviewer_note && (
                      <p class="reviewer-note">💬 {text.reviewerNote}: {r.reviewer_note}</p>
                    )}
                  </div>
                  <div class="review-actions-user">
                    <span class={`review-status status-${r.status}`}>
                      {r.status === "pending" ? text.reviewPending : r.status === "approved" ? text.reviewApproved : text.reviewRejected}
                    </span>
                    {r.status === "rejected" && (
                      <form method="POST" style="margin-top:0.3rem;">
                        <input type="hidden" name="action" value="delete_review" />
                        <input type="hidden" name="review_id" value={r.id} />
                        <button type="submit" class="btn-small btn-retry">🔄 {text.reviewTryAgain}</button>
                      </form>
                    )}
                    {(r.status === "pending" || r.status === "approved") && (
                      <div class="review-edit-actions">
                        <button type="button" class="btn-small btn-edit" data-edit={JSON.stringify({id: r.id, book_id: r.book_id, rating: r.rating, review_text: r.review_text || ""})}>
                          ✏️ {text.reviewEdit}
                        </button>
                        <form method="POST" style="display:inline;" onsubmit={`return confirm('${text.reviewDeleteConfirm}')`}>
                          <input type="hidden" name="action" value="delete_review" />
                          <input type="hidden" name="review_id" value={r.id} />
                          <button type="submit" class="btn-small btn-delete">🗑 {text.reviewDelete}</button>
                        </form>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── CTA: Lottery ── */}
        <div class="surface-card" style="padding:1.4rem; text-align:center;">
          <p>🎁 {text.lotteryHeading}</p>
          <a href={`/${lang}/lottery/`} class="btn btn-secondary">{text.lotteryHeading} →</a>
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Searchable book selector ─────────────────
    const searchInput = document.getElementById("bookSearch");
    const hiddenInput = document.getElementById("book_id");
    const dropdown = document.getElementById("bookDropdown");
    const combo = document.getElementById("bookCombo");
    let allOptions = [];

    if (searchInput && dropdown && hiddenInput) {
      allOptions = Array.from(dropdown.querySelectorAll(".book-option"));

      searchInput.addEventListener("focus", () => {
        dropdown.dataset.open = "true";
        filterOptions();
      });

      searchInput.addEventListener("input", () => {
        dropdown.dataset.open = "true";
        filterOptions();
        hiddenInput.value = "";
        searchInput.setCustomValidity("Please select a book from the list");
      });

      function filterOptions() {
        const q = searchInput.value.toLowerCase().trim();
        allOptions.forEach(opt => {
          const match = !q || opt.textContent.toLowerCase().includes(q);
          opt.style.display = match ? "" : "none";
        });
      }

      allOptions.forEach(opt => {
        opt.addEventListener("click", () => {
          hiddenInput.value = opt.getAttribute("data-value");
          searchInput.value = opt.textContent;
          searchInput.setCustomValidity("");
          dropdown.dataset.open = "false";
        });
        opt.addEventListener("touchend", (e) => {
          e.preventDefault();
          opt.click();
        });
      });

      document.addEventListener("click", (e) => {
        if (!combo.contains(e.target)) {
          dropdown.dataset.open = "false";
        }
      });
    }

    // ── Star picker ─────────────────────────────
    const picker = document.getElementById("starPicker");
    const ratingInput = document.getElementById("ratingInput");
    if (picker && ratingInput) {
      const stars = picker.querySelectorAll(".star-btn");

      function setRating(value) {
        ratingInput.value = value;
        stars.forEach((s, i) => {
          s.dataset.selected = i < value ? "true" : "false";
        });
      }

      stars.forEach((star, i) => {
        star.addEventListener("click", (e) => {
          e.preventDefault();
          setRating(i + 1);
        });
        star.addEventListener("mouseenter", () => {
          stars.forEach((s, j) => s.dataset.hovered = j <= i ? "true" : "false");
        });
        star.addEventListener("mouseleave", () => {
          stars.forEach(s => s.dataset.hovered = "false");
        });
      });
    }

    // ── Drag & drop photo zone ──────────────────
    const dropzone = document.getElementById("photoDropzone");
    const fileInput = document.getElementById("photos");
    const status = document.getElementById("photoStatus");
    const preview = document.getElementById("photoPreview");
    const countEl = document.getElementById("photoCount");

    const MAX_DIM = 800;
    const JPEG_QUALITY = 0.7;
    const MAX_BYTES = 500 * 1024;
    const MAX_FILES = 5;

    if (dropzone && fileInput) {
      // Visual drag feedback
      ["dragenter", "dragover"].forEach(evt => {
        dropzone.addEventListener(evt, (e) => {
          e.preventDefault();
          dropzone.classList.add("dragover");
        });
      });
      ["dragleave", "drop"].forEach(evt => {
        dropzone.addEventListener(evt, (e) => {
          e.preventDefault();
          dropzone.classList.remove("dragover");
        });
      });

      // Handle drop
      dropzone.addEventListener("drop", (e) => {
        const files = e.dataTransfer.files;
        if (files.length) {
          fileInput.files = files;
          fileInput.dispatchEvent(new Event("change"));
        }
      });
    }

    function compressImage(file) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        const url = URL.createObjectURL(file);
        img.onload = () => {
          URL.revokeObjectURL(url);
          let w = img.width, h = img.height;
          if (w > MAX_DIM || h > MAX_DIM) {
            const ratio = Math.min(MAX_DIM / w, MAX_DIM / h);
            w = Math.round(w * ratio);
            h = Math.round(h * ratio);
          }
          const canvas = document.createElement("canvas");
          canvas.width = w;
          canvas.height = h;
          const ctx = canvas.getContext("2d");
          ctx.drawImage(img, 0, 0, w, h);
          canvas.toBlob(
            (blob) => blob ? resolve(blob) : reject(new Error("Compression failed")),
            "image/jpeg",
            JPEG_QUALITY
          );
        };
        img.onerror = () => { URL.revokeObjectURL(url); reject(new Error("Invalid image")); };
        img.src = url;
      });
    }

    var compressedBlobs = [];
    var originalFiles = [];

    if (fileInput) {
      fileInput.addEventListener("change", async function (e) {
        compressedBlobs = [];
        originalFiles = [];
        var files = Array.from(e.target.files);
        if (!files.length) return;

        if (files.length > MAX_FILES) {
          if (status) {
            status.style.display = "block";
            status.textContent = "❌ Max " + MAX_FILES + " photos.";
            status.className = "photo-status photo-error";
          }
          e.target.value = "";
          return;
        }

        originalFiles = files;

        if (countEl) {
          countEl.style.display = "block";
          countEl.textContent = files.length + "/5 " + (document.documentElement.lang === "es" ? "fotos seleccionadas" : "photos selected");
        }

        if (status) {
          status.style.display = "block";
          status.textContent = "⏳ " + (document.documentElement.lang === "es" ? "Comprimiendo" : "Compressing") + " " + files.length + " " + (document.documentElement.lang === "es" ? "foto" : "photo") + (files.length > 1 ? "s" : "") + "...";
          status.className = "photo-status";
        }
        if (preview) preview.innerHTML = "";

        try {
          var totalKb = 0;
          for (var i = 0; i < files.length; i++) {
            // Show progress
            if (status) {
              status.textContent = "⏳ " + (document.documentElement.lang === "es" ? "Comprimiendo" : "Compressing") + " " + (i + 1) + "/" + files.length + "...";
            }
            var blob = await compressImage(files[i]);
            if (blob.size > MAX_BYTES) {
              if (status) {
                status.textContent = "❌ " + (document.documentElement.lang === "es" ? "Foto" : "Photo") + " " + (i + 1) + " " + (document.documentElement.lang === "es" ? "muy grande después de comprimir." : "still too large after compression.");
                status.className = "photo-status photo-error";
              }
              compressedBlobs = [];
              if (preview) preview.innerHTML = "";
              return;
            }
            compressedBlobs.push(blob);
            totalKb += Math.round(blob.size / 1024);

            if (preview) {
              var thumb = document.createElement("img");
              thumb.src = URL.createObjectURL(blob);
              thumb.className = "preview-thumb";
              preview.appendChild(thumb);
            }
          }

          if (status) {
            status.textContent = "✅ " + files.length + " " + (document.documentElement.lang === "es" ? "foto" : "photo") + (files.length > 1 ? "s" : "") + " — " + totalKb + " KB total";
            status.className = "photo-status photo-ok";
          }
        } catch (err) {
          compressedBlobs = [];
          if (status) {
            status.style.display = "block";
            status.textContent = "⚠️ " + (document.documentElement.lang === "es" ? "No se pudo comprimir — se subirán los originales." : "Could not compress — originals will be uploaded.");
            status.className = "photo-status";
          }
        }
      });
    }

    // ── Form submit via fetch ──────────────────
    var shareForm = document.getElementById("shareForm");
    if (shareForm) {
      shareForm.addEventListener("submit", async function (e) {
        e.preventDefault();
        var submitBtn = document.getElementById("submitBtn");
        var origLabel = submitBtn ? submitBtn.textContent : "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "⏳ " + (document.documentElement.lang === "es" ? "Subiendo…" : "Uploading…");
        }

        // Upload progress bar
        var progressWrap = document.createElement("div");
        progressWrap.className = "upload-progress";
        var progressBar = document.createElement("div");
        progressBar.className = "upload-progress-bar";
        progressWrap.appendChild(progressBar);
        if (submitBtn) submitBtn.parentElement.insertBefore(progressWrap, submitBtn);

        try {
          var fd = new FormData();
          var formElements = shareForm.elements;
          for (var i = 0; i < formElements.length; i++) {
            var el = formElements[i];
            if (!el.name || el.name === "photos" || el.type === "submit") continue;
            if (el.type === "checkbox") {
              if (el.checked) fd.append(el.name, "on");
            } else {
              fd.append(el.name, el.value);
            }
          }

          var photosToSend = compressedBlobs.length > 0
            ? compressedBlobs.map(function (b, i) { return new File([b], "photo_" + (i + 1) + ".jpg", { type: "image/jpeg" }); })
            : originalFiles;

          for (var i = 0; i < photosToSend.length; i++) {
            fd.append("photos", photosToSend[i]);
          }

          // Simulate progress
          var pct = 0;
          var pInterval = setInterval(function() {
            if (pct < 90) { pct += Math.random() * 15; progressBar.style.width = Math.min(pct, 90) + "%"; }
          }, 300);

          var res = await fetch(window.location.pathname, {
            method: "POST",
            body: fd,
            credentials: "same-origin",
          });

          clearInterval(pInterval);
          progressBar.style.width = "100%";

          if (!res.ok) throw new Error("status " + res.status);
          window.location.reload();
        } catch (err) {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = origLabel;
          }
          if (progressWrap) progressWrap.remove();
          if (status) {
            status.style.display = "block";
            status.textContent = "❌ Upload failed. Please try again.";
            status.className = "photo-status photo-error";
          }
        }
      });
    }

    // ── Edit review buttons ──────────────────────
    document.querySelectorAll(".btn-edit").forEach(btn => {
      btn.addEventListener("click", () => {
        try {
          const data = JSON.parse(btn.getAttribute("data-edit"));
          const form = document.getElementById("shareForm");
          if (!form) return;
          document.getElementById("editId").value = data.id;

          if (hiddenInput) hiddenInput.value = data.book_id;
          if (searchInput) {
            const opt = allOptions.length ? allOptions.find(o => o.getAttribute("data-value") === data.book_id) : null;
            searchInput.value = opt ? opt.textContent : data.book_id;
            searchInput.setCustomValidity("");
            searchInput.readOnly = true;
          }

          const reviewField = document.getElementById("review_text");
          if (reviewField) reviewField.value = data.review_text;

          if (ratingInput && picker) {
            ratingInput.value = data.rating;
            const starBtns = picker.querySelectorAll(".star-btn");
            starBtns.forEach((s, j) => s.dataset.selected = j < data.rating ? "true" : "false");
          }

          const photosInput = document.getElementById("photos");
          if (photosInput) photosInput.removeAttribute("required");

          form.scrollIntoView({ behavior: "smooth", block: "start" });
        } catch(e) { console.error(e); }
      });
    });
  });
</script>

