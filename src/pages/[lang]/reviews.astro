---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase, getServiceClient } from "../../lib/supabase";
import { books } from "../../data/books";
import { notifyNewReview, notifyReviewUpdated } from "../../lib/notifications";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/reviews/`;

// ── Auth ─────────────────────────────────────────────
const user = Astro.locals.user;
const sc = getServiceClient();

// ── User state ───────────────────────────────────────
let myReviews: { id: string; book_id: string; photo_url: string; extra_photos?: string[]; rating: number; review_text: string; status: string; submitted_at: string; reviewer_note?: string }[] = [];
let shareMsg = "";
let shareMsgType: "success" | "error" | "" = "";

if (user) {
  const { data: reviewData } = await supabase
    .from("book_reviews")
    .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
    .eq("user_id", user.id)
    .order("submitted_at", { ascending: false });
  myReviews = reviewData ?? [];

  // ── Handle POST actions ──────────────────────────
  if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "delete_review") {
      const reviewId = formData.get("review_id")?.toString();
      if (reviewId) {
        const toDelete = myReviews.find(r => r.id === reviewId);
        if (toDelete) {
          // Remove both possible extensions (.jpg and .webp)
          const base = `${user.id}/${toDelete.book_id}`;
          await sc.storage.from("book-photos").remove([`${base}.jpg`, `${base}.webp`]);
          await sc.from("book_reviews").delete().eq("id", reviewId).eq("user_id", user.id);
          const { data: refreshed } = await supabase
            .from("book_reviews")
            .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
            .eq("user_id", user.id)
            .order("submitted_at", { ascending: false });
          myReviews = refreshed ?? [];
          shareMsg = lang === "es" ? "Review eliminada." : "Review deleted.";
          shareMsgType = "success";
        }
      }
    }

    if (action === "share_book") {
      const bookId = formData.get("book_id")?.toString() || "";
      const rating = parseInt(formData.get("rating")?.toString() || "0", 10);
      const reviewText = formData.get("review_text")?.toString().trim() || "";
      const photos = formData.getAll("photos") as File[];
      const editId = formData.get("edit_id")?.toString() || "";

      const MAX_BYTES = 500 * 1024;
      const MAX_PHOTOS = 5;
      const ALLOWED_TYPES = ["image/jpeg", "image/png", "image/webp", "image/heic", "image/heif"];

      const validPhotos = photos.filter(f => f && f.size > 0);
      const tooLarge = validPhotos.some(f => f.size > MAX_BYTES);
      const badType = validPhotos.some(f => !ALLOWED_TYPES.includes(f.type));

      if (tooLarge) {
        shareMsg = text.shareTooLarge;
        shareMsgType = "error";
      } else if (badType) {
        shareMsg = text.shareInvalidType;
        shareMsgType = "error";
      } else if (validPhotos.length > MAX_PHOTOS) {
        shareMsg = text.shareTooLarge;
        shareMsgType = "error";
      } else if (!editId && validPhotos.length < 2) {
        shareMsg = text.shareNeedInterior;
        shareMsgType = "error";
      } else if (!bookId || rating < 1 || rating > 5) {
        shareMsg = text.loginError;
        shareMsgType = "error";
      } else {
        let photoUrl = "";
        let extraPhotos: string[] = [];

        if (validPhotos.length > 0) {
          for (let i = 0; i < validPhotos.length; i++) {
            const mime = validPhotos[i].type || "image/jpeg";
            const ext = mime === "image/webp" ? ".webp" : ".jpg";
            const suffix = i === 0 ? "" : `_${i + 1}`;
            const filePath = `${user.id}/${bookId}${suffix}${ext}`;
            const arrayBuf = await validPhotos[i].arrayBuffer();
            const buffer = new Uint8Array(arrayBuf);
            const { error: uploadError } = await sc.storage
              .from("book-photos")
              .upload(filePath, buffer, { contentType: mime, upsert: true });
            if (uploadError) {
              shareMsg = text.loginError;
              shareMsgType = "error";
              break;
            }
            const { data: urlData } = sc.storage.from("book-photos").getPublicUrl(filePath);
            if (i === 0) {
              photoUrl = urlData.publicUrl;
            } else {
              extraPhotos.push(urlData.publicUrl);
            }
          }
        }

        if (shareMsgType !== "error") {
          if (editId) {
            const photosChanged = validPhotos.length > 0;
            const updateData: any = {
              rating,
              review_text: reviewText,
              show_in_gallery: formData.get("show_in_gallery") === "on",
            };
            if (photosChanged) {
              updateData.status = "pending";
              updateData.reviewed_at = null;
              updateData.reviewer_note = null;
            }
            if (photoUrl) updateData.photo_url = photoUrl;
            if (extraPhotos.length > 0) updateData.extra_photos = extraPhotos;

            const { error: updateError } = await sc
              .from("book_reviews")
              .update(updateData)
              .eq("id", editId)
              .eq("user_id", user.id);

            if (updateError) {
              shareMsg = text.loginError;
              shareMsgType = "error";
            } else {
              shareMsg = text.shareSuccess;
              shareMsgType = "success";
              const bTitle = books.find(b => b.id === bookId)?.title[lang] || bookId;
              notifyReviewUpdated(user.email || "unknown", bTitle, rating).catch(() => {});
            }
          } else {
            if (!photoUrl) {
              shareMsg = text.shareInvalidType;
              shareMsgType = "error";
            } else {
              const { error: insertError } = await sc
                .from("book_reviews")
                .insert({
                  user_id: user.id,
                  book_id: bookId,
                  photo_url: photoUrl,
                  extra_photos: extraPhotos,
                  rating,
                  review_text: reviewText,
                  show_in_gallery: formData.get("show_in_gallery") === "on",
                });

              if (insertError?.code === "23505") {
                shareMsg = text.shareAlreadyReviewed;
                shareMsgType = "error";
              } else if (insertError) {
                shareMsg = text.loginError;
                shareMsgType = "error";
              } else {
                shareMsg = text.shareSuccess;
                shareMsgType = "success";
                const bTitle = books.find(b => b.id === bookId)?.title[lang] || bookId;
                notifyNewReview(user.email || "unknown", bTitle, rating, reviewText).catch(() => {});
              }
            }
          }

          const { data: refreshed } = await supabase
            .from("book_reviews")
            .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
            .eq("user_id", user.id)
            .order("submitted_at", { ascending: false });
          myReviews = refreshed ?? [];
        }
      }
    }
  }
}

// Books already reviewed (to exclude from dropdown)
const reviewedBookIds = new Set(myReviews.map(r => r.book_id));
const bookOptions = books.map(b => ({ id: b.id, title: b.title[lang] }));
const availableBooks = bookOptions.filter(b => !reviewedBookIds.has(b.id));
const bookMap = Object.fromEntries(bookOptions.map(b => [b.id, b.title]));
const stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);

// Approved reviews earn 5 tickets each
const approvedCount = myReviews.filter(r => r.status === "approved").length;
---

<BaseLayout
  lang={lang}
  title={text.reviewsMetaTitle}
  description={text.reviewsDescription}
  pathname={pathname}
  breadcrumbs={[
    { name: text.navHome, url: `/${lang}/` },
    { name: text.reviewsHeading, url: pathname }
  ]}
>
  <section class="page-section container">
    <div class="section-head" style="text-align:center; max-width:42rem; margin:0 auto 2rem;">
      <h1>{text.reviewsHeading}</h1>
      <p>{text.reviewsDescription}</p>
    </div>

    {!user ? (
      <div class="surface-card" style="max-width:28rem; margin:0 auto; padding:2rem 1.6rem; text-align:center;">
        <p>{text.lotteryNotLoggedIn}</p>
        <a href={`/${lang}/login/`} class="btn btn-primary">{text.navLogin}</a>
      </div>
    ) : (
      <div style="max-width:42rem; margin:0 auto;">

        {/* ── Peanuts earned info ── */}
        {approvedCount > 0 && (
          <div class="surface-card peanuts-info" style="padding:1rem 1.4rem; margin-bottom:1.5rem; text-align:center;">
            <p>🥜 {approvedCount} {approvedCount === 1
              ? (lang === "es" ? "review aprobada" : "approved review")
              : (lang === "es" ? "reviews aprobadas" : "approved reviews")} = <strong>{approvedCount * 5} 🥜</strong> {lang === "es" ? "ganados" : "earned"}</p>
            <a href={`/${lang}/peanuts/`} class="btn-small" style="color:var(--accent-gold);">{text.peanutShopTitle} →</a>
          </div>
        )}

        {/* ── Review editing note ── */}
        <div class="surface-card edit-info" style="padding:0.8rem 1.2rem; margin-bottom:1.2rem; font-size:0.88rem; color:var(--ink-soft);">
          <p style="margin:0;">✏️ {text.reviewsEditKeepsApproval}</p>
          <p style="margin:0.3rem 0 0;">📸 {text.reviewsEditResetsPhotos}</p>
        </div>

        {/* ── Share Your Book Form ── */}
        {availableBooks.length > 0 && (
          <div class="surface-card" style="padding:1.6rem; margin-bottom:1.5rem;">
            <h2 style="margin-bottom:1rem;">📸 {text.shareYourBook}</h2>

            {shareMsg && (
              <p class={`msg ${shareMsgType === "success" ? "msg-success" : "msg-error"}`}>{shareMsg}</p>
            )}

            <form method="POST" enctype="multipart/form-data" class="form-grid" id="shareForm">
              <input type="hidden" name="action" value="share_book" />
              <input type="hidden" name="edit_id" id="editId" value="" />

              <div class="form-group">
                <label for="bookSearch">{text.shareBookLabel}</label>
                <input type="hidden" id="book_id" name="book_id" value="" required />
                <div class="book-combo" id="bookCombo">
                  <input
                    type="text"
                    id="bookSearch"
                    class="book-search-input"
                    placeholder={text.shareBookSearch}
                    autocomplete="off"
                    required
                  />
                  <ul class="book-dropdown" id="bookDropdown" role="listbox">
                    {availableBooks.map(b => (
                      <li class="book-option" role="option" data-value={b.id}>{b.title}</li>
                    ))}
                  </ul>
                </div>
              </div>

              {/* ── Book Cover photo zone ── */}
              <div class="form-group">
                <label>{text.reviewsCoverLabel}</label>
                <small class="field-hint">{text.reviewsCoverHint}</small>
                <div class="photo-dropzone" id="coverDropzone">
                  <div class="dropzone-content">
                    <span class="dropzone-icon">📕</span>
                    <p class="dropzone-text">{text.reviewsCoverDropzone}</p>
                    <small class="dropzone-hint">{text.reviewsCoverHintFormat}</small>
                  </div>
                  <input
                    type="file"
                    id="coverPhoto"
                    name="cover_photo"
                    accept="image/*"
                    required
                    class="dropzone-input"
                  />
                </div>
                <div id="coverPreview" class="photo-preview"></div>
                <small class="rotate-hint" id="coverRotateHint" style="display:none;">{lang === "es" ? "↻ Toca el botón para rotar si la foto no se ve derecha" : "↻ Tap the button to rotate if the photo looks sideways"}</small>
                <small id="coverStatus" class="photo-status" style="display:none;"></small>
              </div>

              {/* ── Interior pages photo zone ── */}
              <div class="form-group">
                <label>{text.reviewsInteriorsLabel}</label>
                <small class="field-hint">{text.reviewsInteriorsHint}</small>
                <div class="photo-dropzone" id="interiorsDropzone">
                  <div class="dropzone-content">
                    <span class="dropzone-icon">📖</span>
                    <p class="dropzone-text">{text.reviewsInteriorsDropzone}</p>
                    <small class="dropzone-hint">{text.reviewsInteriorsHintFormat}</small>
                  </div>
                  <input
                    type="file"
                    id="interiorPhotos"
                    name="interior_photos"
                    accept="image/*"
                    multiple
                    required
                    class="dropzone-input"
                  />
                </div>
                <div id="interiorsPreview" class="photo-preview"></div>
                <small class="rotate-hint" id="interiorsRotateHint" style="display:none;">{lang === "es" ? "↻ Toca el botón para rotar si alguna foto no se ve derecha" : "↻ Tap the button to rotate if any photo looks sideways"}</small>
                <small id="interiorsCount" class="photo-count" style="display:none;"></small>
                <small id="interiorsStatus" class="photo-status" style="display:none;"></small>
              </div>

              <div class="form-group">
                <label>{text.shareRatingLabel}</label>
                <div class="star-picker" id="starPicker">
                  {[1, 2, 3, 4, 5].map(n => (
                    <button type="button" class="star-btn" data-value={n.toString()} aria-label={`${n} star${n > 1 ? "s" : ""}`}>
                      <span class="star-icon">★</span>
                    </button>
                  ))}
                </div>
                <input type="hidden" name="rating" id="ratingInput" value="" required />
              </div>

              <div class="form-group">
                <label for="review_text">{text.shareReviewLabel}</label>
                <textarea
                  id="review_text"
                  name="review_text"
                  rows="3"
                  placeholder={text.shareReviewPlaceholder}
                ></textarea>
              </div>

              <div class="form-group" style="display:flex; align-items:center; gap:0.5rem;">
                <input type="checkbox" id="show_in_gallery" name="show_in_gallery" checked />
                <label for="show_in_gallery" style="margin:0; font-size:0.95rem;">{text.shareGalleryOptIn}</label>
              </div>

              <button type="submit" class="btn btn-primary" style="width:100%;" id="submitBtn">{text.shareSubmit}</button>
            </form>
          </div>
        )}

        {/* ── My Reviews ── */}
        {myReviews.length > 0 && (
          <div class="surface-card" style="padding:1.4rem; margin-bottom:1.5rem;">
            <h2 style="margin-bottom:1rem;">{text.myReviews}</h2>
            <div class="reviews-list">
              {myReviews.map(r => (
                <div class="review-row">
                  <div class="review-thumbs">
                    <img src={r.photo_url} alt="" class="review-thumb" loading="lazy" width="56" height="56" />
                    {(r.extra_photos || []).map((url: string) => (
                      <img src={url} alt="" class="review-thumb review-thumb-extra" loading="lazy" width="36" height="36" />
                    ))}
                  </div>
                  <div class="review-info">
                    <strong>{bookMap[r.book_id] || r.book_id}</strong>
                    <span class="review-stars">{stars(r.rating)}</span>
                    {r.review_text && <p class="review-text-preview">{r.review_text}</p>}
                    {r.status === "rejected" && r.reviewer_note && (
                      <p class="reviewer-note">💬 {text.reviewerNote}: {r.reviewer_note}</p>
                    )}
                  </div>
                  <div class="review-actions-user">
                    <span class={`review-status status-${r.status}`}>
                      {r.status === "pending" ? text.reviewPending : r.status === "approved" ? text.reviewApproved : text.reviewRejected}
                    </span>
                    {r.status === "rejected" && (
                      <form method="POST" style="margin-top:0.3rem;">
                        <input type="hidden" name="action" value="delete_review" />
                        <input type="hidden" name="review_id" value={r.id} />
                        <button type="submit" class="btn-small btn-retry">🔄 {text.reviewTryAgain}</button>
                      </form>
                    )}
                    {(r.status === "pending" || r.status === "approved") && (
                      <div class="review-edit-actions">
                        <button type="button" class="btn-small btn-edit" data-edit={JSON.stringify({id: r.id, book_id: r.book_id, rating: r.rating, review_text: r.review_text || ""})}>
                          ✏️ {text.reviewEdit}
                        </button>
                        <form method="POST" style="display:inline;" onsubmit={`return confirm('${text.reviewDeleteConfirm}')`}>
                          <input type="hidden" name="action" value="delete_review" />
                          <input type="hidden" name="review_id" value={r.id} />
                          <button type="submit" class="btn-small btn-delete">🗑 {text.reviewDelete}</button>
                        </form>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── CTA: Lottery ── */}
        <div class="surface-card" style="padding:1.4rem; text-align:center;">
          <p>🎁 {text.lotteryHeading}</p>
          <a href={`/${lang}/lottery/`} class="btn btn-secondary">{text.lotteryHeading} →</a>
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    // ── Searchable book selector ─────────────────
    const searchInput = document.getElementById("bookSearch");
    const hiddenInput = document.getElementById("book_id");
    const dropdown = document.getElementById("bookDropdown");
    const combo = document.getElementById("bookCombo");
    let allOptions = [];

    if (searchInput && dropdown && hiddenInput) {
      allOptions = Array.from(dropdown.querySelectorAll(".book-option"));

      searchInput.addEventListener("focus", () => {
        dropdown.dataset.open = "true";
        filterOptions();
      });

      searchInput.addEventListener("input", () => {
        dropdown.dataset.open = "true";
        filterOptions();
        hiddenInput.value = "";
        searchInput.setCustomValidity("Please select a book from the list");
      });

      function filterOptions() {
        const q = searchInput.value.toLowerCase().trim();
        allOptions.forEach(opt => {
          const match = !q || opt.textContent.toLowerCase().includes(q);
          opt.style.display = match ? "" : "none";
        });
      }

      allOptions.forEach(opt => {
        opt.addEventListener("click", () => {
          hiddenInput.value = opt.getAttribute("data-value");
          searchInput.value = opt.textContent;
          searchInput.setCustomValidity("");
          dropdown.dataset.open = "false";
        });
        opt.addEventListener("touchend", (e) => {
          e.preventDefault();
          opt.click();
        });
      });

      document.addEventListener("click", (e) => {
        if (!combo.contains(e.target)) {
          dropdown.dataset.open = "false";
        }
      });
    }

    // ── Star picker ─────────────────────────────
    const picker = document.getElementById("starPicker");
    const ratingInput = document.getElementById("ratingInput");
    if (picker && ratingInput) {
      const stars = picker.querySelectorAll(".star-btn");

      function setRating(value) {
        ratingInput.value = value;
        stars.forEach((s, i) => {
          s.dataset.selected = i < value ? "true" : "false";
        });
      }

      stars.forEach((star, i) => {
        star.addEventListener("click", (e) => {
          e.preventDefault();
          setRating(i + 1);
        });
        star.addEventListener("mouseenter", () => {
          stars.forEach((s, j) => s.dataset.hovered = j <= i ? "true" : "false");
        });
        star.addEventListener("mouseleave", () => {
          stars.forEach(s => s.dataset.hovered = "false");
        });
      });
    }

    // ── Drag & drop photo zones ──────────────────
    const MAX_DIM = 800;
    const IMG_QUALITY = 0.75;
    const MAX_BYTES = 500 * 1024;
    const MAX_INTERIORS = 4;
    const isEs = document.documentElement.lang === "es";

    // Detect WebP support once (much lighter than JPEG)
    var supportsWebP = false;
    (function () {
      var c = document.createElement("canvas"); c.width = 1; c.height = 1;
      supportsWebP = c.toDataURL("image/webp").indexOf("data:image/webp") === 0;
    })();
    var outMime = supportsWebP ? "image/webp" : "image/jpeg";
    var outExt  = supportsWebP ? ".webp" : ".jpg";

    // ── Detect if this browser auto-rotates EXIF in <img> ──
    // Loads a tiny 2×1 JPEG with Orientation=6 (90° CW → should become 1×2).
    // If the browser auto-rotates, naturalWidth=1, naturalHeight=2.
    // If NOT, naturalWidth=2, naturalHeight=1 → we must rotate manually.
    var browserAutoRotates = null; // null = not tested yet, true/false after
    var autoRotatePromise = new Promise(function (resolve) {
      var testImg = new Image();
      // Minimal JPEG: 2×1 px, EXIF Orientation=6 (rotate 90° CW)
      testImg.onload = function () {
        browserAutoRotates = testImg.naturalWidth === 1 && testImg.naturalHeight === 2;
        resolve();
      };
      testImg.onerror = function () {
        browserAutoRotates = false; // assume no auto-rotate
        resolve();
      };
      testImg.src = "data:image/jpeg;base64,"
        + "/9j/4QBiRXhpZgAATU0AKgAAAAgAAgESAAMAAAABAAYAAAEh"
        + "AAUAAAABAAAAJgAAAAAAAqACAAQAAAABAAAAAqADAAQAAAAB"
        + "AAAAAQAAAAAAAAAAAAEAAAABAAAAHgAAAAD/2wBDAAgGBgcG"
        + "BQgHBwcJCQgKDBQNDAsLDBkSEw8UHRofHh0aHBwgJC4nICIs"
        + "IxwcKDcpLDAxNDQ0Hyc5PTgyPC4zNDL/2wBDAQkJCQwLDBgN"
        + "DRgyIRwhMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIy"
        + "MjIyMjIyMjIyMjIyMjIyMjL/wAARCAABAAIDASIAAhEBAxEB"
        + "/8QAHwAAAQUBAQEBAQEAAAAAAAAAAAECAwQFBgcICQoL/8QA"
        + "tRAAAgEDAwIEAwUFBAQAAAF9AQIDAAQRBRIhMUEGE1FhByJx"
        + "FDKBkaEII0KxwRVS0fAkM2JyggkKFhcYGRolJicoKSo0NTY3"
        + "ODk6Q0RFRkdISUpTVFVWV1hZWmNkZWZnaGlqc3R1dnd4eXqD"
        + "hIWGh4iJipKTlJWWl5iZmqKjpKWmp6ipqrKztLW2t7i5usLD"
        + "xMXGx8jJytLT1NXW19jZ2uHi4+Tl5ufo6erx8vP09fb3+Pn6"
        + "/8QAHwEAAwEBAQEBAQEBAQAAAAAAAAECAwQFBgcICQoL/8QA"
        + "tREAAgECBAQDBAcFBAQAAQJ3AAECAxEEBSExBhJBUQdhcRMi"
        + "MoEIFEKRobHBCSMzUvAVYnLRChYkNOEl8RcYI4Q/RFhHYnUt"
        + "FCcS8hclcoMwbOBkZz/9oADAMBAAIRAxEAPwC/RRRQB//Z";
    });

    // ── Read EXIF orientation from JPEG bytes ──
    function getExifOrientation(file) {
      return new Promise(function (resolve) {
        var reader = new FileReader();
        reader.onload = function (e) {
          var view = new DataView(e.target.result);
          if (view.getUint16(0) !== 0xFFD8) { resolve(1); return; } // not JPEG
          var offset = 2;
          while (offset < view.byteLength - 2) {
            var marker = view.getUint16(offset);
            if (marker === 0xFFE1) { // APP1 = EXIF
              var exifOffset = offset + 4;
              // Check "Exif\0\0"
              if (view.getUint32(exifOffset) !== 0x45786966) { resolve(1); return; }
              var tiffStart = exifOffset + 6;
              var bigEndian = view.getUint16(tiffStart) === 0x4D4D;
              var ifdOffset = view.getUint32(tiffStart + 4, !bigEndian);
              var tags = view.getUint16(tiffStart + ifdOffset, !bigEndian);
              for (var i = 0; i < tags; i++) {
                var tagOffset = tiffStart + ifdOffset + 2 + i * 12;
                if (view.getUint16(tagOffset, !bigEndian) === 0x0112) { // Orientation tag
                  resolve(view.getUint16(tagOffset + 8, !bigEndian));
                  return;
                }
              }
              resolve(1); return;
            }
            offset += 2 + view.getUint16(offset + 2);
          }
          resolve(1);
        };
        reader.onerror = function () { resolve(1); };
        reader.readAsArrayBuffer(file.slice(0, 65536)); // only first 64KB
      });
    }

    // ── Blob helpers with CSP-safe data URL fallback ──
    function blobToDataUrl(blob) {
      return new Promise(function (resolve, reject) {
        var reader = new FileReader();
        reader.onload = function () { resolve(reader.result); };
        reader.onerror = function () { reject(new Error("data url read failed")); };
        reader.readAsDataURL(blob);
      });
    }

    function loadImageFromBlob(blob) {
      return new Promise(function (resolve) {
        var img = new Image();

        function loadWithDataUrl() {
          blobToDataUrl(blob)
            .then(function (dataUrl) {
              img.onload = function () { resolve(img); };
              img.onerror = function () { resolve(null); };
              img.src = dataUrl;
            })
            .catch(function () { resolve(null); });
        }

        if (typeof URL !== "undefined" && typeof URL.createObjectURL === "function") {
          try {
            var objectUrl = URL.createObjectURL(blob);
            img.onload = function () {
              URL.revokeObjectURL(objectUrl);
              resolve(img);
            };
            img.onerror = function () {
              URL.revokeObjectURL(objectUrl);
              loadWithDataUrl();
            };
            img.src = objectUrl;
            return;
          } catch (_) {
            // Fall through to data URL mode.
          }
        }

        loadWithDataUrl();
      });
    }

    function setPreviewSource(imgEl, blob) {
      function setDataUrl() {
        blobToDataUrl(blob)
          .then(function (dataUrl) {
            imgEl.onload = null;
            imgEl.onerror = null;
            imgEl.src = dataUrl;
          })
          .catch(function () {
            imgEl.onload = null;
            imgEl.onerror = null;
          });
      }

      if (typeof URL !== "undefined" && typeof URL.createObjectURL === "function") {
        try {
          var objectUrl = URL.createObjectURL(blob);
          imgEl.onload = function () {
            URL.revokeObjectURL(objectUrl);
            imgEl.onload = null;
            imgEl.onerror = null;
          };
          imgEl.onerror = function () {
            URL.revokeObjectURL(objectUrl);
            setDataUrl();
          };
          imgEl.src = objectUrl;
          return;
        } catch (_) {
          // Fall through to data URL mode.
        }
      }

      setDataUrl();
    }

    // ── Canvas → blob helper (tries WebP first, falls back to JPEG) ──
    function canvasToBlob(canvas) {
      return new Promise(function (resolve, reject) {
        canvas.toBlob(
          function (blob) {
            if (blob && blob.size > 0) { resolve(blob); return; }
            // WebP toBlob failed — retry as JPEG
            canvas.toBlob(
              function (jpgBlob) { jpgBlob ? resolve(jpgBlob) : reject(new Error("toBlob failed")); },
              "image/jpeg", IMG_QUALITY
            );
          },
          outMime, IMG_QUALITY
        );
      });
    }

    // ── Resize + optional manual EXIF rotation + draw to canvas → blob ──
    function resizeAndBlob(source, srcW, srcH, orientation) {
      var w = srcW, h = srcH;
      if (w > MAX_DIM || h > MAX_DIM) {
        var ratio = Math.min(MAX_DIM / w, MAX_DIM / h);
        w = Math.round(w * ratio);
        h = Math.round(h * ratio);
      }
      var canvas = document.createElement("canvas");
      var ctx = canvas.getContext("2d");

      // If browser does NOT auto-rotate and EXIF says rotate, do it manually
      var needsManual = !browserAutoRotates && orientation && orientation > 1;
      if (needsManual) {
        // Orientations 5-8 swap width/height
        if (orientation >= 5) {
          canvas.width = h;
          canvas.height = w;
        } else {
          canvas.width = w;
          canvas.height = h;
        }
        switch (orientation) {
          case 2: ctx.transform(-1, 0, 0, 1, w, 0); break;                 // flip H
          case 3: ctx.transform(-1, 0, 0, -1, w, h); break;               // 180°
          case 4: ctx.transform(1, 0, 0, -1, 0, h); break;                // flip V
          case 5: ctx.transform(0, 1, 1, 0, 0, 0); break;                 // transpose
          case 6: ctx.transform(0, 1, -1, 0, h, 0); break;                // 90° CW
          case 7: ctx.transform(0, -1, -1, 0, h, w); break;               // transverse
          case 8: ctx.transform(0, -1, 1, 0, 0, w); break;                // 90° CCW
        }
        ctx.drawImage(source, 0, 0, w, h);
      } else {
        canvas.width = w;
        canvas.height = h;
        ctx.drawImage(source, 0, 0, w, h);
      }
      return canvasToBlob(canvas);
    }

    // ── Compress image ──
    // PRIMARY: createImageBitmap with resizeWidth/Height (non-blocking, runs off main thread)
    // FALLBACK: new Image() + canvas drawImage (blocks main thread — old browsers only)
    async function compressImage(file) {
      // debug removed
      await autoRotatePromise;
      // debug removed

      // ── PRIMARY: createImageBitmap with resize (non-blocking) ──
      if (typeof createImageBitmap === "function") {
        try {
          // First decode to get natural dimensions
          var bmpOpts = browserAutoRotates !== false ? { imageOrientation: "from-image" } : {};
          var probe = await createImageBitmap(file, bmpOpts);
          var natW = probe.width, natH = probe.height;
          probe.close();

          // Calculate target size
          var w = natW, h = natH;
          if (w > MAX_DIM || h > MAX_DIM) {
            var ratio = Math.min(MAX_DIM / w, MAX_DIM / h);
            w = Math.round(w * ratio);
            h = Math.round(h * ratio);
          }

          // Decode + resize off the main thread (no UI freeze!)
          var resizeOpts = Object.assign({}, bmpOpts, {
            resizeWidth: w,
            resizeHeight: h,
            resizeQuality: "high"
          });
          var bmp = await createImageBitmap(file, resizeOpts);

          // Draw the already-small bitmap to canvas (instant)
          var canvas = document.createElement("canvas");
          canvas.width = bmp.width;
          canvas.height = bmp.height;
          canvas.getContext("2d").drawImage(bmp, 0, 0);
          bmp.close();
          // debug removed
          return canvasToBlob(canvas);
        } catch (bmpErr) {
          // debug removed
          // Fall through to Image() path
        }
      }

      // ── FALLBACK: Image element + canvas (blocks main thread) ──
      // Yield the thread so "Compressing..." text renders before the freeze
      await new Promise(function (r) { setTimeout(r, 50); });

      var orientation = 1;
      if (!browserAutoRotates) {
        orientation = await getExifOrientation(file);
      }

      var loaded = await loadImageFromBlob(file);

      if (loaded) {
        var natW2 = loaded.naturalWidth || loaded.width;
        var natH2 = loaded.naturalHeight || loaded.height;
        // debug removed
        return resizeAndBlob(loaded, natW2, natH2, orientation);
      }

      throw new Error("Cannot load image");
    }

    // ── Rotate a blob/file 90° clockwise via canvas ──
    async function rotateBlob90(source) {
      var img = await loadImageFromBlob(source);
      if (!img) throw new Error("rotate load failed");

      var canvas = document.createElement("canvas");
      canvas.width = img.naturalHeight;
      canvas.height = img.naturalWidth;
      var ctx = canvas.getContext("2d");
      ctx.translate(canvas.width, 0);
      ctx.rotate(Math.PI / 2);
      ctx.drawImage(img, 0, 0);
      return canvasToBlob(canvas);
    }

    // ── Is mobile? ──
    function isMobile() { return window.innerWidth <= 700; }

    // ── Photo Review Modal ──
    // Shows each photo fullscreen one-at-a-time with rotate + confirm buttons.
    // On mobile this opens BEFORE compression so the user sees the photo instantly.
    var modalOverlay = null;
    var modalItems = [];   // array of { blob, label }
    var modalIndex = 0;
    var modalResolve = null;

    function buildModal() {
      if (modalOverlay) return;
      modalOverlay = document.createElement("div");
      modalOverlay.className = "photo-modal-overlay";
      modalOverlay.innerHTML =
        '<div class="photo-modal">' +
          '<p class="photo-modal-counter" id="modalCounter"></p>' +
          '<p class="photo-modal-copy">' + (isEs
            ? '¿Se ve derecha? Si no, toca rotar.'
            : 'Does it look straight? If not, tap rotate.') + '</p>' +
          '<div class="photo-modal-imgwrap"><img id="modalImg" class="photo-modal-img" /></div>' +
          '<div class="photo-modal-actions">' +
            '<button type="button" class="photo-modal-btn modal-rotate" id="modalRotateBtn">↻ ' +
              (isEs ? 'Rotar' : 'Rotate') + '</button>' +
            '<button type="button" class="photo-modal-btn modal-ok" id="modalOkBtn">✓ ' +
              (isEs ? 'OK, siguiente' : 'OK, next') + '</button>' +
          '</div>' +
        '</div>';
      document.body.appendChild(modalOverlay);

      document.getElementById("modalRotateBtn").addEventListener("click", async function () {
        var self = this;
        var okBtn = document.getElementById("modalOkBtn");
        self.disabled = true;
        okBtn.disabled = true;
        self.textContent = "⏳…";
        try {
          var entry = modalItems[modalIndex];
          var rotated = await rotateBlob90(entry.blob);
          entry.blob = rotated;
          var modalImg = document.getElementById("modalImg");
          setPreviewSource(modalImg, rotated);
        } catch (_) {}
        self.disabled = false;
        okBtn.disabled = false;
        self.textContent = "↻ " + (isEs ? "Rotar" : "Rotate");
      });

      document.getElementById("modalOkBtn").addEventListener("click", function () {
        modalIndex++;
        if (modalIndex < modalItems.length) {
          showModalPhoto(modalIndex);
        } else {
          closeModal();
        }
      });
    }

    function showModalPhoto(idx) {
      var entry = modalItems[idx];
      var modalImg = document.getElementById("modalImg");
      setPreviewSource(modalImg, entry.blob);
      document.getElementById("modalCounter").textContent =
        (entry.label ? entry.label + " — " : "") +
        (idx + 1) + " / " + modalItems.length;
      var okBtn = document.getElementById("modalOkBtn");
      if (modalItems.length === 1) {
        okBtn.textContent = "✓ " + (isEs ? "Confirmar" : "Confirm");
      } else if (idx === modalItems.length - 1) {
        okBtn.textContent = "✓ " + (isEs ? "Confirmar todas" : "Confirm all");
      } else {
        okBtn.textContent = "✓ " + (isEs ? "OK, siguiente" : "OK, next");
      }
    }

    // Opens the modal and returns a promise that resolves with the final blobs
    function openPhotoModal(items) {
      // debug removed
      buildModal();
      modalItems = items;
      modalIndex = 0;
      showModalPhoto(0);
      modalOverlay.classList.add("active");
      // debug removed
      document.body.style.overflow = "hidden";
      return new Promise(function (resolve) { modalResolve = resolve; });
    }

    function closeModal() {
      if (modalOverlay) {
        modalOverlay.classList.remove("active");
        document.body.style.overflow = "";
        var modalImg = document.getElementById("modalImg");
        if (modalImg && modalImg.src && modalImg.src.indexOf("blob:") === 0) {
          URL.revokeObjectURL(modalImg.src);
        }
      }
      // Resolve with the final blobs (may have been rotated)
      var finalBlobs = modalItems.map(function (e) { return e.blob; });
      if (modalResolve) { modalResolve(finalBlobs); modalResolve = null; }
    }

    // ── Create a preview wrapper with optional rotate button ──
    function createPreviewItem(blob, onRotated, extraClass) {
      var wrap = document.createElement("div");
      wrap.className = "preview-item";
      var currentBlob = blob;

      var thumb = document.createElement("img");
      thumb.className = "preview-thumb" + (extraClass ? " " + extraClass : "");
      setPreviewSource(thumb, currentBlob);
      wrap.appendChild(thumb);

      if (typeof onRotated === "function") {
        var rotateBtn = document.createElement("button");
        rotateBtn.type = "button";
        rotateBtn.className = "rotate-btn";
        var rotateIdleText = "↻ 90°";
        rotateBtn.textContent = rotateIdleText;
        rotateBtn.title = isEs ? "Rotar 90°" : "Rotate 90°";
        rotateBtn.setAttribute("aria-label", isEs ? "Rotar foto 90 grados" : "Rotate photo 90 degrees");

        rotateBtn.addEventListener("click", async function (e) {
          e.preventDefault();
          e.stopPropagation();
          rotateBtn.disabled = true;
          rotateBtn.textContent = "⏳";
          try {
            var rotated = await rotateBlob90(currentBlob);
            currentBlob = rotated;
            setPreviewSource(thumb, rotated);
            onRotated(rotated);
          } catch (_) {}
          rotateBtn.disabled = false;
          rotateBtn.textContent = rotateIdleText;
        });

        wrap.appendChild(rotateBtn);
      }

      return wrap;
    }

    function setupDropzone(zoneId, inputId) {
      const zone = document.getElementById(zoneId);
      const input = document.getElementById(inputId);
      if (!zone || !input) return;
      ["dragenter", "dragover"].forEach(evt => {
        zone.addEventListener(evt, (e) => { e.preventDefault(); zone.classList.add("dragover"); });
      });
      ["dragleave", "drop"].forEach(evt => {
        zone.addEventListener(evt, (e) => { e.preventDefault(); zone.classList.remove("dragover"); });
      });
      zone.addEventListener("drop", (e) => {
        const dt = new DataTransfer();
        Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
        input.files = dt.files;
        input.dispatchEvent(new Event("change"));
      });
    }

    setupDropzone("coverDropzone", "coverPhoto");
    setupDropzone("interiorsDropzone", "interiorPhotos");

    // ── Cover photo handler ──
    var coverBlob = null;
    var coverOriginal = null;
    const coverInput = document.getElementById("coverPhoto");
    const coverPreview = document.getElementById("coverPreview");
    const coverStatus = document.getElementById("coverStatus");

    if (coverInput) {
      coverInput.addEventListener("change", async function (e) {
        coverBlob = null;
        coverOriginal = null;
        const file = e.target.files[0];
        if (!file) return;
        coverOriginal = file;
        if (coverPreview) coverPreview.innerHTML = "";
        var coverHint = document.getElementById("coverRotateHint");
        if (coverHint) coverHint.style.display = "none";

        if (coverStatus) {
          coverStatus.style.display = "block";
          coverStatus.textContent = "⏳ " + (isEs ? "Comprimiendo portada..." : "Compressing cover...");
          coverStatus.className = "photo-status";
        }

        try {
          const blob = await compressImage(file);
          if (blob.size > MAX_BYTES) {
            if (coverStatus) {
              coverStatus.textContent = "❌ " + (isEs ? "Portada muy grande después de comprimir." : "Cover too large after compression.");
              coverStatus.className = "photo-status photo-error";
            }
            return;
          }
          coverBlob = blob;
          if (coverPreview) {
            coverPreview.innerHTML = "";
            var item = createPreviewItem(
              blob,
              function (rotatedBlob) {
                coverBlob = rotatedBlob;
                if (coverStatus) {
                  coverStatus.style.display = "block";
                  coverStatus.textContent = "✅ " + (isEs ? "Portada lista" : "Cover ready") + " — " + Math.round(rotatedBlob.size / 1024) + " KB";
                  coverStatus.className = "photo-status photo-ok";
                }
              },
              "cover-thumb"
            );
            coverPreview.appendChild(item);
          }
          if (coverHint) coverHint.style.display = "block";
          if (coverStatus) {
            coverStatus.textContent = "✅ " + (isEs ? "Portada lista" : "Cover ready") + " — " + Math.round(blob.size / 1024) + " KB";
            coverStatus.className = "photo-status photo-ok";
          }
        } catch (err) {
          coverBlob = null;
          if (coverStatus) {
            coverStatus.style.display = "block";
            coverStatus.textContent = "⚠️ " + (isEs ? "No se pudo comprimir — se subirá el original." : "Could not compress — original will be uploaded.");
            coverStatus.className = "photo-status";
          }
        }
      });
    }

    // ── Interior photos handler ──
    var interiorBlobs = [];
    var interiorOriginals = [];
    const interiorsInput = document.getElementById("interiorPhotos");
    const interiorsPreview = document.getElementById("interiorsPreview");
    const interiorsStatus = document.getElementById("interiorsStatus");
    const interiorsCountEl = document.getElementById("interiorsCount");

    if (interiorsInput) {
      interiorsInput.addEventListener("change", async function (e) {
        interiorBlobs = [];
        interiorOriginals = [];
        var files = Array.from(e.target.files);
        if (!files.length) return;
        var interiorsHint = document.getElementById("interiorsRotateHint");
        if (interiorsHint) interiorsHint.style.display = "none";

        if (files.length > MAX_INTERIORS) {
          if (interiorsStatus) {
            interiorsStatus.style.display = "block";
            interiorsStatus.textContent = "❌ Max " + MAX_INTERIORS + " " + (isEs ? "fotos de interiores." : "interior photos.");
            interiorsStatus.className = "photo-status photo-error";
          }
          e.target.value = "";
          return;
        }

        interiorOriginals = files;

        if (interiorsCountEl) {
          interiorsCountEl.style.display = "block";
          interiorsCountEl.textContent = files.length + "/" + MAX_INTERIORS + " " + (isEs ? "fotos seleccionadas" : "photos selected");
        }

        if (interiorsStatus) {
          interiorsStatus.style.display = "block";
          interiorsStatus.textContent = "⏳ " + (isEs ? "Comprimiendo" : "Compressing") + " " + files.length + " " + (isEs ? "foto" : "photo") + (files.length > 1 ? "s" : "") + "...";
          interiorsStatus.className = "photo-status";
        }
        if (interiorsPreview) interiorsPreview.innerHTML = "";

        try {
          var totalKb = 0;
          for (var i = 0; i < files.length; i++) {
            if (interiorsStatus) {
              interiorsStatus.textContent = "⏳ " + (isEs ? "Comprimiendo" : "Compressing") + " " + (i + 1) + "/" + files.length + "...";
            }
            var blob = await compressImage(files[i]);
            if (blob.size > MAX_BYTES) {
              if (interiorsStatus) {
                interiorsStatus.textContent = "❌ " + (isEs ? "Foto" : "Photo") + " " + (i + 1) + " " + (isEs ? "muy grande después de comprimir." : "still too large after compression.");
                interiorsStatus.className = "photo-status photo-error";
              }
              interiorBlobs = [];
              if (interiorsPreview) interiorsPreview.innerHTML = "";
              return;
            }
            interiorBlobs.push(blob);
            totalKb += Math.round(blob.size / 1024);

            if (interiorsPreview) {
              const blobIndex = interiorBlobs.length - 1;
              var item = createPreviewItem(blob, function (rotatedBlob) {
                interiorBlobs[blobIndex] = rotatedBlob;
              });
              interiorsPreview.appendChild(item);
            }
          }

          if (interiorsStatus) {
            interiorsStatus.textContent = "✅ " + files.length + " " + (isEs ? "foto" : "photo") + (files.length > 1 ? "s" : "") + " — " + totalKb + " KB total";
            interiorsStatus.className = "photo-status photo-ok";
          }
          if (interiorsHint) interiorsHint.style.display = "block";
        } catch (err) {
          interiorBlobs = [];
          if (interiorsStatus) {
            interiorsStatus.style.display = "block";
            interiorsStatus.textContent = "⚠️ " + (isEs ? "No se pudo comprimir — se subirán los originales." : "Could not compress — originals will be uploaded.");
            interiorsStatus.className = "photo-status";
          }
        }
      });
    }

    // ── Form submit via fetch ──────────────────
    var shareForm = document.getElementById("shareForm");
    if (shareForm) {
      shareForm.addEventListener("submit", async function (e) {
        e.preventDefault();
        var submitBtn = document.getElementById("submitBtn");
        var origLabel = submitBtn ? submitBtn.textContent : "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "⏳ " + (document.documentElement.lang === "es" ? "Subiendo…" : "Uploading…");
        }

        // Upload progress bar
        var progressWrap = document.createElement("div");
        progressWrap.className = "upload-progress";
        var progressBar = document.createElement("div");
        progressBar.className = "upload-progress-bar";
        progressWrap.appendChild(progressBar);
        if (submitBtn) submitBtn.parentElement.insertBefore(progressWrap, submitBtn);

        try {
          var fd = new FormData();
          var formElements = shareForm.elements;
          for (var i = 0; i < formElements.length; i++) {
            var el = formElements[i];
            if (!el.name || el.name === "cover_photo" || el.name === "interior_photos" || el.type === "submit") continue;
            if (el.type === "checkbox") {
              if (el.checked) fd.append(el.name, "on");
            } else {
              fd.append(el.name, el.value);
            }
          }

          // Cover photo (first photo → photo_url)
          var coverToSend = null;
          if (coverBlob) {
            coverToSend = (coverBlob instanceof File)
              ? coverBlob
              : new File([coverBlob], "cover" + outExt, { type: coverBlob.type || outMime });
          } else {
            coverToSend = coverOriginal;
          }
          if (coverToSend) fd.append("photos", coverToSend);

          // Interior photos (→ extra_photos)
          var interiorsToSend = interiorBlobs.length > 0
            ? interiorBlobs.map(function (b, i) {
                return (b instanceof File)
                  ? b
                  : new File([b], "interior_" + (i + 1) + outExt, { type: b.type || outMime });
              })
            : interiorOriginals;
          for (var i = 0; i < interiorsToSend.length; i++) {
            fd.append("photos", interiorsToSend[i]);
          }

          // Simulate progress
          var pct = 0;
          var pInterval = setInterval(function() {
            if (pct < 90) { pct += Math.random() * 15; progressBar.style.width = Math.min(pct, 90) + "%"; }
          }, 300);

          var res = await fetch(window.location.pathname, {
            method: "POST",
            body: fd,
            credentials: "same-origin",
          });

          clearInterval(pInterval);
          progressBar.style.width = "100%";

          if (!res.ok) throw new Error("status " + res.status);
          window.location.reload();
        } catch (err) {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = origLabel;
          }
          if (progressWrap) progressWrap.remove();
          if (coverStatus) {
            coverStatus.style.display = "block";
            coverStatus.textContent = "❌ Upload failed. Please try again.";
            coverStatus.className = "photo-status photo-error";
          }
        }
      });
    }

    // ── Edit review buttons ──────────────────────
    document.querySelectorAll(".btn-edit").forEach(btn => {
      btn.addEventListener("click", () => {
        try {
          const data = JSON.parse(btn.getAttribute("data-edit"));
          const form = document.getElementById("shareForm");
          if (!form) return;
          document.getElementById("editId").value = data.id;

          if (hiddenInput) hiddenInput.value = data.book_id;
          if (searchInput) {
            const opt = allOptions.length ? allOptions.find(o => o.getAttribute("data-value") === data.book_id) : null;
            searchInput.value = opt ? opt.textContent : data.book_id;
            searchInput.setCustomValidity("");
            searchInput.readOnly = true;
          }

          const reviewField = document.getElementById("review_text");
          if (reviewField) reviewField.value = data.review_text;

          if (ratingInput && picker) {
            ratingInput.value = data.rating;
            const starBtns = picker.querySelectorAll(".star-btn");
            starBtns.forEach((s, j) => s.dataset.selected = j < data.rating ? "true" : "false");
          }

          const coverInput2 = document.getElementById("coverPhoto");
          if (coverInput2) coverInput2.removeAttribute("required");
          const interiorsInput2 = document.getElementById("interiorPhotos");
          if (interiorsInput2) interiorsInput2.removeAttribute("required");

          form.scrollIntoView({ behavior: "smooth", block: "start" });
        } catch(e) { console.error(e); }
      });
    });
  });
</script>

<style>
  /* ── Drag & Drop Photo Zone ── */
  .field-hint {
    display: block;
    font-size: 0.82rem;
    color: var(--ink-soft);
    margin-bottom: 0.4rem;
  }
  .photo-dropzone {
    position: relative;
    border: 2px dashed var(--line);
    border-radius: var(--radius);
    padding: 2rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .photo-dropzone:hover,
  .photo-dropzone.dragover {
    border-color: var(--brand-blue);
    background: rgba(31, 79, 134, 0.04);
  }
  .dropzone-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .dropzone-icon { font-size: 2.4rem; display: block; margin-bottom: 0.3rem; }
  .dropzone-text { margin: 0; font-weight: 600; color: var(--ink); }
  .dropzone-hint { color: var(--ink-soft); font-size: 0.82rem; }

  .photo-count {
    display: block;
    margin-top: 0.3rem;
    font-weight: 600;
    color: var(--brand-blue);
    font-size: 0.85rem;
  }

  /* ── Upload Progress ── */
  .upload-progress {
