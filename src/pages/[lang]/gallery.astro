---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase } from "../../lib/supabase";
import { books } from "../../data/books";
import { getSampleItems, SAMPLE_THRESHOLD } from "../../data/sample-reviews";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/gallery/`;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://www.littlechubbypress.com";

const bookMap = Object.fromEntries(books.map(b => [b.id, b.title[lang]]));
const bookOptions = books.map(b => ({ id: b.id, title: b.title[lang] }));
const stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);

const PAGE_SIZE = 12;

// Fetch initial items + total count
let items: any[] = [];
let totalCount = 0;
let fetchError = false;
try {
  const { count } = await supabase
    .from("gallery_feed")
    .select("id", { count: "exact", head: true });
  totalCount = count ?? 0;

  const { data: gallery, error } = await supabase
    .from("gallery_feed")
    .select("id, book_id, photo_url, extra_photos, rating, review_text, featured, submitted_at, display_name")
    .range(0, PAGE_SIZE - 1);
  if (error) throw error;
  items = gallery ?? [];
} catch {
  fetchError = true;
}

// Merge sample reviews when gallery is empty or has few real reviews
const realCount = items.length;
if (realCount < SAMPLE_THRESHOLD && !fetchError) {
  const samples = getSampleItems(lang);
  items = [...samples, ...items];
  if (totalCount < SAMPLE_THRESHOLD) {
    totalCount = items.length;
  }
}
---

<BaseLayout
  lang={lang}
  title={text.galleryMetaTitle}
  description={text.galleryDescription}
  pathname={pathname}
  breadcrumbs={[
    { name: text.navHome, url: `/${lang}/` },
    { name: text.galleryHeading, url: pathname }
  ]}
>
  <section class="page-section container">
    <div class="section-head" style="text-align:center; max-width:42rem; margin:0 auto 2rem;">
      <h1>{text.galleryHeading}</h1>
      <p>{text.galleryDescription}</p>
    </div>

    {fetchError ? (
      <div style="text-align:center; padding:2rem;">
        <p style="color:var(--accent-coral); font-weight:700;">
          {lang === "es" ? "No pudimos cargar la galería. Intenta de nuevo más tarde." : "We couldn't load the gallery. Please try again later."}
        </p>
      </div>
    ) : items.length === 0 ? (
      <p style="text-align:center; color:var(--ink-soft);">{text.galleryEmpty}</p>
    ) : (
      <div>
        {/* ── Filter Bar ── */}
        <div class="gallery-filters">
          <div class="filter-group">
            <label for="filterBook">{text.galleryFilterBook}</label>
            <select id="filterBook" class="filter-select">
              <option value="">{text.galleryFilterAll}</option>
              {bookOptions.map(b => (
                <option value={b.id}>{b.title}</option>
              ))}
            </select>
          </div>
          <div class="filter-group">
            <label>{text.galleryFilterRating}</label>
            <div class="filter-stars" id="filterStars">
              <button type="button" class="filter-star-btn active" data-rating="">{text.galleryFilterAll}</button>
              {[5,4,3,2,1].map(n => (
                <button type="button" class="filter-star-btn" data-rating={n.toString()}>{"★".repeat(n)}</button>
              ))}
            </div>
          </div>
          <div class="filter-group">
            <label class="filter-toggle">
              <input type="checkbox" id="filterFeatured" />
              {text.galleryFilterFeatured}
            </label>
          </div>
          <button type="button" class="btn btn-ghost filter-reset" id="resetFilters" style="font-size:0.82rem;">
            {text.galleryResetFilters}
          </button>
        </div>

        {/* ── Counter ── */}
        <p class="gallery-counter" id="galleryCounter">
          {text.galleryShowing} <strong id="shownCount">{items.length}</strong> {text.galleryOf} <strong id="totalCount">{totalCount}</strong>
        </p>

        {/* ── Grid ── */}
        <div class="gallery-grid" id="galleryGrid">
          {items.map((item: any) => {
            const extras: string[] = item.extra_photos || [];
            const allPhotos = [item.photo_url, ...extras];
            return (
            <article
              class={`gallery-card${item.featured ? " featured" : ""}${item.isSample ? " sample" : ""}`}
              id={`review-${item.id}`}
              data-book={item.book_id}
              data-rating={item.rating}
              data-featured={item.featured ? "1" : "0"}
              data-photo={item.photo_url}
              data-extras={JSON.stringify(extras)}
              data-all-photos={JSON.stringify(allPhotos)}
              data-review={item.review_text || ""}
              data-author={item.display_name}
              data-id={item.id}
            >
              {item.featured && <span class="featured-badge">{text.galleryFeatured}</span>}
              <div class="gallery-img-wrap">
                <img src={item.photo_url} alt={bookMap[item.book_id] || item.book_id} class="gallery-img" loading="lazy" width="320" height="240" />
              </div>
              {extras.length > 0 && (
                <div class="gallery-thumbs">
                  {extras.slice(0, 3).map((url: string, i: number) => (
                    <button type="button" class="gallery-thumb" data-idx={i + 1}>
                      <img src={url} alt={`Interior ${i + 1}`} loading="lazy" width="48" height="48" />
                    </button>
                  ))}
                  {extras.length > 3 && (
                    <span class="gallery-thumb-more">+{extras.length - 3}</span>
                  )}
                </div>
              )}
              <div class="gallery-body">
                <strong class="gallery-book">{bookMap[item.book_id] || item.book_id}</strong>
                <span class="gallery-stars">{stars(item.rating)}</span>
                {item.review_text && <p class="gallery-text">{item.review_text}</p>}
                <div class="gallery-footer">
                  <span class="gallery-author">— {item.display_name}</span>
                  <button type="button" class="share-btn" title={text.galleryShareReview} data-id={item.id} data-book={bookMap[item.book_id] || item.book_id}>
                    ↗
                  </button>
                </div>
              </div>
            </article>
            );
          })}
        </div>

        {/* ── Skeleton loader ── */}
        <div class="gallery-grid skeleton-grid" id="skeletonGrid" style="display:none;">
          {[1,2,3,4].map(() => (
            <div class="skeleton-card">
              <div class="skeleton-img"></div>
              <div class="skeleton-body">
                <div class="skeleton-line w60"></div>
                <div class="skeleton-line w40"></div>
                <div class="skeleton-line w80"></div>
              </div>
            </div>
          ))}
        </div>

        {/* ── Load More ── */}
        {totalCount > PAGE_SIZE && (
          <div style="text-align:center; margin-top:2rem;">
            <button type="button" class="btn btn-primary" id="loadMoreBtn">
              {text.galleryLoadMore}
            </button>
          </div>
        )}
      </div>
    )}

    <div style="text-align:center; margin-top:2.5rem;">
      <a href={`/${lang}/lottery/`} class="btn btn-primary">📸 {text.shareYourBook}</a>
    </div>
  </section>

  {/* ── Lightbox Modal ── */}
  <div class="lightbox-overlay" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox-close" id="lightboxClose" aria-label={text.galleryCloseModal}>&times;</button>
    <button class="lightbox-nav lightbox-prev" id="lightboxPrev" aria-label={text.galleryPrev}>‹</button>
    <button class="lightbox-nav lightbox-next" id="lightboxNext" aria-label={text.galleryNext}>›</button>
    <div class="lightbox-content">
      <img id="lightboxImg" src="" alt="" class="lightbox-image" />
      <div class="lightbox-dots" id="lightboxDots"></div>
      <div class="lightbox-info">
        <strong id="lightboxBook" class="lightbox-book"></strong>
        <span id="lightboxStars" class="lightbox-stars"></span>
        <p id="lightboxText" class="lightbox-text"></p>
        <span id="lightboxAuthor" class="lightbox-author"></span>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ lang, siteUrl, PAGE_SIZE, bookMapJson: JSON.stringify(bookMap), textsJson: JSON.stringify({loadMore: text.galleryLoadMore, showing: text.galleryShowing, of: text.galleryOf, featured: text.galleryFeatured, share: text.galleryShareReview, copyLink: text.galleryCopyLink, linkCopied: text.galleryLinkCopied}) }}>
document.addEventListener("DOMContentLoaded", () => {
  const bookMap = JSON.parse(bookMapJson);
  const txt = JSON.parse(textsJson);
  const grid = document.getElementById("galleryGrid");
  const loadMoreBtn = document.getElementById("loadMoreBtn");
  const shownEl = document.getElementById("shownCount");
  const totalEl = document.getElementById("totalCount");
  const skeleton = document.getElementById("skeletonGrid");

  let offset = PAGE_SIZE;
  let activeFilters = { book: "", rating: "", featured: false };
  const starsStr = (n) => "★".repeat(n) + "☆".repeat(5 - n);

  // ── Create card HTML ──
  function createCard(item) {
    const art = document.createElement("article");
    const extras = item.extra_photos || [];
    const allPhotos = [item.photo_url, ...extras];
    art.className = "gallery-card" + (item.featured ? " featured" : "");
    art.id = "review-" + item.id;
    art.dataset.book = item.book_id;
    art.dataset.rating = item.rating;
    art.dataset.featured = item.featured ? "1" : "0";
    art.dataset.photo = item.photo_url;
    art.dataset.extras = JSON.stringify(extras);
    art.dataset.allPhotos = JSON.stringify(allPhotos);
    art.dataset.review = item.review_text || "";
    art.dataset.author = item.display_name;
    art.dataset.id = item.id;
    const bookTitle = bookMap[item.book_id] || item.book_id;

    let thumbsHtml = "";
    if (extras.length > 0) {
      const thumbItems = extras.slice(0, 3).map((url, i) =>
        '<button type="button" class="gallery-thumb" data-idx="' + (i+1) + '"><img src="' + url + '" alt="Interior ' + (i+1) + '" loading="lazy" width="48" height="48" /></button>'
      ).join("");
      const moreHtml = extras.length > 3 ? '<span class="gallery-thumb-more">+' + (extras.length - 3) + '</span>' : '';
      thumbsHtml = '<div class="gallery-thumbs">' + thumbItems + moreHtml + '</div>';
    }

    art.innerHTML = (item.featured ? '<span class="featured-badge">' + txt.featured + '</span>' : '') +
      '<div class="gallery-img-wrap"><img src="' + item.photo_url + '" alt="' + bookTitle + '" class="gallery-img" loading="lazy" width="320" height="240" /></div>' +
      thumbsHtml +
      '<div class="gallery-body">' +
        '<strong class="gallery-book">' + bookTitle + '</strong>' +
        '<span class="gallery-stars">' + starsStr(item.rating) + '</span>' +
        (item.review_text ? '<p class="gallery-text">' + item.review_text + '</p>' : '') +
        '<div class="gallery-footer"><span class="gallery-author">— ' + item.display_name + '</span>' +
        '<button type="button" class="share-btn" title="' + txt.share + '" data-id="' + item.id + '" data-book="' + bookTitle + '">↗</button></div></div>';
    return art;
  }

  // ── Load more ──
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener("click", async () => {
      loadMoreBtn.disabled = true;
      loadMoreBtn.textContent = "⏳...";
      skeleton.style.display = "grid";
      try {
        const params = new URLSearchParams();
        params.set("select", "id,book_id,photo_url,extra_photos,rating,review_text,featured,submitted_at,display_name");
        const from = offset;
        const to = offset + PAGE_SIZE - 1;

        let query = supabaseRest("gallery_feed", params, from, to);
        const data = await query;
        if (data.length > 0) {
          data.forEach(item => grid.appendChild(createCard(item)));
          offset += data.length;
          if (shownEl) shownEl.textContent = offset;
          observeCards();
        }
        if (data.length < PAGE_SIZE) {
          loadMoreBtn.style.display = "none";
        }
      } catch(e) { console.error(e); }
      skeleton.style.display = "none";
      loadMoreBtn.disabled = false;
      loadMoreBtn.textContent = txt.loadMore;
    });
  }

  // ── Supabase REST helper ──
  async function supabaseRest(table, extraParams, from, to) {
    const base = document.querySelector('meta[name="x-sb-url"]')?.content;
    const key = document.querySelector('meta[name="x-sb-key"]')?.content;
    if (!base || !key) return [];
    const url = base + "/rest/v1/" + table + "?" + extraParams.toString();
    const res = await fetch(url, {
      headers: {
        apikey: key,
        Authorization: "Bearer " + key,
        Range: from + "-" + to,
        Prefer: "count=exact",
      },
    });
    const total = res.headers.get("content-range")?.split("/")[1];
    if (total && totalEl) totalEl.textContent = total;
    return res.json();
  }

  // ── Filters ──
  const filterBook = document.getElementById("filterBook");
  const filterStars = document.getElementById("filterStars");
  const filterFeatured = document.getElementById("filterFeatured");
  const resetBtn = document.getElementById("resetFilters");

  async function applyFilters() {
    skeleton.style.display = "grid";
    grid.innerHTML = "";
    const params = new URLSearchParams();
    params.set("select", "id,book_id,photo_url,extra_photos,rating,review_text,featured,submitted_at,display_name");
    if (activeFilters.book) params.set("book_id", "eq." + activeFilters.book);
    if (activeFilters.rating) params.set("rating", "eq." + activeFilters.rating);
    if (activeFilters.featured) params.set("featured", "eq.true");
    params.set("order", "featured.desc,submitted_at.desc");
    try {
      const data = await supabaseRest("gallery_feed", params, 0, PAGE_SIZE - 1);
      data.forEach(item => grid.appendChild(createCard(item)));
      offset = data.length;
      if (shownEl) shownEl.textContent = data.length;
      if (loadMoreBtn) loadMoreBtn.style.display = data.length >= PAGE_SIZE ? "" : "none";
      observeCards();
    } catch(e) { console.error(e); }
    skeleton.style.display = "none";
  }

  if (filterBook) filterBook.addEventListener("change", () => { activeFilters.book = filterBook.value; applyFilters(); });
  if (filterFeatured) filterFeatured.addEventListener("change", () => { activeFilters.featured = filterFeatured.checked; applyFilters(); });
  if (filterStars) {
    filterStars.querySelectorAll(".filter-star-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        filterStars.querySelectorAll(".filter-star-btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        activeFilters.rating = btn.dataset.rating;
        applyFilters();
      });
    });
  }
  if (resetBtn) {
    resetBtn.addEventListener("click", () => {
      activeFilters = { book: "", rating: "", featured: false };
      if (filterBook) filterBook.value = "";
      if (filterFeatured) filterFeatured.checked = false;
      if (filterStars) {
        filterStars.querySelectorAll(".filter-star-btn").forEach((b, i) => b.classList.toggle("active", i === 0));
      }
      applyFilters();
    });
  }

  // ── Lightbox ──
  const lightbox = document.getElementById("lightbox");
  const lbImg = document.getElementById("lightboxImg");
  const lbBook = document.getElementById("lightboxBook");
  const lbStars = document.getElementById("lightboxStars");
  const lbText = document.getElementById("lightboxText");
  const lbAuthor = document.getElementById("lightboxAuthor");
  const lbClose = document.getElementById("lightboxClose");
  const lbPrev = document.getElementById("lightboxPrev");
  const lbNext = document.getElementById("lightboxNext");
  const lbDots = document.getElementById("lightboxDots");
  let lbIndex = 0;       // card index
  let lbPhotoIdx = 0;    // photo index within current card
  let lbPhotos = [];     // all photos for current card

  function getCards() { return grid.querySelectorAll(".gallery-card"); }

  function renderDots() {
    if (lbPhotos.length <= 1) { lbDots.innerHTML = ""; return; }
    lbDots.innerHTML = lbPhotos.map((_, i) =>
      '<button type="button" class="lb-dot' + (i === lbPhotoIdx ? ' active' : '') + '" data-pi="' + i + '"></button>'
    ).join("") + '<span class="lb-counter">' + (lbPhotoIdx + 1) + '/' + lbPhotos.length + '</span>';
  }

  function showPhoto() {
    lbImg.src = lbPhotos[lbPhotoIdx];
    renderDots();
  }

  function openLightbox(idx, photoIdx) {
    const cards = getCards();
    if (idx < 0 || idx >= cards.length) return;
    lbIndex = idx;
    lbPhotoIdx = photoIdx || 0;
    const card = cards[idx];
    try { lbPhotos = JSON.parse(card.dataset.allPhotos || "[]"); } catch { lbPhotos = [card.dataset.photo]; }
    if (lbPhotos.length === 0) lbPhotos = [card.dataset.photo];
    if (lbPhotoIdx >= lbPhotos.length) lbPhotoIdx = 0;
    lbImg.alt = bookMap[card.dataset.book] || card.dataset.book;
    lbBook.textContent = bookMap[card.dataset.book] || card.dataset.book;
    lbStars.textContent = starsStr(parseInt(card.dataset.rating));
    lbText.textContent = card.dataset.review || "";
    lbAuthor.textContent = "— " + card.dataset.author;
    showPhoto();
    lightbox.classList.add("open");
    document.body.style.overflow = "hidden";
    lbClose.focus();
  }

  function lbPrevPhoto() {
    if (lbPhotos.length > 1 && lbPhotoIdx > 0) {
      lbPhotoIdx--;
      showPhoto();
    } else {
      // go to previous card, last photo
      const cards = getCards();
      const prevIdx = lbIndex - 1;
      if (prevIdx >= 0) {
        const prevCard = cards[prevIdx];
        let prevPhotos;
        try { prevPhotos = JSON.parse(prevCard.dataset.allPhotos || "[]"); } catch { prevPhotos = [prevCard.dataset.photo]; }
        openLightbox(prevIdx, (prevPhotos.length || 1) - 1);
      }
    }
  }

  function lbNextPhoto() {
    if (lbPhotos.length > 1 && lbPhotoIdx < lbPhotos.length - 1) {
      lbPhotoIdx++;
      showPhoto();
    } else {
      // go to next card, first photo
      openLightbox(lbIndex + 1, 0);
    }
  }

  function closeLightbox() {
    lightbox.classList.remove("open");
    document.body.style.overflow = "";
  }

  grid.addEventListener("click", (e) => {
    // Thumbnail click → open lightbox at that photo index
    const thumb = e.target.closest(".gallery-thumb");
    if (thumb) {
      const card = thumb.closest(".gallery-card");
      const cards = getCards();
      const idx = [...cards].indexOf(card);
      const photoIdx = parseInt(thumb.dataset.idx) || 0;
      if (idx >= 0) openLightbox(idx, photoIdx);
      return;
    }
    const img = e.target.closest(".gallery-img");
    if (!img) return;
    const card = img.closest(".gallery-card");
    const cards = getCards();
    const idx = [...cards].indexOf(card);
    if (idx >= 0) openLightbox(idx, 0);
  });

  lbClose.addEventListener("click", closeLightbox);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
    // Dot click
    const dot = e.target.closest(".lb-dot");
    if (dot) { lbPhotoIdx = parseInt(dot.dataset.pi) || 0; showPhoto(); }
  });
  lbPrev.addEventListener("click", () => lbPrevPhoto());
  lbNext.addEventListener("click", () => lbNextPhoto());
  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("open")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") lbPrevPhoto();
    if (e.key === "ArrowRight") lbNextPhoto();
  });

  // ── Share buttons ──
  document.addEventListener("click", (e) => {
    const btn = e.target.closest(".share-btn");
    if (!btn) return;
    const reviewId = btn.dataset.id;
    const bookTitle = btn.dataset.book;
    const shareUrl = siteUrl + "/" + lang + "/gallery/#review-" + reviewId;
    const shareText = (lang === "es"
      ? "Mira mi review de " + bookTitle + " en @LittleChubbyPress!"
      : "Check out my review of " + bookTitle + " on @LittleChubbyPress!");

    if (navigator.share) {
      navigator.share({ title: bookTitle, text: shareText, url: shareUrl }).catch(() => {});
    } else {
      navigator.clipboard.writeText(shareUrl).then(() => {
        btn.textContent = "✓";
        setTimeout(() => { btn.textContent = "↗"; }, 2000);
      }).catch(() => {});
    }
  });

  // ── Fade-in on scroll ──
  function observeCards() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    grid.querySelectorAll(".gallery-card:not(.visible)").forEach(card => observer.observe(card));
  }
  observeCards();
});
</script>

<style>
  /* ── Filter Bar ── */
  .gallery-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-end;
    margin-bottom: 1.2rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }
  .filter-group { display: flex; flex-direction: column; gap: 0.3rem; }
  .filter-group label { font-size: 0.78rem; font-weight: 600; color: var(--ink-soft); text-transform: uppercase; letter-spacing: 0.04em; }
  .filter-select {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--bg);
    font-size: 0.88rem;
    min-width: 10rem;
  }
  .filter-stars { display: flex; gap: 0.35rem; flex-wrap: wrap; }
  .filter-star-btn {
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--bg);
    cursor: pointer;
    font-size: 0.82rem;
    color: var(--accent-gold);
    transition: background 0.15s, border-color 0.15s;
  }
  .filter-star-btn.active { background: var(--accent-gold); color: #fff; border-color: var(--accent-gold); }
  .filter-toggle { display: flex; align-items: center; gap: 0.4rem; cursor: pointer; font-size: 0.88rem; }
  .filter-reset { align-self: flex-end; }
  .gallery-counter { font-size: 0.85rem; color: var(--ink-soft); margin-bottom: 0.8rem; }

  /* ── Grid ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.4rem;
  }

  /* ── Card ── */
  .gallery-card {
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--surface);
    overflow: hidden;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.45s ease, transform 0.45s ease, box-shadow 0.2s;
  }
  .gallery-card.visible { opacity: 1; transform: translateY(0); }
  .gallery-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.1); transform: translateY(-4px); }
  .gallery-card.visible:hover { transform: translateY(-4px); }
  .gallery-card.featured {
    border-color: var(--accent-gold);
    box-shadow: 0 0 0 2px rgba(211,164,66,0.2);
  }
  .featured-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--accent-gold);
    color: #fff;
    font-family: "Baloo 2", sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    z-index: 2;
  }
  .gallery-img-wrap { overflow: hidden; }
  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    cursor: pointer;
    transition: transform 0.35s ease;
  }
