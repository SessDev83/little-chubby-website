            <label style="display:flex; align-items:flex-start; gap:0.55rem; cursor:pointer; margin-bottom:0.55rem;">
              <input
                type="checkbox"
                name="notif_community"
                checked={(profile?.notification_prefs?.community ?? true) === true}
                style="margin-top:0.2rem;"
              />
              <span>
                <strong>{text.profileNotifCommunity}</strong><br />
                <span style="font-size:0.85rem; color:var(--muted);">{text.profileNotifCommunityHint}</span>
              </span>
            </label>

            <label style="display:flex; align-items:flex-start; gap:0.55rem; cursor:pointer;">
              <input
                type="checkbox"
                name="notif_shop"
                checked={(profile?.notification_prefs?.shop ?? true) === true}
                style="margin-top:0.2rem;"
              />
              <span>
                <strong>{text.profileNotifShop}</strong><br />
                <span style="font-size:0.85rem; color:var(--muted);">{text.profileNotifShopHint}</span>
