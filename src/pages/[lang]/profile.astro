<script is:inline define:vars={{ displayName: profile?.display_name || "" }}>
  if (displayName) {
    localStorage.setItem("lcp-display-name", displayName);
  } else {
    localStorage.removeItem("lcp-display-name");
  }
  // Update header username immediately if element already exists
  var el = document.getElementById("auth-username");
  if (el) el.textContent = displayName || "";

  // Peanuts balance for profile card
  fetch("/api/me/", { credentials: "same-origin" })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.user && typeof d.balance === "number") {
        var card = document.getElementById("peanuts-profile-card");
        var bal = document.getElementById("profile-peanuts-balance");
        if (card) card.style.display = "flex";
        if (bal) bal.textContent = String(d.balance);
      }
    })
    .catch(function(){});
</script>

<script is:inline>
  // Phase F — featured badge picker
  (function(){
    var picker = document.getElementById("featured-badge-picker");
    if (!picker) return;
    var container = picker.querySelector(".featured-picker");
    var status = document.getElementById("featured-badge-status");
    if (!container) return;
    var busy = false;

    container.addEventListener("click", function(ev){
      var btn = ev.target.closest(".featured-option");
      if (!btn || busy) return;
      var badge = btn.getAttribute("data-badge") || "";
      var current = container.getAttribute("data-current") || "";
      if (badge === current) return;

      busy = true;
      status.textContent = "…";
      status.style.color = "var(--ink-soft)";

      fetch("/api/set-featured-badge/", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ badge_type: badge || null }),
      })
        .then(function(r){ return r.json().then(function(j){ return { ok: r.ok, j: j }; }); })
        .then(function(res){
          busy = false;
          if (!res.ok || !res.j || res.j.success === false) {
            status.textContent = (res.j && res.j.error) || "Error";
            status.style.color = "#8f1f18";
            return;
          }
          container.setAttribute("data-current", res.j.featured_badge || "");
          var all = container.querySelectorAll(".featured-option");
          all.forEach(function(b){
            var bg = b.getAttribute("data-badge") || "";
            b.setAttribute("aria-pressed", bg === (res.j.featured_badge || "") ? "true" : "false");
          });
          status.textContent = "✓";
          status.style.color = "var(--brand-green, #5c9650)";
          setTimeout(function(){ status.textContent = ""; }, 1400);
        })
        .catch(function(){
          busy = false;
          status.textContent = "Error";
          status.style.color = "#8f1f18";
        });
    });
  })();
</script>
