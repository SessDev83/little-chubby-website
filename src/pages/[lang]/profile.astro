        </form>
      </div>

      </div>{/* /panel-settings */}

      <div id="panel-security" class="tab-panel" data-panel="security" role="tabpanel" aria-labelledby="tab-security" hidden>

      <div class="profile-forms">
        {/* ── Security section ── */}
        <div class="surface-card profile-section">
          <h2 class="profile-section-title">{text.profileSecurity}</h2>

          {securityMessage && (
            <p class={`auth-message ${securityMessageType}`}>{securityMessage}</p>
          )}

          {/* Change email */}
          <details class="security-block">
            <summary>{text.profileChangeEmail}</summary>
            <form method="POST" class="security-form">
              <input type="hidden" name="action" value="change-email" />
              <div class="form-group">
                <label for="new_email">{text.profileNewEmail}</label>
                <input
                  type="email"
                  id="new_email"
                  name="new_email"
                  required
                  autocomplete="email"
                  inputmode="email"
                  placeholder={user.email || ""}
                />
              </div>
              <button type="submit" class="btn btn-primary btn-sm">
                {text.profileChangeEmailSubmit}
              </button>
            </form>
          </details>

          {/* Change / set password */}
          <details class="security-block">
            <summary>{text.profileChangePassword}</summary>
            <form method="POST" class="security-form">
              <input type="hidden" name="action" value="change-password" />
              <div class="form-group">
                <label for="new_password">{text.profileNewPassword}</label>
                <input
                  type="password"
                  id="new_password"
                  name="new_password"
                  required
                  autocomplete="new-password"
                  minlength="6"
                />
              </div>
              <div class="form-group">
                <label for="confirm_password">{text.profileConfirmPassword}</label>
                <input
                  type="password"
                  id="confirm_password"
                  name="confirm_password"
                  required
                  autocomplete="new-password"
                  minlength="6"
                />
              </div>
              <button type="submit" class="btn btn-primary btn-sm">
                {text.profileChangePasswordSubmit}
              </button>
            </form>
          </details>
        </div>

        {/* ── Privacy & data (GDPR) section ── */}
        <div class="surface-card profile-section" id="privacy-data">
          <h2 class="profile-section-title">{text.profilePrivacyTitle}</h2>
          <p class="profile-section-subtitle">{text.profilePrivacySubtitle}</p>

          <details class="security-block">
            <summary>{text.profileExportDataTitle}</summary>
            <p class="privacy-block-hint">{text.profileExportDataHint}</p>
            <a
              href={`/api/export-my-data`}
              class="btn btn-primary btn-sm"
              download
              rel="nofollow"
            >
              {text.profileExportDataButton}
            </a>
            <p class="privacy-block-foot">
              {text.profileExportDataFoot}{" "}
              <a href={`/${lang}/privacy/`}>{text.profilePrivacyLink}</a>
            </p>
          </details>

          <details class="security-block danger-block">
            <summary>{text.profileDeleteTitle}</summary>
            <p class="privacy-block-hint">{text.profileDeleteHint}</p>
            <form id="delete-account-form" class="security-form" novalidate>
              <div class="form-group">
                <label for="delete-confirm">{text.profileDeleteConfirmLabel}</label>
                <input
                  type="email"
