---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase } from "../../lib/supabase";
import { validateOrigin } from "../../lib/csrf";
import { getServiceClient } from "../../lib/supabase";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/profile/`;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/${lang}/login/`);
}

// Fetch profile
interface Profile {
  display_name: string | null;
  lang_pref: string | null;
  avatar_url: string | null;
  phone: string | null;
  address_line1: string | null;
  address_line2: string | null;
  city: string | null;
  state: string | null;
  zip_code: string | null;
  country: string | null;
  show_in_leaderboards?: boolean | null;
  notification_prefs?: Record<string, boolean> | null;
  created_at?: string | null;
}

let profile: Profile | null = null;
let saveMessage = "";
let saveMessageType: "success" | "error" = "success";
let securityMessage = "";
let securityMessageType: "success" | "error" = "success";

const { data: profileData } = await supabase
  .from("profiles")
  .select("display_name, lang_pref, avatar_url, phone, address_line1, address_line2, city, state, zip_code, country, show_in_leaderboards, notification_prefs, accent_color, featured_badge, created_at")
  .eq("id", user.id)
  .single();
profile = profileData as (Profile & { created_at?: string | null }) | null;

// ── Activity stats (read-only, fail-safe) ──────────────────────────
let statDownloads = 0;
let statReviews = 0;
let statPeanutsEarned = 0;
let statTickets = 0;
let peanutsBalance = 0;
let latestReviewId: string | null = null;
let currentStreak = 0;
let longestStreak = 0;
try {
  const [dl, rv, tt, pn, lr, st] = await Promise.all([
    supabase.from("artwork_downloads").select("id", { count: "exact", head: true }).eq("user_id", user.id),
    supabase.from("book_reviews").select("id", { count: "exact", head: true }).eq("user_id", user.id).eq("status", "approved"),
    supabase.from("ticket_transactions").select("amount").eq("user_id", user.id),
    supabase.from("credit_transactions").select("amount").eq("user_id", user.id),
    supabase.from("book_reviews").select("id").eq("user_id", user.id).eq("status", "approved").order("submitted_at", { ascending: false }).limit(1).maybeSingle(),
    getServiceClient().rpc("touch_streak", { p_user_id: user.id }),
  ]);
  statDownloads = dl.count ?? 0;
  statReviews = rv.count ?? 0;
  statTickets = (tt.data ?? []).reduce((s, r: any) => s + (r.amount || 0), 0);
  const pnRows = pn.data ?? [];
  peanutsBalance = pnRows.reduce((s, r: any) => s + (r.amount || 0), 0);
  statPeanutsEarned = pnRows.reduce((s, r: any) => s + Math.max(0, r.amount || 0), 0);
  latestReviewId = (lr.data as any)?.id ?? null;
  const streakData: any = st?.data ?? {};
  currentStreak = Number(streakData.current_streak ?? 0);
  longestStreak = Number(streakData.longest_streak ?? 0);
} catch {
  // Silently degrade — if any table is missing, stats just show 0
}

// ── Phase A: profile badges (read-only, fail-safe) ─────────────────
// Temporary badges (top_earner_*) have expires_at; filter them out here.
let userBadges: string[] = [];
let hasFrameGold = false;
let hasFrameSilver = false;
try {
  const nowIso = new Date().toISOString();
  const { data: badgeRows } = await supabase
    .from("profile_badges")
    .select("badge_type, expires_at")
    .eq("user_id", user.id)
    .eq("active", true)
    .or(`expires_at.is.null,expires_at.gt.${nowIso}`);
  userBadges = (badgeRows ?? []).map((r: any) => r.badge_type).filter(Boolean);
  hasFrameGold = userBadges.includes("frame_gold");
  hasFrameSilver = userBadges.includes("frame_silver") && !hasFrameGold;
} catch {
  // No badges table yet or query failed — render no badges
}
const badgeEmoji: Record<string, string> = {
  frame_gold: "🖼️",
  frame_silver: "🪞",
  frame_animated: "🎭",
  top_reviewer: "⭐",
  star_parent: "💖",
  milestone_50: "🌱",
  milestone_100: "🌟",
  milestone_250: "💫",
  milestone_500: "🏆",
  milestone_1000: "👑",
};
const badgeLabelMap: Record<string, string> = {
  frame_gold: text.badgeFrameGold,
  frame_silver: text.badgeFrameSilver,
  frame_animated: text.badgeFrameAnimated,
  top_reviewer: text.badgeTopReviewer,
  star_parent: text.badgeStarParent,
  milestone_50: text.badgeMilestone50,
  milestone_100: text.badgeMilestone100,
  milestone_250: text.badgeMilestone250,
  milestone_500: text.badgeMilestone500,
  milestone_1000: text.badgeMilestone1000,
};

// Dynamic label for monthly top-earner badges (top_earner_YYYY_MM).
const MONTH_NAMES_ES = ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"];
const MONTH_NAMES_EN = ["January","February","March","April","May","June","July","August","September","October","November","December"];

// Drops catalog (D.4): badge_type → { label, icon }
const dropLabelMap: Record<string, { label: string; icon: string }> = {};
if (userBadges.some(b => /^drop_/.test(b))) {
  try {
    const dropTypes = userBadges.filter(b => /^drop_/.test(b));
    const { data: dropsMeta } = await supabase
      .from("shop_drops")
      .select("badge_type, label_es, label_en, icon")
      .in("badge_type", dropTypes);
    for (const row of (dropsMeta || [])) {
      dropLabelMap[row.badge_type] = {
        label: lang === "es" ? row.label_es : row.label_en,
        icon: row.icon || "🎁",
      };
    }
  } catch {}
}

function labelForBadge(bType: string): string {
  if (badgeLabelMap[bType]) return badgeLabelMap[bType];
  if (dropLabelMap[bType]) return dropLabelMap[bType].label;
  const m = /^top_earner_(\d{4})_(\d{2})$/.exec(bType);
  if (m) {
    const mi = parseInt(m[2], 10) - 1;
    const name = (lang === "es" ? MONTH_NAMES_ES : MONTH_NAMES_EN)[mi] || m[2];
    return `${text.badgeTopEarner} ${name} ${m[1]}`;
  }
  if (/^drop_/.test(bType)) return lang === "es" ? "Edición limitada" : "Limited edition";
  return bType;
}
function iconForBadge(bType: string): string {
  if (badgeEmoji[bType]) return badgeEmoji[bType];
  if (dropLabelMap[bType]) return dropLabelMap[bType].icon;
  if (/^top_earner_/.test(bType)) return "\uD83C\uDFC6";
  if (/^drop_/.test(bType)) return "\uD83C\uDF81";
  return "\u2B50";
}
const MILESTONES: { type: string; threshold: number }[] = [
  { type: "milestone_50", threshold: 50 },
  { type: "milestone_100", threshold: 100 },
  { type: "milestone_250", threshold: 250 },
  { type: "milestone_500", threshold: 500 },
  { type: "milestone_1000", threshold: 1000 },
];
const hasFrameAnimated = userBadges.includes("frame_animated");
const avatarFrameClass = hasFrameAnimated
  ? "frame-animated"
  : hasFrameGold ? "frame-gold" : hasFrameSilver ? "frame-silver" : "";
const accentColor = (profile as any)?.accent_color as string | null | undefined;
const accentClass = accentColor ? `has-accent accent-${accentColor}` : "";

function formatJoinDate(iso?: string | null): string {
  if (!iso) return "";
  try {
    const d = new Date(iso);
    return d.toLocaleDateString(lang === "es" ? "es-ES" : "en-US", { month: "long", year: "numeric" });
  } catch { return ""; }
}
const memberSince = formatJoinDate(profile?.created_at);

if (Astro.request.method === "POST") {
  if (!validateOrigin(Astro.request, Astro.url)) {
    saveMessage = "⛔ Request blocked.";
    saveMessageType = "error";
  } else {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString() || "save-profile";

  if (action === "save-profile") {
    const updates = {
      display_name: formData.get("display_name")?.toString().trim().slice(0, 100) || null,
      lang_pref: formData.get("lang_pref")?.toString().trim() || "es",
      phone: formData.get("phone")?.toString().trim().slice(0, 30) || null,
      address_line1: formData.get("address_line1")?.toString().trim().slice(0, 200) || null,
      address_line2: formData.get("address_line2")?.toString().trim().slice(0, 200) || null,
      city: formData.get("city")?.toString().trim().slice(0, 100) || null,
      state: formData.get("state")?.toString().trim().slice(0, 100) || null,
      zip_code: formData.get("zip_code")?.toString().trim().slice(0, 20) || null,
      country: formData.get("country")?.toString().trim().slice(0, 100) || null,
      show_in_leaderboards: formData.get("show_in_leaderboards") === "on",
      notification_prefs: {
        giveaway:  formData.get("notif_giveaway") === "on",
        community: formData.get("notif_community") === "on",
        shop:      formData.get("notif_shop") === "on",
      },
    };

    const { error } = await supabase
      .from("profiles")
      .update(updates)
      .eq("id", user.id);

    if (error) {
      saveMessage = text.loginError;
      saveMessageType = "error";
    } else {
      profile = { ...profile, ...updates } as Profile;
      saveMessage = text.profileSaved;
      saveMessageType = "success";
    }
  } else if (action === "change-email") {
    const newEmail = formData.get("new_email")?.toString().trim() || "";
    if (newEmail) {
      const { error } = await supabase.auth.updateUser({ email: newEmail });
      if (error) {
        securityMessage = error.message;
        securityMessageType = "error";
      } else {
        securityMessage = text.profileChangeEmailSuccess;
        securityMessageType = "success";
      }
    }
  } else if (action === "change-password") {
    const newPassword = formData.get("new_password")?.toString() || "";
    const confirmPassword = formData.get("confirm_password")?.toString() || "";

    if (newPassword.length < 6) {
      securityMessage = text.profilePasswordTooShort;
      securityMessageType = "error";
    } else if (newPassword !== confirmPassword) {
      securityMessage = text.profilePasswordMismatch;
      securityMessageType = "error";
    } else {
      const { error } = await supabase.auth.updateUser({ password: newPassword });
      if (error) {
        securityMessage = error.message;
        securityMessageType = "error";
      } else {
        securityMessage = text.profilePasswordChanged;
        securityMessageType = "success";
      }
    }
  }
  } // end CSRF else
}

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout lang={lang} title={text.profileMetaTitle} description={text.profileHeading} pathname={pathname}>
  <section class="page-section container">
    <div class="profile-layout">

      {/* ── Hero identity card ── */}
      <div class="profile-hero surface-card">
        <div class="hero-avatar">
          <div class={`avatar-wrap ${avatarFrameClass}`}>
            <img
              id="avatar-preview"
              src={profile?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(profile?.display_name || user.email || "U")}&background=4a90d9&color=fff&size=128`}
              alt={text.profileAvatar}
              width="112"
              height="112"
              class="avatar-img"
            />
          </div>
          <div class="avatar-actions">
            <label class="btn btn-secondary btn-sm" for="avatar-input" style="cursor:pointer;">
              {text.profileAvatarChange}
            </label>
            <input
              type="file"
              id="avatar-input"
              accept="image/jpeg,image/png,image/webp"
              style="display:none;"
            />
            {profile?.avatar_url && (
              <button type="button" id="avatar-remove" class="btn btn-secondary btn-sm" style="color:#8f1f18;">
                {text.profileAvatarRemove}
              </button>
            )}
          </div>
          <p id="avatar-status" style="font-size:0.82rem; color:var(--ink-soft); margin-top:0.4rem; text-align:center;"></p>
        </div>
        <div class="hero-info">
          <h1 class={`hero-name ${accentClass}`}>{profile?.display_name || user.email}</h1>
          {currentStreak > 0 && (
            <div class="streak-pill" title={longestStreak > currentStreak ? `${text.profileStreakBest || "Best"}: ${longestStreak}` : undefined}>
              <span class="streak-flame" aria-hidden="true">🔥</span>
              <span class="streak-count">{currentStreak}</span>
              <span class="streak-label">{currentStreak === 1 ? (text.profileStreakDay || "day") : (text.profileStreakDays || "day streak")}</span>
            </div>
          )}
          {userBadges.length > 0 && (
            <div class="profile-badge-strip" aria-label={text.profileBadgesTitle}>
              {userBadges.slice(0, 3).map((b: string) => (
                <a href="#badges-collection" class="profile-badge-chip" title={labelForBadge(b)}>
                  <span class="profile-badge-emoji" aria-hidden="true">{iconForBadge(b)}</span>
                  <span class="profile-badge-label">{labelForBadge(b)}</span>
                </a>
              ))}
              {userBadges.length > 3 && (
                <a href="#badges-collection" class="profile-badge-more" title={text.profileBadgesCollection}>
                  {text.badgesMore.replace("{n}", String(userBadges.length - 3))}
                </a>
              )}
            </div>
          )}
          <p class="hero-email">{user.email}</p>
          {memberSince && (
            <p class="hero-meta">🗓️ {text.profileMemberSince} {memberSince}</p>
          )}
          <div class="hero-currencies">
            <div class="currency-pill currency-peanuts" id="peanuts-profile-card">
              <span class="currency-icon" aria-hidden="true">🥜</span>
              <span class="currency-balance" id="profile-peanuts-balance">{peanutsBalance.toLocaleString()}</span>
              <span class="currency-label">Peanuts</span>
            </div>
            <div class="currency-pill currency-tickets">
              <span class="currency-icon" aria-hidden="true">🎟️</span>
              <span class="currency-balance">{statTickets.toLocaleString()}</span>
              <span class="currency-label">Tickets</span>
            </div>
          </div>
          <div class="hero-actions">
            <a href={`/${lang}/peanuts/`} class="btn btn-sm btn-primary">{text.peanutShopTitle} &amp; {text.peanutHistory}</a>
          </div>
        </div>
      </div>

      {/* ── Tab navigation ── */}
      <nav class="profile-tabs" role="tablist" aria-label={text.profileHeading}>
        <button type="button" role="tab" class="profile-tab is-active" data-tab="adventure" aria-selected="true" aria-controls="panel-adventure">
          <span class="profile-tab-icon" aria-hidden="true">🎮</span>
          <span class="profile-tab-label">{text.profileTabAdventure}</span>
        </button>
        <button type="button" role="tab" class="profile-tab" data-tab="settings" aria-selected="false" aria-controls="panel-settings">
          <span class="profile-tab-icon" aria-hidden="true">⚙️</span>
          <span class="profile-tab-label">{text.profileTabSettings}</span>
        </button>
        <button type="button" role="tab" class="profile-tab" data-tab="security" aria-selected="false" aria-controls="panel-security">
          <span class="profile-tab-icon" aria-hidden="true">🔒</span>
          <span class="profile-tab-label">{text.profileTabSecurity}</span>
        </button>
      </nav>

      <div id="panel-adventure" class="tab-panel" data-panel="adventure" role="tabpanel" aria-labelledby="tab-adventure">

      {/* ── Badges collection (all possible badges + owned state) ── */}
      <div id="badges-collection" class="profile-badges-panel surface-card">
        <div class="badges-panel-head">
          <div>
            <h2 class="profile-section-title" style="margin-top:0; margin-bottom:0.2rem;">{text.profileBadgesCollection}</h2>
            <p class="badges-panel-subtitle">{text.profileBadgesSubtitle}</p>
          </div>
          <span class="badges-count-pill">
            {text.profileBadgesCountOwned.replace("{owned}", String(userBadges.length)).replace("{total}", "5")}
          </span>
        </div>
        <div class="badges-collection-grid">
          {[
            { type: "frame_gold",     icon: "🖼️", cost: 15 },
            { type: "frame_silver",   icon: "🪞", cost: 15 },
            { type: "top_reviewer",   icon: "⭐", cost: 15 },
            { type: "star_parent",    icon: "💖", cost: 15 },
            { type: "frame_animated", icon: "🎭", cost: 20 },
          ].map((b) => {
            const owned = userBadges.includes(b.type);
            return (
              <div class={`badge-card ${owned ? "owned" : "locked"}`}>
                <div class="badge-card-icon" aria-hidden="true">{b.icon}</div>
                <div class="badge-card-name">{badgeLabelMap[b.type] || b.type}</div>
                {owned ? (
                  <span class="badge-card-status owned">✓ {text.profileBadgesOwned}</span>
                ) : (
                  <a href={`/${lang}/peanuts/#shop`} class="badge-card-status locked">
                    🥜 {b.cost} · {text.profileBadgesBuyNow}
                  </a>
                )}
              </div>
            );
          })}
        </div>
      </div>

      {/* ── Featured badge picker (Phase F — visibility loop) ── */}
      {userBadges.length > 0 && (
        <div id="featured-badge-picker" class="profile-badges-panel surface-card">
          <div class="badges-panel-head">
            <div>
              <h2 class="profile-section-title" style="margin-top:0; margin-bottom:0.2rem;">{text.profileFeaturedBadgeTitle}</h2>
              <p class="badges-panel-subtitle">{text.profileFeaturedBadgeSubtitle}</p>
            </div>
          </div>
          <div class="featured-picker" data-current={(profile as any)?.featured_badge || ""}>
            <button type="button" class="featured-option" data-badge="" aria-pressed={!(profile as any)?.featured_badge}>
              <span class="featured-option-icon" aria-hidden="true">🚫</span>
              <span class="featured-option-label">{text.profileFeaturedBadgeNone}</span>
            </button>
            {userBadges.map((b: string) => (
              <button
                type="button"
                class="featured-option"
                data-badge={b}
                aria-pressed={(profile as any)?.featured_badge === b}
                title={labelForBadge(b)}
              >
                <span class="featured-option-icon" aria-hidden="true">{iconForBadge(b)}</span>
                <span class="featured-option-label">{labelForBadge(b)}</span>
              </button>
            ))}
          </div>
          <p id="featured-badge-status" class="featured-status" role="status" aria-live="polite"></p>
        </div>
      )}

      {/* ── Milestones (earned automatically) ── */}
      <div id="milestones-collection" class="profile-badges-panel surface-card">
        <div class="badges-panel-head">
          <div>
            <h2 class="profile-section-title" style="margin-top:0; margin-bottom:0.2rem;">{text.profileMilestonesTitle}</h2>
            <p class="badges-panel-subtitle">{text.profileMilestonesSubtitle}</p>
          </div>
          <span class="badges-count-pill">
            {text.profileBadgesCountOwned
              .replace("{owned}", String(MILESTONES.filter(m => userBadges.includes(m.type)).length))
              .replace("{total}", String(MILESTONES.length))}
          </span>
        </div>
        <div class="badges-collection-grid">
          {MILESTONES.map((m) => {
            const owned = userBadges.includes(m.type);
            return (
              <div class={`badge-card ${owned ? "owned" : "locked"}`}>
                <div class="badge-card-icon" aria-hidden="true">{badgeEmoji[m.type]}</div>
                <div class="badge-card-name">{badgeLabelMap[m.type]}</div>
                {owned ? (
                  <span class="badge-card-status owned">✓ {text.profileMilestoneEarned}</span>
                ) : (
                  <span class="badge-card-status locked">
                    {text.profileMilestoneLocked.replace("{n}", String(m.threshold))}
                  </span>
                )}
              </div>
            );
          })}
        </div>
      </div>

      {/* ── Activity stats ── */}
      <div class="profile-activity surface-card">
        <h2 class="profile-section-title" style="margin-top:0;">{text.profileActivityTitle}</h2>
        <div class="stats-grid">
          <a href={`/${lang}/coloring-corner/`} class="stat-card">
            <div class="stat-icon" aria-hidden="true">🎨</div>
            <div class="stat-value">{statDownloads.toLocaleString()}</div>
            <div class="stat-label">{text.profileStatDownloads}</div>
          </a>
          <a href={latestReviewId ? `/${lang}/gallery/#review-${latestReviewId}` : `/${lang}/gallery/`} class="stat-card">
            <div class="stat-icon" aria-hidden="true">⭐</div>
            <div class="stat-value">{statReviews.toLocaleString()}</div>
            <div class="stat-label">{text.profileStatReviews}</div>
          </a>
          <a href={`/${lang}/peanuts/`} class="stat-card">
            <div class="stat-icon" aria-hidden="true">🥜</div>
            <div class="stat-value">{statPeanutsEarned.toLocaleString()}</div>
            <div class="stat-label">{text.profileStatPeanutsEarned}</div>
          </a>
          <a href={`/${lang}/lottery/`} class="stat-card">
            <div class="stat-icon" aria-hidden="true">🎟️</div>
            <div class="stat-value">{statTickets.toLocaleString()}</div>
            <div class="stat-label">{text.profileStatTickets}</div>
          </a>
        </div>
      </div>

      </div>{/* /panel-adventure */}

      <div id="panel-settings" class="tab-panel" data-panel="settings" role="tabpanel" aria-labelledby="tab-settings" hidden>

      {/* ── Profile form ── */}
      <div class="profile-forms">

        {saveMessage && (
          <p class={`auth-message ${saveMessageType}`}>{saveMessage}</p>
        )}

        <form method="POST" class="surface-card profile-section">
          <input type="hidden" name="action" value="save-profile" />

          <h2 class="profile-section-title">{text.profilePersonalInfo}</h2>

          <div class="form-grid-2">
            <div class="form-group">
              <label for="display_name">{text.profileDisplayName}</label>
              <input
                type="text"
                id="display_name"
                name="display_name"
                value={profile?.display_name || ""}
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="phone">{text.profilePhone}</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                value={profile?.phone || ""}
                autocomplete="tel"
                inputmode="tel"
              />
            </div>
          </div>

          <details class="form-collapsible" style="margin-top:1.25rem;">
            <summary>
              <span class="collapsible-title">📬 {text.profileAddressSection}</span>
              <span class="collapsible-hint">{text.profileAddressHint}</span>
            </summary>
            <div class="collapsible-body">
              <div class="form-group">
                <label for="address_line1">{text.profileAddress1}</label>
                <input
                  type="text"
                  id="address_line1"
                  name="address_line1"
                  value={profile?.address_line1 || ""}
                  autocomplete="address-line1"
                />
              </div>
              <div class="form-group">
                <label for="address_line2">{text.profileAddress2}</label>
                <input
                  type="text"
                  id="address_line2"
                  name="address_line2"
                  value={profile?.address_line2 || ""}
