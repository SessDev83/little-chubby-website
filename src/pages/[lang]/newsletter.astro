---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsletterForm from "../../components/NewsletterForm.astro";
import { siteConfig } from "../../data/site";
import { languages, getLangFromParam, ui } from "../../data/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/newsletter/`;
---

<BaseLayout
  lang={lang}
  title={text.newsletterMetaTitle}
  description={text.newsletterMetaDescription}
  pathname={pathname}
>
  <section class="page-section">
    <div class="container">
      <div class="section-head">
        <h1>{text.newsletterSectionTitle}</h1>
        <p>
          {lang === "es"
            ? "Recibe lanzamientos, novedades editoriales y recursos para colorear en familia."
            : "Get launches, editorial updates, and family coloring resources."}
        </p>
        <p>
          {lang === "es"
            ? `Proveedor sugerido: ${siteConfig.newsletter.providerName}.`
            : `Suggested provider: ${siteConfig.newsletter.providerName}.`}
        </p>
      </div>

      <NewsletterForm lang={lang} />
    </div>
  </section>
</BaseLayout>
