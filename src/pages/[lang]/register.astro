---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase } from "../../lib/supabase";
import { validateOrigin } from "../../lib/csrf";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/register/`;

// Optional: prefill email when coming from a gift invite link.
const prefillEmailRaw = Astro.url.searchParams.get("email") || "";
const prefillEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(prefillEmailRaw) ? prefillEmailRaw : "";

// If already logged in, redirect to profile
const user = Astro.locals.user;
if (user) {
  return Astro.redirect(`/${lang}/profile/`);
}

let message = "";
let messageType: "success" | "error" | "" = "";

if (Astro.request.method === "POST") {
  if (!validateOrigin(Astro.request, Astro.url)) {
    message = "⛔ Request blocked.";
    messageType = "error";
  } else {
  const formData = await Astro.request.formData();
  const email = formData.get("email")?.toString().trim() || "";
  const password = formData.get("password")?.toString() || "";
  const confirmPassword = formData.get("confirm_password")?.toString() || "";

  if (password.length < 6) {
    message = text.registerPasswordTooShort;
    messageType = "error";
  } else if (password !== confirmPassword) {
    message = text.registerPasswordMismatch;
    messageType = "error";
  } else if (email) {
    const { error } = await supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: `${Astro.url.origin}/${lang}/auth/callback/`,
      },
    });

    if (error) {
      // Translate common Supabase auth errors
      const errorMap: Record<string, Record<string, string>> = {
        es: {
          "User already registered": "Este correo ya está registrado. Intenta iniciar sesión.",
          "Password should be at least 6 characters": "La contraseña debe tener al menos 6 caracteres.",
          "Unable to validate email address: invalid format": "El formato del correo no es válido.",
        },
        en: {
          "User already registered": "This email is already registered. Try logging in.",
          "Password should be at least 6 characters": "Password must be at least 6 characters.",
          "Unable to validate email address: invalid format": "Invalid email format.",
        },
      };
      const translated = errorMap[lang]?.[error.message];
      message = translated || (lang === "es" ? "Ocurrió un error. Intenta de nuevo." : "An error occurred. Please try again.");
      messageType = "error";
    } else {
      message = text.registerSuccess;
      messageType = "success";
    }
  }
  } // end CSRF else
}
---

<BaseLayout lang={lang} title={text.registerMetaTitle} description={text.registerSubheading} pathname={pathname}>
  <section class="page-section container">
    <div class="auth-card surface-card">
      <div class="section-head" style="text-align:center;">
        <h1>{text.registerHeading}</h1>
        <p>{text.registerSubheading}</p>
      </div>

      {message && (
        <p class={`auth-message ${messageType}`}>{message}</p>
      )}

      {messageType !== "success" && (
        <form method="POST" class="form-grid">
          <div class="form-group">
            <label for="email">{text.loginEmailLabel}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              inputmode="email"
              value={prefillEmail}
            />
          </div>

          <div class="form-group">
            <label for="password">{text.loginPasswordLabel}</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="new-password"
              minlength="6"
            />
          </div>

          <div class="form-group">
            <label for="confirm_password">{text.registerPasswordConfirm}</label>
            <input
              type="password"
              id="confirm_password"
              name="confirm_password"
              required
              autocomplete="new-password"
              minlength="6"
            />
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;">
            {text.registerSubmit}
          </button>
        </form>
      )}

      <p style="text-align:center; margin-top:1.2rem; font-size:0.95rem;">
        {text.registerHaveAccount}{" "}
        <a href={`/${lang}/login/`}><strong>{text.registerSignIn}</strong></a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .auth-card {
    max-width: 28rem;
    margin: 0 auto;
    padding: 2rem 1.6rem;
  }

  .auth-message {
    text-align: center;
    padding: 0.8rem;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }

  .auth-message.success {
    background: rgba(92, 150, 80, 0.14);
    color: var(--brand-green);
    border: 1px solid rgba(92, 150, 80, 0.3);
  }

  .auth-message.error {
    background: rgba(220, 50, 50, 0.08);
    color: #8f1f18;
    border: 1px solid rgba(220, 50, 50, 0.25);
  }
</style>
