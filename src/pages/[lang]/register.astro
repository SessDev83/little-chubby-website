---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase } from "../../lib/supabase";
import { validateOrigin } from "../../lib/csrf";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/register/`;

// Optional: prefill email when coming from a gift invite link.
const prefillEmailRaw = Astro.url.searchParams.get("email") || "";
const prefillEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(prefillEmailRaw) ? prefillEmailRaw : "";

// If already logged in, redirect to profile
const user = Astro.locals.user;
if (user) {
  return Astro.redirect(`/${lang}/profile/`);
}

let message = "";
let messageType: "success" | "error" | "" = "";

if (Astro.request.method === "POST") {
  if (!validateOrigin(Astro.request, Astro.url)) {
    message = "⛔ Request blocked.";
    messageType = "error";
  } else {
  const formData = await Astro.request.formData();
  const email = formData.get("email")?.toString().trim() || "";
  const password = formData.get("password")?.toString() || "";
  const parentConsent = formData.get("parent_consent")?.toString() === "on";

  if (!parentConsent) {
    message = text.registerParentConsentError;
    messageType = "error";
  } else if (password.length < 6) {
    message = text.registerPasswordTooShort;
    messageType = "error";
  } else if (email) {
    const consentTimestamp = new Date().toISOString();
    const { error } = await supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: `${Astro.url.origin}/${lang}/auth/callback/`,
        data: {
          parent_consent_at: consentTimestamp,
        },
      },
    });

    if (error) {
      // Translate common Supabase auth errors
      const errorMap: Record<string, Record<string, string>> = {
        es: {
          "User already registered": "Este correo ya está registrado. Intenta iniciar sesión.",
          "Password should be at least 6 characters": "La contraseña debe tener al menos 6 caracteres.",
          "Unable to validate email address: invalid format": "El formato del correo no es válido.",
        },
        en: {
          "User already registered": "This email is already registered. Try logging in.",
          "Password should be at least 6 characters": "Password must be at least 6 characters.",
          "Unable to validate email address: invalid format": "Invalid email format.",
        },
      };
      const translated = errorMap[lang]?.[error.message];
      message = translated || (lang === "es" ? "Ocurrió un error. Intenta de nuevo." : "An error occurred. Please try again.");
      messageType = "error";
    } else {
      message = text.registerSuccess;
      messageType = "success";
    }
  }
  } // end CSRF else
}
---

<BaseLayout lang={lang} title={text.registerMetaTitle} description={text.registerSubheading} pathname={pathname}>
  <section class="page-section container">
    <div class="auth-card surface-card">
      <div class="section-head" style="text-align:center;">
        <h1>{text.registerHeading}</h1>
        <p>{text.registerSubheading}</p>
      </div>

      {message && (
        <p class={`auth-message ${messageType}`}>{message}</p>
      )}

      {messageType !== "success" && (
        <form method="POST" class="form-grid">
          <div class="form-group">
            <label for="email">{text.loginEmailLabel}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              inputmode="email"
              value={prefillEmail}
            />
          </div>

          <div class="form-group">
            <label for="password">{text.loginPasswordLabel}</label>
            <div class="password-wrapper">
              <input
                type="password"
                id="password"
                name="password"
                required
                autocomplete="new-password"
                minlength="6"
              />
              <button
                type="button"
                class="password-toggle"
                id="password-toggle"
                aria-label={lang === "es" ? "Mostrar u ocultar contraseña" : "Show or hide password"}
                aria-pressed="false"
              >
                <span data-show>{lang === "es" ? "Mostrar" : "Show"}</span>
                <span data-hide hidden>{lang === "es" ? "Ocultar" : "Hide"}</span>
              </button>
            </div>
          </div>

          <label class="consent-row">
            <input
              type="checkbox"
              name="parent_consent"
              id="parent_consent"
              required
            />
            <span>{text.registerParentConsentLabel}</span>
          </label>

          <button type="submit" class="btn btn-primary" style="width:100%;">
            {text.registerSubmit}
          </button>
        </form>
      )}

      <p style="text-align:center; margin-top:1.2rem; font-size:0.95rem;">
        {text.registerHaveAccount}{" "}
        <a href={`/${lang}/login/`}><strong>{text.registerSignIn}</strong></a>
      </p>
    </div>
  </section>

  {/* P5-T2: hidden sentinel carrying server-rendered outcome for client tracker */}
  <div id="register-track" data-msg-type={messageType} hidden></div>
</BaseLayout>

<script is:inline>
  // P5-T2: register-funnel tracking
  (function () {
    if (typeof window.lcpTrack !== "function") return;

    var sentinel = document.getElementById("register-track");
    var msgType = sentinel ? sentinel.getAttribute("data-msg-type") : "";

    window.lcpTrack("register_view");

    if (msgType === "success") {
      window.lcpTrack("register_submit_success");
    } else if (msgType === "error") {
      window.lcpTrack("register_submit_error");
    }

    var form = document.querySelector("form.form-grid");
    if (form) {
      form.addEventListener("submit", function () {
        try { window.lcpTrack("register_submit_attempt"); } catch (e) {}
      });
    }
  })();
</script>

<style>
  .auth-card {
    max-width: 28rem;
    margin: 0 auto;
    padding: 2rem 1.6rem;
  }

  .auth-message {
    text-align: center;
    padding: 0.8rem;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }

  .auth-message.success {
    background: rgba(92, 150, 80, 0.14);
    color: var(--brand-green);
    border: 1px solid rgba(92, 150, 80, 0.3);
  }

  .auth-message.error {
    background: rgba(220, 50, 50, 0.08);
    color: #8f1f18;
    border: 1px solid rgba(220, 50, 50, 0.25);
  }

  .consent-row {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin: 0.2rem 0 0.6rem;
    font-size: 0.92rem;
    line-height: 1.45;
    cursor: pointer;
  }

  .consent-row input[type="checkbox"] {
    margin-top: 0.2rem;
    flex: 0 0 auto;
    width: 1.05rem;
    height: 1.05rem;
  }

  .consent-row span {
    flex: 1 1 auto;
    color: var(--text-soft, #444);
  }

  /* Pkg P4-A3: show-password toggle. Wrapper positions the button inside
     the input row without altering the existing input layout. */
  .password-wrapper {
    position: relative;
    display: block;
  }
  .password-wrapper input {
    width: 100%;
    padding-right: 4.5rem;
  }
  .password-toggle {
    position: absolute;
    top: 50%;
    right: 0.5rem;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    color: var(--brand-blue);
    font-family: "Baloo 2", "Trebuchet MS", sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    border-radius: 0.4rem;
  }
  .password-toggle:hover { background: rgba(31, 79, 134, 0.08); }
  .password-toggle:focus-visible { outline: 2px solid var(--brand-blue); outline-offset: 2px; }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById("password-toggle");
    var input = document.getElementById("password");
    if (!btn || !input) return;
    var showLabel = btn.querySelector("[data-show]");
    var hideLabel = btn.querySelector("[data-hide]");
    btn.addEventListener("click", function () {
      var revealed = input.getAttribute("type") === "text";
      input.setAttribute("type", revealed ? "password" : "text");
      btn.setAttribute("aria-pressed", revealed ? "false" : "true");
      if (showLabel && hideLabel) {
        if (revealed) { showLabel.hidden = false; hideLabel.hidden = true; }
        else { showLabel.hidden = true; hideLabel.hidden = false; }
      }
    });
  })();
</script>
