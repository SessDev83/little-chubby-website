---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase, getServiceClient } from "../../lib/supabase";
import { books } from "../../data/books";
import { notifyLotteryClaim } from "../../lib/notifications";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/lottery/`;

// ── Auth ─────────────────────────────────────────────
const user = Astro.locals.user;
const sc = getServiceClient();

// ── User state ───────────────────────────────────────
let myReviewCount = 0;
let approvedCount = 0;
let pendingClaim: any = null;
let claimMsg = "";

if (user) {
  const { data: reviewData } = await supabase
    .from("book_reviews")
    .select("id, status")
    .eq("user_id", user.id);
  myReviewCount = reviewData?.length ?? 0;
  approvedCount = reviewData?.filter(r => r.status === "approved").length ?? 0;

  // Check for unclaimed win
  const { data: winData } = await supabase
    .from("lottery_winners")
    .select("*")
    .eq("user_id", user.id)
    .eq("claimed", false)
    .gt("claim_deadline", new Date().toISOString())
    .order("created_at", { ascending: false })
    .limit(1)
    .maybeSingle();
  pendingClaim = winData;

  // ── Handle POST actions ──────────────────────────
  if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "claim" && pendingClaim) {
      const bookChosen = formData.get("book_chosen")?.toString() || "";
      const shippingName = formData.get("shipping_name")?.toString().trim() || "";
      const shippingAddress = formData.get("shipping_address")?.toString().trim() || "";

      if (bookChosen && shippingName && shippingAddress) {
        await supabase
          .from("lottery_winners")
          .update({
            book_chosen: bookChosen,
            shipping_name: shippingName,
            shipping_address: shippingAddress,
            claimed: true,
          })
          .eq("id", pendingClaim.id);

        claimMsg = text.claimSuccess;
        pendingClaim = null;
        notifyLotteryClaim(user.email || "unknown", bookChosen, shippingName, shippingAddress);
      }
    }
  }
}

// Compute tickets: each approved review = 5 tickets
const totalTickets = approvedCount * 5;

// ── Public winners ───────────────────────────────────
const { data: publicWinners } = await supabase
  .from("lottery_winners_public")
  .select("month, book_chosen, display_name")
  .limit(12);

const bookOptions = books.map(b => ({ id: b.id, title: b.title[lang] }));
const bookMap = Object.fromEntries(bookOptions.map(b => [b.id, b.title]));
---

<BaseLayout
  lang={lang}
  title={text.lotteryMetaTitle}
  description={text.lotteryDescription}
  pathname={pathname}
  breadcrumbs={[
    { name: text.navHome, url: `/${lang}/` },
    { name: text.lotteryHeading, url: pathname }
  ]}
>
  <section class="page-section container">
    <!-- Header -->
    <div class="section-head" style="text-align:center; max-width:42rem; margin:0 auto 2rem;">
      <h1>{text.lotteryHeading}</h1>
      <p>{text.lotteryDescription}</p>
    </div>

    <!-- How It Works — Accordion on mobile, open on desktop -->
    <details class="lottery-steps surface-card" style="max-width:42rem; margin:0 auto 2rem; padding:0;" open>
      <summary class="steps-summary">
        <h2>{text.lotteryHowItWorks}</h2>
        <svg class="steps-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </summary>
      <div class="steps-body">
        <div class="steps-row">
          <div class="step-card">
            <span class="step-icon">📚</span>
            <span class="step-num">1</span>
            <p class="step-text">{text.lotteryStep1}</p>
          </div>
          <span class="step-arrow">→</span>
          <div class="step-card">
            <span class="step-icon">📸</span>
            <span class="step-num">2</span>
            <p class="step-text">{text.lotteryStep2}</p>
          </div>
          <span class="step-arrow">→</span>
          <div class="step-card">
            <span class="step-icon">🎫</span>
            <span class="step-num">3</span>
            <p class="step-text">{text.lotteryStep3}</p>
          </div>
          <span class="step-arrow">→</span>
          <div class="step-card">
            <span class="step-icon">🎁</span>
            <span class="step-num">4</span>
            <p class="step-text">{text.lotteryStep4}</p>
          </div>
        </div>
      </div>
    </details>

    {!user ? (
      <!-- Not logged in -->
      <div class="surface-card" style="max-width:28rem; margin:0 auto; padding:2rem 1.6rem; text-align:center;">
        <p>{text.lotteryNotLoggedIn}</p>
        <a href={`/${lang}/login/`} class="btn btn-primary">{text.navLogin}</a>
      </div>
    ) : (
      <div style="max-width:42rem; margin:0 auto;">

        {/* ── Pending claim banner ── */}
        {pendingClaim && !claimMsg && (
          <div class="surface-card claim-card">
            <div class="claim-header">
              <span class="claim-confetti">🎉</span>
              <h2>{text.claimCongrats} {text.claimTitle}</h2>
              <span class="claim-confetti">🎉</span>
            </div>
            <p>{text.claimInstructions}</p>
            <p class="claim-countdown" data-deadline={pendingClaim.claim_deadline}>
              <span class="claim-days" id="claimDays"></span> {text.claimDaysLeft}
            </p>
            <form method="POST" class="form-grid">
              <input type="hidden" name="action" value="claim" />
              <div class="form-group">
                <label for="book_chosen">{text.claimBookChoice}</label>
                <div class="claim-book-grid">
                  {bookOptions.map(b => {
                    const book = books.find(bk => bk.id === b.id);
                    return (
                      <label class="claim-book-option">
                        <input type="radio" name="book_chosen" value={b.id} required />
                        {book?.coverSrc && <img src={book.coverSrc} alt={b.title} class="claim-book-cover" loading="lazy" width="80" height="100" />}
                        <span class="claim-book-title">{b.title}</span>
                      </label>
                    );
                  })}
                </div>
              </div>
              <div class="form-group">
                <label for="shipping_name">{text.claimShippingName}</label>
                <input type="text" id="shipping_name" name="shipping_name" required />
              </div>
              <div class="form-group">
                <label for="shipping_address">{text.claimShippingAddress}</label>
                <textarea id="shipping_address" name="shipping_address" rows="3" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;">{text.claimSubmit}</button>
            </form>
          </div>
        )}

        {claimMsg && (
          <div class="surface-card" style="padding:1.6rem; margin-bottom:1.5rem; text-align:center; border:2px solid var(--brand-green);">
            <h2>✅ {text.claimOrderSummary}</h2>
            <p class="msg msg-success">{claimMsg}</p>
          </div>
        )}

        {/* ── Tickets summary ── */}
        <div class="surface-card" style="padding:1.4rem; margin-bottom:1.5rem; text-align:center;">
          <h2>{text.lotteryTickets}: <strong style="color:var(--brand-blue);">{totalTickets}</strong></h2>
          {totalTickets === 0 && <p style="color:var(--ink-soft);">{text.lotteryNoTickets}</p>}
          {approvedCount > 0 && (
            <p style="color:var(--ink-soft);">
              {approvedCount} {approvedCount === 1 ? (lang === "es" ? "libro" : "book") : (lang === "es" ? "libros" : "books")} × 5 = {totalTickets} {lang === "es" ? "boletos" : "tickets"}
            </p>
          )}
          <p style="margin-top:0.8rem;">
            <a href={`/${lang}/reviews/`} class="btn btn-secondary">{text.reviewsHeading} →</a>
          </p>
          {myReviewCount === 0 && (
            <p style="margin-top:0.5rem; font-size:0.9rem; color:var(--ink-soft);">
              {lang === "es" ? "¡Escribe tu primera review para ganar boletos!" : "Write your first review to earn tickets!"}
            </p>
          )}
        </div>

        {/* ── Buy extra lottery entries with Peanuts ── */}
        <div class="surface-card" style="padding:1.4rem; margin-bottom:1.5rem; text-align:center;">
          <h3>🥜 {text.peanutShopLottery}</h3>
          <p style="font-size:0.9rem; color:var(--ink-soft);">{text.peanutShopLotteryDesc}</p>
          <a href={`/${lang}/peanuts/`} class="btn btn-sm btn-secondary">{text.peanutShopTitle} →</a>
        </div>
      </div>
    )}

    {/* ── Past Winners ── */}
    {publicWinners && publicWinners.length > 0 && (
      <div style="max-width:42rem; margin:2.5rem auto 0;">
        <h2 style="text-align:center; margin-bottom:1rem;">{text.lotteryWinnersTitle}</h2>
        <div class="winners-list">
          {publicWinners.map((w: any) => (
            <div class="winner-row">
              <span class="winner-month">{w.month}</span>
              <span class="winner-name">{w.display_name || "—"}</span>
              <span class="winner-book">{w.book_chosen ? bookMap[w.book_chosen] || w.book_chosen : ""}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Auto-collapse "How it works" on mobile ──
    const stepsDetails = document.querySelector("details.lottery-steps");
    if (stepsDetails && window.innerWidth <= 600) {
      stepsDetails.removeAttribute("open");
    }

    // ── Claim countdown ──────────────────────────
    const countdownEl = document.querySelector(".claim-countdown");
    const daysEl = document.getElementById("claimDays");
    if (countdownEl && daysEl) {
      const deadline = new Date(countdownEl.getAttribute("data-deadline"));
      const now = new Date();
      const diffMs = deadline - now;
      const days = Math.max(0, Math.ceil(diffMs / (1000 * 60 * 60 * 24)));
      daysEl.textContent = days;
    }
  });
</script>

<style>
  /* ── Visual Steps ── */
  .steps-row {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .step-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.8rem 0.6rem;
    max-width: 10rem;
    flex: 1;
    min-width: 7rem;
  }
  .step-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.3rem;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--brand-blue);
    color: #fff;
    font-family: "Baloo 2", sans-serif;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    margin-bottom: 0.4rem;
  }
  .step-text {
    font-size: 0.88rem;
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.35;
  }
  .step-arrow {
    font-size: 1.5rem;
    color: var(--accent-gold);
    align-self: center;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Accordion Summary ── */
  .steps-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    cursor: default;
    list-style: none;
    padding: 1.2rem 1.6rem;
  }
  .steps-summary::-webkit-details-marker { display: none; }
  .steps-summary h2 {
    margin: 0;
    text-align: center;
  }
  .steps-chevron {
    display: none;
    color: var(--brand-brown);
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  details.lottery-steps[open] .steps-chevron {
    transform: rotate(180deg);
  }
  .steps-body {
    padding: 0 1.6rem 1.6rem;
  }

  @media (max-width: 600px) {
    .steps-row { flex-direction: column; align-items: center; gap: 0; }
    .step-arrow { transform: rotate(90deg); font-size: 1.2rem; }
    .step-card { max-width: 100%; min-width: 0; padding: 0.5rem 0.6rem; }

    /* Collapsed by default on mobile */
    details.lottery-steps:not([open]) .steps-body { display: none; }
    .steps-summary {
      cursor: pointer;
      justify-content: space-between;
      padding: 1rem 1.2rem;
    }
    .steps-chevron {
      display: block;
    }
  }

  /* ── Claim Card ── */
  .claim-card {
    padding: 1.6rem;
    margin-bottom: 1.5rem;
    border: 2px solid var(--accent-gold);
    background: linear-gradient(135deg, rgba(211,164,66,0.06), rgba(211,164,66,0.02));
  }
  .claim-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }
  .claim-confetti { font-size: 1.6rem; }
  .claim-countdown {
    text-align: center;
    font-weight: 700;
    font-family: "Baloo 2", sans-serif;
    color: var(--accent-coral);
    font-size: 1.1rem;
    margin: 0.5rem 0 1rem;
  }
  .claim-days {
    display: inline-block;
    background: var(--accent-coral);
    color: #fff;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-sm);
    font-size: 1.3rem;
    margin-right: 0.3rem;
  }
  .claim-book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(6rem, 1fr));
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
  .claim-book-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.6rem;
    border: 2px solid var(--line);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    text-align: center;
  }
  .claim-book-option:has(input:checked) {
    border-color: var(--brand-blue);
    box-shadow: 0 0 0 2px rgba(31,79,134,0.2);
  }
  .claim-book-option input { display: none; }
  .claim-book-cover {
    width: 80px;
    height: 100px;
    object-fit: cover;
    border-radius: 4px;
  }
  .claim-book-title {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }

  .msg {
    padding: 0.8rem;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    text-align: center;
  }
  .msg-success {
    background: rgba(92, 150, 80, 0.14);
    color: var(--brand-green);
    border: 1px solid rgba(92, 150, 80, 0.3);
  }
  .msg-error {
    background: rgba(220, 50, 50, 0.08);
    color: #8f1f18;
    border: 1px solid rgba(220, 50, 50, 0.25);
  }

  .winners-list { display: grid; gap: 0.5rem; }
  .winner-row {
    display: grid;
    grid-template-columns: 6rem 1fr 1fr;
    gap: 0.5rem;
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius-sm);
    background: var(--surface);
    border: 1px solid var(--line);
    font-size: 0.95rem;
  }
  .winner-month { font-family: "Baloo 2", sans-serif; font-weight: 700; color: var(--brand-blue); }
  .winner-name { color: var(--brand-brown); font-weight: 700; }
  .winner-book { color: var(--ink-soft); }
</style>
