---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase, getServiceClient } from "../../lib/supabase";
import { books } from "../../data/books";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/lottery/`;

// ── Auth ─────────────────────────────────────────────
const user = Astro.locals.user;

const sc = getServiceClient();

// ── User state ───────────────────────────────────────
let myReviews: { id: string; book_id: string; photo_url: string; extra_photos?: string[]; rating: number; review_text: string; status: string; submitted_at: string; reviewer_note?: string }[] = [];
let pendingClaim: any = null;
let shareMsg = "";
let shareMsgType: "success" | "error" | "" = "";
let claimMsg = "";
let editingReview: any = null;

if (user) {
  // Get user's reviews
  const { data: reviewData } = await supabase
    .from("book_reviews")
    .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
    .eq("user_id", user.id)
    .order("submitted_at", { ascending: false });
  myReviews = reviewData ?? [];

  // Check for unclaimed win
  const { data: winData } = await supabase
    .from("lottery_winners")
    .select("*")
    .eq("user_id", user.id)
    .eq("claimed", false)
    .gt("claim_deadline", new Date().toISOString())
    .order("created_at", { ascending: false })
    .limit(1)
    .maybeSingle();
  pendingClaim = winData;

  // ── Handle POST actions ──────────────────────────
  if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "delete_review") {
      const reviewId = formData.get("review_id")?.toString();
      if (reviewId) {
        // Find the review to delete its photo too
        const toDelete = myReviews.find(r => r.id === reviewId);
        if (toDelete) {
          const photoPath = `${user.id}/${toDelete.book_id}.jpg`;
          await sc.storage.from("book-photos").remove([photoPath]);
          await sc.from("book_reviews").delete().eq("id", reviewId).eq("user_id", user.id);
          // Refresh reviews
          const { data: refreshed } = await supabase
            .from("book_reviews")
            .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
            .eq("user_id", user.id)
            .order("submitted_at", { ascending: false });
          myReviews = refreshed ?? [];
          shareMsg = lang === "es" ? "Review eliminada." : "Review deleted.";
          shareMsgType = "success";
        }
      }
    }

    if (action === "share_book") {
      const bookId = formData.get("book_id")?.toString() || "";
      const rating = parseInt(formData.get("rating")?.toString() || "0", 10);
      const reviewText = formData.get("review_text")?.toString().trim() || "";
      const showGallery = formData.get("show_in_gallery") === "on";
      const photos = formData.getAll("photos") as File[];
      const editId = formData.get("edit_id")?.toString() || "";

      const MAX_BYTES = 500 * 1024;
      const MAX_PHOTOS = 5;
      const ALLOWED_TYPES = ["image/jpeg", "image/png", "image/webp"];

      const validPhotos = photos.filter(f => f && f.size > 0);
      const tooLarge = validPhotos.some(f => f.size > MAX_BYTES);
      const badType = validPhotos.some(f => !ALLOWED_TYPES.includes(f.type));

      if (tooLarge) {
        shareMsg = text.shareTooLarge;
        shareMsgType = "error";
      } else if (badType) {
        shareMsg = text.shareInvalidType;
        shareMsgType = "error";
      } else if (validPhotos.length > MAX_PHOTOS) {
        shareMsg = text.shareTooLarge;
        shareMsgType = "error";
      } else if (!bookId || rating < 1 || rating > 5) {
        shareMsg = text.loginError;
        shareMsgType = "error";
      } else {
        let photoUrl = "";
        let extraPhotos: string[] = [];

        if (validPhotos.length > 0) {
          for (let i = 0; i < validPhotos.length; i++) {
            const suffix = i === 0 ? "" : `_${i + 1}`;
            const filePath = `${user.id}/${bookId}${suffix}.jpg`;
            const arrayBuf = await validPhotos[i].arrayBuffer();
            const buffer = new Uint8Array(arrayBuf);
            const { error: uploadError } = await sc.storage
              .from("book-photos")
              .upload(filePath, buffer, { contentType: "image/jpeg", upsert: true });
            if (uploadError) {
              shareMsg = text.loginError;
              shareMsgType = "error";
              break;
            }
            const { data: urlData } = sc.storage.from("book-photos").getPublicUrl(filePath);
            if (i === 0) {
              photoUrl = urlData.publicUrl;
            } else {
              extraPhotos.push(urlData.publicUrl);
            }
          }
        }

        if (shareMsgType !== "error") {
          if (editId) {
            // Update existing review — reset status to pending
            const updateData: any = {
              rating,
              review_text: reviewText,
              show_in_gallery: formData.get("show_in_gallery") === "on",
              status: "pending",
              reviewed_at: null,
              reviewer_note: null,
            };
            if (photoUrl) updateData.photo_url = photoUrl;
            if (extraPhotos.length > 0) updateData.extra_photos = extraPhotos;

            const { error: updateError } = await sc
              .from("book_reviews")
              .update(updateData)
              .eq("id", editId)
              .eq("user_id", user.id);

            if (updateError) {
              shareMsg = text.loginError;
              shareMsgType = "error";
            } else {
              shareMsg = text.shareSuccess;
              shareMsgType = "success";
            }
          } else {
            // New review
            if (!photoUrl) {
              shareMsg = text.shareInvalidType;
              shareMsgType = "error";
            } else {
              const { error: insertError } = await sc
                .from("book_reviews")
                .insert({
                  user_id: user.id,
                  book_id: bookId,
                  photo_url: photoUrl,
                  extra_photos: extraPhotos,
                  rating,
                  review_text: reviewText,
                  show_in_gallery: formData.get("show_in_gallery") === "on",
                });

              if (insertError?.code === "23505") {
                shareMsg = text.shareAlreadyReviewed;
                shareMsgType = "error";
              } else if (insertError) {
                shareMsg = text.loginError;
                shareMsgType = "error";
              } else {
                shareMsg = text.shareSuccess;
                shareMsgType = "success";
              }
            }
          }

          // Refresh reviews
          const { data: refreshed } = await supabase
            .from("book_reviews")
            .select("id, book_id, photo_url, extra_photos, rating, review_text, status, submitted_at, reviewer_note")
            .eq("user_id", user.id)
            .order("submitted_at", { ascending: false });
          myReviews = refreshed ?? [];
        }
      }
    }

    if (action === "claim" && pendingClaim) {
      const bookChosen = formData.get("book_chosen")?.toString() || "";
      const shippingName = formData.get("shipping_name")?.toString().trim() || "";
      const shippingAddress = formData.get("shipping_address")?.toString().trim() || "";

      if (bookChosen && shippingName && shippingAddress) {
        await supabase
          .from("lottery_winners")
          .update({
            book_chosen: bookChosen,
            shipping_name: shippingName,
            shipping_address: shippingAddress,
            claimed: true,
          })
          .eq("id", pendingClaim.id);

        claimMsg = text.claimSuccess;
        pendingClaim = null;
      }
    }
  }
}

// Compute tickets: each approved review = 5 tickets
const approvedCount = myReviews.filter(r => r.status === "approved").length;
const totalTickets = approvedCount * 5;

// Books already reviewed (to exclude from dropdown)
const reviewedBookIds = new Set(myReviews.map(r => r.book_id));

// ── Public winners ───────────────────────────────────
const { data: publicWinners } = await supabase
  .from("lottery_winners_public")
  .select("month, book_chosen, display_name")
  .limit(12);

// Book helpers
const bookOptions = books.map(b => ({ id: b.id, title: b.title[lang] }));
const availableBooks = bookOptions.filter(b => !reviewedBookIds.has(b.id));
const bookMap = Object.fromEntries(bookOptions.map(b => [b.id, b.title]));

// Star helper
const stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);
---

<BaseLayout
  lang={lang}
  title={text.lotteryMetaTitle}
  description={text.lotteryDescription}
  pathname={pathname}
  breadcrumbs={[
    { name: text.navHome, url: `/${lang}/` },
    { name: text.lotteryHeading, url: pathname }
  ]}
>
  <section class="page-section container">
    <!-- Header -->
    <div class="section-head" style="text-align:center; max-width:42rem; margin:0 auto 2rem;">
      <h1>{text.lotteryHeading}</h1>
      <p>{text.lotteryDescription}</p>
    </div>

    <!-- How It Works — Visual Steps -->
    <div class="lottery-steps surface-card" style="max-width:42rem; margin:0 auto 2rem; padding:1.6rem;">
      <h2 style="text-align:center; margin-bottom:1.2rem;">{text.lotteryHowItWorks}</h2>
      <div class="steps-row">
        <div class="step-card">
          <span class="step-icon">📚</span>
          <span class="step-num">1</span>
          <p class="step-text">{text.lotteryStep1}</p>
        </div>
        <span class="step-arrow">→</span>
        <div class="step-card">
          <span class="step-icon">📸</span>
          <span class="step-num">2</span>
          <p class="step-text">{text.lotteryStep2}</p>
        </div>
        <span class="step-arrow">→</span>
        <div class="step-card">
          <span class="step-icon">🎫</span>
          <span class="step-num">3</span>
          <p class="step-text">{text.lotteryStep3}</p>
        </div>
        <span class="step-arrow">→</span>
        <div class="step-card">
          <span class="step-icon">🎁</span>
          <span class="step-num">4</span>
          <p class="step-text">{text.lotteryStep4}</p>
        </div>
      </div>
    </div>

    {!user ? (
      <!-- Not logged in -->
      <div class="surface-card" style="max-width:28rem; margin:0 auto; padding:2rem 1.6rem; text-align:center;">
        <p>{text.lotteryNotLoggedIn}</p>
        <a href={`/${lang}/login/`} class="btn btn-primary">{text.navLogin}</a>
      </div>
    ) : (
      <div style="max-width:42rem; margin:0 auto;">

        {/* ── Pending claim banner ── */}
        {pendingClaim && !claimMsg && (
          <div class="surface-card claim-card">
            <div class="claim-header">
              <span class="claim-confetti">🎉</span>
              <h2>{text.claimCongrats} {text.claimTitle}</h2>
              <span class="claim-confetti">🎉</span>
            </div>
            <p>{text.claimInstructions}</p>
            <p class="claim-countdown" data-deadline={pendingClaim.claim_deadline}>
              <span class="claim-days" id="claimDays"></span> {text.claimDaysLeft}
            </p>
            <form method="POST" class="form-grid">
              <input type="hidden" name="action" value="claim" />
              <div class="form-group">
                <label for="book_chosen">{text.claimBookChoice}</label>
                <div class="claim-book-grid">
                  {bookOptions.map(b => {
                    const book = books.find(bk => bk.id === b.id);
                    return (
                      <label class="claim-book-option">
                        <input type="radio" name="book_chosen" value={b.id} required />
                        {book?.coverSrc && <img src={book.coverSrc} alt={b.title} class="claim-book-cover" loading="lazy" width="80" height="100" />}
                        <span class="claim-book-title">{b.title}</span>
                      </label>
                    );
                  })}
                </div>
              </div>
              <div class="form-group">
                <label for="shipping_name">{text.claimShippingName}</label>
                <input type="text" id="shipping_name" name="shipping_name" required />
              </div>
              <div class="form-group">
                <label for="shipping_address">{text.claimShippingAddress}</label>
                <textarea id="shipping_address" name="shipping_address" rows="3" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;">{text.claimSubmit}</button>
            </form>
          </div>
        )}

        {claimMsg && (
          <div class="surface-card" style="padding:1.6rem; margin-bottom:1.5rem; text-align:center; border:2px solid var(--brand-green);">
            <h2>✅ {text.claimOrderSummary}</h2>
            <p class="msg msg-success">{claimMsg}</p>
          </div>
        )}

        {/* ── Tickets summary ── */}
        <div class="surface-card" style="padding:1.4rem; margin-bottom:1.5rem; text-align:center;">
          <h2>{text.lotteryTickets}: <strong style="color:var(--brand-blue);">{totalTickets}</strong></h2>
          {totalTickets === 0 && <p style="color:var(--ink-soft);">{text.lotteryNoTickets}</p>}
          {approvedCount > 0 && (
            <p style="color:var(--ink-soft);">
              {approvedCount} {approvedCount === 1 ? (lang === "es" ? "libro" : "book") : (lang === "es" ? "libros" : "books")} × 5 = {totalTickets} {lang === "es" ? "boletos" : "tickets"}
            </p>
          )}
        </div>

        {/* ── Share Your Book Form ── */}
        {availableBooks.length > 0 && (
          <div class="surface-card" style="padding:1.6rem; margin-bottom:1.5rem;">
            <h2 style="margin-bottom:1rem;">📸 {text.shareYourBook}</h2>

            {shareMsg && (
              <p class={`msg ${shareMsgType === "success" ? "msg-success" : "msg-error"}`}>{shareMsg}</p>
            )}

            <form method="POST" enctype="multipart/form-data" class="form-grid" id="shareForm">
              <input type="hidden" name="action" value="share_book" />
              <input type="hidden" name="edit_id" id="editId" value="" />

              {/* Searchable book selector */}
              <div class="form-group">
                <label for="bookSearch">{text.shareBookLabel}</label>
                <input type="hidden" id="book_id" name="book_id" value="" required />
                <div class="book-combo" id="bookCombo">
                  <input
                    type="text"
                    id="bookSearch"
                    class="book-search-input"
                    placeholder={text.shareBookSearch}
                    autocomplete="off"
                    required
                  />
                  <ul class="book-dropdown" id="bookDropdown" role="listbox">
                    {availableBooks.map(b => (
                      <li class="book-option" role="option" data-value={b.id}>{b.title}</li>
                    ))}
                  </ul>
                </div>
              </div>

              {/* Multi-photo upload */}
              <div class="form-group">
                <label for="photos">{text.sharePhotoLabel}</label>
                <input
                  type="file"
                  id="photos"
                  name="photos"
                  accept="image/jpeg,image/png,image/webp"
                  multiple
                  required
                  class="file-input"
                />
                <small style="color:var(--ink-soft);">{text.sharePhotoHint}</small>
                <div id="photoPreview" class="photo-preview"></div>
                <small id="photoStatus" class="photo-status" style="display:none;"></small>
              </div>

              {/* Star rating — mobile-friendly */}
              <div class="form-group">
                <label>{text.shareRatingLabel}</label>
                <div class="star-picker" id="starPicker">
                  {[1, 2, 3, 4, 5].map(n => (
                    <button type="button" class="star-btn" data-value={n.toString()} aria-label={`${n} star${n > 1 ? "s" : ""}`}>
                      <span class="star-icon">★</span>
                    </button>
                  ))}
                </div>
                <input type="hidden" name="rating" id="ratingInput" value="" required />
              </div>

              <div class="form-group">
                <label for="review_text">{text.shareReviewLabel}</label>
                <textarea
                  id="review_text"
                  name="review_text"
                  rows="3"
                  placeholder={text.shareReviewPlaceholder}
                ></textarea>
              </div>

              <div class="form-group" style="display:flex; align-items:center; gap:0.5rem;">
                <input type="checkbox" id="show_in_gallery" name="show_in_gallery" checked />
                <label for="show_in_gallery" style="margin:0; font-size:0.95rem;">{text.shareGalleryOptIn}</label>
              </div>

              <button type="submit" class="btn btn-primary" style="width:100%;">{text.shareSubmit}</button>
            </form>
          </div>
        )}

        {/* ── My Reviews ── */}
        {myReviews.length > 0 && (
          <div class="surface-card" style="padding:1.4rem; margin-bottom:1.5rem;">
            <h2 style="margin-bottom:1rem;">{text.myReviews}</h2>
            <div class="reviews-list">
              {myReviews.map(r => (
                <div class="review-row">
                  <div class="review-thumbs">
                    <img src={r.photo_url} alt="" class="review-thumb" loading="lazy" width="56" height="56" />
                    {(r.extra_photos || []).map((url: string) => (
                      <img src={url} alt="" class="review-thumb review-thumb-extra" loading="lazy" width="36" height="36" />
                    ))}
                  </div>
                  <div class="review-info">
                    <strong>{bookMap[r.book_id] || r.book_id}</strong>
                    <span class="review-stars">{stars(r.rating)}</span>
                    {r.review_text && <p class="review-text-preview">{r.review_text}</p>}
                    {r.status === "rejected" && r.reviewer_note && (
                      <p class="reviewer-note">💬 {text.reviewerNote}: {r.reviewer_note}</p>
                    )}
                  </div>
                  <div class="review-actions-user">
                    <span class={`review-status status-${r.status}`}>
                      {r.status === "pending" ? text.reviewPending : r.status === "approved" ? text.reviewApproved : text.reviewRejected}
                    </span>
                    {r.status === "rejected" && (
                      <form method="POST" style="margin-top:0.3rem;">
                        <input type="hidden" name="action" value="delete_review" />
                        <input type="hidden" name="review_id" value={r.id} />
                        <button type="submit" class="btn-small btn-retry">🔄 {text.reviewTryAgain}</button>
                      </form>
                    )}
                    {(r.status === "pending" || r.status === "approved") && (
                      <div class="review-edit-actions">
                        <button type="button" class="btn-small btn-edit" data-edit={JSON.stringify({id: r.id, book_id: r.book_id, rating: r.rating, review_text: r.review_text || ""})}>
                          ✏️ {text.reviewEdit}
                        </button>
                        <form method="POST" style="display:inline;" onsubmit={`return confirm('${text.reviewDeleteConfirm}')`}>
                          <input type="hidden" name="action" value="delete_review" />
                          <input type="hidden" name="review_id" value={r.id} />
                          <button type="submit" class="btn-small btn-delete">🗑 {text.reviewDelete}</button>
                        </form>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    {/* ── Past Winners ── */}
    {publicWinners && publicWinners.length > 0 && (
      <div style="max-width:42rem; margin:2.5rem auto 0;">
        <h2 style="text-align:center; margin-bottom:1rem;">{text.lotteryWinnersTitle}</h2>
        <div class="winners-list">
          {publicWinners.map((w: any) => (
            <div class="winner-row">
              <span class="winner-month">{w.month}</span>
              <span class="winner-name">{w.display_name || "—"}</span>
              <span class="winner-book">{w.book_chosen ? bookMap[w.book_chosen] || w.book_chosen : ""}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Searchable book selector ─────────────────
    const searchInput = document.getElementById("bookSearch");
    const hiddenInput = document.getElementById("book_id");
    const dropdown = document.getElementById("bookDropdown");
    const combo = document.getElementById("bookCombo");

    if (searchInput && dropdown && hiddenInput) {
      const allOptions = Array.from(dropdown.querySelectorAll(".book-option"));

      searchInput.addEventListener("focus", () => {
        dropdown.classList.add("open");
        filterOptions();
      });

      searchInput.addEventListener("input", () => {
        dropdown.classList.add("open");
        filterOptions();
        // Clear hidden value when typing (must re-select)
        hiddenInput.value = "";
        searchInput.setCustomValidity("Please select a book from the list");
      });

      function filterOptions() {
        const q = searchInput.value.toLowerCase().trim();
        let visible = 0;
        allOptions.forEach(opt => {
          const match = !q || opt.textContent.toLowerCase().includes(q);
          opt.style.display = match ? "" : "none";
          if (match) visible++;
        });
      }

      allOptions.forEach(opt => {
        opt.addEventListener("click", () => {
          hiddenInput.value = opt.getAttribute("data-value");
          searchInput.value = opt.textContent;
          searchInput.setCustomValidity("");
          dropdown.classList.remove("open");
        });
        // Touch support for mobile
        opt.addEventListener("touchend", (e) => {
          e.preventDefault();
          opt.click();
        });
      });

      // Close dropdown on outside click
      document.addEventListener("click", (e) => {
        if (!combo.contains(e.target)) {
          dropdown.classList.remove("open");
        }
      });
    }

    // ── Star picker (mobile-friendly buttons) ────
    const picker = document.getElementById("starPicker");
    const ratingInput = document.getElementById("ratingInput");
    if (picker && ratingInput) {
      const stars = picker.querySelectorAll(".star-btn");

      function setRating(value) {
        ratingInput.value = value;
        stars.forEach((s, i) => {
          s.classList.toggle("selected", i < value);
        });
      }

      stars.forEach((star, i) => {
        star.addEventListener("click", (e) => {
          e.preventDefault();
          setRating(i + 1);
        });
        // Hover effect (desktop)
        star.addEventListener("mouseenter", () => {
          stars.forEach((s, j) => s.classList.toggle("hovered", j <= i));
        });
        star.addEventListener("mouseleave", () => {
          stars.forEach(s => s.classList.remove("hovered"));
        });
      });
    }

    // ── Client-side multi-image compression ──────
    const MAX_DIM = 800;
    const JPEG_QUALITY = 0.7;
    const MAX_BYTES = 500 * 1024;
    const MAX_FILES = 5;

    const fileInput = document.getElementById("photos");
    const status = document.getElementById("photoStatus");
    const preview = document.getElementById("photoPreview");

    function compressImage(file) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        const url = URL.createObjectURL(file);
        img.onload = () => {
          URL.revokeObjectURL(url);
          let w = img.width, h = img.height;
          if (w > MAX_DIM || h > MAX_DIM) {
            const ratio = Math.min(MAX_DIM / w, MAX_DIM / h);
            w = Math.round(w * ratio);
            h = Math.round(h * ratio);
          }
          const canvas = document.createElement("canvas");
          canvas.width = w;
          canvas.height = h;
          const ctx = canvas.getContext("2d");
          ctx.drawImage(img, 0, 0, w, h);
          canvas.toBlob(
            (blob) => blob ? resolve(blob) : reject(new Error("Compression failed")),
            "image/jpeg",
            JPEG_QUALITY
          );
        };
        img.onerror = () => { URL.revokeObjectURL(url); reject(new Error("Invalid image")); };
        img.src = url;
      });
    }

    if (fileInput) {
      fileInput.addEventListener("change", async (e) => {
        const files = Array.from(e.target.files);
        if (!files.length) return;

        if (files.length > MAX_FILES) {
          if (status) {
            status.style.display = "block";
            status.textContent = "❌ Max " + MAX_FILES + " photos.";
            status.className = "photo-status photo-error";
          }
          e.target.value = "";
          return;
        }

        if (status) {
          status.style.display = "block";
          status.textContent = "⏳ Compressing " + files.length + " photo" + (files.length > 1 ? "s" : "") + "...";
          status.className = "photo-status";
        }
        if (preview) preview.innerHTML = "";

        try {
          const dt = new DataTransfer();
          let totalKb = 0;

          for (let i = 0; i < files.length; i++) {
            const blob = await compressImage(files[i]);
            if (blob.size > MAX_BYTES) {
              if (status) {
                status.textContent = "❌ Photo " + (i + 1) + " still too large after compression.";
                status.className = "photo-status photo-error";
              }
              e.target.value = "";
              if (preview) preview.innerHTML = "";
              return;
            }
            const compressed = new File([blob], "photo_" + (i + 1) + ".jpg", { type: "image/jpeg" });
            dt.items.add(compressed);
            totalKb += Math.round(blob.size / 1024);

            // Show thumbnail preview
            if (preview) {
              const thumb = document.createElement("img");
              thumb.src = URL.createObjectURL(blob);
              thumb.className = "preview-thumb";
              preview.appendChild(thumb);
            }
          }

          e.target.files = dt.files;
          if (status) {
            status.textContent = "✅ " + files.length + " photo" + (files.length > 1 ? "s" : "") + " — " + totalKb + " KB total";
            status.className = "photo-status photo-ok";
          }
        } catch (err) {
          if (status) {
            status.textContent = "❌ Could not process image(s).";
            status.className = "photo-status photo-error";
          }
          e.target.value = "";
          if (preview) preview.innerHTML = "";
        }
      });
    }

    // ── Edit review buttons ──────────────────────
    document.querySelectorAll(".btn-edit").forEach(btn => {
      btn.addEventListener("click", () => {
        try {
          const data = JSON.parse(btn.getAttribute("data-edit"));
          const form = document.getElementById("shareForm");
          if (!form) return;
          document.getElementById("editId").value = data.id;

          // Set book via searchable input
          if (hiddenInput) hiddenInput.value = data.book_id;
          if (searchInput) {
            // Find book title from options
            const opt = allOptions ? allOptions.find(o => o.getAttribute("data-value") === data.book_id) : null;
            searchInput.value = opt ? opt.textContent : data.book_id;
            searchInput.setCustomValidity("");
            searchInput.readOnly = true;
          }

          const reviewField = document.getElementById("review_text");
          if (reviewField) reviewField.value = data.review_text;

          // Set rating via star buttons
          if (ratingInput && picker) {
            ratingInput.value = data.rating;
            const starBtns = picker.querySelectorAll(".star-btn");
            starBtns.forEach((s, j) => s.classList.toggle("selected", j < data.rating));
          }

          // Make photos optional for edits
          const photosInput = document.getElementById("photos");
          if (photosInput) photosInput.removeAttribute("required");

          // Scroll to form
          form.scrollIntoView({ behavior: "smooth", block: "start" });
        } catch(e) { console.error(e); }
      });
    });

    // ── Claim countdown ──────────────────────────
    const countdownEl = document.querySelector(".claim-countdown");
    const daysEl = document.getElementById("claimDays");
    if (countdownEl && daysEl) {
      const deadline = new Date(countdownEl.getAttribute("data-deadline"));
      const now = new Date();
      const diffMs = deadline - now;
      const days = Math.max(0, Math.ceil(diffMs / (1000 * 60 * 60 * 24)));
      daysEl.textContent = days;
    }
  });
</script>

