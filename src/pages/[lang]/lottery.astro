---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { supabase, getServiceClient } from "../../lib/supabase";
import { validateOrigin } from "../../lib/csrf";
import { books, getMonthlyPrizeBook, resolveMonthlyPrizeBook } from "../../data/books";
import { notifyLotteryClaim } from "../../lib/notifications";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/lottery/`;

// ── Auth ─────────────────────────────────────────────
const user = Astro.locals.user;
const sc = getServiceClient();

// ── User state ───────────────────────────────────────
let myReviewCount = 0;
let approvedCount = 0;
let pendingClaim: any = null;
let winPrizeBook: any = null;
let claimMsg = "";
let purchasedEntries = 0;
let ticketBalance = 0;
let isSubscribed = false;
let isPending = false;

// ── Giveaway state ───────────────────────────────────
const currentMonth = new Date().toISOString().slice(0, 7);
let { data: giveawayConfig } = await sc
  .from("lottery_config")
  .select("draw_date, prize_description, participant_boost, prize_book_id")
  .eq("month", currentMonth)
  .maybeSingle();

// Auto-create config row if missing (ensures giveaway always exists)
if (!giveawayConfig) {
  const now0 = new Date();
  const nextFirst0 = new Date(now0.getFullYear(), now0.getMonth() + 1, 1);
  await sc.from("lottery_config").insert({
    month: currentMonth,
    draw_date: nextFirst0.toISOString().slice(0, 10),
  });
  const { data: fresh } = await sc
    .from("lottery_config")
    .select("draw_date, prize_description, participant_boost, prize_book_id")
    .eq("month", currentMonth)
    .single();
  giveawayConfig = fresh;
}

// Default draw date: 1st of next month
const now = new Date();
const nextFirst = new Date(now.getFullYear(), now.getMonth() + 1, 1);
const defaultDrawDate = nextFirst.toISOString().slice(0, 10);
const rawDrawDate = giveawayConfig?.draw_date || defaultDrawDate;
// Format draw date in user-friendly locale
const drawDate = new Date(rawDrawDate + "T00:00:00").toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  { month: "long", day: "numeric", year: "numeric" }
);
const prizeDescription = giveawayConfig?.prize_description ?? "";
const prizeBook = resolveMonthlyPrizeBook(
  currentMonth,
  (giveawayConfig as any)?.prize_book_id ?? null,
);

// Count unique participants for this month + optional boost
const { data: participantData } = await sc
  .from("lottery_entries")
  .select("user_id")
  .eq("month", currentMonth);
const realParticipants = new Set((participantData ?? []).map((p: any) => p.user_id)).size;
const participantBoost = (giveawayConfig as any)?.participant_boost ?? 0;
const displayedParticipants = realParticipants + participantBoost;

// Human-friendly month name for the giveaway (e.g. "April" / "abril")
const giveawayMonthName = new Date(now.getFullYear(), now.getMonth(), 1)
  .toLocaleDateString(lang === "es" ? "es-ES" : "en-US", { month: "long" });
// ISO draw date string for countdown JS
const drawDateISO = rawDrawDate;

// Check if draw already happened
const { data: monthWinners } = await sc
  .from("lottery_winners")
  .select("id")
  .eq("month", currentMonth)
  .limit(1);
const drawDone = (monthWinners ?? []).length > 0;

if (user) {
  const { data: reviewData } = await supabase
    .from("book_reviews")
    .select("id, status")
    .eq("user_id", user.id);
  myReviewCount = reviewData?.length ?? 0;
  approvedCount = reviewData?.filter(r => r.status === "approved").length ?? 0;

  // Purchased lottery entries this month
  const { data: paidData } = await sc
    .from("lottery_entries")
    .select("entry_count")
    .eq("user_id", user.id)
    .eq("month", currentMonth);
  purchasedEntries = (paidData ?? []).reduce((sum, e) => sum + (e.entry_count || 0), 0);

  // Ticket balance
  const { data: tb } = await sc.rpc("get_user_tickets", { p_user_id: user.id });
  ticketBalance = tb ?? 0;

  // Newsletter subscription status
  const userEmail = user.email?.toLowerCase();
  if (userEmail) {
    const { data: subData } = await sc
      .from("newsletter_subscribers")
      .select("confirmed")
      .eq("email", userEmail)
      .maybeSingle();
    if (subData) {
      isSubscribed = subData.confirmed === true;
      isPending = subData.confirmed === false;
    }
  }

  // Check for unclaimed win
  const { data: winData } = await supabase
    .from("lottery_winners")
    .select("*")
    .eq("user_id", user.id)
    .eq("claimed", false)
    .gt("claim_deadline", new Date().toISOString())
    .order("created_at", { ascending: false })
    .limit(1)
    .maybeSingle();
  pendingClaim = winData;

  // Resolve the prize book for the WINNER's month (may differ from current month
  // if the win is from a prior draw). Respects lottery_config.prize_book_id override.
  if (pendingClaim) {
    const { data: winConfig } = await sc
      .from("lottery_config")
      .select("prize_book_id")
      .eq("month", pendingClaim.month)
      .maybeSingle();
    winPrizeBook = resolveMonthlyPrizeBook(
      pendingClaim.month,
      (winConfig as any)?.prize_book_id ?? null,
    );
  }

  // ── Handle POST actions ──────────────────────────
  if (Astro.request.method === "POST") {
    if (!validateOrigin(Astro.request, Astro.url)) {
      claimMsg = "⛔ Request blocked.";
    } else {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "claim" && pendingClaim) {
      // Re-verify deadline hasn't expired since page load
      const { data: freshClaim } = await sc
        .from("lottery_winners")
        .select("id, claimed, claim_deadline")
        .eq("id", pendingClaim.id)
        .eq("claimed", false)
        .gt("claim_deadline", new Date().toISOString())
        .maybeSingle();

      if (!freshClaim) {
        claimMsg = text.claimExpired;
        pendingClaim = null;
      } else {
        const bookChosen = formData.get("book_chosen")?.toString().slice(0, 100) || "";
        const shippingName = (formData.get("shipping_name")?.toString().trim() || "").slice(0, 200);
        const shippingAddress = (formData.get("shipping_address")?.toString().trim() || "").slice(0, 500);

        if (bookChosen && shippingName && shippingAddress && winPrizeBook) {
          // LOTTERY-001: enforce that book_chosen matches the resolved prize book
          // for the winner's month. Prevents tampered POSTs from claiming other titles.
          if (bookChosen !== winPrizeBook.id) {
            claimMsg = text.claimError;
          } else {
            await sc
              .from("lottery_winners")
              .update({
                book_chosen: bookChosen,
                shipping_name: shippingName,
                shipping_address: shippingAddress,
                claimed: true,
              })
              .eq("id", pendingClaim.id);

            claimMsg = text.claimSuccess;
            pendingClaim = null;
            await notifyLotteryClaim(user.email || "unknown", bookChosen, shippingName, shippingAddress);
          }
        }
      }
    }
    } // end CSRF else
  }
}

// ── Public winners ───────────────────────────────────
const { data: publicWinners } = await supabase
  .from("lottery_winners_public")
  .select("month, book_chosen, display_name, state, country")
  .order("month", { ascending: false })
  .limit(3);

// Sample winners for preview if DB empty (dynamic, relative to current month)
const sampleNames = [
  { display_name: "Sofia Martinez", state: "New York", country: "US" },
  { display_name: "Carlos Rodriguez", state: "Texas", country: "US" },
  { display_name: "Maria Garcia", state: "Florida", country: "US" },
];
const samplePreviewWinners = sampleNames.map((s, i) => {
  const d = new Date(now.getFullYear(), now.getMonth() - (i + 1), 1);
  const m = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  return { ...s, month: m, book_chosen: getMonthlyPrizeBook(m).id };
});
const previewWinners = (publicWinners && publicWinners.length > 0) ? publicWinners : samplePreviewWinners;

function safeName(d: string | null) {
  if (!d) return "—";
  const p = d.trim().split(/\s+/);
  return p.length === 1 ? p[0] : `${p[0]} ${p[1][0]}.`;
}

const bookOptions = books.map(b => ({ id: b.id, title: b.title[lang] }));
const bookMap = Object.fromEntries(bookOptions.map(b => [b.id, b.title]));
const coverMap = Object.fromEntries(books.map(b => [b.id, b.coverSrc]));
---

<BaseLayout
  lang={lang}
  title={text.lotteryMetaTitle}
  description={text.lotteryDescription}
  pathname={pathname}
  breadcrumbs={[
    { name: text.navHome, url: `/${lang}/` },
    { name: text.lotteryHeading, url: pathname }
  ]}
>
  <section class="page-section container">
    <!-- Header -->
    <div class="section-head" style="text-align:center; max-width:42rem; margin:0 auto 2rem;">
      <h1>{text.lotteryHeading}</h1>
      <p>{text.lotteryDescription}</p>
    </div>

    <div style="max-width:42rem; margin:0 auto;">

      {/* ── Giveaway Status Card ── */}
      <div class={`surface-card status-card ${drawDone ? "status-drawn" : "status-open"}`}>
        {drawDone ? (
          <p class="status-text">{text.lotteryStatusDrawn}</p>
        ) : (
          <Fragment>
            <p class="status-month">{text.lotteryMonth.replace("{month}", giveawayMonthName)}</p>
            <p class="status-text">{text.lotteryStatusOpen.replace("{date}", drawDate || "TBD")}</p>

            {/* ── Countdown ── */}
            <div class="draw-countdown" data-draw-date={drawDateISO}>
              <div class="cd-unit"><span class="cd-num" id="cdDays">--</span><span class="cd-label">{text.lotteryCountdownDays}</span></div>
              <span class="cd-sep">:</span>
              <div class="cd-unit"><span class="cd-num" id="cdHours">--</span><span class="cd-label">{text.lotteryCountdownHours}</span></div>
              <span class="cd-sep">:</span>
              <div class="cd-unit"><span class="cd-num" id="cdMin">--</span><span class="cd-label">{text.lotteryCountdownMin}</span></div>
              <span class="cd-sep">:</span>
              <div class="cd-unit"><span class="cd-num" id="cdSec">--</span><span class="cd-label">{text.lotteryCountdownSec}</span></div>
            </div>

            {displayedParticipants > 0 && (
              <p class="participant-count" id="participant-count" data-count={realParticipants} data-boost={participantBoost}>
                👥 {displayedParticipants} {lang === "es"
                  ? `participante${displayedParticipants > 1 ? "s" : ""} en este sorteo`
                  : `participant${displayedParticipants > 1 ? "s" : ""} in this giveaway`}
              </p>
            )}

            <div class="prize-showcase">
              <img src={prizeBook.coverSrc} alt={prizeBook.title[lang]} class="prize-cover" loading="lazy" width="96" height="128" />
              <div class="prize-info">
                <p class="prize-label">🎁 {text.lotteryPrize}</p>
                <p class="prize-book-title">{prizeBook.title[lang]}</p>
                {prizeDescription && <p class="prize-desc">{prizeDescription}</p>}
                <a href={prizeBook.amazonUrl} target="_blank" rel="noopener noreferrer" class="amazon-link">{text.lotteryViewOnAmazon}</a>
                {user && purchasedEntries > 0 && (
                  <p class="giveaway-entries-badge" id="giveaway-entries-badge" data-count={purchasedEntries}>
                    🎟️ {purchasedEntries} ticket{purchasedEntries > 1 ? "s" : ""} {lang === "es" ? "en este sorteo" : "in this giveaway"}
                  </p>
                )}
              </div>
            </div>
          </Fragment>
        )}
      </div>

      {!user ? (
        <!-- Not logged in -->
        <div class="surface-card" style="padding:2rem 1.6rem; text-align:center;">
          <p>{text.lotteryNotLoggedIn}</p>
          <a href={`/${lang}/login/`} class="btn btn-primary">{text.navLogin}</a>
        </div>
      ) : (
        <Fragment>
          {/* ── Pending claim banner (compact + expandable) ── */}
          {pendingClaim && !claimMsg && winPrizeBook && (
            <details class="surface-card claim-card-compact" id="claimBanner">
              <summary class="claim-summary-compact">
                <span class="claim-trophy">🏆</span>
                <span class="claim-summary-text">
                  <strong>{text.claimCompactTitle}</strong>
                  <span class="claim-days-inline" data-deadline={pendingClaim.claim_deadline}>
                    {" — "}<span class="claim-days" id="claimDays"></span> {text.claimDaysLeft}
                  </span>
                </span>
                <span class="claim-summary-cta">{text.claimExpandCta}</span>
              </summary>

              <div class="claim-expanded">
                <p>{text.claimInstructions}</p>
                <form method="POST" class="form-grid">
                  <input type="hidden" name="action" value="claim" />

                  {/* Single book — no choice allowed, per master doc §III-D LOTTERY-001 */}
                  <div class="form-group">
                    <label>{text.claimBookLabel}</label>
                    <div class="claim-book-fixed">
                      {winPrizeBook.coverSrc && (
                        <img
                          src={winPrizeBook.coverSrc}
                          alt={winPrizeBook.title[lang]}
                          width="80"
                          height="100"
                          loading="lazy"
                        />
                      )}
                      <span class="claim-book-title">{winPrizeBook.title[lang]}</span>
                    </div>
                    <input type="hidden" name="book_chosen" value={winPrizeBook.id} />
                  </div>

                  <div class="form-group">
                    <label for="shipping_name">{text.claimShippingName}</label>
                    <input type="text" id="shipping_name" name="shipping_name" required maxlength="200" />
                  </div>
                  <div class="form-group">
                    <label for="shipping_address">{text.claimShippingAddress}</label>
                    <textarea id="shipping_address" name="shipping_address" rows="3" required maxlength="500"></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary" style="width:100%;">{text.claimSubmit}</button>
                </form>
              </div>
            </details>
          )}

          {claimMsg && (
            <div class="surface-card" style="padding:1.6rem; margin-bottom:1.5rem; text-align:center; border:2px solid var(--brand-green);">
              <h2>✅ {text.claimOrderSummary}</h2>
              <p class="msg msg-success">{claimMsg}</p>
            </div>
          )}

          {/* ── Your Tickets & Enter Giveaway Card ── */}
          <div class="surface-card entries-card">
            <div class="entries-total">
              <span class="entries-number" id="giveaway-ticket-balance">{ticketBalance}</span>
              <span class="entries-label">{lang === "es" ? "Tickets disponibles" : "Tickets available"}</span>
            </div>

            {purchasedEntries > 0 && (
              <p class="entries-breakdown">
                ✅ {lang === "es"
                  ? `Ya entraste con ${purchasedEntries} ticket${purchasedEntries > 1 ? "s" : ""} este mes`
                  : `Already entered ${purchasedEntries} ticket${purchasedEntries > 1 ? "s" : ""} this month`}
              </p>
            )}

            {!drawDone && isSubscribed && (
              <div class="enter-giveaway-form" style="margin-top:1rem;">
                <p style="font-size:0.88rem; color:var(--ink-soft); margin:0 0 0.6rem;">
                  {lang === "es" ? "¿Cuántos tickets quieres usar para este sorteo?" : "How many tickets do you want to use for this giveaway?"}
                </p>
                <div class="lottery-qty" style="justify-content:center;">
                  <button class="qty-btn" id="giveaway-qty-minus">−</button>
                  <span id="giveaway-qty-value">1</span>
                  <button class="qty-btn" id="giveaway-qty-plus">+</button>
                </div>
                <button class="btn btn-primary btn-sm" id="enter-giveaway-btn" style="margin-top:0.6rem;">
                  🎟️ {lang === "es" ? "Entrar al sorteo" : "Enter giveaway"}
                </button>
                <p class="msg" id="giveaway-msg" style="display:none; margin-top:0.5rem;"></p>
              </div>
            )}

            {drawDone && (
              <p style="color:var(--ink-soft); font-size:0.88rem; margin-top:0.6rem;">{text.lotteryStatusDrawn}</p>
            )}

            {ticketBalance > 0 && (
              <details class="gift-ticket-box" style="margin-top:1rem;">
                <summary class="gift-ticket-summary">
                  🎁 {text.giftTicketCta}
                </summary>
                <div class="gift-ticket-body">
                  <p class="gift-ticket-hint">{text.giftTicketHint}</p>
                  <p class="gift-ticket-bonus">{text.giftTicketBonus}</p>
                  <label class="gift-ticket-label" for="gift-recipient-email">{text.giftTicketEmailLabel}</label>
                  <input type="email" id="gift-recipient-email" class="gift-ticket-input" placeholder="amigo@ejemplo.com" maxlength="320" />
                  <label class="gift-ticket-label" for="gift-quantity">{text.giftTicketQtyLabel}</label>
                  <div class="lottery-qty" style="justify-content:flex-start;">
                    <button type="button" class="qty-btn" id="gift-qty-minus">−</button>
                    <span id="gift-qty-value">1</span>
                    <button type="button" class="qty-btn" id="gift-qty-plus">+</button>
                  </div>
                  <button type="button" class="btn btn-sm btn-primary" id="gift-send-btn" style="margin-top:0.6rem;">
                    🎁 {text.giftTicketSend}
                  </button>
                  <p class="msg" id="gift-msg" style="display:none; margin-top:0.5rem;"></p>
                </div>
              </details>
            )}

            <div class="entries-actions" style="margin-top:1rem;">
              <a href={`/${lang}/peanuts/`} class="btn btn-sm btn-secondary">🥜 {lang === "es" ? "Comprar más tickets" : "Buy more tickets"}</a>
              <a href={`/${lang}/reviews/`} class="btn btn-secondary btn-sm">{text.reviewsHeading} →</a>
            </div>

            {/* ── Newsletter Gate Banner ── */}
            {!isSubscribed && !isPending && (
              <div class="newsletter-gate">
                <p class="newsletter-gate-title">{text.lotterySubscribeBanner}</p>
                <p class="newsletter-gate-detail">{text.lotterySubscribeDetail}</p>
                <a href={`/${lang}/newsletter/`} class="btn btn-sm btn-primary">{text.lotterySubscribeCta}</a>
              </div>
            )}
            {isPending && (
              <div class="newsletter-gate newsletter-gate--pending">
                <p>📧 {text.lotterySubscribePending}</p>
              </div>
            )}
          </div>
        </Fragment>
      )}

      {/* ── How It Works — collapsed by default ── */}
      <details class="lottery-steps surface-card" style="padding:0;">
        <summary class="steps-summary">
          <h2>{text.lotteryHowItWorks}</h2>
          <svg class="steps-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <div class="steps-body">
          <div class="steps-row">
            <div class="step-card">
              <span class="step-icon">�</span>
              <span class="step-num">1</span>
              <p class="step-text">{text.lotteryStep1}</p>
            </div>
            <span class="step-arrow">→</span>
            <div class="step-card">
              <span class="step-icon">📸</span>
              <span class="step-num">2</span>
              <p class="step-text">{text.lotteryStep2}</p>
            </div>
            <span class="step-arrow">→</span>
            <div class="step-card">
              <span class="step-icon">🎫</span>
              <span class="step-num">3</span>
              <p class="step-text">{text.lotteryStep3}</p>
            </div>
          </div>
          <div class="steps-row" style="margin-top:0.6rem;">
            <div class="step-card step-card--bonus">
              <span class="step-icon">🥜</span>
              <span class="step-num step-num--bonus">+</span>
              <p class="step-text">{text.lotteryStep4}</p>
            </div>
            <span class="step-arrow">→</span>
            <div class="step-card">
              <span class="step-icon">🏆</span>
              <span class="step-num">5</span>
              <p class="step-text">{text.lotteryStep5}</p>
            </div>
          </div>
        </div>
      </details>
    </div>

    {/* ── Latest Winners ── */}
    {previewWinners && previewWinners.length > 0 && (
      <div style="max-width:42rem; margin:2.5rem auto 0;">
        <h2 style="text-align:center; margin-bottom:1rem;">{text.lotteryWinnersTitle}</h2>
        <div class="winners-list">
          {previewWinners.map((w: any) => {
            const cover = w.book_chosen ? coverMap[w.book_chosen] : null;
            const loc = [w.state, w.country].filter(Boolean).join(", ");
            return (
              <div class="winner-row">
                <span class="winner-month">{w.month}</span>
                {cover && <img src={cover} alt={bookMap[w.book_chosen] || w.book_chosen} class="winner-preview-cover" loading="lazy" width="40" height="50" />}
                <div class="winner-preview-info">
                  <span class="winner-name">{safeName(w.display_name)}</span>
                  <span class="winner-book">{w.book_chosen ? bookMap[w.book_chosen] || w.book_chosen : ""}</span>
                  {loc && <span class="winner-loc">{loc}</span>}
                </div>
              </div>
            );
          })}
        </div>
        <p style="text-align:center; margin-top:1rem;">
          <a href={`/${lang}/winners/`} class="btn btn-ghost btn-sm">{text.winnersSeeAll}</a>
        </p>
      </div>
    )}
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    // ── Claim countdown (days only) ──────────────
    const countdownEl = document.querySelector(".claim-countdown");
    const daysEl = document.getElementById("claimDays");
    if (countdownEl && daysEl) {
      const deadline = new Date(countdownEl.getAttribute("data-deadline"));
      const now = new Date();
      const diffMs = deadline - now;
      const days = Math.max(0, Math.ceil(diffMs / (1000 * 60 * 60 * 24)));
      daysEl.textContent = days;
    }

    // ── Draw countdown (live ticker) ─────────────
    const cdWrap = document.querySelector(".draw-countdown");
    if (!cdWrap) return;
    const target = new Date(cdWrap.getAttribute("data-draw-date") + "T08:00:00Z"); // draw at 8AM UTC
    const $d = document.getElementById("cdDays");
    const $h = document.getElementById("cdHours");
    const $m = document.getElementById("cdMin");
    const $s = document.getElementById("cdSec");
    if (!$d || !$h || !$m || !$s) return;

    function tick() {
      const diff = Math.max(0, target - Date.now());
      const s = Math.floor(diff / 1000);
      $d.textContent = String(Math.floor(s / 86400)).padStart(2, "0");
      $h.textContent = String(Math.floor((s % 86400) / 3600)).padStart(2, "0");
      $m.textContent = String(Math.floor((s % 3600) / 60)).padStart(2, "0");
      $s.textContent = String(s % 60).padStart(2, "0");
      if (diff <= 0) clearInterval(timer);
    }
    tick();
    const timer = setInterval(tick, 1000);

    // ── Enter giveaway qty selector & submit ─────
    const gqMinus = document.getElementById("giveaway-qty-minus");
    const gqPlus  = document.getElementById("giveaway-qty-plus");
    const gqVal   = document.getElementById("giveaway-qty-value");
    const gqBtn   = document.getElementById("enter-giveaway-btn");
    const gqMsg   = document.getElementById("giveaway-msg");

    if (gqMinus && gqPlus && gqVal && gqBtn) {
      let gQty = 1;
      gqMinus.addEventListener("click", () => { gQty = Math.max(1, gQty - 1); gqVal.textContent = gQty; });
      gqPlus.addEventListener("click",  () => { gQty = Math.min(20, gQty + 1); gqVal.textContent = gQty; });

      gqBtn.addEventListener("click", async () => {
        gqBtn.disabled = true;
        gqBtn.textContent = "...";
        if (gqMsg) { gqMsg.style.display = "none"; gqMsg.className = "msg"; }
        try {
          const badgeExisted = !!document.getElementById("giveaway-entries-badge");
          const res = await fetch("/api/enter-giveaway/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ quantity: gQty, month: new Date().toISOString().slice(0, 7) }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || "Error");
          // Update ticket balance on page and header
          const balEl = document.getElementById("giveaway-ticket-balance");
          if (balEl) balEl.textContent = data.ticket_balance;
          const ht = document.getElementById("tickets-count");
          if (ht) ht.textContent = data.ticket_balance;
          sessionStorage.setItem("lcp-tickets", String(data.ticket_balance));
          // Update entries badge in giveaway banner
          const badge = document.getElementById("giveaway-entries-badge");
          if (badge) {
            const prev = parseInt(badge.dataset.count || "0", 10);
            const newTotal = prev + data.entries_added;
            badge.dataset.count = newTotal;
            badge.textContent = "🎟️ " + newTotal + " ticket" + (newTotal > 1 ? "s" : "") + (document.documentElement.lang === "es" ? " en este sorteo" : " in this giveaway");
          } else {
            // Badge didn't exist yet (first entry) — create it
            const prizeInfo = document.querySelector(".prize-info");
            if (prizeInfo) {
              const newBadge = document.createElement("p");
              newBadge.className = "giveaway-entries-badge";
              newBadge.id = "giveaway-entries-badge";
              newBadge.dataset.count = data.entries_added;
              newBadge.textContent = "🎟️ " + data.entries_added + " ticket" + (data.entries_added > 1 ? "s" : "") + (document.documentElement.lang === "es" ? " en este sorteo" : " in this giveaway");
              prizeInfo.appendChild(newBadge);
            }
          }
          // Update participant count in banner (first entry by this user)
          const pcEl = document.getElementById("participant-count");
          if (pcEl && !badgeExisted) {
            // User's first entry — increment displayed count
            const boost = parseInt(pcEl.dataset.boost || "0", 10);
            const prev = parseInt(pcEl.dataset.count || "0", 10);
            const newReal = prev + 1;
            pcEl.dataset.count = String(newReal);
            const total = newReal + boost;
            const lang = document.documentElement.lang;
            pcEl.textContent = "👥 " + total + (lang === "es" ? ` participante${total > 1 ? "s" : ""} en este sorteo` : ` participant${total > 1 ? "s" : ""} in this giveaway`);
          } else if (!pcEl) {
            // No participant count element yet — create it
            const countdown = document.querySelector(".draw-countdown");
            if (countdown) {
              const p = document.createElement("p");
              p.className = "participant-count";
              p.id = "participant-count";
              p.dataset.count = "1";
              p.dataset.boost = "0";
              const lang = document.documentElement.lang;
              p.textContent = "👥 1 " + (lang === "es" ? "participante en este sorteo" : "participant in this giveaway");
              countdown.after(p);
            }
          }
          if (gqMsg) {
            gqMsg.textContent = data.entries_added + " ticket" + (data.entries_added > 1 ? "s" : "") + " entered!";
            gqMsg.classList.add("msg-success");
            gqMsg.style.display = "block";
          }
        } catch (e) {
          if (gqMsg) {
            gqMsg.textContent = e.message;
            gqMsg.classList.add("msg-error");
            gqMsg.style.display = "block";
          }
        } finally {
          gqBtn.disabled = false;
          gqBtn.textContent = "🎟️ Enter giveaway";
        }
      });
    }

    // ── Gift tickets to a friend ──
    const giftBtn = document.getElementById("gift-send-btn");
    const giftQtyMinus = document.getElementById("gift-qty-minus");
    const giftQtyPlus = document.getElementById("gift-qty-plus");
    const giftQtyVal = document.getElementById("gift-qty-value");
    const giftMsg = document.getElementById("gift-msg");
    const giftEmail = document.getElementById("gift-recipient-email");
    const LANG = document.documentElement.lang === "en" ? "en" : "es";
    const giftLabels = LANG === "es"
      ? {
          invalid_email: "Email inválido.",
          invalid_quantity: "Cantidad inválida.",
          recipient_not_found: "No encontramos una cuenta con ese email.",
          self_gift_not_allowed: "No puedes regalarte a ti mismo.",
          insufficient_tickets: "No tienes suficientes tickets.",
          rate_limit: "Límite diario alcanzado (3 regalos por día).",
          generic: "No se pudo enviar el regalo.",
          success: "¡Regalo enviado a {email}!",
          pending: "¡Invitación enviada a {email}! Los tickets quedan reservados 30 días mientras crea su cuenta.",
          sending: "Enviando…",
        }
      : {
          invalid_email: "Invalid email.",
          invalid_quantity: "Invalid quantity.",
          recipient_not_found: "No account found with that email.",
          self_gift_not_allowed: "You can't gift yourself.",
          insufficient_tickets: "Not enough tickets.",
          rate_limit: "Daily limit reached (3 gifts per day).",
          generic: "Could not send gift.",
          success: "Gift sent to {email}!",
          pending: "Invite sent to {email}! Tickets are reserved for 30 days while they create their account.",
          sending: "Sending…",
        };
    if (giftQtyMinus && giftQtyPlus && giftQtyVal) {
      giftQtyMinus.addEventListener("click", () => {
        const v = parseInt(giftQtyVal.textContent || "1", 10);
        if (v > 1) giftQtyVal.textContent = String(v - 1);
      });
      giftQtyPlus.addEventListener("click", () => {
        const v = parseInt(giftQtyVal.textContent || "1", 10);
        if (v < 5) giftQtyVal.textContent = String(v + 1);
      });
    }
    if (giftBtn) {
      giftBtn.addEventListener("click", async () => {
        if (!giftMsg || !giftEmail || !giftQtyVal) return;
        giftMsg.style.display = "none";
        giftMsg.classList.remove("msg-success", "msg-error");
        const email = (giftEmail.value || "").trim();
        const qty = parseInt(giftQtyVal.textContent || "1", 10);
        const originalLabel = giftBtn.textContent;
        giftBtn.disabled = true;
        giftBtn.textContent = giftLabels.sending;
        try {
          const res = await fetch("/api/gift-ticket/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ recipient_email: email, quantity: qty }),
          });
          const data = await res.json();
          if (!res.ok || !data.success) {
            const key = data && data.error ? data.error : "generic";
            const label = giftLabels[key] || giftLabels.generic;
            giftMsg.textContent = label;
            giftMsg.classList.add("msg-error");
            giftMsg.style.display = "block";
            return;
          }
          // Update sender balance in-page
          const balEl = document.getElementById("giveaway-ticket-balance");
          if (balEl && typeof data.sender_balance === "number") balEl.textContent = data.sender_balance;
          const ht = document.getElementById("tickets-count");
          if (ht && typeof data.sender_balance === "number") ht.textContent = data.sender_balance;
          if (typeof data.sender_balance === "number") {
            sessionStorage.setItem("lcp-tickets", String(data.sender_balance));
          }
          const labelKey = data.pending ? "pending" : "success";
          giftMsg.textContent = giftLabels[labelKey].replace("{email}", data.recipient_email || email);
          giftMsg.classList.add("msg-success");
          giftMsg.style.display = "block";
          giftEmail.value = "";
          giftQtyVal.textContent = "1";
        } catch (e) {
          giftMsg.textContent = giftLabels.generic;
          giftMsg.classList.add("msg-error");
          giftMsg.style.display = "block";
        } finally {
          giftBtn.disabled = false;
          giftBtn.textContent = originalLabel;
        }
      });
    }
  });
</script>

