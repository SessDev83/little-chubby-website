---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { siteConfig } from "../../data/site";
import { languages, getLangFromParam, ui } from "../../data/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/contact/`;
---

<BaseLayout lang={lang} title={text.contactMetaTitle} description={text.contactMetaDescription} pathname={pathname}>
  <section class="page-section">
    <div class="container">
      <div class="section-head">
        <h1>{text.contactSectionTitle}</h1>
        <p>
          {lang === "es"
            ? "Colaboraciones, prensa, preguntas editoriales o propuestas de distribucion."
            : "Collaborations, press, editorial questions, or distribution proposals."}
        </p>
        <p>
          {lang === "es" ? "Email directo:" : "Direct email:"}
          <a href={`mailto:${siteConfig.contactEmail}`} style="margin-left: 0.4rem; color: var(--brand-blue);">
            {siteConfig.contactEmail}
          </a>
        </p>
      </div>

      <ContactForm lang={lang} />
    </div>
  </section>
</BaseLayout>
