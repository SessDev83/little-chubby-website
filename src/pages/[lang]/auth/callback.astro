---
export const prerender = false;

import { getLangFromParam } from "../../../data/i18n";
import type { Lang } from "../../../data/i18n";
import { supabase } from "../../../lib/supabase";

const RESEND_API_KEY = import.meta.env.RESEND_API_KEY;
const ANALYTICS_EMAIL = import.meta.env.ANALYTICS_EMAIL || "ivan.c4u@gmail.com";

async function notifyNewUser(email: string, lang: string) {
  if (!RESEND_API_KEY) return;
  try {
    await fetch("https://api.resend.com/emails", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${RESEND_API_KEY}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        from: "Little Chubby Press <noreply@littlechubbypress.com>",
        to: [ANALYTICS_EMAIL],
        subject: `🎉 New User Registered: ${email}`,
        html: `
          <div style="font-family:sans-serif;max-width:400px;margin:0 auto;padding:20px;background:#f9f7f3;border-radius:12px">
            <h2 style="color:#6b4c3b;margin:0 0 12px">🎉 New User!</h2>
            <table style="width:100%;border-collapse:collapse">
              <tr><td style="padding:6px 0;color:#888">Email</td><td style="padding:6px 0;font-weight:700">${email}</td></tr>
              <tr><td style="padding:6px 0;color:#888">Language</td><td style="padding:6px 0">${lang}</td></tr>
              <tr><td style="padding:6px 0;color:#888">Time</td><td style="padding:6px 0">${new Date().toISOString().replace("T", " ").slice(0, 19)} UTC</td></tr>
            </table>
          </div>`,
      }),
    });
  } catch {
    // Non-blocking
  }
}

const lang = getLangFromParam(Astro.params.lang) as Lang;

// ── PKCE flow: Supabase sends ?code= as a query param ──
const code = Astro.url.searchParams.get("code");

if (code) {
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);

  if (!error && data.session) {
    Astro.cookies.set("sb-access-token", data.session.access_token, {
      path: "/",
      httpOnly: true,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });
    Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
      path: "/",
      httpOnly: true,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });
    Astro.cookies.set("sb-logged-in", "1", {
      path: "/",
      httpOnly: false,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });

    // Notify admin if this is a brand-new user (created within last 5 minutes)
    const user = data.session.user;
    const createdAt = new Date(user.created_at).getTime();
    const fiveMinAgo = Date.now() - 5 * 60 * 1000;
    if (createdAt > fiveMinAgo) {
      notifyNewUser(user.email || "unknown", lang);
    }

    return Astro.redirect(`/${lang}/profile/`);
  }

  // Code exchange failed — redirect to login
  return Astro.redirect(`/${lang}/login/`);
}

// ── Legacy implicit flow fallback: tokens arrive in URL hash ──
// Server cannot read hash, so a client-side script extracts them and
// redirects with query params that the server can read.
const accessToken = Astro.url.searchParams.get("access_token");
const refreshToken = Astro.url.searchParams.get("refresh_token");

if (accessToken && refreshToken) {
  Astro.cookies.set("sb-access-token", accessToken, {
    path: "/",
    httpOnly: true,
    secure: true,
    sameSite: "lax",
    maxAge: 60 * 60 * 24 * 7,
  });
  Astro.cookies.set("sb-refresh-token", refreshToken, {
    path: "/",
    httpOnly: true,
    secure: true,
    sameSite: "lax",
    maxAge: 60 * 60 * 24 * 7,
  });
  Astro.cookies.set("sb-logged-in", "1", {
    path: "/",
    httpOnly: false,
    secure: true,
    sameSite: "lax",
    maxAge: 60 * 60 * 24 * 7,
  });

  return Astro.redirect(`/${lang}/profile/`);
}

// No code or tokens — render client-side fallback that reads hash fragment
---
<html lang="en">
<head><meta charset="utf-8"><title>Signing in…</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif;color:#2f261f;background:#f6f1e7;">
  <p id="msg" style="font-size:1.2rem;">Signing you in…</p>
  <script define:vars={{ lang }}>
    // Fallback: read tokens from URL hash fragment (legacy implicit flow)
    const hash = window.location.hash.substring(1);
    const params = new URLSearchParams(hash);
    const accessToken = params.get("access_token");
    const refreshToken = params.get("refresh_token");

    if (accessToken && refreshToken) {
      window.location.replace(
        `/${lang}/auth/callback/?access_token=${encodeURIComponent(accessToken)}&refresh_token=${encodeURIComponent(refreshToken)}`
      );
    } else {
      document.getElementById("msg").textContent = "Session expired. Redirecting to login…";
      setTimeout(() => { window.location.replace(`/${lang}/login/`); }, 1500);
    }
  </script>
</body>
</html>
