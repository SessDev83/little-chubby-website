---
export const prerender = false;

import { getLangFromParam } from "../../../data/i18n";
import type { Lang } from "../../../data/i18n";
import { supabase } from "../../../lib/supabase";
import { getServiceClient } from "../../../lib/supabase";
import { notifyNewUser, notifySubscriberConfirmed } from "../../../lib/notifications";

const lang = getLangFromParam(Astro.params.lang) as Lang;

// ── PKCE flow: Supabase sends ?code= as a query param ──
const code = Astro.url.searchParams.get("code");

if (code) {
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);

  if (!error && data.session) {
    Astro.cookies.set("sb-access-token", data.session.access_token, {
      path: "/",
      httpOnly: true,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });
    Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
      path: "/",
      httpOnly: true,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });
    Astro.cookies.set("sb-logged-in", "1", {
      path: "/",
      httpOnly: false,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });

    // Notify admin if this is a brand-new user (created within last 5 minutes)
    const user = data.session.user;
    const createdAt = new Date(user.created_at).getTime();
    const fiveMinAgo = Date.now() - 5 * 60 * 1000;
    if (createdAt > fiveMinAgo) {
      await notifyNewUser(user.email || "unknown", lang);

      // Auto-confirm newsletter subscriber if they registered with the same email
      if (user.email) {
        const svc = getServiceClient();
        const { data: updated } = await svc.from("newsletter_subscribers")
          .update({ confirmed: true })
          .eq("email", user.email.toLowerCase())
          .eq("confirmed", false)
          .select("email")
          .maybeSingle();

        if (updated) {
          await notifySubscriberConfirmed(updated.email);
        }
      }
    }

    return Astro.redirect(`/${lang}/profile/`);
  }

  // Code exchange failed — redirect to login with error
  return Astro.redirect(`/${lang}/login/?msg=error`);
}

// No code provided — redirect to login
return Astro.redirect(`/${lang}/login/`);
---
