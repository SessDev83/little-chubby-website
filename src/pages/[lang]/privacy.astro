---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";
import { languages, getLangFromParam, ui } from "../../data/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromParam(Astro.params.lang);
const text = ui[lang];
const pathname = `/${lang}/privacy/`;
---

<BaseLayout lang={lang} title={text.privacyMetaTitle} description={text.privacyMetaDescription} pathname={pathname}>
  <section class="page-section">
    <div class="container">
      <article class="surface-card" style="padding: clamp(1rem, 2.8vw, 2rem);">
        <h1>{text.privacySectionTitle}</h1>

        {
          lang === "es" ? (
            <div class="article-prose">
              <p>Ultima actualizacion: 7 de abril de 2026.</p>
              <p>
                En {siteConfig.brandName} respetamos tu privacidad. Esta pagina resume como recopilamos, usamos y
                protegemos tus datos.
              </p>
              <h2>1. Datos que recopilamos</h2>
              <p>Recopilamos la informacion que envias voluntariamente mediante formularios de contacto o newsletter.</p>
              <h2>2. Uso de la informacion</h2>
              <p>Usamos tus datos para responder mensajes, enviar novedades y mejorar la experiencia del sitio.</p>
              <h2>3. Proveedores externos</h2>
              <p>
                Los formularios pueden procesarse mediante servicios de terceros (por ejemplo Formspree),
                sujetos a sus propias politicas de privacidad.
              </p>
              <h2>4. Conservacion y derechos</h2>
              <p>
                Puedes solicitar acceso, correccion o eliminacion de tus datos escribiendo a {siteConfig.contactEmail}.
              </p>
              <h2>5. Contacto</h2>
              <p>
                Para cualquier consulta de privacidad, escribe a
                <a href={`mailto:${siteConfig.contactEmail}`}> {siteConfig.contactEmail}</a>.
              </p>
            </div>
          ) : (
            <div class="article-prose">
              <p>Last updated: April 7, 2026.</p>
              <p>
                At {siteConfig.brandName}, we respect your privacy. This page summarizes how we collect, use, and
                protect your information.
              </p>
              <h2>1. Data we collect</h2>
              <p>We collect data that you voluntarily submit through contact and newsletter forms.</p>
              <h2>2. How we use data</h2>
              <p>We use your information to reply to messages, send updates, and improve the website experience.</p>
              <h2>3. Third-party providers</h2>
              <p>
                Forms may be processed through third-party services (for example Formspree), each with
                their own privacy policies.
              </p>
              <h2>4. Retention and rights</h2>
              <p>You can request data access, correction, or deletion by emailing {siteConfig.contactEmail}.</p>
              <h2>5. Contact</h2>
              <p>
                For privacy requests, contact
                <a href={`mailto:${siteConfig.contactEmail}`}> {siteConfig.contactEmail}</a>.
              </p>
            </div>
          )
        }
      </article>
    </div>
  </section>
</BaseLayout>
