---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromParam, ui } from "../../data/i18n";
import type { Lang } from "../../data/i18n";
import { getServiceClient } from "../../lib/supabase";

const lang = getLangFromParam(Astro.params.lang) as Lang;
const text = ui[lang];
const pathname = `/${lang}/peanuts/`;

// Giveaway + newsletter state (kept for reason labels)
const sc = getServiceClient();
const user = Astro.locals.user;

const reasonLabels: Record<string, string> = {
  review: text.peanutReasonReview,
  share: text.peanutReasonShare,
  download: text.peanutReasonDownload,
  admin: text.peanutReasonAdmin,
  giveaway: text.peanutReasonGiveaway,
  badge: text.peanutShopBadge,
  boost: text.peanutShopBoost,
  lottery_entry: text.peanutShopLottery,
  ticket_purchase: lang === "es" ? "Compra de tickets" : "Ticket purchase",
  top_earner_bonus: text.peanutReasonTopEarner,
  early_access: text.peanutReasonEarlyAccess,
};

const reasonIcons: Record<string, string> = {
  review: "📝",
  share: "🔗",
  download: "🎨",
  admin: "⚙️",
  giveaway: "🎟️",
  badge: "🖼️",
  boost: "📌",
  lottery_entry: "🎟️",
  ticket_purchase: "🎟️",
  top_earner_bonus: "🏆",
  early_access: "🔓",
};

const badgeItems = [
  { type: "frame_gold", label: text.badgeFrameGold, icon: "🖼️", cost: 15 },
  { type: "frame_silver", label: text.badgeFrameSilver, icon: "🪞", cost: 15 },
  { type: "top_reviewer", label: text.badgeTopReviewer, icon: "⭐", cost: 15 },
  { type: "star_parent", label: text.badgeStarParent, icon: "💖", cost: 15 },
  { type: "frame_animated", label: text.badgeFrameAnimated, icon: "🎭", cost: 20 },
];

const ACCENT_COLORS = [
  { id: "gold",   swatch: "#f59e0b" },
  { id: "coral",  swatch: "#fb7185" },
  { id: "teal",   swatch: "#14b8a6" },
  { id: "violet", swatch: "#8b5cf6" },
  { id: "rose",   swatch: "#f472b6" },
  { id: "sage",   swatch: "#84cc16" },
];
const ACCENT_COST = 8;

const boostItems = [
  { type: "pin_7d", label: text.boostPin7d, icon: "📌", cost: 10 },
  { type: "gold_border", label: text.boostGoldBorder, icon: "✨", cost: 10 },
];

// ── Monthly leaderboard (top 5, opted-in only, public data) ───
interface LeaderboardRow {
  rank: number;
  user_id: string;
  display_name: string | null;
  peanuts_earned: number;
}
let leaderboard: LeaderboardRow[] = [];
try {
  const { data: lbData } = await sc
    .from("monthly_leaderboard")
    .select("rank, user_id, display_name, peanuts_earned")
    .order("rank", { ascending: true })
    .limit(5);
  leaderboard = (lbData || []) as LeaderboardRow[];
} catch {
  leaderboard = [];
}

// Is the current user already opted in? (used to hide the CTA)
let userOptedIntoLeaderboard = false;
if (user) {
  const { data: meProfile } = await sc
    .from("profiles")
    .select("show_in_leaderboards")
    .eq("id", user.id)
    .maybeSingle();
  userOptedIntoLeaderboard = meProfile?.show_in_leaderboards === true;
}

const rankMedals: Record<number, string> = { 1: "🥇", 2: "🥈", 3: "🥉" };

// ── Active limited-time drops (Phase D.4) ─────────────────────
interface ShopDrop {
  id: string;
  badge_type: string;
  label_es: string;
  label_en: string;
  desc_es: string | null;
  desc_en: string | null;
  icon: string;
  cost: number;
  active_from: string;
  active_to: string;
}
let activeDrops: ShopDrop[] = [];
let ownedDropTypes: Set<string> = new Set();
try {
  const nowIso = new Date().toISOString();
  const { data: dropsData } = await sc
    .from("shop_drops")
    .select("id, badge_type, label_es, label_en, desc_es, desc_en, icon, cost, active_from, active_to")
    .lte("active_from", nowIso)
    .gt("active_to", nowIso)
    .order("active_to", { ascending: true });
  activeDrops = (dropsData || []) as ShopDrop[];
  if (user && activeDrops.length > 0) {
    const types = activeDrops.map(d => d.badge_type);
    const { data: owned } = await sc
      .from("profile_badges")
      .select("badge_type")
      .eq("user_id", user.id)
      .in("badge_type", types);
    ownedDropTypes = new Set((owned || []).map(r => r.badge_type));
  }
} catch {
  activeDrops = [];
}
---

<BaseLayout
  lang={lang}
  title={text.peanutMetaTitle}
  description={text.peanutHeading}
  pathname={pathname}
>
  <section class="peanuts-page">
    <!-- Balance Summary -->
    <div class="balance-hero">
      <h1>{text.peanutHeading}</h1>
      <div class="balance-card">
        <div class="balance-main">
          <span class="balance-number" id="balance-number">—</span>
          <span class="balance-label">{text.peanutBalance}</span>
        </div>
        <div class="balance-stats">
          <div class="stat earned">
            <span class="stat-value" id="stat-earned">0</span>
            <span class="stat-label">{text.peanutTotalEarned}</span>
          </div>
          <div class="stat spent">
            <span class="stat-value" id="stat-spent">0</span>
            <span class="stat-label">{text.peanutTotalSpent}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Login required message (hidden by default) -->
    <div id="login-prompt" class="login-prompt" style="display:none">
      <p>{text.lotteryNotLoggedIn}</p>
      <a href={`/${lang}/login/`} class="btn btn-primary">{text.loginHeading}</a>
    </div>

    <!-- Main content (hidden until loaded) -->
    <div id="peanuts-content" style="display:none">

      <!-- Shop Section -->
      <div class="shop-section" id="shop">
        <h2>🛍️ {text.peanutShopTitle}</h2>

        <!-- ─── TIER 1 — Functional powers ─────────────────────── -->
        <div class="tier-block tier-1">
          <div class="tier-head">
            <span class="tier-badge tier-badge-1">⚡ Tier 1</span>
            <div class="tier-titles">
              <h3 class="tier-title">{text.peanutShopTier1Title}</h3>
              <p class="tier-subtitle">{text.peanutShopTier1Desc}</p>
            </div>
          </div>

          <h4 class="subshop-title">{text.peanutShopBoost}</h4>
          <div class="shop-grid">
            {boostItems.map(item => (
              <div class="shop-card" data-shop="boost" data-type={item.type} data-cost={item.cost}>
                <span class="shop-icon">{item.icon}</span>
                <span class="shop-name">{item.label}</span>
                <span class="shop-price">{item.cost} 🥜</span>
                <select class="boost-review-select" data-boost={item.type} style="display:none; width:100%; margin:0.4rem 0; padding:0.3rem; border-radius:6px; border:1px solid var(--border);">
                  <option value="">{lang === "es" ? "— Elige una review —" : "— Pick a review —"}</option>
                </select>
                <button class="btn btn-sm btn-buy" data-action="buy-boost" data-boost={item.type}>
                  {text.peanutBuy}
                </button>
              </div>
            ))}
          </div>

          <h4 class="subshop-title">🌟 {text.peanutShopHighlight}</h4>
          <p class="subshop-desc">{text.peanutShopHighlightDesc}</p>
          <div class="shop-grid">
            <div class="shop-card highlight-card" data-shop="highlight" data-cost="8">
              <span class="shop-icon">🌟</span>
              <span class="shop-name">{text.highlightBuy}</span>
              <span class="shop-price">8 🥜 · 7d</span>
              <select class="highlight-review-select" style="display:none; width:100%; margin:0.4rem 0; padding:0.3rem; border-radius:6px; border:1px solid var(--border);">
                <option value="">{lang === "es" ? "— Elige una review —" : "— Pick a review —"}</option>
              </select>
              <button class="btn btn-sm btn-buy" data-action="buy-highlight">
                {text.peanutBuy}
              </button>
            </div>
            <div class="shop-card home-pin-card" data-shop="home-pin" data-cost="25">
              <span class="shop-icon">🎯</span>
              <span class="shop-name">{text.peanutShopHomePin}</span>
              <span class="shop-price">25 🥜 · 3d</span>
              <span class="shop-desc" style="font-size:0.8rem; opacity:0.85;">{text.peanutShopHomePinDesc}</span>
              <select class="home-pin-review-select" style="display:none; width:100%; margin:0.4rem 0; padding:0.3rem; border-radius:6px; border:1px solid var(--border);">
                <option value="">{lang === "es" ? "— Elige una review —" : "— Pick a review —"}</option>
              </select>
              <button class="btn btn-sm btn-buy" data-action="buy-home-pin">
                {text.peanutBuy}
              </button>
            </div>
          </div>

          <h4 class="subshop-title">{text.peanutShopLottery}</h4>
          <p class="subshop-desc">{text.peanutShopLotteryDesc}</p>
          <div class="shop-card lottery-entry-card">
            <span class="shop-icon">🎟️</span>
            <span class="shop-name">{lang === "es" ? "Comprar tickets" : "Buy tickets"}</span>
            <span class="shop-price">3 🥜 / ticket</span>
            <div class="lottery-qty">
              <button class="qty-btn" id="qty-minus">−</button>
              <span id="qty-value">1</span>
              <button class="qty-btn" id="qty-plus">+</button>
            </div>
            <button class="btn btn-sm btn-buy" id="buy-lottery-btn">
              {text.peanutBuy} (<span id="lottery-total-cost">3</span> 🥜)
            </button>
            <a href={`/${lang}/lottery/`} style="font-size:0.82rem; color:var(--brand-blue); margin-top:0.3rem;">
              {lang === "es" ? "Ver sorteo actual →" : "View current giveaway →"}
            </a>
          </div>
        </div>

        <!-- ─── TIER 2 — Cosmetics & collectibles ─────────────────── -->
        <div class="tier-block tier-2">
          <div class="tier-head">
            <span class="tier-badge tier-badge-2">🎨 Tier 2</span>
            <div class="tier-titles">
              <h3 class="tier-title">{text.peanutShopTier2Title}</h3>
              <p class="tier-subtitle">{text.peanutShopTier2Desc}</p>
            </div>
          </div>

          <h4 class="subshop-title">{text.peanutShopBadge}</h4>
          <div class="shop-grid">
            {badgeItems.map(item => (
              <div class="shop-card" data-shop="badge" data-type={item.type} data-cost={item.cost}>
                <span class="shop-icon">{item.icon}</span>
                <span class="shop-name">{item.label}</span>
                <span class="shop-price">{item.cost} 🥜</span>
                <button class="btn btn-sm btn-buy" data-action="buy-badge" data-badge={item.type}>
                  {text.peanutBuy}
                </button>
              </div>
            ))}
          </div>

          <h4 class="subshop-title">🎨 {text.peanutShopAccent}</h4>
          <p class="subshop-desc">{text.peanutShopAccentDesc}</p>
          <div class="shop-card accent-card" data-shop="accent" data-cost={ACCENT_COST}>
            <span class="shop-icon">🎨</span>
            <span class="shop-name">{text.peanutShopAccent}</span>
            <span class="shop-price">{ACCENT_COST} 🥜</span>
            <div class="accent-swatches" role="radiogroup" aria-label={text.peanutShopAccent}>
              {ACCENT_COLORS.map(c => (
                <button
                  type="button"
                  class="accent-swatch"
                  role="radio"
                  aria-checked="false"
                  data-accent={c.id}
                  style={`--sw:${c.swatch};`}
                  title={c.id}
                />
              ))}
            </div>
            <button class="btn btn-sm btn-buy" data-action="buy-accent" disabled>
              {text.peanutBuy}
            </button>
          </div>

          <h4 class="subshop-title">🔓 {text.peanutShopEarlyAccess}</h4>
          <p class="subshop-desc">{text.peanutShopEarlyAccessDesc}</p>
          <div class="shop-card early-access-card">
            <span class="shop-icon">📖</span>
            <span class="shop-name">{text.peanutShopEarlyAccess}</span>
            <span class="shop-price">20 🥜 {lang === "es" ? "/ libro" : "/ book"}</span>
            <a href={`/${lang}/books/early-access/`} class="btn btn-sm btn-buy">
              {lang === "es" ? "Ver libros →" : "See books →"}
            </a>
          </div>

          <h4 class="subshop-title">📣 {text.peanutShopShoutout}</h4>
          <p class="subshop-desc">{text.peanutShopShoutoutDesc}</p>
          <div class="shop-grid">
            <div class="shop-card shoutout-card" data-shop="shoutout" data-cost="30">
              <span class="shop-icon">📣</span>
              <span class="shop-name">{text.peanutShopShoutout}</span>
              <span class="shop-price">30 🥜</span>
              <select class="shoutout-review-select" style="display:none; width:100%; margin:0.4rem 0; padding:0.3rem; border-radius:6px; border:1px solid var(--border);">
                <option value="">{lang === "es" ? "— Elige una review —" : "— Pick a review —"}</option>
              </select>
              <button class="btn btn-sm btn-buy" data-action="buy-shoutout">
                {text.peanutBuy}
              </button>
            </div>
          </div>

          {activeDrops.length > 0 && (
            <>
              <h4 class="subshop-title">⏳ {text.peanutShopDrops}</h4>
              <p class="subshop-desc">{text.peanutShopDropsDesc}</p>
              <div class="shop-grid">
                {activeDrops.map(d => {
                  const owned = ownedDropTypes.has(d.badge_type);
                  const label = lang === "es" ? d.label_es : d.label_en;
                  const desc  = lang === "es" ? d.desc_es  : d.desc_en;
                  const endsMs = Date.parse(d.active_to);
                  return (
                    <div
                      class={`shop-card drop-card ${owned ? "is-owned" : ""}`}
                      data-shop="drop"
                      data-drop-id={d.id}
                      data-ends={endsMs}
                    >
                      <span class="drop-ribbon">{text.peanutShopDropBadge}</span>
                      <span class="shop-icon">{d.icon}</span>
                      <span class="shop-name">{label}</span>
                      {desc && <span class="drop-desc">{desc}</span>}
                      <span class="shop-price">{d.cost} 🥜</span>
                      <span class="drop-countdown" data-countdown={endsMs} aria-live="polite"></span>
                      {owned ? (
                        <span class="drop-owned-tag">✓ {text.profileBadgesOwned}</span>
                      ) : (
                        <button class="btn btn-sm btn-buy" data-action="buy-drop" data-drop-id={d.id}>
                          {text.peanutBuy}
                        </button>
                      )}
                    </div>
                  );
                })}
              </div>
            </>
          )}
        </div>
      </div>

      <!-- Monthly Leaderboard (opt-in) -->
      <div class="leaderboard-section">
        <h2>{text.peanutLeaderboardTitle}</h2>
        <p class="leaderboard-desc">{text.peanutLeaderboardDesc}</p>

        {leaderboard.length === 0 ? (
          <p class="leaderboard-empty">{text.peanutLeaderboardEmpty}</p>
        ) : (
          <ol class="leaderboard-list" aria-label={text.peanutLeaderboardTitle}>
            {leaderboard.map(row => (
              <li class={`leaderboard-row rank-${row.rank}`}>
                <span class="lb-rank">{rankMedals[row.rank] || `#${row.rank}`}</span>
                <span class="lb-name">{row.display_name || text.peanutLeaderboardAnonymous}</span>
                <span class="lb-peanuts">{row.peanuts_earned} 🥜</span>
              </li>
            ))}
          </ol>
        )}

        {user && !userOptedIntoLeaderboard && (
          <p class="leaderboard-cta">
            <a href={`/${lang}/profile/#show_in_leaderboards`}>{text.peanutLeaderboardYouCta}</a>
          </p>
        )}
      </div>

      <!-- Transaction History -->
      <div class="history-section">
        <h2>{text.peanutHistory}</h2>

        <div class="history-controls">
          <div class="history-range" role="tablist" aria-label={text.peanutHistory}>
            <button class="range-btn active" data-range="30d">{text.peanutHistoryRange30}</button>
            <button class="range-btn" data-range="90d">{text.peanutHistoryRange90}</button>
            <button class="range-btn" data-range="all">{text.peanutHistoryRangeAll}</button>
          </div>
          <a id="tx-export-csv" class="history-export" href="#" download>
            ⬇️ {text.peanutHistoryExport}
          </a>
        </div>

        {/* A: Summary card */}
        <div id="history-summary" class="history-summary" aria-live="polite">
          <div class="history-summary-loading">…</div>
        </div>

        {/* Filter chips for the grouped list */}
        <div class="history-filters">
          <button class="filter-btn active" data-filter="all">{text.peanutFilterAll}</button>
          <button class="filter-btn" data-filter="earned">{text.peanutFilterEarned}</button>
          <button class="filter-btn" data-filter="spent">{text.peanutFilterSpent}</button>
        </div>

        {/* B: Day-grouped collapsible list */}
        <div id="tx-list" class="tx-list">
          <p class="tx-empty">{text.peanutNoTransactions}</p>
        </div>

        {/* C: Load older */}
        <button id="tx-load-more" class="btn btn-outline" style="display:none">
          {text.peanutHistoryLoadOlder}
        </button>
      </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast" style="display:none"></div>
  </section>
</BaseLayout>

<script define:vars={{ lang, reasonLabels: JSON.stringify(reasonLabels), reasonIcons: JSON.stringify(reasonIcons), uiText: JSON.stringify({
  events: text.peanutHistoryEvents,
  oneEvent: text.peanutHistoryOneEvent,
  net: text.peanutHistoryNet,
  summaryTitle: text.peanutHistorySummaryTitle,
  dayNet: text.peanutHistoryDayNet,
  noTx: text.peanutNoTransactions,
}) }}>
(function() {
  const labels = JSON.parse(reasonLabels);
  const icons = JSON.parse(reasonIcons);
  const ui = JSON.parse(uiText);
  let currentFilter = "all";
  let currentRange = "30d";
  let currentPage = 1;
  let balance = 0;
  let lotteryQty = 1;

  async function init() {
    // Check auth
    const res = await fetch("/api/me/", { credentials: "same-origin" });
    const data = await res.json();

    if (!data.user) {
      document.getElementById("login-prompt").style.display = "block";
      return;
    }

    document.getElementById("peanuts-content").style.display = "block";
    await loadHistory();
    await loadBoostReviews();
    setupShop();
    setupFilters();
    setupRangeTabs();
    setupCsvExport();
    setupLotteryQty();
  }

  async function loadBoostReviews() {
    try {
      const res = await fetch("/api/my-reviews/", { credentials: "same-origin" });
      const data = await res.json();
      if (!data.reviews) return;
      const approved = data.reviews.filter(r => r.status === "approved");
      document.querySelectorAll(".boost-review-select").forEach(sel => {
        sel.style.display = approved.length > 0 ? "block" : "none";
        approved.forEach(r => {
          const opt = document.createElement("option");
          opt.value = r.id;
          opt.textContent = (r.book_title || r.book_id) + " ★" + r.rating;
          sel.appendChild(opt);
        });
      });
      document.querySelectorAll(".highlight-review-select").forEach(sel => {
        sel.style.display = approved.length > 0 ? "block" : "none";
        approved.forEach(r => {
          const opt = document.createElement("option");
          opt.value = r.id;
          opt.textContent = (r.book_title || r.book_id) + " ★" + r.rating;
          sel.appendChild(opt);
        });
      });
      document.querySelectorAll(".home-pin-review-select").forEach(sel => {
        sel.style.display = approved.length > 0 ? "block" : "none";
        approved.forEach(r => {
          const opt = document.createElement("option");
          opt.value = r.id;
          opt.textContent = (r.book_title || r.book_id) + " ★" + r.rating;
          sel.appendChild(opt);
        });
      });
      document.querySelectorAll(".shoutout-review-select").forEach(sel => {
        sel.style.display = approved.length > 0 ? "block" : "none";
        approved.forEach(r => {
          const opt = document.createElement("option");
          opt.value = r.id;
          opt.textContent = (r.book_title || r.book_id) + " ★" + r.rating;
          sel.appendChild(opt);
        });
      });
    } catch { /* ignore - boost selectors stay hidden */ }
  }

  async function loadHistory() {
    let data;
    try {
      const res = await fetch(`/api/credit-history/?page=${currentPage}&filter=${currentFilter}&range=${currentRange}`, {
        credentials: "same-origin",
      });
      data = await res.json();
      if (!res.ok) {
        console.error("[peanuts] HTTP", res.status, data);
        return;
      }
    } catch (e) {
      console.error("[peanuts] fetch failed", e);
      return;
    }

    if (data.error) {
      console.error("[peanuts] API error:", data.error);
      return;
    }

    balance = data.balance || 0;
    document.getElementById("balance-number").textContent = balance;
    document.getElementById("stat-earned").textContent = "+" + (data.totalEarned || 0);
    document.getElementById("stat-spent").textContent = "-" + (data.totalSpent || 0);

    // Update header badge via sessionStorage
    sessionStorage.setItem("lcp-peanuts", String(balance));
    const headerBadge = document.getElementById("peanuts-count");
    if (headerBadge) headerBadge.textContent = balance;

    if (currentPage === 1) {
      renderSummary(data.summary || [], data.rangeNet || 0);
    }
    renderTransactions(data.transactions || [], currentPage === 1);

    const loadMore = document.getElementById("tx-load-more");
    loadMore.style.display = data.hasMore ? "block" : "none";
    loadMore.onclick = () => { currentPage++; loadHistory(); };

    // Update CSV link
    const csv = document.getElementById("tx-export-csv");
    if (csv) csv.setAttribute("href", `/api/credit-history/?format=csv&range=${currentRange}&lang=${lang}`);
  }

  function renderSummary(summary, rangeNet) {
    const box = document.getElementById("history-summary");
    if (!summary || summary.length === 0) {
      box.innerHTML = `<p class="tx-empty" style="margin:0">${ui.noTx}</p>`;
      return;
    }
    const rows = summary.map(s => {
      const icon = icons[s.reason] || "🥜";
      const label = labels[s.reason] || s.reason;
      const sign = s.net > 0 ? "+" : "";
      const evText = s.count === 1
        ? ui.oneEvent
        : ui.events.replace("{n}", String(s.count));
      const cls = s.net > 0 ? "sum-earned" : s.net < 0 ? "sum-spent" : "";
      return `<div class="sum-row ${cls}">
        <span class="sum-icon">${icon}</span>
        <span class="sum-label">${label}</span>
        <span class="sum-count">${evText}</span>
        <span class="sum-net">${sign}${s.net} 🥜</span>
      </div>`;
    }).join("");
    const netSign = rangeNet > 0 ? "+" : "";
    const netCls = rangeNet > 0 ? "net-positive" : rangeNet < 0 ? "net-negative" : "";
    box.innerHTML = `
      <div class="summary-head">📊 ${ui.summaryTitle}</div>
      <div class="sum-rows">${rows}</div>
      <div class="summary-net ${netCls}">${ui.net}: <strong>${netSign}${rangeNet} 🥜</strong></div>
    `;
  }

  function groupByDay(txs) {
    const map = new Map();
    txs.forEach(tx => {
      const d = new Date(tx.created_at);
      const key = d.toISOString().slice(0, 10); // YYYY-MM-DD
      if (!map.has(key)) map.set(key, []);
      map.get(key).push(tx);
    });
    return Array.from(map.entries()); // [[day, txs[]], ...] preserves order
  }

  function dayLabel(ymd) {
    const d = new Date(ymd + "T00:00:00Z");
    return d.toLocaleDateString(lang === "es" ? "es-ES" : "en-US", {
      month: "short", day: "numeric", year: "numeric"
    });
  }

  function renderTransactions(txs, replace) {
    const list = document.getElementById("tx-list");
    if (replace) list.innerHTML = "";

    if (txs.length === 0 && replace) {
      list.innerHTML = `<p class="tx-empty">${ui.noTx}</p>`;
      return;
    }

    const groups = groupByDay(txs);
    groups.forEach(([ymd, dayTxs]) => {
      const dayNet = dayTxs.reduce((s, t) => s + (t.amount || 0), 0);
      const netSign = dayNet > 0 ? "+" : "";
      const netCls = dayNet > 0 ? "net-positive" : dayNet < 0 ? "net-negative" : "";
      const evText = dayTxs.length === 1
        ? ui.oneEvent
        : ui.events.replace("{n}", String(dayTxs.length));

      const details = document.createElement("details");
      details.className = "tx-day";

      const summary = document.createElement("summary");
      summary.className = "tx-day-head";
      summary.innerHTML = `
        <span class="tx-day-date">${dayLabel(ymd)}</span>
        <span class="tx-day-count">${evText}</span>
        <span class="tx-day-net ${netCls}">${ui.dayNet} ${netSign}${dayNet} 🥜</span>
      `;
      details.appendChild(summary);

      const body = document.createElement("div");
      body.className = "tx-day-body";
      dayTxs.forEach(tx => {
        const row = document.createElement("div");
        row.className = `tx-row ${tx.amount > 0 ? "tx-earned" : "tx-spent"}`;
        const icon = icons[tx.reason] || "🥜";
        const label = labels[tx.reason] || tx.reason;
        const sign = tx.amount > 0 ? "+" : "";
        row.innerHTML = `
          <span class="tx-icon">${icon}</span>
          <span class="tx-label">${label}</span>
          <span class="tx-amount">${sign}${tx.amount} 🥜</span>
        `;
        body.appendChild(row);
      });
      details.appendChild(body);
      list.appendChild(details);
    });
  }

  function setupFilters() {
    document.querySelectorAll(".filter-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        currentFilter = btn.dataset.filter;
        currentPage = 1;
        loadHistory();
      });
    });
  }

  function setupRangeTabs() {
    document.querySelectorAll(".range-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".range-btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        currentRange = btn.dataset.range;
        currentPage = 1;
        loadHistory();
      });
    });
  }

  function setupCsvExport() {
    const csv = document.getElementById("tx-export-csv");
    if (csv) csv.setAttribute("href", `/api/credit-history/?format=csv&range=${currentRange}&lang=${lang}`);
  }

  function setupLotteryQty() {
    const qtyEl = document.getElementById("qty-value");
    const costEl = document.getElementById("lottery-total-cost");
    const minusBtn = document.getElementById("qty-minus");
    const plusBtn = document.getElementById("qty-plus");
    const buyBtn = document.getElementById("buy-lottery-btn");

    // Elements only exist when user is subscribed and draw is pending
    if (!minusBtn || !plusBtn || !buyBtn) return;

    minusBtn.addEventListener("click", () => {
      if (lotteryQty > 1) {
        lotteryQty--;
        qtyEl.textContent = lotteryQty;
        costEl.textContent = lotteryQty * 3;
      }
    });

    plusBtn.addEventListener("click", () => {
      if (lotteryQty < 20) {
        lotteryQty++;
        qtyEl.textContent = lotteryQty;
        costEl.textContent = lotteryQty * 3;
      }
    });

    buyBtn.addEventListener("click", async () => {
      await purchaseAction("/api/buy-tickets/", { quantity: lotteryQty });
    });
  }

  function setupShop() {
    // Badge buttons
    document.querySelectorAll("[data-action='buy-badge']").forEach(btn => {
      btn.addEventListener("click", async () => {
        await purchaseAction("/api/buy-badge/", { badge_type: btn.dataset.badge });
      });
    });

    // Boost buttons — populate review selectors, then purchase on click
    document.querySelectorAll("[data-action='buy-boost']").forEach(btn => {
      const card = btn.closest(".shop-card");
      const select = card.querySelector(".boost-review-select");
      btn.addEventListener("click", async () => {
        const reviewId = select.value;
        if (!reviewId) {
          showToast(lang === "es" ? "Selecciona una review." : "Select a review first.", "error");
          return;
        }
        await purchaseAction("/api/boost-review/", {
          review_id: reviewId,
          boost_type: btn.dataset.boost,
        });
      });
    });

    // Gallery highlight button
    document.querySelectorAll("[data-action='buy-highlight']").forEach(btn => {
      const card = btn.closest(".shop-card");
      const select = card.querySelector(".highlight-review-select");
      btn.addEventListener("click", async () => {
        const reviewId = select.value;
        if (!reviewId) {
          showToast(lang === "es" ? "Selecciona una review." : "Select a review first.", "error");
          return;
        }
        await purchaseAction("/api/buy-highlight/", { review_id: reviewId });
      });
    });

    // Home-page pin button (E.2)
    document.querySelectorAll("[data-action='buy-home-pin']").forEach(btn => {
      const card = btn.closest(".shop-card");
      const select = card.querySelector(".home-pin-review-select");
      btn.addEventListener("click", async () => {
        const reviewId = select.value;
        if (!reviewId) {
          showToast(lang === "es" ? "Selecciona una review." : "Select a review first.", "error");
          return;
        }
        await purchaseAction("/api/buy-home-pin/", { review_id: reviewId });
      });
    });

    // Social shoutout button (E.1)
    document.querySelectorAll("[data-action='buy-shoutout']").forEach(btn => {
      const card = btn.closest(".shop-card");
      const select = card.querySelector(".shoutout-review-select");
      btn.addEventListener("click", async () => {
        const reviewId = select.value;
        if (!reviewId) {
          showToast(lang === "es" ? "Selecciona una review." : "Select a review first.", "error");
          return;
        }
        await purchaseAction("/api/buy-shoutout/", { review_id: reviewId });
      });
    });

    // Limited-time drops
    document.querySelectorAll("[data-action='buy-drop']").forEach(btn => {
      btn.addEventListener("click", async () => {
        const dropId = btn.getAttribute("data-drop-id");
        if (!dropId) return;
        await purchaseAction("/api/buy-drop/", { drop_id: dropId });
      });
    });

    // Drop countdowns (pure presentation; server is source of truth)
    const countdownEls = document.querySelectorAll("[data-countdown]");
    if (countdownEls.length > 0) {
      const tick = () => {
        const now = Date.now();
        countdownEls.forEach(el => {
          const ends = parseInt(el.getAttribute("data-countdown") || "0", 10);
          const ms = ends - now;
          if (ms <= 0) {
            el.textContent = lang === "es" ? "Terminado" : "Ended";
            const card = el.closest(".drop-card");
            const btn = card?.querySelector("[data-action='buy-drop']");
            if (btn) btn.setAttribute("disabled", "true");
            return;
          }
          const d = Math.floor(ms / 86400000);
          const h = Math.floor((ms % 86400000) / 3600000);
          const m = Math.floor((ms % 3600000) / 60000);
          if (d >= 1) {
            el.textContent = lang === "es" ? `Quedan ${d}d ${h}h` : `${d}d ${h}h left`;
          } else if (h >= 1) {
            el.textContent = lang === "es" ? `Quedan ${h}h ${m}m` : `${h}h ${m}m left`;
          } else {
            el.textContent = lang === "es" ? `Quedan ${m}m` : `${m}m left`;
          }
        });
      };
      tick();
      setInterval(tick, 60000);
    }

    // Accent-color picker: select swatch → enable button → buy
    document.querySelectorAll(".accent-card").forEach(card => {
      const swatches = card.querySelectorAll(".accent-swatch");
      const buyBtn = card.querySelector("[data-action='buy-accent']");
      let chosen = null;
      swatches.forEach(sw => {
        sw.addEventListener("click", () => {
          chosen = sw.getAttribute("data-accent");
          swatches.forEach(s => {
            s.setAttribute("aria-checked", s === sw ? "true" : "false");
            s.classList.toggle("is-selected", s === sw);
          });
          if (buyBtn) buyBtn.removeAttribute("disabled");
        });
      });
      if (buyBtn) {
        buyBtn.addEventListener("click", async () => {
          if (!chosen) {
            showToast(lang === "es" ? "Elige un color primero." : "Pick a color first.", "error");
            return;
          }
          await purchaseAction("/api/buy-accent/", { color: chosen });
        });
      }
    });
  }

  async function purchaseAction(url, body) {
    try {
      const res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify(body),
      });
      const data = await res.json();

      if (data.error === "insufficient_credits") {
        showToast(document.querySelector("[data-filter]")?.closest(".peanuts-page")
          ? (lang === "es" ? "No tienes suficientes Peanuts." : "Not enough Peanuts.")
          : "Not enough Peanuts.", "error");
        return;
      }
      if (data.error === "already_owned") {
        showToast(lang === "es" ? "Ya tienes este badge." : "You already own this badge.", "info");
        return;
      }
      if (data.error === "boost_active") {
        showToast(lang === "es" ? "Este boost ya esta activo." : "This boost is already active.", "info");
        return;
      }
      if (data.error === "highlight_active_on_other") {
        showToast(text.highlightErrorActiveOther || "You already have another highlighted review.", "info");
        return;
      }
      if (data.error === "home_pin_active_on_other") {
        showToast(text.homePinErrorActiveOther || (lang === "es" ? "Ya tienes otra review fijada en la home." : "You already have another review pinned on the home page."), "info");
        return;
      }
      if (data.error === "active_shoutout_exists") {
        showToast(text.shoutoutErrorActiveExists || (lang === "es" ? "Esta review ya tiene un shoutout en curso." : "This review already has a pending shoutout."), "info");
        return;
      }
      if (data.error === "not_review_owner") {
        showToast(text.highlightErrorNotOwner || "You can only highlight your own reviews.", "error");
        return;
      }
      if (data.error === "invalid_color") {
        showToast(text.accentErrorInvalidColor || "Color not available.", "error");
        return;
      }
      if (data.error === "drop_inactive") {
        showToast(lang === "es" ? "Esta edición ya terminó." : "This drop has ended.", "info");
        return;
      }
      if (data.error === "drop_not_found") {
        showToast(lang === "es" ? "Edición no disponible." : "Drop not available.", "error");
        return;
      }
      if (data.error) {
        showToast(data.error, "error");
        return;
      }

      // Success
      if (typeof data.balance === "number") {
        balance = data.balance;
        document.getElementById("balance-number").textContent = balance;
        sessionStorage.setItem("lcp-peanuts", String(balance));
        const hb = document.getElementById("peanuts-count");
        if (hb) hb.textContent = balance;
      }
      if (typeof data.ticket_balance === "number") {
        const ht = document.getElementById("tickets-count");
        if (ht) ht.textContent = data.ticket_balance;
        sessionStorage.setItem("lcp-tickets", String(data.ticket_balance));
      }
      const successMsg = data.extended
        ? (lang === "es" ? "¡Boost extendido +7 dias!" : "Boost extended +7 days!")
        : (lang === "es" ? "¡Compra realizada!" : "Purchase complete!");
      showToast(successMsg, "success");
      currentPage = 1;
      loadHistory();
    } catch {
      showToast("Error", "error");
    }
  }

  function showToast(msg, type) {
    const toast = document.getElementById("toast");
    toast.textContent = msg;
    toast.className = `toast toast-${type}`;
    toast.style.display = "block";
    setTimeout(() => { toast.style.display = "none"; }, 3000);
  }

  init();
})();
</script>

