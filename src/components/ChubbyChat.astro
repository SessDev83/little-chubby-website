---
/**
 * ChubbyChat вҖ” AI chat widget for Little Chubby Press.
 * Reads from the CHUBBY_AGENT_REFERENCE knowledge base and responds as "Chubby",
 * a friendly elephant mascot.  Fully responsive across all devices.
 *
 * Implementation: client-side only, no external AI API required for now.
 * Uses a keyword/intent matching system with the pre-built knowledge base.
 * Can be upgraded to an LLM backend by swapping the `getResponse()` function.
 */
interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;

const t = {
  es: {
    greeting: "ВЎHola! Soy Chubby рҹҗҳ, tu elefante favorito de Little Chubby Press. ВҝEn quГ© te puedo ayudar? Puedo contarte sobre nuestros libros, los Peanuts рҹҘң, el sorteo mensual, las lГЎminas para colorear, y todo sobre nuestra web. ВЎPregГәntame!",
    placeholder: "Escribe tu mensaje...",
    send: "Enviar",
    title: "Chubby рҹҗҳ",
    subtitle: "Tu asistente de Little Chubby Press",
    close: "Cerrar chat",
    open: "Hablar con Chubby",
    thinking: "Chubby estГЎ pensando...",
    poweredBy: "Asistente de Little Chubby Press",
    quickQ1: "рҹ“ҡ ВҝQuГ© libros tienen?",
    quickQ2: "рҹҘң ВҝQuГ© son los Peanuts?",
    quickQ3: "рҹҺҒ ВҝCГіmo funciona el sorteo?",
    quickQ4: "рҹҺЁ LГЎminas gratis",
  },
  en: {
    greeting: "Hi there! I'm Chubby рҹҗҳ, your friendly elephant from Little Chubby Press. How can I help? I can tell you about our books, Peanuts рҹҘң, the monthly giveaway, coloring pages, and everything about our website!",
    placeholder: "Type your message...",
    send: "Send",
    title: "Chubby рҹҗҳ",
    subtitle: "Your Little Chubby Press assistant",
    close: "Close chat",
    open: "Chat with Chubby",
    thinking: "Chubby is thinking...",
    poweredBy: "Little Chubby Press assistant",
    quickQ1: "рҹ“ҡ What books do you have?",
    quickQ2: "рҹҘң What are Peanuts?",
    quickQ3: "рҹҺҒ How does the giveaway work?",
    quickQ4: "рҹҺЁ Free coloring pages",
  },
};

const text = t[lang] || t.es;
---

<!-- Chat toggle button (floating) -->
<button
  id="chubby-toggle"
  class="chubby-toggle"
  aria-label={text.open}
  title={text.open}
>
  <span class="chubby-toggle-icon" aria-hidden="true">рҹҗҳ</span>
  <span class="chubby-toggle-close" aria-hidden="true">&times;</span>
</button>

<!-- Chat window -->
<div id="chubby-chat" class="chubby-chat" role="dialog" aria-label={text.title} aria-hidden="true">
  <!-- Header -->
  <div class="chubby-header">
    <div class="chubby-header-info">
      <span class="chubby-avatar" aria-hidden="true">рҹҗҳ</span>
      <div>
        <div class="chubby-header-name">{text.title}</div>
        <div class="chubby-header-sub">{text.subtitle}</div>
      </div>
    </div>
    <button class="chubby-header-close" aria-label={text.close} id="chubby-close">&times;</button>
  </div>

  <!-- Messages -->
  <div class="chubby-messages" id="chubby-messages">
    <!-- Greeting is injected by JS -->
  </div>

  <!-- Quick questions -->
  <div class="chubby-quick" id="chubby-quick">
    <button class="chubby-quick-btn" data-q="books">{text.quickQ1}</button>
    <button class="chubby-quick-btn" data-q="peanuts">{text.quickQ2}</button>
    <button class="chubby-quick-btn" data-q="giveaway">{text.quickQ3}</button>
    <button class="chubby-quick-btn" data-q="coloring">{text.quickQ4}</button>
  </div>

  <!-- Input -->
  <form class="chubby-input" id="chubby-form" autocomplete="off">
    <input
      type="text"
      id="chubby-input"
      class="chubby-input-field"
      placeholder={text.placeholder}
      autocomplete="off"
      maxlength="500"
    />
    <button type="submit" class="chubby-send" aria-label={text.send}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </form>

  <div class="chubby-footer">{text.poweredBy}</div>
</div>

<script is:inline define:vars={{ lang, thinkingText: text.thinking, greetingText: text.greeting }}>
(function () {
  /* в”Җв”Җ Knowledge Base в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  const KB = {
    books: {
      es: `ВЎTenemos 15 libros de colorear increГӯbles! рҹ“ҡ AquГӯ estГЎn algunos:\n\nвҖў **Easy Animals** (3-8 aГұos, 110 pГЎgs) вҖ” Animalitos fГЎciles, perfecto para empezar\nвҖў **Awesome Girls** (4-8, 90 pГЎgs) вҖ” Aventuras para niГұas вӯҗ 5.0\nвҖў **Awesome Boys** (4-8, 90 pГЎgs) вҖ” Aventuras para niГұos\nвҖў **Magical Creatures** (4-8, 90 pГЎgs) вҖ” Unicornios, sirenas, dragones\nвҖў **Blast Off!** (4-8, 90 pГЎgs) вҖ” Espacio y cohetes рҹҡҖ\nвҖў **Mighty Machines** (3-8, 100 pГЎgs) вҖ” VehГӯculos y construcciГіn\nвҖў **Awesome Airplanes** (4-8, 90 pГЎgs) вҖ” Aviones вӯҗ 5.0\nвҖў **Chic Styles** (12-18+, 90 pГЎgs) вҖ” Moda para teens y adultos\nвҖў **Dresses and Dolls** (4-8, 90 pГЎgs) вҖ” Moda y muГұecas\nвҖў **Pizza & Sweet Treats** (4-8, 90 pГЎgs) вҖ” Comida divertida рҹҚ•\nвҖў Y mГЎs!\n\nTodos estГЎn en Amazon. ВҝPara quГ© edad buscas? Te puedo recomendar el perfecto. рҹҳҠ\n\nрҹ‘ү [Ver todos los libros](/${lang}/books/)`,
      en: `We have 15 amazing coloring books! рҹ“ҡ Here are some highlights:\n\nвҖў **Easy Animals** (ages 3-8, 110 pages) вҖ” Simple animal designs, perfect for beginners\nвҖў **Awesome Girls** (4-8, 90 pages) вҖ” Adventures for girls вӯҗ 5.0\nвҖў **Awesome Boys** (4-8, 90 pages) вҖ” Adventures for boys\nвҖў **Magical Creatures** (4-8, 90 pages) вҖ” Unicorns, mermaids, dragons\nвҖў **Blast Off!** (4-8, 90 pages) вҖ” Space and rockets рҹҡҖ\nвҖў **Mighty Machines** (3-8, 100 pages) вҖ” Vehicles and construction\nвҖў **Awesome Airplanes** (4-8, 90 pages) вҖ” Planes вӯҗ 5.0\nвҖў **Chic Styles** (12-18+, 90 pages) вҖ” Fashion for teens & adults\nвҖў **Dresses and Dolls** (4-8, 90 pages) вҖ” Fashion & dolls\nвҖў **Pizza & Sweet Treats** (4-8, 90 pages) вҖ” Fun food coloring рҹҚ•\nвҖў And more!\n\nAll available on Amazon. What age are you looking for? I can recommend the perfect one! рҹҳҠ\n\nрҹ‘ү [See all books](/${lang}/books/)`
    },
    peanuts: {
      es: `Los **Peanuts** рҹҘң son nuestra moneda de lealtad. ВЎAsГӯ funcionan!\n\n**CГіmo ganar:**\nвҖў Publicar una reseГұa aprobada вҶ’ **+5 рҹҘң**\nвҖў Compartir un enlace (galerГӯa o lГЎmina) вҶ’ **+1 рҹҘң** (mГЎx 3/dГӯa)\n\n**CГіmo gastar:**\nвҖў Badges de perfil вҶ’ **15 рҹҘң** (Marco Dorado, Plateado, Top Reviewer, Super MamГЎ/PapГЎ)\nвҖў Destacar review en galerГӯa вҶ’ **10 рҹҘң** (7 dГӯas)\nвҖў Boletos extra del sorteo вҶ’ **3 рҹҘң** cada uno\nвҖў Descargar lГЎmina de colorear вҶ’ **1 рҹҘң**\n\nPuedes ver tu saldo en el header y tu historial completo en la pГЎgina de Peanuts.\n\nрҹ‘ү [Ir a mis Peanuts](/${lang}/peanuts/)`,
      en: `**Peanuts** рҹҘң are our loyalty currency! Here's how they work:\n\n**How to earn:**\nвҖў Submit an approved review вҶ’ **+5 рҹҘң**\nвҖў Share a link (gallery or coloring page) вҶ’ **+1 рҹҘң** (max 3/day)\n\n**How to spend:**\nвҖў Profile badges вҶ’ **15 рҹҘң** (Gold Frame, Silver Frame, Top Reviewer, Super Parent)\nвҖў Boost review in gallery вҶ’ **10 рҹҘң** (7 days)\nвҖў Extra giveaway tickets вҶ’ **3 рҹҘң** each\nвҖў Download coloring page вҶ’ **1 рҹҘң**\n\nYou can see your balance in the header and full history on the Peanuts page.\n\nрҹ‘ү [Go to my Peanuts](/${lang}/peanuts/)`
    },
    giveaway: {
      es: `ВЎNuestro **Sorteo Mensual de Libros** es sГәper fГЎcil! рҹҺҒ\n\n**5 pasos:**\n1пёҸвғЈ Compra cualquier libro en Amazon\n2пёҸвғЈ Sube una foto de portada + al menos 1 foto del interior\n3пёҸвғЈ Cada review aprobada = **5 boletos gratis**\n4пёҸвғЈ ВҝQuieres mГЎs? SuscrГӯbete al newsletter y usa tus Peanuts рҹҘң para comprar boletos extra (3 рҹҘң cada uno)\n5пёҸвғЈ Sorteo automГЎtico el **1В° de cada mes** вҖ” ВЎgana un libro gratis!\n\n**Premio:** Un libro diferente cada mes (rotaciГіn automГЎtica)\n**Ganadores:** Hasta 3 por mes\n**Plazo para reclamar:** 14 dГӯas\n\nВЎSolo necesitas una cuenta y una reseГұa aprobada para participar!\n\nрҹ‘ү [Ir al sorteo](/${lang}/lottery/)`,
      en: `Our **Monthly Book Giveaway** is super easy! рҹҺҒ\n\n**5 steps:**\n1пёҸвғЈ Buy any book on Amazon\n2пёҸвғЈ Upload a cover photo + at least 1 interior photo\n3пёҸвғЈ Each approved review = **5 free tickets**\n4пёҸвғЈ Want more? Subscribe to the newsletter and use your Peanuts рҹҘң to buy extra tickets (3 рҹҘң each)\n5пёҸвғЈ Automatic draw on the **1st of each month** вҖ” win a free book!\n\n**Prize:** A different book each month (auto-rotated)\n**Winners:** Up to 3 per month\n**Claim deadline:** 14 days\n\nYou just need an account and one approved review to enter!\n\nрҹ‘ү [Go to giveaway](/${lang}/lottery/)`
    },
    coloring: {
      es: `ВЎEl **RincГіn de Colorear** tiene lГЎminas gratis para descargar! рҹҺЁ\n\n**CategorГӯas:**\nвҖў Animales y Naturaleza рҹҰҒ\nвҖў Astronautas y Espacio рҹҡҖ\nвҖў Elementos BГЎsicos\nвҖў Dinosaurios рҹҰ•\nвҖў Comida y Bebidas рҹҚ•\nвҖў Profesiones\nвҖў Favoritos de NiГұos (Juguetes, FantasГӯa)\nвҖў MГЎquinas y ConstrucciГіn рҹҸ—пёҸ\nвҖў Mini Escenas\n\n**ВҝCГіmo descargar?**\nвҖў Necesitas una cuenta y al menos 1 Peanut рҹҘң\nвҖў Cada descarga cuesta 1 рҹҘң\nвҖў ВЎComparte lГЎminas para ganar mГЎs Peanuts!\n\nрҹ‘ү [Ir al RincГіn de Colorear](/${lang}/coloring-corner/)`,
      en: `The **Coloring Corner** has free coloring pages to download! рҹҺЁ\n\n**Categories:**\nвҖў Animals & Nature рҹҰҒ\nвҖў Astronauts & Space рҹҡҖ\nвҖў Basic Elements\nвҖў Dinosaurs рҹҰ•\nвҖў Food & Drinks рҹҚ•\nвҖў Jobs\nвҖў Kids Favorites (Toys, Fantasy)\nвҖў Machines & Construction рҹҸ—пёҸ\nвҖў Mini Scenes\n\n**How to download?**\nвҖў You need an account and at least 1 Peanut рҹҘң\nвҖў Each download costs 1 рҹҘң\nвҖў Share coloring pages to earn more Peanuts!\n\nрҹ‘ү [Go to Coloring Corner](/${lang}/coloring-corner/)`
    },
    review: {
      es: `ВЎNos encantarГӯa ver las creaciones de tus peques! рҹҺЁ\n\n**CГіmo enviar tu reseГұa:**\n1. Ve a la GalerГӯa y haz clic en "Compartir tu reseГұa"\n2. Selecciona tu libro\n3. Sube una foto de portada (obligatoria)\n4. Sube al menos 1 foto del interior (obligatoria)\n5. Agrega tu calificaciГіn (1-5 estrellas)\n6. EnvГӯa вҖ” ВЎnuestro equipo la revisarГЎ en 24-48 horas!\n\n**Formatos:** JPG, PNG, WebP, HEIC (mГЎx 500KB cada una, mГЎx 5 fotos)\n**Recompensa:** +5 Peanuts рҹҘң + 5 boletos del sorteo\n\nрҹ‘ү [Ir a la GalerГӯa](/${lang}/gallery/)`,
      en: `We'd love to see your little ones' creations! рҹҺЁ\n\n**How to submit your review:**\n1. Go to Gallery and click "Share your review"\n2. Select your book\n3. Upload a cover photo (required)\n4. Upload at least 1 interior photo (required)\n5. Add your star rating (1-5)\n6. Submit вҖ” our team will review it within 24-48 hours!\n\n**Formats:** JPG, PNG, WebP, HEIC (max 500KB each, max 5 photos)\n**Reward:** +5 Peanuts рҹҘң + 5 giveaway tickets\n\nрҹ‘ү [Go to Gallery](/${lang}/gallery/)`
    },
    account: {
      es: `**Tu cuenta** te da acceso a todo:\n\nвҖў Peanuts рҹҘң вҖ” gana y gasta\nвҖў GalerГӯa вҖ” sube reseГұas\nвҖў Sorteo вҖ” participa cada mes\nвҖў RincГіn de Colorear вҖ” descarga lГЎminas\nвҖў Perfil вҖ” foto, nombre, idioma, direcciГіn\n\n**Crear cuenta:** Correo + contraseГұa (mГӯn 6 caracteres) вҶ’ confirma por email\n**Iniciar sesiГіn:** Correo + contraseГұa, o link mГЎgico por email\n**ВҝOlvidaste tu contraseГұa?** Click en "ВҝOlvidaste tu contraseГұa?" en la pГЎgina de login\n\nрҹ‘ү [Iniciar sesiГіn](/${lang}/login/) | [Crear cuenta](/${lang}/register/)`,
