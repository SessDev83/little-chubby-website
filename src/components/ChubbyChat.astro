  };

  /* в”Җв”Җ Off-topic detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  var offTopicPatterns = /\b(weather|clima|trump|politics|politic|gobierno|government|recipe|receta|math|matemat|calcul|code|program|javascript|python|html|css|song|cancion|movie|pelicula|sport|deporte|futbol|soccer|basketball|baseball|bitcoin|crypto|stock|acciones|translate|traduc|write me|escrib|essay|ensayo|homework|tarea|diet|dieta|doctor|medic|hospital|lawyer|abogado|invest|inversion|travel|viaj|hotel|flight|vuelo|restaurant|news|noticias|war|guerra|religion|iglesia|church)\b/i;

  /* в”Җв”Җ Intent detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  var patterns = [
    { key: "greeting_reply",  re: /^(hola|hi|hey|hello|buenos?\s*d[iГӯ]as?|buenas?\s*(tardes?|noches?)|saludos|que\s*tal|what'?s?\s*up|sup|yo\b)/i },
    { key: "thanks_reply",    re: /\b(gracias|thanks?|thank\s*you|genial|perfecto|great|awesome|cool|excelente|got it|entendido|vale|ok[ay]?)\b/i },
    { key: "books",        re: /libros?|books?|catГЎlogo|catalog|tГӯtulos?|titles?|publicaciones/i },
    { key: "peanuts",      re: /peanuts?|рҹҘң|crГ©ditos?|credits?|moneda|currency|saldo|balance|ganar peanuts|earn/i },
    { key: "giveaway",     re: /sorteo|giveaway|loterГӯa|lottery|boletos?|tickets?|rifa|ganar gratis|win free|premio|prize|draw/i },
    { key: "coloring",     re: /colorear|coloring|lГЎminas?|corner|descargar lГЎmina|download page|rincГіn/i },
    { key: "review",       re: /reseГұa|review|galerГӯa|gallery|subir foto|upload photo|compartir review|share review|fotos?/i },
    { key: "account",      re: /cuenta|account|login|iniciar sesiГіn|registr|sign up|contraseГұa|password|perfil|profile|avatar/i },
    { key: "newsletter",   re: /newsletter|suscri|subscri|boletГӯn|email list|mini.*coloring.*book|lead magnet|pdf gratis|free pdf/i },
    { key: "contact",      re: /contacto|contact|email|correo|instagram|facebook|soporte|support|ayuda|help me/i },
    { key: "privacy",      re: /privacidad|privacy|cookies?|datos|data|tracking|rastreo|seguridad|security/i },
    { key: "recommend_boys",  re: /niГұos?|boys?|varГіn|masculino|hijo\b|aventura|space|espacio|aviones?|planes?|mГЎquinas?|machines?|vehicles?|trucks?|dinosaur/i },
    { key: "recommend_girls", re: /niГұas?|girls?|hija\b|unicornio|unicorn|sirena|mermaid|princesa|princess|muГұeca|doll|vestido|dress|moda|fashion/i },
    { key: "recommend_teens", re: /adolescent|teen|adult|grande|mayor|12|13|14|15|16|17|18|grown/i },
    { key: "recommend_young", re: /pequeГұo|pequeГұa|peque|toddler|young|3\s*aГұos|4\s*aГұos|beginner|empezar|primer|first/i },
    { key: "amazon",       re: /amazon|comprar|buy|envГӯo|shipping|pedido|order|devoluciГіn|return|precio|price|costo|cost/i },
    { key: "winners",      re: /ganadores?|winners?|resultados?|results?|quiГ©n ganГі|who won/i },
  ];

  function getIntent(msg) {
    var normalized = msg.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
    // Check off-topic FIRST вҖ” reject before matching website intents
    if (offTopicPatterns.test(normalized)) return "off_topic";
    for (var i = 0; i < patterns.length; i++) {
      if (patterns[i].re.test(normalized) || patterns[i].re.test(msg)) return patterns[i].key;
    }
    return "fallback";
  }

  function getResponse(userMsg) {
    var intent = getIntent(userMsg);
    var entry = KB[intent];
    return entry ? (entry[lang] || entry.es) : (KB.fallback[lang] || KB.fallback.es);
  }

  /* в”Җв”Җ DOM helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  var MAX_MESSAGES = 60;
  var RATE_LIMIT_MS = 800;
  var lastSendTime = 0;

  var toggle = document.getElementById("chubby-toggle");
  var chat = document.getElementById("chubby-chat");
  var messages = document.getElementById("chubby-messages");
  var form = document.getElementById("chubby-form");
  var input = document.getElementById("chubby-input");
  var quick = document.getElementById("chubby-quick");
  var closeBtn = document.getElementById("chubby-close");
  var isOpen = false;

  function sanitizeUrl(url) {
    // Only allow relative paths and https links вҖ” block javascript: etc.
    if (/^\/[a-z]/.test(url)) return url;
    if (/^https:\/\//i.test(url)) return url;
    return "#";
  }

  function renderMarkdown(text) {
    return text
      .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, function(_, label, url) {
        var safe = sanitizeUrl(url);
        return '<a href="' + safe + '" class="chubby-link" rel="noopener noreferrer">' + label + '</a>';
      })
      .replace(/\n/g, "<br>");
  }

  function trimHistory() {
    while (messages.children.length > MAX_MESSAGES) {
      messages.removeChild(messages.firstChild);
    }
  }

  function addMessage(text, sender) {
    var bubble = document.createElement("div");
    bubble.className = "chubby-bubble chubby-bubble--" + sender;
    if (sender === "bot") {
      bubble.innerHTML = renderMarkdown(text);
    } else {
      bubble.textContent = text;
    }
    messages.appendChild(bubble);
    trimHistory();
    messages.scrollTop = messages.scrollHeight;
    return bubble;
  }

  function showTyping() {
    var el = document.createElement("div");
    el.className = "chubby-bubble chubby-bubble--bot chubby-typing";
    el.innerHTML = '<span class="chubby-dot"></span><span class="chubby-dot"></span><span class="chubby-dot"></span>';
    el.setAttribute("aria-label", thinkingText);
    messages.appendChild(el);
    messages.scrollTop = messages.scrollHeight;
    return el;
  }

  function toggleChat() {
    isOpen = !isOpen;
    chat.setAttribute("aria-hidden", String(!isOpen));
    chat.classList.toggle("chubby-chat--open", isOpen);
    toggle.classList.toggle("chubby-toggle--open", isOpen);
    if (isOpen) {
      input.focus();
      // Add greeting if first time
      if (messages.children.length === 0) {
        addMessage(greetingText, "bot");
      }
    }
  }

  function handleSend(text) {
    if (!text.trim()) return;
    // Rate-limit: ignore rapid-fire sends
    var now = Date.now();
    if (now - lastSendTime < RATE_LIMIT_MS) return;
    lastSendTime = now;
    // Limit input length client-side
    var clean = text.trim().slice(0, 500);
    addMessage(clean, "user");
    quick.style.display = "none";
    input.value = "";
    input.focus();
    var typing = showTyping();
    var delay = 300 + Math.random() * 500;
    setTimeout(function() {
      typing.remove();
      var response = getResponse(clean);
      addMessage(response, "bot");
    }, delay);
  }

  /* в”Җв”Җ Events в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  toggle.addEventListener("click", toggleChat);
  closeBtn.addEventListener("click", toggleChat);

  form.addEventListener("submit", function(e) {
    e.preventDefault();
    handleSend(input.value);
  });

  quick.addEventListener("click", function(e) {
    var btn = e.target.closest(".chubby-quick-btn");
    if (!btn) return;
    var q = btn.getAttribute("data-q");
    // Map quick question key to a user-friendly message
    var qMap = {
      books:    lang === "es" ? "ВҝQuГ© libros tienen?" : "What books do you have?",
      peanuts:  lang === "es" ? "ВҝQuГ© son los Peanuts?" : "What are Peanuts?",
      giveaway: lang === "es" ? "ВҝCГіmo funciona el sorteo?" : "How does the giveaway work?",
      coloring: lang === "es" ? "ВҝCГіmo descargo lГЎminas gratis?" : "How do I download free coloring pages?"
    };
    handleSend(qMap[q] || btn.textContent);
  });

  // Close on Escape
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && isOpen) toggleChat();
  });

  // Close chat on outside click (overlay-like behavior on mobile)
  document.addEventListener("click", function(e) {
    if (isOpen && !chat.contains(e.target) && !toggle.contains(e.target)) {
      toggleChat();
    }
  });
})();
</script>

<style>
  /* в”Җв”Җ Toggle Button в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
