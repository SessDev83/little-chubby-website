---
type Lang = "en" | "es";

type Author = {
  id: string;
  name: string;
  avatarSrc: string;
  href: string;
  bio?: string;
};

type MediaItem = {
  src: string;
  alt: string;
  label: string;
};

type ManuscriptSampleType = "cover" | "front-matter" | "interior" | "back-matter" | "back-cover";
type ManuscriptWatermarkStyle = "none" | "logo" | "text";

type ManuscriptSampleItem = MediaItem & {
  type: ManuscriptSampleType;
  watermarkStyle?: ManuscriptWatermarkStyle;
  pageNumber?: number;
};

type IndexedSampleItem = ManuscriptSampleItem & {
  sampleIndex: number;
  isEager: boolean;
};

type SampleSpread = {
  pages: IndexedSampleItem[];
  isSingle: boolean;
};

interface Props {
  lang: Lang;
  bookId: string;
  bookTitle: string;
  coverSrc: string;
  coverAlt: string;
  previewImages: string[];
  manuscriptSample?: ManuscriptSampleItem[];
  amazonUrl: string;
  author: Author;
}

const {
  lang,
  bookId,
  bookTitle,
  coverSrc,
  coverAlt,
  previewImages,
  manuscriptSample = [],
  author,
} = Astro.props;

const copy = lang === "es"
  ? {
      heading: "Mira dentro",
      sampleCta: "Leer muestra",
      sampleViewerTitle: "Vista previa del libro",
      closeSample: "Cerrar vista previa",
      previousPage: "Pagina anterior",
      nextPage: "Pagina siguiente",
      authorTitle: "Sigue al autor",
      authorPage: "Pagina de autor",
      follow: "Seguir",
      openViewer: "Abrir visor de muestra",
      note: "Muestra protegida: portada limpia y paginas interiores con proteccion.",
      coverLabel: "Portada",
      backCoverLabel: "Contraportada",
      previewAlt: (index: number) => `Pagina ${index + 1} de ${bookTitle} (vista previa con marca de agua)`,
      pageLabel: (index: number) => `Pagina ${index + 1}`,
      counter: (index: number, total: number) => `${index + 1} de ${total}`,
      thumbLabel: (label: string) => `Mostrar ${label}`,
      morePagesLabel: (count: number) => `Abrir muestra con ${count} paginas mas`,
      reading: (label: string) => `Viendo: ${label}`,
      fallbackSampleLabel: (type: ManuscriptSampleType) =>
        ({
          cover: "Portada",
          "front-matter": "Paginas iniciales",
          interior: "Pagina para colorear",
          "back-matter": "Paginas finales",
          "back-cover": "Contraportada",
        })[type],
    }
  : {
      heading: "Look Inside",
      sampleCta: "Read sample",
      sampleViewerTitle: "Book sample preview",
      closeSample: "Close sample preview",
      previousPage: "Previous page",
      nextPage: "Next page",
      authorTitle: "Follow the author",
      authorPage: "Author page",
      follow: "Follow",
      openViewer: "Open sample viewer",
      note: "Protected sample: clean covers and protected interior pages.",
      coverLabel: "Cover",
      backCoverLabel: "Back cover",
      previewAlt: (index: number) => `Page ${index + 1} of ${bookTitle} (watermarked preview)`,
      pageLabel: (index: number) => `Page ${index + 1}`,
      counter: (index: number, total: number) => `${index + 1} of ${total}`,
      thumbLabel: (label: string) => `Show ${label}`,
      morePagesLabel: (count: number) => `Open sample with ${count} more pages`,
      reading: (label: string) => `Viewing: ${label}`,
      fallbackSampleLabel: (type: ManuscriptSampleType) =>
        ({
          cover: "Cover",
          "front-matter": "Front matter",
          interior: "Coloring page",
          "back-matter": "Back matter",
          "back-cover": "Back cover",
        })[type],
    };

const allInteriorPages = previewImages.filter((src): src is string =>
  typeof src === "string" && src.trim().length > 0
);

const lookInsideBackCover = manuscriptSample.find((item) =>
  item?.type === "back-cover" &&
  typeof item.src === "string" &&
  item.src.trim().length > 0 &&
  typeof item.alt === "string" &&
  item.alt.trim().length > 0
);

const previewItems: MediaItem[] = [
  {
    src: coverSrc,
    alt: coverAlt,
    label: copy.coverLabel,
  },
  ...(
    lookInsideBackCover
      ? [{ src: lookInsideBackCover.src, alt: lookInsideBackCover.alt, label: copy.backCoverLabel }]
      : []
  ),
  ...allInteriorPages.map((src, index) => ({
    src,
    alt: copy.previewAlt(index),
    label: copy.pageLabel(index),
  })),
];

const watermarkText = lang === "es"
  ? "PROPIEDAD DE LITTLE CHUBBY PRESS"
  : "PROPERTY OF LITTLE CHUBBY PRESS";

const VISIBLE_PREVIEW_THUMB_COUNT = 5;
const visiblePreviewItems = previewItems.slice(0, VISIBLE_PREVIEW_THUMB_COUNT);
const hiddenPreviewCount = Math.max(0, previewItems.length - visiblePreviewItems.length);
const firstHiddenPreviewItem = hiddenPreviewCount > 0 ? previewItems[visiblePreviewItems.length] : null;

const samplePages: IndexedSampleItem[] = previewItems.map((item, index) => ({
  ...item,
  type: index === 0 ? "cover" : lookInsideBackCover && index === 1 ? "back-cover" : "interior",
  watermarkStyle: "none",
  pageNumber: index === 0 ? undefined : index,
  sampleIndex: index,
  isEager: index < 2,
}));

const validWatermarkStyles = new Set<ManuscriptWatermarkStyle>(["none", "logo", "text"]);

function defaultWatermarkStyle(type: ManuscriptSampleType): ManuscriptWatermarkStyle {
  if (type === "cover" || type === "back-cover") return "none";
  if (type === "interior") return "logo";
  return "text";
}

const fallbackBookSampleItems: ManuscriptSampleItem[] = previewItems.map((item, index) => ({
  ...item,
  type: index === 0 ? "cover" : lookInsideBackCover && index === 1 ? "back-cover" : "interior",
  watermarkStyle: index === 0 || (lookInsideBackCover && index === 1) ? "none" : "logo",
  pageNumber: index === 0 ? undefined : index,
}));

const bookSamplePages: IndexedSampleItem[] = (
  manuscriptSample.length > 0 ? manuscriptSample : fallbackBookSampleItems
)
  .filter((item) => item.src?.trim() && item.alt?.trim() && item.label?.trim())
  .map((item, index) => {
    const watermarkStyle = item.watermarkStyle && validWatermarkStyles.has(item.watermarkStyle)
      ? item.watermarkStyle
      : defaultWatermarkStyle(item.type);

    return {
      ...item,
      watermarkStyle,
      label: item.label?.trim() || copy.fallbackSampleLabel(item.type),
      sampleIndex: index,
      isEager: index < 2,
    };
  });

const bookSampleSpreads: SampleSpread[] = bookSamplePages.map((page) => ({
  pages: [page],
  isSingle: true,
}));

const safePreviewItemsJson = JSON.stringify(previewItems).replace(/</g, "\\u003c");
const safeReadingText = copy.reading(samplePages[0]?.label ?? copy.coverLabel).replace(/</g, "\\u003c");
const safeBookSampleReadingText = copy.reading(bookSamplePages[0]?.label ?? copy.coverLabel).replace(/</g, "\\u003c");

const authorFollowHref = author.id.trim()
  ? `https://www.amazon.com/stores/Little-Chubby-Press/author/${encodeURIComponent(author.id.trim())}`
  : author.href;
---

<section
  class="editorial-media"
  data-editorial-preview
  aria-labelledby={`editorial-media-${bookId}`}
>
  <h2 id={`editorial-media-${bookId}`} class="editorial-media__sr-only">{copy.heading}</h2>

  <button class="editorial-media__stage" type="button" data-preview-open aria-label={copy.openViewer}>
    <img
      src={previewItems[0].src}
      alt={previewItems[0].alt}
      width="420"
      height="420"
      fetchpriority="high"
      decoding="async"
      data-preview-main
    />
  </button>

  <div class="editorial-media__label-row">
    <span>{copy.heading}</span>
    <span data-preview-counter aria-live="polite">{copy.counter(0, previewItems.length)}</span>
  </div>

  <div class="editorial-media__thumbs" role="listbox" aria-label={copy.heading}>
    {visiblePreviewItems.map((item, index) => (
      <button
        class="editorial-media__thumb"
        type="button"
        role="option"
        aria-label={copy.thumbLabel(item.label)}
        aria-selected={index === 0 ? "true" : "false"}
        data-preview-thumb={String(index)}
      >
        <img
          src={item.src}
          alt={item.alt}
          width="88"
          height="114"
          loading={index === 0 ? "eager" : "lazy"}
          decoding="async"
        />
      </button>
    ))}
    {hiddenPreviewCount > 0 && firstHiddenPreviewItem && (
      <button
        class="editorial-media__thumb editorial-media__thumb--more"
        type="button"
        role="option"
        aria-label={copy.morePagesLabel(hiddenPreviewCount)}
        aria-selected="false"
        data-preview-thumb={String(visiblePreviewItems.length)}
        data-preview-more="true"
      >
        <img
          src={firstHiddenPreviewItem.src}
          alt=""
          width="88"
          height="114"
          loading="lazy"
          decoding="async"
        />
        <span class="editorial-media__thumb-more-count" aria-hidden="true">+{hiddenPreviewCount}</span>
      </button>
    )}
  </div>

  <button
    class="editorial-media__sample"
    type="button"
    data-sample-open
    aria-haspopup="dialog"
    aria-controls={`editorial-book-sample-modal-${bookId}`}
  >
    {copy.sampleCta}
  </button>

  <p class="editorial-media__note">{copy.note}</p>

  <div
    class="editorial-sample-modal"
    id={`editorial-sample-modal-${bookId}`}
    data-sample-modal
    aria-hidden="true"
  >
    <div class="editorial-sample-modal__backdrop" data-sample-backdrop></div>

    <div
      class="editorial-sample-modal__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`editorial-sample-title-${bookId}`}
      tabindex="-1"
      data-sample-panel
    >
      <button
        class="editorial-sample-modal__close"
        type="button"
        data-sample-close
        aria-label={copy.closeSample}
      >
        X
      </button>

      <p class="editorial-sample-modal__title" id={`editorial-sample-title-${bookId}`}>
        {copy.sampleViewerTitle}
      </p>

      <div class="editorial-sample-modal__scroll" data-sample-scroll>
        <div class="editorial-sample-modal__pages">
          {samplePages.map((item) => (
            <figure
              class={`editorial-sample-modal__page${item.sampleIndex === 0 ? " is-active" : ""}`}
              data-sample-page
              data-sample-index={String(item.sampleIndex)}
              data-sample-label={item.label}
              data-sample-type={item.type}
              data-sample-watermark-style={item.watermarkStyle}
              hidden={item.sampleIndex !== 0}
            >
              <div class="editorial-sample-modal__page-artboard">
                <img
                  src={item.src}
                  alt={item.alt}
                  width="1200"
                  height="1600"
                  loading={item.isEager ? "eager" : "lazy"}
                  decoding="async"
                />
                {item.watermarkStyle === "logo" && (
                  <span class="editorial-sample-modal__wm-logo editorial-look-inside-modal__wm-logo" aria-hidden="true"></span>
                )}
                {item.watermarkStyle === "text" && (
                  <span class="editorial-sample-modal__wm-text" aria-hidden="true">
                    <span class="editorial-sample-modal__wm-line editorial-sample-modal__wm-line--top">{watermarkText}</span>
                    <span class="editorial-sample-modal__wm-line editorial-sample-modal__wm-line--bottom">{watermarkText}</span>
                  </span>
                )}
              </div>
              <figcaption>{item.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>

      <div class="editorial-sample-modal__controls">
        <button class="editorial-sample-modal__nav" type="button" data-sample-prev aria-label={copy.previousPage}>&lt;</button>
        <p class="editorial-sample-modal__indicator" data-sample-indicator aria-live="polite" set:html={safeReadingText}></p>
        <button class="editorial-sample-modal__nav" type="button" data-sample-next aria-label={copy.nextPage}>&gt;</button>
      </div>
    </div>
  </div>

  <div
    class="editorial-sample-modal editorial-book-sample-modal"
    id={`editorial-book-sample-modal-${bookId}`}
    data-book-sample-modal
    aria-hidden="true"
  >
    <div class="editorial-sample-modal__backdrop" data-book-sample-backdrop></div>

    <div
      class="editorial-sample-modal__panel editorial-book-sample-modal__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`editorial-book-sample-title-${bookId}`}
      tabindex="-1"
      data-book-sample-panel
    >
      <button
        class="editorial-sample-modal__close"
        type="button"
        data-book-sample-close
        aria-label={copy.closeSample}
      >
        X
      </button>

      <p class="editorial-sample-modal__title" id={`editorial-book-sample-title-${bookId}`}>
        {copy.sampleViewerTitle}
      </p>

      <div class="editorial-sample-modal__scroll editorial-book-sample-modal__scroll" data-book-sample-scroll>
        <div class="editorial-sample-modal__pages editorial-book-sample-modal__pages">
          {bookSampleSpreads.map((spread) => (
            <div
              class:list={[
                "editorial-book-sample-modal__spread",
                spread.isSingle && "editorial-book-sample-modal__spread--single",
              ]}
            >
              {spread.pages.map((item) => (
                <figure
                  class="editorial-sample-modal__page editorial-book-sample-modal__page"
                  data-book-sample-page
                  data-book-sample-index={String(item.sampleIndex)}
                  data-book-sample-label={item.label}
                  data-book-sample-type={item.type}
                  data-book-sample-watermark-style={item.watermarkStyle}
                >
                  <div class="editorial-sample-modal__page-artboard editorial-book-sample-modal__page-artboard">
                    <img
                      src={item.src}
                      alt={item.alt}
                      width="1200"
                      height="1600"
                      loading={item.isEager ? "eager" : "lazy"}
                      decoding="async"
                    />
                    {item.watermarkStyle === "logo" && (
                      <span class="editorial-sample-modal__wm-logo editorial-book-sample-modal__wm-logo" aria-hidden="true"></span>
                    )}
                    {item.watermarkStyle === "text" && (
                      <span class="editorial-sample-modal__wm-text" aria-hidden="true">
                        <span class="editorial-sample-modal__wm-line editorial-sample-modal__wm-line--top">{watermarkText}</span>
                        <span class="editorial-sample-modal__wm-line editorial-sample-modal__wm-line--bottom">{watermarkText}</span>
                      </span>
                    )}
                  </div>
                  <figcaption>{item.label}</figcaption>
                </figure>
              ))}
            </div>
          ))}
        </div>
      </div>

      <div class="editorial-sample-modal__controls">
        <button class="editorial-sample-modal__nav" type="button" data-book-sample-prev aria-label={copy.previousPage}>&lt;</button>
        <p class="editorial-sample-modal__indicator" data-book-sample-indicator aria-live="polite" set:html={safeBookSampleReadingText}></p>
        <button class="editorial-sample-modal__nav" type="button" data-book-sample-next aria-label={copy.nextPage}>&gt;</button>
      </div>
    </div>
  </div>

  <aside class="editorial-author" aria-labelledby={`editorial-author-${bookId}`}>
    <p class="editorial-author__label">{copy.authorTitle}</p>
    <div class="editorial-author__row">
      <img
        src={author.avatarSrc}
        alt=""
        width="44"
        height="44"
        loading="lazy"
        decoding="async"
        class="editorial-author__avatar"
      />
      <a id={`editorial-author-${bookId}`} class="editorial-author__name" href={author.href} target="_blank" rel="noopener noreferrer">
        {author.name}
      </a>
      <a class="editorial-author__follow" href={authorFollowHref} target="_blank" rel="noopener noreferrer">
        {copy.follow}
      </a>
    </div>
    {author.bio && <p class="editorial-author__bio">{author.bio}</p>}
    <a class="editorial-author__page" href={author.href} target="_blank" rel="noopener noreferrer">
      {copy.authorPage}
    </a>
  </aside>

  <script type="application/json" data-preview-items is:inline set:html={safePreviewItemsJson}></script>
</section>

<script>
  const initialized = new WeakSet<Element>();

  type MediaItem = {
    src: string;
    alt: string;
    label: string;
  };

  function initEditorialPreview(root: Element) {
    if (initialized.has(root)) return;
    initialized.add(root);

    const itemsNode = root.querySelector("[data-preview-items]");
    const mainImage = root.querySelector<HTMLImageElement>("[data-preview-main]");
    const counter = root.querySelector<HTMLElement>("[data-preview-counter]");
    const stageButton = root.querySelector<HTMLButtonElement>("[data-preview-open]");
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-preview-thumb]"));

    const sampleOpenButton = root.querySelector<HTMLButtonElement>("[data-sample-open]");
    const sampleModal = root.querySelector<HTMLElement>("[data-sample-modal]");
    const samplePanel = root.querySelector<HTMLElement>("[data-sample-panel]");
    const sampleBackdrop = root.querySelector<HTMLElement>("[data-sample-backdrop]");
    const sampleCloseButton = root.querySelector<HTMLButtonElement>("[data-sample-close]");
    const samplePrevButton = root.querySelector<HTMLButtonElement>("[data-sample-prev]");
    const sampleNextButton = root.querySelector<HTMLButtonElement>("[data-sample-next]");
    const sampleScroll = root.querySelector<HTMLElement>("[data-sample-scroll]");
    const sampleIndicator = root.querySelector<HTMLElement>("[data-sample-indicator]");
    const samplePages = Array.from(root.querySelectorAll<HTMLElement>("[data-sample-page]"));

    const bookSampleModal = root.querySelector<HTMLElement>("[data-book-sample-modal]");
    const bookSamplePanel = root.querySelector<HTMLElement>("[data-book-sample-panel]");
    const bookSampleBackdrop = root.querySelector<HTMLElement>("[data-book-sample-backdrop]");
    const bookSampleCloseButton = root.querySelector<HTMLButtonElement>("[data-book-sample-close]");
    const bookSamplePrevButton = root.querySelector<HTMLButtonElement>("[data-book-sample-prev]");
    const bookSampleNextButton = root.querySelector<HTMLButtonElement>("[data-book-sample-next]");
    const bookSampleScroll = root.querySelector<HTMLElement>("[data-book-sample-scroll]");
    const bookSampleIndicator = root.querySelector<HTMLElement>("[data-book-sample-indicator]");
    const bookSamplePages = Array.from(root.querySelectorAll<HTMLElement>("[data-book-sample-page]"));

    if (!itemsNode || !mainImage || !counter || thumbs.length === 0) return;

    let items: MediaItem[] = [];
    try {
      const parsed = JSON.parse(itemsNode.textContent || "[]");
      items = Array.isArray(parsed)
        ? parsed.filter((item): item is MediaItem =>
            item &&
            typeof item.src === "string" &&
            typeof item.alt === "string" &&
            typeof item.label === "string"
          )
        : [];
    } catch {
      items = [];
    }

    if (items.length === 0) return;

    let previewCurrent = 0;
    let sampleCurrent = 0;
    let bookSampleCurrent = 0;
    let modalOpen = false;
    let bookSampleModalOpen = false;
    let restoreFocusTo: HTMLElement | null = null;
    let bookSampleRestoreFocusTo: HTMLElement | null = null;
    let bookSampleScrollFrame = 0;

    const hasModal =
      !!sampleModal &&
      !!samplePanel &&
      !!sampleBackdrop &&
      !!sampleCloseButton &&
      !!samplePrevButton &&
      !!sampleNextButton &&
      !!sampleScroll &&
      !!sampleIndicator &&
      samplePages.length > 0;
    const hasBookSampleModal =
      !!sampleOpenButton &&
      !!bookSampleModal &&
      !!bookSamplePanel &&
      !!bookSampleBackdrop &&
      !!bookSampleCloseButton &&
      !!bookSamplePrevButton &&
      !!bookSampleNextButton &&
      !!bookSampleScroll &&
      !!bookSampleIndicator &&
      bookSamplePages.length > 0;
    const visibleThumbCount = thumbs.filter((thumb) => thumb.dataset.previewMore !== "true").length;
    const moreThumb = thumbs.find((thumb) => thumb.dataset.previewMore === "true") ?? null;

    function labelFor(index: number) {
      const isSpanish = document.documentElement.lang === "es";
      return isSpanish ? `${index + 1} de ${items.length}` : `${index + 1} of ${items.length}`;
    }

    function readingText(label: string) {
      const isSpanish = document.documentElement.lang === "es";
      return isSpanish ? `Viendo: ${label}` : `Viewing: ${label}`;
    }

    function samplePositionText(index: number) {
      const isSpanish = document.documentElement.lang === "es";
      return isSpanish ? `${index + 1} de ${samplePages.length}` : `${index + 1} of ${samplePages.length}`;
    }

    function bookSamplePositionText(index: number) {
      const isSpanish = document.documentElement.lang === "es";
      return isSpanish ? `${index + 1} de ${bookSamplePages.length}` : `${index + 1} of ${bookSamplePages.length}`;
    }

    function syncThumbs(focusThumb = false) {
      thumbs.forEach((thumb) => {
        const thumbIndex = Number.parseInt(thumb.dataset.previewThumb || "0", 10);
        const isMoreThumb = thumb.dataset.previewMore === "true";
        const isActive = isMoreThumb ? previewCurrent >= visibleThumbCount : thumbIndex === previewCurrent;
        thumb.setAttribute("aria-selected", String(isActive));
        thumb.setAttribute("tabindex", isActive ? "0" : "-1");
      });

      if (focusThumb) {
        const target = previewCurrent >= visibleThumbCount
          ? moreThumb
          : thumbs.find((thumb) => Number.parseInt(thumb.dataset.previewThumb || "0", 10) === previewCurrent);
        target?.focus();
      }
    }

    function updateMainPreview(focusThumb = false) {
      mainImage!.src = items[previewCurrent].src;
      mainImage!.alt = items[previewCurrent].alt;
      counter!.textContent = labelFor(previewCurrent);
      syncThumbs(focusThumb);
    }

    function setIndicator(index: number) {
      if (!sampleIndicator) return;
      const label = samplePages[index]?.dataset.sampleLabel || items[0]?.label || labelFor(0);
      sampleIndicator.textContent = `${samplePositionText(index)} - ${readingText(label)}`;
      if (samplePrevButton) samplePrevButton.disabled = index <= 0;
      if (sampleNextButton) sampleNextButton.disabled = index >= samplePages.length - 1;
    }

    function setPreviewActive(index: number, focusThumb = false) {
      previewCurrent = (index + items.length) % items.length;
      updateMainPreview(focusThumb);
    }

    function setSampleActive(index: number) {
      sampleCurrent = Math.max(0, Math.min(samplePages.length - 1, index));
      samplePages.forEach((page, pageIndex) => {
        const isActive = pageIndex === sampleCurrent;
        page.hidden = !isActive;
        page.classList.toggle("is-active", isActive);
      });
      setIndicator(sampleCurrent);
    }

    function setBookSampleIndicator(index: number) {
      if (!bookSampleIndicator) return;
      const label = bookSamplePages[index]?.dataset.bookSampleLabel || bookSamplePages[0]?.dataset.bookSampleLabel || "";
      bookSampleIndicator.textContent = `${bookSamplePositionText(index)} - ${readingText(label)}`;
      if (bookSamplePrevButton) bookSamplePrevButton.disabled = index <= 0;
      if (bookSampleNextButton) bookSampleNextButton.disabled = index >= bookSamplePages.length - 1;
    }

    function setBookSampleActive(index: number, scrollIntoView = false) {
      bookSampleCurrent = Math.max(0, Math.min(bookSamplePages.length - 1, index));
      bookSamplePages.forEach((page, pageIndex) => {
        page.classList.toggle("is-active", pageIndex === bookSampleCurrent);
      });
      setBookSampleIndicator(bookSampleCurrent);

      if (scrollIntoView && bookSampleModalOpen) {
        bookSamplePages[bookSampleCurrent]?.scrollIntoView({ block: "center", inline: "nearest", behavior: "smooth" });
      }
    }

    function getModalFocusableElements() {
      if (!hasModal) return [] as HTMLElement[];
      return Array.from(
        samplePanel!.querySelectorAll<HTMLElement>(
          'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((element) => !element.closest("[hidden]"));
    }

    function getBookSampleFocusableElements() {
      if (!hasBookSampleModal) return [] as HTMLElement[];
      return Array.from(
        bookSamplePanel!.querySelectorAll<HTMLElement>(
          'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((element) => !element.closest("[hidden]"));
    }

    function syncBookSampleFromScroll() {
      bookSampleScrollFrame = 0;
      if (!hasBookSampleModal || !bookSampleModalOpen) return;

      const scrollRect = bookSampleScroll!.getBoundingClientRect();
      const targetCenter = scrollRect.top + scrollRect.height * 0.45;
      let bestIndex = bookSampleCurrent;
      let bestDistance = Number.POSITIVE_INFINITY;

      bookSamplePages.forEach((page, index) => {
        const rect = page.getBoundingClientRect();
        const pageCenter = rect.top + rect.height / 2;
        const distance = Math.abs(pageCenter - targetCenter);
        if (distance < bestDistance) {
          bestDistance = distance;
          bestIndex = index;
        }
      });

      setBookSampleActive(bestIndex);
    }

    function scheduleBookSampleScrollSync() {
      if (bookSampleScrollFrame) return;
      bookSampleScrollFrame = window.requestAnimationFrame(syncBookSampleFromScroll);
    }

    function openModal(startIndex = previewCurrent) {
      if (!hasModal) return;

      if (modalOpen) {
        setSampleActive(startIndex);
        return;
      }

      modalOpen = true;
      restoreFocusTo = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      sampleModal!.classList.add("is-open");
      sampleModal!.setAttribute("aria-hidden", "false");
      document.body.classList.add("editorial-no-scroll");

      setSampleActive(startIndex);

      sampleCloseButton!.focus();
    }

    function closeModal() {
      if (!hasModal || !modalOpen) return;

      modalOpen = false;

      const fallbackTrigger = stageButton ?? null;
      const focusTarget =
        restoreFocusTo && !sampleModal!.contains(restoreFocusTo)
          ? restoreFocusTo
          : fallbackTrigger;
      focusTarget?.focus();

      sampleModal!.classList.remove("is-open");
      sampleModal!.setAttribute("aria-hidden", "true");
      if (!bookSampleModalOpen) document.body.classList.remove("editorial-no-scroll");
    }

    function openBookSampleModal(startIndex = 0) {
      if (!hasBookSampleModal) return;

      if (modalOpen) closeModal();

      bookSampleModalOpen = true;
      bookSampleRestoreFocusTo = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      bookSampleModal!.classList.add("is-open");
      bookSampleModal!.setAttribute("aria-hidden", "false");
      document.body.classList.add("editorial-no-scroll");

      setBookSampleActive(startIndex);
      bookSampleScroll!.scrollTop = 0;
      window.requestAnimationFrame(() => setBookSampleActive(startIndex));
      bookSampleCloseButton!.focus();
    }

    function closeBookSampleModal() {
      if (!hasBookSampleModal || !bookSampleModalOpen) return;

      bookSampleModalOpen = false;
      const focusTarget =
        bookSampleRestoreFocusTo && !bookSampleModal!.contains(bookSampleRestoreFocusTo)
          ? bookSampleRestoreFocusTo
          : sampleOpenButton;
      focusTarget?.focus();

      bookSampleModal!.classList.remove("is-open");
      bookSampleModal!.setAttribute("aria-hidden", "true");
      if (!modalOpen) document.body.classList.remove("editorial-no-scroll");
    }

    thumbs.forEach((thumb, index) => {
      thumb.setAttribute("tabindex", index === 0 ? "0" : "-1");
      thumb.addEventListener("click", () => {
        const targetIndex = Number.parseInt(thumb.dataset.previewThumb || String(index), 10);
        setPreviewActive(targetIndex);
        openModal(targetIndex);
      });
      thumb.addEventListener("keydown", (event: KeyboardEvent) => {
        if (event.key === "ArrowRight" || event.key === "ArrowDown") {
          event.preventDefault();
          setPreviewActive(previewCurrent + 1, true);
        }
        if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
          event.preventDefault();
          setPreviewActive(previewCurrent - 1, true);
        }
        if (event.key === "Home") {
          event.preventDefault();
          setPreviewActive(0, true);
        }
        if (event.key === "End") {
          event.preventDefault();
          setPreviewActive(items.length - 1, true);
        }
      });
    });

    stageButton?.addEventListener("click", () => openModal(previewCurrent));
    sampleOpenButton?.addEventListener("click", () => openBookSampleModal(0));

    if (hasModal) {
      sampleCloseButton!.addEventListener("click", closeModal);
      sampleBackdrop!.addEventListener("click", closeModal);
      samplePrevButton!.addEventListener("click", () => setSampleActive(sampleCurrent - 1));
      sampleNextButton!.addEventListener("click", () => setSampleActive(sampleCurrent + 1));

      samplePanel!.addEventListener("keydown", (event: KeyboardEvent) => {
        if (!modalOpen) return;

        if (event.key === "Escape") {
          event.preventDefault();
          closeModal();
          return;
        }

        if (event.key === "ArrowLeft") {
          event.preventDefault();
          setSampleActive(sampleCurrent - 1);
          return;
        }

        if (event.key === "ArrowRight") {
          event.preventDefault();
          setSampleActive(sampleCurrent + 1);
          return;
        }

        if (event.key === "Tab") {
          const focusable = getModalFocusableElements();
          if (focusable.length === 0) {
            event.preventDefault();
            samplePanel!.focus();
            return;
          }

          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          const activeEl = document.activeElement;

          if (event.shiftKey && activeEl === first) {
            event.preventDefault();
            last.focus();
          } else if (!event.shiftKey && activeEl === last) {
            event.preventDefault();
            first.focus();
          }
        }
      });
    }

    if (hasBookSampleModal) {
      bookSampleCloseButton!.addEventListener("click", closeBookSampleModal);
      bookSampleBackdrop!.addEventListener("click", closeBookSampleModal);
      bookSamplePrevButton!.addEventListener("click", () => setBookSampleActive(bookSampleCurrent - 1, true));
      bookSampleNextButton!.addEventListener("click", () => setBookSampleActive(bookSampleCurrent + 1, true));
      bookSampleScroll!.addEventListener("scroll", scheduleBookSampleScrollSync, { passive: true });

      bookSamplePanel!.addEventListener("keydown", (event: KeyboardEvent) => {
        if (!bookSampleModalOpen) return;

        if (event.key === "Escape") {
          event.preventDefault();
          closeBookSampleModal();
          return;
        }

        if (event.key === "ArrowLeft" || event.key === "PageUp") {
          event.preventDefault();
          setBookSampleActive(bookSampleCurrent - 1, true);
          return;
        }

        if (event.key === "ArrowRight" || event.key === "PageDown") {
          event.preventDefault();
          setBookSampleActive(bookSampleCurrent + 1, true);
          return;
        }

        if (event.key === "Tab") {
          const focusable = getBookSampleFocusableElements();
          if (focusable.length === 0) {
            event.preventDefault();
            bookSamplePanel!.focus();
            return;
          }

          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          const activeEl = document.activeElement;

          if (event.shiftKey && activeEl === first) {
            event.preventDefault();
            last.focus();
          } else if (!event.shiftKey && activeEl === last) {
            event.preventDefault();
            first.focus();
          }
        }
      });
    }

    setPreviewActive(0);
    setIndicator(0);
    setBookSampleIndicator(0);
  }

  document.querySelectorAll("[data-editorial-preview]").forEach(initEditorialPreview);
</script>

