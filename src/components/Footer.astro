---
import { siteConfig } from "../data/site";
import type { Lang } from "../data/i18n";
import { ui } from "../data/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const text = ui[lang];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer-shell">
    <div class="footer-info">
      <a class="footer-brand" href={`/${lang}/`}>
        <img src={siteConfig.brandAssets.logoMark} alt={siteConfig.brandName} width="52" height="52" />
        <span>{siteConfig.brandName}</span>
      </a>
      <p class="footer-small">{text.footerTagline}</p>
      <p class="footer-small">© {year} {siteConfig.brandName}</p>
    </div>

    <nav class="footer-columns" aria-label="Footer">
      <div class="footer-col">
        <h4 class="footer-col-title">{lang === "es" ? "Explorar" : "Explore"}</h4>
        <a href={`/${lang}/books/`}>{text.navBooks}</a>
        <a href={`/${lang}/blog/`}>{text.navBlog}</a>
        <a href={`/${lang}/about/`}>{text.navAbout}</a>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">{lang === "es" ? "Comunidad" : "Community"}</h4>
        <a href={`/${lang}/lottery/`}>{lang === "es" ? "Sorteo" : "Giveaway"}</a>
        <a href={`/${lang}/gallery/`}>{text.navGallery}</a>
        <a href={`/${lang}/newsletter/`}>{text.navNewsletter}</a>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">{lang === "es" ? "Conectar" : "Connect"}</h4>
        <a href={`/${lang}/contact/`}>{text.navContact}</a>
        <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </nav>
  </div>

  <div class="container footer-bottom">
    <a href={`/${lang}/privacy/`}>{text.navPrivacy}</a>
  </div>
</footer>
