---
import { siteConfig } from "../data/site";
import type { Lang } from "../data/i18n";
import { ui } from "../data/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const text = ui[lang];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer-shell">
    <div class="footer-info">
      <a class="footer-brand" href={`/${lang}/`}>
        <img src={siteConfig.brandAssets.logoMark} alt={siteConfig.brandName} width="52" height="52" />
        <span>{siteConfig.brandName}</span>
      </a>
      <p class="footer-small">{text.footerTagline}</p>
      <p class="footer-small">© {year} {siteConfig.brandName}</p>
    </div>

    <nav class="footer-columns" aria-label="Footer">
      <div class="footer-col">
        <h3 class="footer-col-title">{lang === "es" ? "Explorar" : "Explore"}</h3>
        <a href={`/${lang}/books/`}>{text.navBooks}</a>
        <a href={`/${lang}/blog/`}>{text.navBlog}</a>
        <a href={`/${lang}/about/`}>{text.navAbout}</a>
      </div>
      <div class="footer-col">
        <h3 class="footer-col-title">{lang === "es" ? "Comunidad" : "Community"}</h3>
        <a href={`/${lang}/coloring-corner/`}>{text.navColoringCorner}</a>
        <a href={`/${lang}/lottery/`}>{lang === "es" ? "Sorteo" : "Giveaway"}</a>
        <a href={`/${lang}/gallery/`}>{text.navGallery}</a>
        <a href={`/${lang}/winners/`}>{text.navWinners}</a>
        <a href={`/${lang}/newsletter/`}>{text.navNewsletter}</a>
      </div>
      <div class="footer-col">
        <h3 class="footer-col-title">{lang === "es" ? "Conectar" : "Connect"}</h3>
        <a href={`/${lang}/contact/`}>{text.navContact}</a>
        <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          Instagram
        </a>
        <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          Facebook
        </a>
        <a href={siteConfig.social.bluesky} target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.643 3.593 3.519 6.173 3.175-.375.52-1.611 1.753-.875 3.613C7.182 20.756 12 18.906 12 18.906s4.818 1.85 6.078-1.871c.736-1.86-.5-3.093-.875-3.613 2.58.344 5.388-.532 6.173-3.175C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.86-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.747 13.087 8.686 12 10.8"/></svg>
          Bluesky
        </a>
      </div>
    </nav>
  </div>

  <div class="container footer-bottom">
    <a href={`/${lang}/faq/`}>{text.navFaq}</a>
    <span aria-hidden="true" style="opacity:0.5; margin:0 0.4rem;">·</span>
    <a href={`/${lang}/privacy/`}>{text.navPrivacy}</a>
    <span aria-hidden="true" style="opacity:0.5; margin:0 0.4rem;">·</span>
    <a href={`/${lang}/terms/`}>{text.navTerms}</a>
  </div>
</footer>
