---
import type { Lang } from "../data/i18n";
import { ui } from "../data/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const text = ui[lang];
---

<div id="lead-magnet-overlay" class="lead-magnet-overlay" style="display:none;" role="dialog" aria-modal="true" aria-label={text.leadMagnetHeadline}>
  <div class="lead-magnet-popup">
    <button class="lead-magnet-close" id="lead-magnet-close" type="button" aria-label={lang === "es" ? "Cerrar" : "Close"}>&times;</button>

    <h2>{text.leadMagnetHeadline}</h2>
    <p class="lead-subtitle">{text.leadMagnetSubheadline}</p>

    <div id="lead-magnet-form-section">
      <form class="lead-magnet-form" id="lead-magnet-form" novalidate>
        <input type="text" name="name" placeholder={text.formName} autocomplete="given-name" />
        <input type="email" name="email" placeholder={text.formEmail} required autocomplete="email" />
        <input type="text" name="company" style="display:none;" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="lang" value={lang} />
        <button type="submit" class="btn btn-primary" style="width:100%;">
          🎨 {text.leadMagnetCta}
        </button>
      </form>
      <button class="lead-magnet-dismiss" id="lead-magnet-dismiss" type="button">
        {text.leadMagnetDismiss}
      </button>
    </div>

    <div id="lead-magnet-success" class="lead-magnet-success" style="display:none;">
      <p class="lead-magnet-thankyou">🎉 {lang === "es" ? "¡Gracias por suscribirte!" : "Thanks for subscribing!"}</p>
      <p class="lead-magnet-check-inbox">{text.leadMagnetSuccess}</p>
    </div>
  </div>
</div>

<script is:inline>
var _lmTimer = null;
var _lmAC = null;

function initLeadMagnet() {
  // Clean up previous init (View Transition re-runs)
  if (_lmTimer) { clearTimeout(_lmTimer); _lmTimer = null; }
  if (_lmAC) { _lmAC.abort(); _lmAC = null; }

  var overlay = document.getElementById("lead-magnet-overlay");
  var closeBtn = document.getElementById("lead-magnet-close");
  var dismissBtn = document.getElementById("lead-magnet-dismiss");
  var form = document.getElementById("lead-magnet-form");
  var formSection = document.getElementById("lead-magnet-form-section");
  var successSection = document.getElementById("lead-magnet-success");
  if (!overlay || !form) return;

  // Don't show if user is logged in
  if (document.cookie.indexOf("sb-logged-in=") !== -1) return;

  // Don't show if already registered or recently dismissed
  var stored = localStorage.getItem("lcp-lead-magnet");
  if (stored === "registered") return;
  if (stored) {
    try {
      var data = JSON.parse(stored);
      if (data.dismissed) {
        var daysSince = (Date.now() - data.timestamp) / (1000 * 60 * 60 * 24);
        if (daysSince < 7) return; // Re-show after 7 days
      }
    } catch (e) { /* continue */ }
  }

  _lmAC = typeof AbortController !== "undefined" ? new AbortController() : null;
  var signal = _lmAC ? _lmAC.signal : undefined;

  // Show popup on first of: 50% scroll depth, exit-intent (desktop), or 30s dwell.
  // Less aggressive than the previous 5s timer; respects users who haven't engaged.
  var _lmShown = false;
  function showPopup(reason) {
    if (_lmShown) return;
    _lmShown = true;
    overlay.style.display = "";
    document.body.style.overflow = "hidden";
    if (typeof window.lcpTrack === "function") {
      window.lcpTrack("lead_magnet_shown", { trigger: reason || "unknown" });
    }
  }
  function onScrollCheck() {
    var doc = document.documentElement;
    var scrolled = (window.scrollY || doc.scrollTop || 0) + window.innerHeight;
    var total = doc.scrollHeight || document.body.scrollHeight || 0;
    if (total > 0 && scrolled / total >= 0.5) {
      showPopup("scroll-50");
      window.removeEventListener("scroll", onScrollCheck);
    }
  }
  function onExitIntent(e) {
    if (e.clientY <= 0) {
      showPopup("exit-intent");
      document.removeEventListener("mouseout", onExitIntent);
    }
  }
  window.addEventListener("scroll", onScrollCheck, { passive: true });
  // Exit-intent only on devices with a real cursor (skip touch).
  if (window.matchMedia && window.matchMedia("(pointer:fine)").matches) {
    document.addEventListener("mouseout", onExitIntent);
  }
  // Fallback: 30s dwell so we never miss a slow reader.
  _lmTimer = setTimeout(function () { showPopup("dwell-30s"); }, 30000);

  function closePopup() {
    overlay.style.display = "none";
    document.body.style.overflow = "";
    if (_lmTimer) { clearTimeout(_lmTimer); _lmTimer = null; }
  }

  function dismiss() {
    localStorage.setItem("lcp-lead-magnet", JSON.stringify({
      dismissed: true,
      timestamp: Date.now()
    }));
    closePopup();
  }

  closeBtn.addEventListener("click", dismiss);
  dismissBtn.addEventListener("click", dismiss);

  // Close on overlay click (outside popup)
  overlay.addEventListener("click", function(e) {
    if (e.target === overlay) dismiss();
  });

  // Close on Escape key (with signal to prevent listener leak across View Transitions)
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && overlay.style.display !== "none") dismiss();
  }, signal ? { signal: signal } : undefined);

  form.addEventListener("submit", function(e) {
    e.preventDefault();

    // Honeypot check
    var honeypot = form.querySelector("[name='company']");
    if (honeypot && honeypot.value) return;

    var emailInput = form.querySelector("[name='email']");
    var nameInput = form.querySelector("[name='name']");
    var langInput = form.querySelector("[name='lang']");
    var email = emailInput ? emailInput.value.trim() : "";
    var name = nameInput ? nameInput.value.trim() : "";
    var lang = langInput ? langInput.value : "en";

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailInput.style.borderColor = "var(--accent-coral)";
      emailInput.focus();
      return;
    }

    var btn = form.querySelector("button[type='submit']");
    if (btn) {
      btn.disabled = true;
      btn.textContent = "...";
    }

    // Insert subscriber via server-side API (sends confirmation email)
    fetch("/api/subscribe-newsletter/", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        email: email,
        name: name,
        source: "popup",
        lang_pref: lang,
      })
    }).then(function(res) {
      return res.json().then(function(data) { return { res: res, data: data || {} }; });
    }).then(function(payload) {
      var res = payload.res;
      var data = payload.data;
      var ok = res && res.ok && data && data.ok === true;

      var currentLang = document.documentElement.lang === "en" ? "en" : "es";
      var thankYouEl = successSection.querySelector(".lead-magnet-thankyou");
      var checkInboxEl = successSection.querySelector(".lead-magnet-check-inbox");

      if (!ok) {
        // Server error / 429 throttle / validation failure: do NOT mark as registered.
        // Re-enable the form so user can retry. Show inline error.
        if (btn) { btn.disabled = false; btn.textContent = "🎨 " + (currentLang === "en" ? "Try again" : "Reintentar"); }
        var emailEl = form.querySelector("[name='email']");
        if (emailEl) emailEl.style.borderColor = "var(--accent-coral)";
        var existingErr = formSection.querySelector(".lead-magnet-error");
        if (!existingErr) {
          var errEl = document.createElement("p");
          errEl.className = "lead-magnet-error";
          errEl.setAttribute("role", "alert");
          errEl.style.cssText = "color:var(--accent-coral);font-size:0.9rem;margin:0.5rem 0 0;";
          errEl.textContent = currentLang === "en"
            ? "Couldn't subscribe right now. Please try again in a moment."
            : "No pudimos suscribirte ahora mismo. Intenta de nuevo en un momento.";
          formSection.appendChild(errEl);
        }
        if (typeof window.lcpTrack === "function") {
          window.lcpTrack("lead_magnet_submit_error", { status: res ? res.status : 0 });
        }
        return;
      }

      // Success: now we can safely mark as registered.
      localStorage.setItem("lcp-lead-magnet", "registered");

      if (data.existing && data.confirmed) {
        // Already confirmed subscriber
        if (thankYouEl) thankYouEl.textContent = currentLang === "en" ? "You're already subscribed!" : "¡Ya estás suscrito/a!";
        if (checkInboxEl) checkInboxEl.textContent = "";
      } else if (data.existing) {
        // Re-sent confirmation
        if (thankYouEl) thankYouEl.textContent = currentLang === "en" ? "Thanks for subscribing!" : "¡Gracias por suscribirte!";
        if (checkInboxEl) checkInboxEl.textContent = currentLang === "en"
          ? "We re-sent the confirmation email — check your inbox!"
          : "¡Reenviamos el email de confirmación — revisa tu correo!";
      }
      // else: new subscriber — uses default HTML text

      formSection.style.display = "none";
      successSection.style.display = "";

      if (typeof window.lcpTrack === "function") {
        window.lcpTrack("lead_magnet_submit_success", {
          existing: !!data.existing,
          confirmed: !!data.confirmed
        });
      }

      // Trigger download of the PDF directly
      var downloadLink = document.createElement("a");
      downloadLink.href = "/downloads/mini-coloring-book.pdf";
      downloadLink.download = "Little-Chubby-Press-Mini-Coloring-Book.pdf";
      downloadLink.style.display = "none";
      document.body.appendChild(downloadLink);
      downloadLink.click();
      document.body.removeChild(downloadLink);

      // Close popup after 4 seconds
      setTimeout(function() {
        overlay.style.display = "none";
        document.body.style.overflow = "";
      }, 4000);
    }).catch(function() {
      // Network error: do NOT mark as registered, re-enable form, show error.
      var currentLang = document.documentElement.lang === "en" ? "en" : "es";
      if (btn) { btn.disabled = false; btn.textContent = "🎨 " + (currentLang === "en" ? "Try again" : "Reintentar"); }
      var existingErr = formSection.querySelector(".lead-magnet-error");
      if (!existingErr) {
        var errEl = document.createElement("p");
        errEl.className = "lead-magnet-error";
        errEl.setAttribute("role", "alert");
        errEl.style.cssText = "color:var(--accent-coral);font-size:0.9rem;margin:0.5rem 0 0;";
        errEl.textContent = currentLang === "en"
          ? "Network error. Please check your connection and try again."
          : "Error de red. Comprueba tu conexión e intenta de nuevo.";
        formSection.appendChild(errEl);
      }
      if (typeof window.lcpTrack === "function") {
        window.lcpTrack("lead_magnet_submit_error", { status: 0, network: true });
      }
    });
  });
}

initLeadMagnet();
document.addEventListener("astro:after-swap", initLeadMagnet);
</script>
