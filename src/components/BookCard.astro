---
import type { Book } from "../data/books";
import type { Lang } from "../data/i18n";
import Button from "./Button.astro";

interface Props {
  book: Book;
  lang: Lang;
  labels: {
    buy: string;
    leaveReview: string;
    noReviews: string;
    outOfFive: string;
    reviewSingular: string;
    reviewPlural: string;
    copyLink: string;
  };
}

const { book, lang, labels } = Astro.props;
const detailHref = `/${lang}/books/${book.id}/`;

const asinMatch = book.amazonUrl.match(/\/dp\/([A-Z0-9]{10})/i);
const asin = asinMatch ? asinMatch[1].toUpperCase() : null;
const dynamicCoverSrc = asin
  ? `https://images-na.ssl-images-amazon.com/images/P/${asin}.01.LZZZZZZZ.jpg`
  : book.coverSrc;
const reviewUrl = asin
  ? `https://www.amazon.com/review/create-review?asin=${asin}`
  : `${book.amazonUrl}#customerReviews`;

const hasRating =
  typeof book.ratingValue === "number" &&
  Number.isFinite(book.ratingValue) &&
  typeof book.ratingCount === "number" &&
  book.ratingCount > 0;

const normalizedRating = hasRating
  ? Math.max(0, Math.min(5, book.ratingValue ?? 0))
  : 0;
const ratingPercent = `${(normalizedRating / 5) * 100}%`;
const reviewWord = (book.ratingCount ?? 0) === 1
  ? labels.reviewSingular
  : labels.reviewPlural;
const ratingSummary = hasRating
  ? `${normalizedRating.toFixed(1)} ${labels.outOfFive} (${book.ratingCount} ${reviewWord})`
  : labels.noReviews;
---

<article class="book-card" aria-labelledby={`book-${book.id}`} data-categories={book.ageCategories.join(",")}>
  <div class="book-card-media">
    <a href={detailHref} class="book-card-cover-link" tabindex="-1" aria-hidden="true">
      <img
        src={dynamicCoverSrc}
        alt={book.coverAlt[lang]}
        loading="lazy"
        decoding="async"
        width="600"
        height="600"
      />
    </a>
  </div>
  <h3 id={`book-${book.id}`}>
    <a href={detailHref} class="book-card-title-link">{book.title[lang]}</a>
  </h3>
  <p>{book.subtitle[lang]}</p>
  <p>{book.description[lang]}</p>
  <div class="book-rating" aria-label={ratingSummary}>
    <span class="book-rating-stars" style={`--rating-percent: ${ratingPercent};`} aria-hidden="true"></span>
    <span class="book-rating-copy">{ratingSummary}</span>
  </div>
  <span class="badge-age">{book.ageRange[lang]}</span>
  <div class="card-actions">
    <Button href={book.amazonUrl} label={labels.buy} variant="secondary" external />
    <Button href={reviewUrl} label={labels.leaveReview} variant="ghost" external />
    <button class="btn btn-ghost copy-link-btn" data-copy-url={book.amazonUrl} aria-label={labels.copyLink} type="button">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: -2px; margin-right: 0.3rem;"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <span class="copy-label">{labels.copyLink}</span>
    </button>
  </div>
</article>
