---
import { siteConfig } from "../data/site";
import type { Lang } from "../data/i18n";
import { switchLangPath, ui } from "../data/i18n";

interface Props {
  lang: Lang;
  pathname: string;
  alternatePath?: string;
}

const { lang, pathname, alternatePath } = Astro.props;
const text = ui[lang];
const homeHref = `/${lang}/`;

const navItems = [
  { href: `/${lang}/`, label: text.navHome },
  { href: `/${lang}/books/`, label: text.navBooks },
  { href: `/${lang}/blog/`, label: text.navBlog },
  { href: `/${lang}/coloring-corner/`, label: text.navColoringCorner },
  { href: `/${lang}/gallery/`, label: text.navGallery },
  { href: `/${lang}/contact/`, label: text.navContact },
];
---

<header class="site-header">
  <div class="container site-header-shell">
    <div class="header-top">
      <a class="brand-link" href={homeHref}>
        <img src={siteConfig.brandAssets.logoMark} alt={siteConfig.brandName} width="64" height="64" />
        <span>{siteConfig.brandName}</span>
      </a>

      <div class="header-actions">
        <a href={`/${lang}/login/`} class="header-login" id="auth-login">{text.navLogin}</a>
        <a href={`/${lang}/lottery/`} class="header-tickets" id="auth-tickets" style="display:none;" title={lang === "es" ? "Tus Tickets" : "Your Tickets"}>
          🎟️ <span id="tickets-count">0</span>
        </a>
        <a href={`/${lang}/peanuts/`} class="header-peanuts" id="auth-peanuts" style="display:none;" title={lang === "es" ? "Tus Peanuts" : "Your Peanuts"}>
          🥜 <span id="peanuts-count">0</span>
        </a>
        <button class="header-bell" id="auth-bell" style="display:none;" title={lang === "es" ? "Notificaciones" : "Notifications"} aria-label="Notifications">
          🔔 <span class="bell-badge" id="bell-badge" style="display:none;">0</span>
        </button>
        <span class="header-username" id="auth-username" style="display:none;"></span>
        <div class="settings-wrapper" id="settings-wrapper">
          <button
            class="settings-btn"
            type="button"
            aria-label={lang === "es" ? "Configuración" : "Settings"}
            aria-expanded="false"
            aria-controls="settings-dropdown"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M17.727 7.844l-1.266-.382a6.534 6.534 0 0 0-.553-1.334l.592-1.196a.5.5 0 0 0-.09-.577l-1.764-1.764a.5.5 0 0 0-.577-.09l-1.196.592a6.545 6.545 0 0 0-1.334-.553L11.157 1.273A.5.5 0 0 0 10.67 1H8.33a.5.5 0 0 0-.487.273L7.461 2.54a6.534 6.534 0 0 0-1.334.553l-1.196-.592a.5.5 0 0 0-.577.09L2.59 4.355a.5.5 0 0 0-.09.577l.592 1.196a6.534 6.534 0 0 0-.553 1.334l-1.266.382A.5.5 0 0 0 1 8.33v2.34a.5.5 0 0 0 .273.487l1.266.382c.135.468.322.914.553 1.334l-.592 1.196a.5.5 0 0 0 .09.577l1.764 1.764a.5.5 0 0 0 .577.09l1.196-.592c.42.231.866.418 1.334.553l.382 1.266A.5.5 0 0 0 8.33 18h2.34a.5.5 0 0 0 .487-.273l.382-1.266a6.534 6.534 0 0 0 1.334-.553l1.196.592a.5.5 0 0 0 .577-.09l1.764-1.764a.5.5 0 0 0 .09-.577l-.592-1.196c.231-.42.418-.866.553-1.334l1.266-.382A.5.5 0 0 0 18 10.67V8.33a.5.5 0 0 0-.273-.487Z" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
          <div class="settings-dropdown" id="settings-dropdown">
            <a href={`/${lang}/login/`} class="settings-item settings-login-hint" id="settings-login-hint">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 2h3a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1h-3M7 11l-3-3 3-3M4 8h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {text.settingsLoginHint}
            </a>
            <div class="settings-auth-items" id="settings-auth-items" style="display:none;">
              <a href={`/${lang}/profile/`} class="settings-item">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 14c0-3 2.5-5 5.5-5s5.5 2 5.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                {text.navProfile}
              </a>
              <a href={`/${lang}/reviews/`} class="settings-item">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1.5l1.76 3.57 3.94.57-2.85 2.78.67 3.93L8 10.67l-3.52 1.68.67-3.93L2.3 5.64l3.94-.57L8 1.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {text.navReviews}
              </a>
              <a href={`/${lang}/logout/`} class="settings-item settings-item--logout">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h3M11 11l3-3-3-3M14 8H6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {text.navLogout}
              </a>
            </div>
            <div class="settings-lang" role="group" aria-label={text.languageToggleLabel}>
              <a
                href={lang === "en" && alternatePath ? alternatePath : switchLangPath(pathname, "es")}
                hreflang="es"
                lang="es"
                data-active={lang === "es"}
                data-lang-link="es"
              >
                ES
              </a>
              <a
                href={lang === "es" && alternatePath ? alternatePath : switchLangPath(pathname, "en")}
                hreflang="en"
                lang="en"
                data-active={lang === "en"}
                data-lang-link="en"
              >
                EN
              </a>
            </div>
          </div>
        </div>
        <button
          class="hamburger"
          type="button"
          aria-label={lang === "es" ? "Abrir menú" : "Open menu"}
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>

    <nav class="header-nav" id="mobile-nav" aria-label="Primary">
      <ul>
        {
          navItems.map((item) => {
            const isHome = item.href === `/${lang}/`;
            const isCurrent = isHome
              ? pathname === item.href
              : pathname === item.href || pathname.startsWith(item.href);
            return (
              <li>
                <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  function initHeader() {
    // Clean up display name cache on logout
    if (window.location.search.indexOf("logged-out=1") !== -1) {
      localStorage.removeItem("lcp-display-name");
      // Remove query param from URL without reload
      var cleanUrl = window.location.pathname + window.location.hash;
      window.history.replaceState(null, "", cleanUrl);
    }

    // Auth state: toggle login vs username/settings
    var loggedIn = document.cookie.indexOf("sb-logged-in=") !== -1;
    var loginEl = document.getElementById("auth-login");
    var usernameEl = document.getElementById("auth-username");
    var settingsAuthItems = document.getElementById("settings-auth-items");
    var settingsLoginHint = document.getElementById("settings-login-hint");
    var peanutsEl = document.getElementById("auth-peanuts");
    var peanutsCount = document.getElementById("peanuts-count");
    var ticketsEl = document.getElementById("auth-tickets");
    var ticketsCount = document.getElementById("tickets-count");

    if (loginEl) loginEl.style.display = loggedIn ? "none" : "";
    if (usernameEl) {
      usernameEl.style.display = loggedIn ? "" : "none";
      if (loggedIn) {
        var name = localStorage.getItem("lcp-display-name") || "";
        usernameEl.textContent = name || "";
      }
    }
    if (settingsAuthItems) settingsAuthItems.style.display = loggedIn ? "" : "none";
    if (settingsLoginHint) settingsLoginHint.style.display = loggedIn ? "none" : "";
    if (peanutsEl) peanutsEl.style.display = loggedIn ? "" : "none";
    if (ticketsEl) ticketsEl.style.display = loggedIn ? "" : "none";

    // Bell + notifications
    var bellEl = document.getElementById("auth-bell");
    var bellBadge = document.getElementById("bell-badge");
    if (bellEl) bellEl.style.display = loggedIn ? "" : "none";

    if (loggedIn && bellEl) {
      fetch("/api/notifications/", { credentials: "same-origin" })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.unreadCount && d.unreadCount > 0) {
            bellBadge.textContent = String(d.unreadCount);
            bellBadge.style.display = "";
          } else {
            bellBadge.style.display = "none";
          }
        })
        .catch(function() {});

      // Toggle dropdown on click
      bellEl.addEventListener("click", function(e) {
        e.stopPropagation();
        var existing = document.querySelector(".notif-dropdown");
        if (existing) { existing.remove(); return; }
        fetch("/api/notifications/", { credentials: "same-origin" })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var dd = document.createElement("div");
            dd.className = "notif-dropdown open";
            if (!d.notifications || d.notifications.length === 0) {
              dd.innerHTML = '<div class="notif-empty">🔔 ' + (document.documentElement.lang === "es" ? "No tienes notificaciones." : "No notifications.") + '</div>';
            } else {
              function esc(s) { var d = document.createElement("div"); d.textContent = s; return d.innerHTML; }
              dd.innerHTML = d.notifications.map(function(n) {
                var cls = n.read ? "notif-item" : "notif-item unread";
                var title = document.documentElement.lang === "es" ? (n.title_es || n.title_en) : (n.title_en || n.title_es);
                var body = document.documentElement.lang === "es" ? (n.body_es || n.body_en) : (n.body_en || n.body_es);
                return '<div class="' + cls + '" data-notif-id="' + esc(n.id) + '"><div class="notif-title">' + esc(title) + '</div><div class="notif-body">' + esc(body) + '</div></div>';
              }).join("");
              // Mark all as read
              fetch("/api/notifications/", {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                credentials: "same-origin",
                body: JSON.stringify({ action: "mark_all_read" })
              }).then(function() {
                bellBadge.style.display = "none";
              }).catch(function(){});
            }
            bellEl.parentElement.style.position = "relative";
            bellEl.parentElement.appendChild(dd);
            // Close on outside click
            setTimeout(function() {
              document.addEventListener("click", function closeDD() {
                dd.remove();
                document.removeEventListener("click", closeDD);
              }, { once: true });
            }, 10);
          }).catch(function(){});
      });
    }

    // Fetch peanuts + tickets balance
    if (loggedIn && peanutsCount) {
      var cached = sessionStorage.getItem("lcp-peanuts");
      if (cached !== null) peanutsCount.textContent = cached;
      var cachedTickets = sessionStorage.getItem("lcp-tickets");
      if (cachedTickets !== null && ticketsCount) ticketsCount.textContent = cachedTickets;
      fetch("/api/me/", { credentials: "same-origin" })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.balance !== undefined) {
            peanutsCount.textContent = String(d.balance);
            sessionStorage.setItem("lcp-peanuts", String(d.balance));
          }
          if (d.tickets !== undefined && ticketsCount) {
            ticketsCount.textContent = String(d.tickets);
            sessionStorage.setItem("lcp-tickets", String(d.tickets));
          }
        })
        .catch(function() {});
    }

    const rootLang = document.documentElement.getAttribute("lang");
    if (rootLang === "es" || rootLang === "en") {
      localStorage.setItem("lcp-lang", rootLang);
    }

    // Lang links — clone+replace to avoid duplicate listeners
    document.querySelectorAll("[data-lang-link]").forEach(function(anchor) {
      var clone = anchor.cloneNode(true);
      anchor.parentNode.replaceChild(clone, anchor);
      clone.addEventListener("click", function() {
        var nextLang = clone.getAttribute("data-lang-link");
        if (nextLang === "es" || nextLang === "en") {
          localStorage.setItem("lcp-lang", nextLang);
        }
      });
    });

    // Settings dropdown — clone+replace to avoid duplicate listeners
    var oldSettingsBtn = document.querySelector(".settings-btn");
    var dropdown = document.getElementById("settings-dropdown");
    if (oldSettingsBtn && dropdown) {
      var settingsBtn = oldSettingsBtn.cloneNode(true);
      oldSettingsBtn.parentNode.replaceChild(settingsBtn, oldSettingsBtn);
      settingsBtn.addEventListener("click", function(e) {
        e.stopPropagation();
        var isOpen = settingsBtn.getAttribute("aria-expanded") === "true";
        settingsBtn.setAttribute("aria-expanded", String(!isOpen));
        dropdown.classList.toggle("is-open");
      });
      // Close dropdown when clicking outside
      document.addEventListener("click", function(e) {
        if (!dropdown.contains(e.target) && !settingsBtn.contains(e.target)) {
          settingsBtn.setAttribute("aria-expanded", "false");
          dropdown.classList.remove("is-open");
        }
      });
    }

    // Hamburger menu — clone+replace to avoid duplicate listeners
    var oldBtn = document.querySelector(".hamburger");
    var nav = document.getElementById("mobile-nav");
    if (oldBtn && nav) {
      var btn = oldBtn.cloneNode(true);
      oldBtn.parentNode.replaceChild(btn, oldBtn);
      // Reset state on navigation
      btn.setAttribute("aria-expanded", "false");
      btn.classList.remove("is-open");
      nav.classList.remove("is-open");

      btn.addEventListener("click", function() {
        var isOpen = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!isOpen));
        btn.classList.toggle("is-open");
        nav.classList.toggle("is-open");
      });
      // Close menu when a link is clicked
      nav.querySelectorAll("a").forEach(function(link) {
        link.addEventListener("click", function() {
          btn.setAttribute("aria-expanded", "false");
          btn.classList.remove("is-open");
          nav.classList.remove("is-open");
        });
      });
    }

    // Set --header-h CSS var so sticky filter bars sit below the header
    var headerEl = document.querySelector(".site-header");
    if (headerEl) {
      function syncHeaderH() {
        document.documentElement.style.setProperty("--header-h", headerEl.offsetHeight + "px");
      }
      syncHeaderH();
      window.addEventListener("resize", syncHeaderH);
    }
  }
  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>
