---
import { siteConfig } from "../data/site";
import type { Lang } from "../data/i18n";
import { switchLangPath, ui } from "../data/i18n";

interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const text = ui[lang];
const homeHref = `/${lang}/`;

const navItems = [
  { href: `/${lang}/`, label: text.navHome },
  { href: `/${lang}/books/`, label: text.navBooks },
  { href: `/${lang}/blog/`, label: text.navBlog },
  { href: `/${lang}/contact/`, label: text.navContact },
  { href: `/${lang}/about/`, label: text.navAbout },
];
---

<header class="site-header">
  <div class="container site-header-shell">
    <div class="header-top">
      <a class="brand-link" href={homeHref}>
        <img src={siteConfig.brandAssets.logoMark} alt={siteConfig.brandName} width="64" height="64" />
        <span>{siteConfig.brandName}</span>
      </a>

      <div class="header-actions">
        <button
          class="theme-toggle"
          type="button"
          aria-label={lang === "es" ? "Cambiar tema" : "Toggle theme"}
          title={lang === "es" ? "Modo claro / oscuro" : "Light / dark mode"}
        >
          <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
        <a href={`/${lang}/login/`} class="header-login">{text.navLogin}</a>
        <div class="lang-toggle" role="group" aria-label={text.languageToggleLabel}>
          <a
            href={switchLangPath(pathname, "es")}
            hreflang="es"
            lang="es"
            data-active={lang === "es"}
            data-lang-link="es"
          >
            ES
          </a>
          <a
            href={switchLangPath(pathname, "en")}
            hreflang="en"
            lang="en"
            data-active={lang === "en"}
            data-lang-link="en"
          >
            EN
          </a>
        </div>
        <button
          class="hamburger"
          type="button"
          aria-label={lang === "es" ? "Abrir menú" : "Open menu"}
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>

    <nav class="header-nav" id="mobile-nav" aria-label="Primary">
      <ul>
        {
          navItems.map((item) => {
            const isHome = item.href === `/${lang}/`;
            const isCurrent = isHome
              ? pathname === item.href
              : pathname === item.href || pathname.startsWith(item.href);
            return (
              <li>
                <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  function initHeader() {
    const rootLang = document.documentElement.getAttribute("lang");
    if (rootLang === "es" || rootLang === "en") {
      localStorage.setItem("lcp-lang", rootLang);
    }

    // Lang links — clone+replace to avoid duplicate listeners
    document.querySelectorAll("[data-lang-link]").forEach(function(anchor) {
      var clone = anchor.cloneNode(true);
      anchor.parentNode.replaceChild(clone, anchor);
      clone.addEventListener("click", function() {
        var nextLang = clone.getAttribute("data-lang-link");
        if (nextLang === "es" || nextLang === "en") {
          localStorage.setItem("lcp-lang", nextLang);
        }
      });
    });

    // Theme toggle — clone+replace to avoid duplicate listeners
    var oldThemeBtn = document.querySelector(".theme-toggle");
    if (oldThemeBtn) {
      var themeBtn = oldThemeBtn.cloneNode(true);
      oldThemeBtn.parentNode.replaceChild(themeBtn, oldThemeBtn);
      themeBtn.addEventListener("click", function() {
        var isDark = document.documentElement.getAttribute("data-theme") === "dark";
        if (isDark) {
          document.documentElement.removeAttribute("data-theme");
          localStorage.setItem("lcp-theme", "light");
        } else {
          document.documentElement.setAttribute("data-theme", "dark");
          localStorage.setItem("lcp-theme", "dark");
        }
        var mc = document.querySelector('meta[name="theme-color"]');
        if (mc) mc.setAttribute("content", isDark ? "#f6f1e7" : "#1a1613");
      });
    }

    // Hamburger menu — clone+replace to avoid duplicate listeners
    var oldBtn = document.querySelector(".hamburger");
    var nav = document.getElementById("mobile-nav");
    if (oldBtn && nav) {
      var btn = oldBtn.cloneNode(true);
      oldBtn.parentNode.replaceChild(btn, oldBtn);
      // Reset state on navigation
      btn.setAttribute("aria-expanded", "false");
      btn.classList.remove("is-open");
      nav.classList.remove("is-open");

      btn.addEventListener("click", function() {
        var isOpen = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!isOpen));
        btn.classList.toggle("is-open");
        nav.classList.toggle("is-open");
      });
      // Close menu when a link is clicked
      nav.querySelectorAll("a").forEach(function(link) {
        link.addEventListener("click", function() {
          btn.setAttribute("aria-expanded", "false");
          btn.classList.remove("is-open");
          nav.classList.remove("is-open");
        });
      });
    }
  }
  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>
