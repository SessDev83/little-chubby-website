---
import type { Lang } from "../data/i18n";
import { ui } from "../data/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const text = ui[lang];
---

<form class="surface-card form-shell js-validate-newsletter" novalidate>
  <div class="form-grid">
    <div class="form-group">
      <label for="newsletter-name">{text.formName}</label>
      <input id="newsletter-name" name="name" type="text" autocomplete="name" />
    </div>

    <div class="form-group">
      <label for="newsletter-email">{text.formEmail} *</label>
      <input id="newsletter-email" name="email" type="email" autocomplete="email" required />
    </div>

    <div class="form-group hp-field" aria-hidden="true">
      <label for="newsletter-company">{text.formPhoneHp}</label>
      <input id="newsletter-company" name="company" type="text" tabindex="-1" autocomplete="off" />
    </div>

    <p class="form-note">{text.newsletterDisclaimer}</p>

    <p class="status-msg" id="newsletter-status" aria-live="polite"></p>

    <button class="btn btn-primary btn-submit" type="submit">
      <span class="btn-label">{text.ctaSubscribe}</span>
      <span class="btn-spinner" aria-hidden="true"></span>
    </button>
  </div>
</form>

<script is:inline>
  var newsletterForm = document.querySelector(".js-validate-newsletter");
  var newsletterStatus = document.getElementById("newsletter-status");

  // P5-T1: track inline newsletter view (fires once per page-load when the form is on the page)
  if (newsletterForm && typeof window.lcpTrack === "function") {
    window.lcpTrack("newsletter_inline_view");
  }

  if (newsletterForm && newsletterStatus) {
    newsletterForm.addEventListener("submit", function(event) {
      event.preventDefault();

      var emailInput = newsletterForm.querySelector('input[name="email"]');
      var hpInput = newsletterForm.querySelector('input[name="company"]');
      var nameInput = newsletterForm.querySelector('input[name="name"]');
      var submitBtn = newsletterForm.querySelector('.btn-submit');
      var currentLang = document.documentElement.lang === "en" ? "en" : "es";

      var requiredMsg = currentLang === "en"
        ? "Please complete all required fields."
        : "Por favor completa los campos obligatorios.";
      var emailMsg = currentLang === "en"
        ? "Please enter a valid email."
        : "Ingresa un email valido.";
      var thankYouMsg = currentLang === "en"
        ? "Thanks for subscribing!"
        : "¡Gracias por suscribirte!";
      var successMsg = currentLang === "en"
        ? "Check your inbox to confirm your subscription!"
        : "¡Revisa tu correo para confirmar tu suscripción!";
      var alreadyMsg = currentLang === "en"
        ? "We re-sent the confirmation email — check your inbox!"
        : "¡Reenviamos el email de confirmación — revisa tu correo!";
      var alreadyConfirmedMsg = currentLang === "en"
        ? "You're already subscribed!"
        : "¡Ya estás suscrito!";
      var errorMsg = currentLang === "en"
        ? "Something went wrong. Please try again."
        : "Algo salió mal. Intenta de nuevo.";

      newsletterStatus.textContent = "";
      newsletterStatus.className = "status-msg";

      if (hpInput && hpInput.value.trim()) { return; }

      if (!emailInput || !emailInput.value.trim()) {
        newsletterStatus.textContent = requiredMsg;
        return;
      }

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim())) {
        newsletterStatus.textContent = emailMsg;
        return;
      }

      if (submitBtn) { submitBtn.classList.add('is-loading'); submitBtn.disabled = true; }

      fetch("/api/subscribe-newsletter/", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email: emailInput.value.trim(),
          name: nameInput ? nameInput.value.trim() : "",
          source: "newsletter-page",
          lang_pref: currentLang,
        })
      }).then(function(res) {
        return res.json().then(function(data) {
          if (submitBtn) { submitBtn.classList.remove('is-loading'); submitBtn.disabled = false; }
          var showThankYou = false;
          if (data.existing && data.confirmed) {
            newsletterStatus.textContent = alreadyConfirmedMsg;
            newsletterStatus.className = "status-msg status-info";
            showThankYou = true;
          } else if (data.existing) {
            newsletterStatus.textContent = alreadyMsg;
            newsletterStatus.className = "status-msg status-success";
            showThankYou = true;
          } else if (data.ok) {
            newsletterStatus.textContent = successMsg;
            newsletterStatus.className = "status-msg status-success";
            newsletterForm.reset();
            showThankYou = true;
          } else {
            newsletterStatus.textContent = errorMsg;
          }
          // P5-T1: track outcome
          if (typeof window.lcpTrack === "function") {
            if (showThankYou) {
              window.lcpTrack("newsletter_inline_submit_success", {
                existing: !!data.existing,
                confirmed: !!data.confirmed,
              });
            } else {
              window.lcpTrack("newsletter_inline_submit_error", {
                status: (typeof res !== "undefined" && res) ? res.status : 0,
              });
            }
          }
          if (showThankYou) {
            // Show thank-you heading and hide form fields
            var formGrid = newsletterForm.querySelector('.form-grid');
            if (formGrid) {
              var thankEl = document.createElement('div');
              thankEl.className = 'newsletter-thankyou';
              thankEl.innerHTML = '<p style="font-size:1.25rem;font-weight:700;color:#6b4c3b;margin:0 0 0.5rem;">' + thankYouMsg + '</p>';
              formGrid.innerHTML = '';
              formGrid.appendChild(thankEl);
              formGrid.appendChild(newsletterStatus);
            }
          }
        });
      }).catch(function() {
        if (submitBtn) { submitBtn.classList.remove('is-loading'); submitBtn.disabled = false; }
        newsletterStatus.textContent = errorMsg;
        if (typeof window.lcpTrack === "function") {
          window.lcpTrack("newsletter_inline_submit_error", { status: 0, network: true });
        }
      });
    });
  }
</script>
