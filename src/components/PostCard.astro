---
import type { Lang } from "../data/i18n";
import { formatDate, ui } from "../data/i18n";
import Button from "./Button.astro";

interface Props {
  post: {
    id: string;
    data: {
      postId: string;
      title: string;
      date: string;
      summary: string;
      lang: string;
      image?: string;
      category?: string;
    };
  };
  lang: Lang;
  readLabel: string;
}

const { post, lang, readLabel } = Astro.props;
const slug = post.id.replace(/^(es|en)\//, "");
const postHref = `/${lang}/blog/${slug}/`;
const text = ui[lang];

const categoryLabels: Record<string, string> = {
  "article": text.categoryArticle,
  "fun-fact": text.categoryFunFact,
  "joke": text.categoryJoke,
  "coloring-corner": text.categoryColoringCorner,
};
const category = post.data.category || "article";
const categoryLabel = categoryLabels[category] || categoryLabels["article"];

const categoryColors: Record<string, string> = {
  "article": "var(--brand-blue)",
  "fun-fact": "var(--brand-green)",
  "joke": "var(--accent-coral)",
  "coloring-corner": "var(--accent-gold)",
};
const categoryColor = categoryColors[category] || categoryColors["article"];
---

<article class="post-card" aria-labelledby={`post-${post.data.postId}`}>
  {post.data.image && (
    <a href={postHref} class="post-card-image-link">
      <img src={post.data.image} alt={post.data.title} class="post-card-image" width="300" height="300" loading="lazy" />
    </a>
  )}
  <div class="post-card-body">
    <div class="post-card-meta">
      <span class="category-badge" style={`--badge-color: ${categoryColor};`}>{categoryLabel}</span>
      <p class="post-date">{formatDate(post.data.date, lang)}</p>
    </div>
    <h3 id={`post-${post.data.postId}`}>{post.data.title}</h3>
    <p>{post.data.summary}</p>
    <div class="card-actions">
      <Button href={postHref} label={readLabel} variant="ghost" />
    </div>
  </div>
</article>
